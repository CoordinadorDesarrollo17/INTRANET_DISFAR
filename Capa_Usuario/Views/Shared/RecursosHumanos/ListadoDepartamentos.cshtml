<table id="tbl_listaDpto" class="table table-light table-hover" width="100%">
    <thead class="thead-dark">
        <tr>
            <th class="text-center">#</th>
            <th class="text-center">DEPARTAMENTO</th>
            <th class="text-center" style="width: 120px">ESTADO</th>
            @if (false)
            {
                <th class="text-center" style="width: 50px">ELIMINAR</th>
            }
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            int num = 1;
            foreach (var m in Model)
            {
                <tr>
                    <td class="text-center">@num</td>
                    <td>@m.Nombre</td>
                    <td class="text-center">@m.DescripcionEstado</td>
                    @if (false)
                    {
                        <td class="text-center">
                            <select class="form-control border-success" onchange="cambiarEstadoDpto('@m.IdDepartamento', this.value)">
                                <option value="1" @if (m.Estado == "Y") { Write("selected"); }>ACTIVO</option>
                                <option value="0" @if (m.Estado == "N") { Write("selected"); }>INACTIVO</option>
                            </select>
                        </td>
                        <td class="text-center"><button type="button" class="btn btn-sm btn-danger" data-iddepartamento="@m.IdDepartamento" data-nombre="@m.Nombre" onclick="eliminarDpto(this)"><i class="icon-bin2"></i></button></td>
                    }
                </tr>
                ++num;
            }
        }
    </tbody>
</table>

<script>
    (function () {
        var table_dpto = $('#tbl_listaDpto').DataTable({
            pageLength: 10,                 /* PARA INICIALIZAR LA PAGINACIÓN */
            lengthMenu: [10, 20, 30],   /* RANGO PAGINACIÓN */
        });

        table_dpto.columns.adjust().draw();
    })();
</script>