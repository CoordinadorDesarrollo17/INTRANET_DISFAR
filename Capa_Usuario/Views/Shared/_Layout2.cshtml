<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>@ViewBag.Title - COBEFAR</title>
    <link rel="icon" type="image/x-icon" href="~/Content/img/favicon-cobefar.png">
    <link href="~/Content/css/bootstrap.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/icomoon/style.css" rel="stylesheet" />
    <link href="~/Content/estilos.css" rel="stylesheet" />
    <link href="~/Content/css/jquery-ui-1.12.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            padding: 0;
            background-image: url('/Content/img/bg-cobefar-v2.png');
            background-position: center center;
            background-attachment: fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            flex-wrap: wrap;
        }
    </style>

    <script src="~/Content/js/jquery-3.6.3.js"></script>
    <script src="~/Content/js/bootstrap.bundle.js"></script>
    <script src="~/Content/js/jquery-ui-1.12.js"></script>
    <script src="~/Scripts/Frameworks/sweetalert2@11.js"></script>
    <script src="~/Scripts/shared/jquery.doubleScroll.js"></script>
    <script>
        $(document).ready(function () {
            $('.double-scroll').doubleScroll();
        });
        function statusBD() {
            var parametros;
            $.ajax('/Index/statusBD',
                {
                    data: parametros,
                    dataType: 'html',
                    cache: false,
                    type: 'post',
                })
                .done(function (response) {
                    $('#statusBD').html(response);
                });
        }
    </script>
</head>
<body onload='statusBD();'>
    <div id="contenedor" class="container layout-2" style="width:100%;">
        @*<header>
            <div class="row py-3">
                <div class="col-8">
                    <p>
                        <a style="font-size: 11px;background-color: darkred" href="@Url.Action("LogOut", "Index")" class="btn btn-danger">
                            <strong>Salir</strong>
                        </a> <em id="statusBD" class="font-12 text-white" style="font-weight:700;text-align:right">CONECTADO A BASE DE DATOS: COBEFARWEB_PRUEBAS *** Y BASE DE SAP  : "B1H_COBEFAR_2018".</em>
                    </p>
                </div>

                <div class="col-4 d-flex justify-content-end">
                    <img src="~/Content/img/logo-cobefar.png" width="150">
                </div>
            </div>
        </header>*@

        <div class="container">
            @RenderBody()
        </div>

    </div>
    @*<footer>
        <div class="container-footer bg-dark pt-4">
            <div class="copyright mb-4"><span class="text-cobefar-2">CONTACTO:</span> soporte@cobefar.com.pe <span class="text-cobefar-2">|</span> desarrollo@cobefar.com.pe <span class="text-cobefar-2">|</span> sistemas@cobefar.com.pe</div>
            © Todos los derechos reservados - <span class="text-cobefar-2">COBEFAR S.A.C</span>
        </div>
    </footer>*@
</body>
</html>