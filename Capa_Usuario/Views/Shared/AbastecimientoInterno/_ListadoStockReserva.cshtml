
<table id="tbl_listaStockReserva" class="dt-container dt-empty-footer table table-sm table-hover table-responsive font-12" width="100%">
    <thead class="thead-cobefar">
        <tr>
            <th scope="col" class="text-center">Código de artículo</th>
            <th scope="col" class="text-center">Descripción</th>
            <th scope="col" class="text-center">Lote</th>
            <th scope="col" class="text-center ">Ubicación RESERVA</th>
            <th scope="col" class="text-center ">Cambio de Ubicación</th>
            <th scope="col" class="text-center">Unidad MASTER</th>
            <th scope="col" class="text-center">Stock MASTER</th>
            <th scope="col" class="text-center">Stock SALDO</th>
            <th scope="col" class="text-center">Stock UNIDS</th>
            <th scope="col" class="text-center"></th>
        </tr>
    </thead>
    <tbody class="text-dark">
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                var loteMaster = item.BatchNum.Replace(" ", "") + item.UmAlm;


                <tr>
                    <td scope="col" class="text-center align-middle">@item.ItemCode </td>
                    <td scope="col" class="align-middle"><span class="ps-2">@item.ItemName</span></td>
                    <td scope="col" class="text-center align-middle">@item.BatchNum</td>
                    <td scope="col" class="text-center align-middle">@item.CodigoUbicacion</td>
                    <td scope="col" class="text-center align-middle">
                        <div class="d-flex justify-content-center align-content-center">
                            <select id="idunico_@item.UbicacionLoteMasterId"
                                    data-ubicacionactual="@item.CodigoUbicacion"
                                    class="ss-main cls-slimselect"
                                    style="width: 180px;font-size:12px">
                                <option value="">Seleccione</option>
                            </select>
                        </div>
                    </td>
                    <td scope="col" class="text-center align-middle">@item.UmAlm </td>
                    <td scope="col" class="text-center align-middle">@item.QuantityMaster </td>
                    <td scope="col" class="text-center align-middle">@item.QuantitySaldo</td>
                    <td scope="col" class="text-center align-middle">@item.QuantityUnidadesCajas </td>
                    <td scope="col" class="text-center align-middle">
                        <button class="btn btn-cobefar-2" onclick="cambiarUbicacion('idunico_@item.UbicacionLoteMasterId',@item.UbicacionLoteMasterId)" data-bs-toggle="tooltip" data-bs-placement="top" title="Cambiar ubicación">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<script>
    $('[data-bs-toggle="tooltip"]').tooltip();
</script>

<script>
    iniciar()

    async function iniciar() {
        const ubicaciones = await cargarUbicaciones()

        document.querySelectorAll('.cls-slimselect').forEach(select => {
            llenarSelectConOpciones(select, ubicaciones)
        });
    }

    async function cargarUbicaciones() {
        const almacen = "RESERVA"

        try {
            const response = await fetch("/AbastecimientoInterno/BuscarUbicaciones", {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ almacen })
            });

            if (!response.ok) {
                let errorText = await response.text();
                throw new Error(`Error ${response.status}: ${errorText}`);
            }

            let data = await response.json();

            return data.resultUbicaciones;
        } catch (error) {
            console.error("Error al obtener ubicaciones:", error.message);
        }
    }

    function llenarSelectConOpciones(selectElement, opciones) {
        selectElement.innerHTML = '<option value="">Seleccione</option>'

        // Iteramos las opciones discrimando la ubicación actual del artículo
        opciones.forEach(item => {
            if (item !== selectElement.dataset.ubicacionactual) {
                const option = document.createElement('option')
                option.value = item
                option.textContent = item
                selectElement.appendChild(option)
            }
        });

        if (selectElement.slim instanceof SlimSelect) {
            selectElement.slim.destroy()
        }

        selectElement.classList.remove('ss-main')

        selectElement.slim = new SlimSelect({
            select: selectElement,
            placeholder: 'Selecciona una opción', // Texto de marcador de posición en español
            allowDeselect: true, // Permite deseleccionar
            searchText: 'No encontrado', // Texto que aparece cuando no hay coincidencias en la búsqueda
            searchPlaceholder: 'Buscar...', // Texto de marcador de posición para la búsqueda
            closeOnSelect: false, // No cerrar el desplegable al seleccionar (opcional)
            showSearch: true // Mostrar la barra de búsqueda
        })
    }    

    $('#tbl_listaStockReserva').DataTable({
        ...configDataTable,
        drawCallback: async function () {
            const ubicaciones = await cargarUbicaciones();

            document.querySelectorAll('.cls-slimselect').forEach(select => {
                llenarSelectConOpciones(select, ubicaciones);
            });
        }
    });

</script>