<script>
    inicializarDataTable('tbl_listaArticulosAbastPicking', '25')

    function calcularStockSaliendo(cantidadSolicitada, valorUmAlm, stockSaldo, stockMaster, fila) {
        let stockSaliendoFaltante = 0
        let stockMasterRequerido = 0
        let stockSaliendo = 0

        if (Number(stockSaldo) > 0) {
            stockSaliendoFaltante = Number(cantidadSolicitada) - Number(stockSaldo)
        } else {
            stockSaliendoFaltante = Number(cantidadSolicitada)
        }

        if (stockSaliendoFaltante > 0) {
            let residuo = Number(stockSaliendoFaltante) % Number(valorUmAlm)

            if (residuo == 0) {
                // Dividimos para saber cuantos masters cubren el "stockSaliendoFaltante"
                stockMasterRequerido = Number(stockSaliendoFaltante) / Number(valorUmAlm)
            } else {
                let numero = Number(stockSaliendoFaltante)

                while (numero % 13 !== 0) {
                    numero++
                }
                stockMasterRequerido = numero / Number(valorUmAlm)
            }

            if (stockMasterRequerido > stockMaster) {
                console.warn(`${fila}: El stock MASTER requerido es mayor al stock MASTER disponible.`)
                return 0;
            }
        }


        stockSaliendo = (stockMasterRequerido * Number(valorUmAlm)) + Number(stockSaldo)

        return stockSaliendo;
    }

    let filas = Array.from(document.querySelectorAll('#tbl_listaArticulosAbastPicking tbody tr'));

    filas.forEach((fila, index) => {
        //console.log(`Fila ${index + 1}:`);

        // Obtener valores de los inputs dentro de la fila
        let stockSaldo = parseInt(fila.querySelector('.stockSaldo')?.value || 0);
        let stockMaster = parseInt(fila.querySelector('.stockMaster')?.value || 0);
        let valorUmAlm = parseInt(fila.querySelector('.valorUmAlm')?.value || 0);
        let cantidadSolicitada = document.querySelector('#cantidad_solicitada'); // Cantidad fija

        if (!cantidadSolicitada) {
            console.warn('No existe elemento: cantidad_solicitada')
            return;
        }

        // Calcular el stock saliendo
        fila.querySelector('.stockSaliendo').value = calcularStockSaliendo(cantidadSolicitada.value, valorUmAlm, stockSaldo, stockMaster, `Fila ${index + 1}`);
    });
</script>