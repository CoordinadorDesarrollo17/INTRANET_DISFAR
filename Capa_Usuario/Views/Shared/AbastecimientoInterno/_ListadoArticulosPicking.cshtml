                    </td>
                    <td scope="col" class="text-center">@item.CodigoUbicacion</td>
                    <td scope="col" class="text-center"><input type="hidden" class="valorUmAlm" value="@item.ValorUmAlm" />@item.UmAlm</td>
                    <td scope="col" class="text-center"><input type="hidden" class="stockMaster" value="@item.QuantityMaster" />@item.QuantityMaster</td>
                    <td scope="col" class="text-center"><input type="hidden" class="stockSaldo" value="@item.QuantitySaldo" />@item.QuantitySaldo</td>
                    <td scope="col" class="text-center"><input type="hidden" class="stockTotalUnidades" value="@item.QuantityUnidadesCajas" />@item.QuantityUnidadesCajas</td>
                    <td scope="col" class="text-center"><div class="d-flex justify-content-center"><input type="text" class="form-control stockSaliendo cls-readonly text-center" style="width: 100px" readonly /></div></td>
                </tr>

                num++;
