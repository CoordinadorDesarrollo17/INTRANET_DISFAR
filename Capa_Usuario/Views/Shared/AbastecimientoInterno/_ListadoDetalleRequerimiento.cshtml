@{
    var opciones = new Dictionary<int, string>();
    opciones[0] = "NO";
    opciones[1] = "SI";
    opciones[2] = "RECHAZADO";
}

<div class="row mb-2">
    <div class="col-12 col-md-6 d-flex align-items-center gap-2">
        <label class="mb-0 fw-bold">Filtrar 100%:</label>
        <input type="number" id="filtroPorcentajeMin" class="form-control form-control-sm" placeholder="Mín %" min="0" max="500" step="0.01" style="max-width:120px" />
        <span class="text-muted">-</span>
        <input type="number" id="filtroPorcentajeMax" class="form-control form-control-sm" placeholder="Máx %" min="0" max="500" step="0.01" style="max-width:120px" />
        <button type="button" id="btnLimpiarFiltroPorcentaje" class="btn btn-sm btn-outline-secondary">Limpiar</button>
    </div>
</div>

<table id="tbl_ListadoDetalleRequerimiento" class="dt-container dt-empty-footer table table-hover table-bordered table-striped font-14" width="100%">
    <thead class="thead-cobefar">
        <tr>
            <th scope="col" class="text-center" style="width:40px"><input type="checkbox" id="chkSelectAll" /></th>
            <th scope="col" class="text-center">Cód. Artículo</th>
            <th scope="col" class="text-center">Descripción</th>
            <th scope="col" class="text-center">Lote</th>
            <th scope="col" class="text-center">Ubicación Origen</th>
            <th scope="col" class="text-center">Ubicación Destino</th>
            <th scope="col" class="text-center">Unidad Medida</th>
            <th scope="col" class="text-center">Cant. Máster</th>
            <th scope="col" class="text-center">Cant. Saldo</th>
            <th scope="col" class="text-center">Cant. Unds.</th>
            <th scope="col" class="text-center">Apilado</th>
            <th scope="col" class="text-center">Reabast. Confirm.</th>
            <th scope="col" class="text-center" width="10%">100%</th>
            <th scope="col" class="text-center"></th>
        </tr>
    </thead>
    <tbody class="text-dark">
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                var porcentajeStock = item.StockMinAbastecimiento > 0
                ? (item.StockPicking * 100) / item.StockMinAbastecimiento
                : -1;

                // Definir color basado en la relación con el Stock Mínimo
                string colorClase = "";

                if (item.StockActualUnidades > item.StockPicking && item.StockPicking < item.StockMinAbastecimiento * 0.5m)
                {
                    colorClase = "bg-danger"; //Rojo: Stock crítico
                }
                else if (item.StockActualUnidades == item.StockPicking || item.StockActualUnidades < item.StockMinAbastecimiento)
                {
                    colorClase = "bg-dark text-white";     // Cuando el stock sap no cubre el stock mín.
                }
                else if (item.StockPicking < item.StockMinAbastecimiento)
                {
                    colorClase = "bg-warning text-dark"; // Amarillo: Cerca del mínimo
                }
                else
                {
                    colorClase = "bg-success"; // Verde: Stock suficiente
                }

                decimal formatStockActualUnds = Math.Truncate(item.StockActualUnidades * 100) / 100;
                decimal formatStockPicking = Math.Truncate(item.StockPicking * 100) / 100;
                <tr>
                    <td scope="col" class="text-center"><input type="checkbox" class="chkSelectItem" value="@item.Id" /></td>
                    <td scope="col" class="text-center">@item.ItemCode</td>
                    <td scope="col" class="text-center">@item.ItemName</td>
                    <td scope="col" class="text-center">@item.BatchNum</td>
                    <td scope="col" class="text-center">@item.CodigoUbicacionOrigen</td>
                    <td scope="col" class="text-center">@item.CodigoUbicacionDestino</td>
                    <td scope="col" class="text-center">@item.UmAlm</td>
                    <td scope="col" class="text-center">@item.QuantityMaster</td>
                    <td scope="col" class="text-center">@item.QuantitySaldo</td>
                    <td scope="col" class="text-center">@item.QuantityUnidadesCajas</td>
                    <td scope="col" class="text-center">@opciones[item.AtendidoReserva]</td>
                    <td scope="col" class="text-center">@opciones[item.AtendidoPicking]</td>
                    <td class="text-center align-middle">
                        <div class="d-flex justify-content-center align-items-center">
                            <div class="progress" style="height: 25px; width: 120px;">
                                @{
                                    string estiloBase = "progress-bar";
                                    string texto = "";
                                    string width = "100%";
                                    int ariaValueNow = 0;
                                    decimal porcentajeNum = -1;

                                    if (porcentajeStock > 0 || porcentajeStock == 0)
                                    {
                                        estiloBase += $" {colorClase}";
                                        texto = $"{porcentajeStock.ToString("0.00")}%";
                                        width = $"{(porcentajeStock > 100 ? 100 : porcentajeStock)}%";
                                        ariaValueNow = (int)porcentajeStock;
                                        porcentajeNum = porcentajeStock;
                                    }
                                    else if (item.StockActualUnidades <= 0)
                                    {
                                        estiloBase += " bg-secondary text-white fw-bold";
                                        texto = "SIN STOCK";
                                    }
                                    else if (item.StockPicking < 0)
                                    {
                                        estiloBase += " bg-secondary text-white fw-bold";
                                        texto = "NEGATIVO";
                                    }
                                    else
                                    {
                                        estiloBase += " bg-secondary text-white fw-bold";
                                        texto = "SIN PARAMETRO";
                                    }
                                }

                                <div class="@estiloBase" role="progressbar"
                                     style="width: @width"
                                     aria-valuenow="@ariaValueNow"
                                     data-stockmin="@item.StockMinAbastecimiento"
                                     data-stockpicking="@item.StockPicking"
                                     data-percent="@porcentajeNum"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    @texto
                                </div>

                            </div>
                        </div>
                    </td>
                    <td scope="col" class="text-center">
                        @if (item.AtendidoReserva == 0)
                        {
                            <button type="button" class="btn btn-sm btn-danger btn-eliminarItem" onclick="eliminarItem(@item.Id)"><i class="bi bi-trash-fill"></i></button>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<script>
    (function () {
        // Registra filtro de rango por porcentaje para DataTables
        var minInput = document.getElementById('filtroPorcentajeMin');
        var maxInput = document.getElementById('filtroPorcentajeMax');
        var btnClear = document.getElementById('btnLimpiarFiltroPorcentaje');
        var chkSelectAll = document.getElementById('chkSelectAll');

        function parseNumber(val, def) {
            if (val === null || val === undefined) return def;
            var n = parseFloat(('' + val).replace(',', '.'));
            return isNaN(n) ? def : n;
        }

        // Obtener o inicializar DataTable de esta tabla
        function getTable() {
            try {
                if ($.fn.DataTable.isDataTable('#tbl_ListadoDetalleRequerimiento')) {
                    return $('#tbl_ListadoDetalleRequerimiento').DataTable();
                }
                if (typeof inicializarDataTable === 'function') {
                    return inicializarDataTable('tbl_ListadoDetalleRequerimiento', 25);
                }
                return $('#tbl_ListadoDetalleRequerimiento').DataTable({ pageLength: 25 });
            } catch (e) {
                try {
                    return $('#tbl_ListadoDetalleRequerimiento').DataTable();
                } catch { return null; }
            }
        }

        // Agrega filtro custom solo una vez
        if (!$.fn.dataTable.ext._aiRangeFilterAdded) {
            $.fn.dataTable.ext._aiRangeFilterAdded = true;
            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex, rowData, counter) {
                // Aplica solo a nuestra tabla
                if (settings.nTable && settings.nTable.id !== 'tbl_ListadoDetalleRequerimiento') return true;

                var min = parseNumber(minInput && minInput.value, null);
                var max = parseNumber(maxInput && maxInput.value, null);

                if (min === null && max === null) return true; // sin filtro

                // Tomamos el progress bar de la fila y calculamos el porcentaje desde data-*
                var rowNode = settings.aoData[dataIndex].nTr;
                if (!rowNode) return true;
                var $bar = $(rowNode).find('td').eq(13).find('.progress-bar').first();
                if (!$bar || $bar.length === 0) return true;

                var stockMin = parseNumber($bar.attr('data-stockmin'), 0);
                var stockPicking = parseNumber($bar.attr('data-stockpicking'), 0);
                var percent = (stockMin > 0) ? (stockPicking * 100.0 / stockMin) : parseNumber($bar.attr('data-percent'), -1);

                if (percent < 0) {
                    // valores no numéricos como SIN STOCK/NEGATIVO/SIN PARAMETRO: excluir del rango
                    return false;
                }

                if (min !== null && percent < min) return false;
                if (max !== null && percent > max) return false;
                return true;
            });
        }

        function attachHandlers(table) {
            if (!table) return;
            var redraw = function () { table.draw(); };
            if (minInput) minInput.addEventListener('input', redraw);
            if (maxInput) maxInput.addEventListener('input', redraw);
            if (btnClear) btnClear.addEventListener('click', function () {
                if (minInput) minInput.value = '';
                if (maxInput) maxInput.value = '';
                table.draw();
            });
        }

        // Espera a que el DOM y DataTable estén listos
        document.addEventListener('DOMContentLoaded', function () {
            var table = getTable();
            attachHandlers(table);
        });

        // Si esta vista se inyecta dinámicamente, intenta también después de un pequeńo delay
        setTimeout(function () {
            var table = getTable();
            attachHandlers(table);
        }, 300);
    })();
</script>

