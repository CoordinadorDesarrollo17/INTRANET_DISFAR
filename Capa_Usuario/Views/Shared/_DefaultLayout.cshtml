        function destruirSlimSelect(clase, eliminar = false) {
            const elementos = document.querySelectorAll(`.${clase}`);

            if (!elementos.length) {
                //console.log(`No se encontraron elementos con la clase: "${clase}"`);
                return;
			}

			elementos.forEach(elemento => {
                // Destruir la instancia de Slim Select
                if (elemento && elemento.slim) {
                    elemento.slim.destroy(); // Destruye la instancia de Slim Select
                }

                // Eliminar el elemento del DOM
                if (elemento && eliminar) {
                    elemento.remove(); // O puedes usar selectElement.parentNode.removeChild(selectElement);
                }
			})
    }

	// Función genérica para inicializar Slim Select en todos los <select> con una clase espec�fica
	const inicializarSlimSelectsPorClase = (clase) => {
		const elementos = document.querySelectorAll(`.${clase}`);

		if (!elementos.length) {
			//console.log(`No se encontraron elementos con la clase: "${clase}"`);
			return;
		}

		elementos.forEach(elemento => {
			if (elemento.tagName.toLowerCase() !== 'select') {
				//console.log(`El elemento con clase "${clase}" no es un <select>.`, elemento);
				return;
			}

			// Verificar si SlimSelect ya fue inicializado en este elemento
			if (elemento.slim) {
				elemento.slim.destroy();  // Destruir la instancia previa antes de inicializar
				elemento.slim = null; // Limpiar la referencia para evitar problemas
			}

            if (elemento.tagName.toLowerCase() === 'select' && !elemento.slim) {
                new SlimSelect({
                    select: elemento,
                    placeholder: 'Selecciona una opción', // Texto de marcador de posición en español
                    allowDeselect: true, // Permite deseleccionar
                    searchText: 'No encontrado', // Texto que aparece cuando no hay coincidencias en la búsqueda
                    searchPlaceholder: 'Buscar...', // Texto de marcador de posición para la búsqueda
                    closeOnSelect: false, // No cerrar el desplegable al seleccionar (opcional)
                    showSearch: true // Mostrar la barra de búsqueda
                });
            }
        });
	};

    inicializarSlimSelectsPorClase('cls-select')


	function validarTexto(input) {
		// Expresi�n regular que permite caracteres alfanum�ricos, "-", ".", "�", letras con tildes y acento agudo
		var regex = /^[a-zA-Z0-9�������������� \-\.�']+$/;

		// Comprobar si la cadena coincide con la expresi�n regular
		if (regex.test(input)) {
			// La cadena es v�lida
			return true;
		} else {
			// La cadena contiene caracteres no permitidos
			return false;
		}
	}

	 // Se tiene que enviar de esta forma: resetValoresVacios(["ItmsGrpCod", "Descripcion"]);
	function resetValoresVacios(ids) {
		ids.forEach(id => {
			let element = document.getElementById(id);
			if (element) {
				element.value = '';
			}
		});
	}

	// Recibir� un array de objetos con pares clave-valor, donde la clave es el ID del elemento y el valor es lo que se asignar� a dicho elemento
	function asignarValores(idValuePairs) {
		idValuePairs.forEach(function (pair) {
			for (var id in pair) {
				if (pair.hasOwnProperty(id)) {
					var element = document.getElementById(id);
					if (element) {
						element.value = pair[id];
					} else {
						console.warn(`Elemento con ID ${id} no encontrado.`);
					}
				}
			}
		});
	}

	function convertirFecha(fecha) {
		if (!fecha) return ''; // Manejar fechas no v�lidas

			// Asumimos que la fecha est� en formato "dd/MM/yyyy"
		let partes = fecha.split('/');
		if (partes.length === 3) {
			let dia = partes[0];
			let mes = partes[1];
			let ano = partes[2];
			return `${ano}-${mes}-${dia}`; // Retornar en formato "yyyy-MM-dd"
		}

		return ''; // Manejar formato no esperado
	}

	function dispararEventoChange(id) {
		document.getElementById(`${id}`).checked = true;
		document.getElementById(`${id}`).dispatchEvent(new Event('change'));
	}

	function habilitarCampo(id) {
		let select = document.getElementById(`${id}`);
		select.style.pointerEvents = ""; // Permitir la interacci�n nuevamente
		select.style.backgroundColor = ""; // Restaurar el color de fondo predeterminado
		select.style.cursor = ""; // Restaurar el cursor predeterminado
	}

	function deshabilitarCampo(id) {
		let select = document.getElementById(`${id}`);
		select.style.pointerEvents = "none"; // Deshabilita la interacci�n
		select.style.backgroundColor = "#f0f0f0"; // Cambia el fondo para mostrar que est� "bloqueado"
		select.style.cursor = "not-allowed"; // Cambia el cursor
	}

	function permitirSoloNumeros(id) {
		let campo = document.getElementById(id);

		campo.addEventListener('input', function () {
			var valor = campo.value;
			var regex = /^[0-9]*$/; // Expresi�n regular para permitir solo n�meros

			if (!regex.test(valor)) {
				campo.value = valor.replace(/\D/g, ''); // Elimina todos los caracteres que no son d�gitos
			}
		});
	}

	function limitarMaxCaracteres(id, max) {
		let campo = document.getElementById(id);

		campo.addEventListener('input', function () {
			if (campo.value.length > max) {
				campo.value = campo.value.slice(0, max);
			}
		});
	}

	// Para que funcione, el par�metro "texto" debe llegar en min�scula: toLowerCase()
	function capitalizarTexto(texto) {
		return texto.replace(/\b\w/g, function (l) {
			return l.toUpperCase();
		});
	}

	// botones sweet alert
	const swalWithBootstrapButtons = Swal.mixin({
		customClass: {
			confirmButton: 'btn btn-success mx-3',
			cancelButton: 'btn btn-danger mx-3'
		},
		buttonsStyling: false
	})

	const Toast = Swal.mixin({
		toast: true,
		position: "top-end",
		showConfirmButton: false,
		timer: 3000,
		timerProgressBar: true
	});

	function cargando() {
		Swal.fire({
			html: '<img src="/imagenes/index/ReportesDigemid/cargando.gif" />',
			allowOutsideClick: false,
			showCancelButton: false,
			showConfirmButton: false
		});
	}

	function cargarContenido(idDiv, url) {
		let elemento = document.getElementById(idDiv);
		elemento.innerHTML = "";

		Swal.fire({
			title: 'Cargando...',
			text: 'Por favor, espere.',
			allowOutsideClick: false,
			didOpen: () => Swal.showLoading(),
		});

		fetch(url)
			.then(response => response.text())
			.then(data => {

				setTimeout(() => {
					Swal.close();
				}, 700); // 700 ms = 0.7 segundos

				elemento.innerHTML = data;
				$('[data-bs-toggle="tooltip"]').tooltip();

				// Ejecutar los scripts embebidos
				ejecutarScripts(elemento);

				return true;  // Asegurarse de que se devuelve algo para que .then() pueda encadenarse
			})
			.catch(error => {
				console.error('Error al cargar la vista parcial:', error);
				return false;  // En caso de error, devuelve false
			});
	}

	function procesarOperacion(config) {
		//console.log(config);
		$.ajax({
			url: config.url,
			type: 'POST',
			data: config.data
		}).done(function (response) {
			Swal.fire({
				title: response.Titulo,
                html: response.Mensajes && response.Mensajes.length > 0 ? response.Mensajes.join('<br>') : "",
				icon: response.Icono,
				allowEscapeKey: false,
				allowOutsideClick: false,
				showConfirmButton: response.Icono !== 'success'
			});

			if (response.Icono === 'success') {
				setTimeout(function () {
					cargarContenido(config.divContenido, config.controllerContenido);
				}, 1000); // 1000 milisegundos = 1 segundo
			}
		}).fail(function (jqXHR, textStatus, errorThrown) {
			console.error(jqXHR.status, textStatus, errorThrown); // Imprimir cualquier error en la consola en caso de que la solicitud AJAX falle
		});
	}

	function confirmarEliminacion(mensaje, config) {
		swalWithBootstrapButtons.fire({
			title: '&iquest;Est&aacute seguro(a) de ELIMINAR?',
			html: `${mensaje}`,
			icon: 'warning',
			allowEscapeKey: false,
			showCancelButton: true,
			confirmButtonText: "<i class='bi bi-check-lg'></i> Si, eliminar",
			cancelButtonText: "<i class='bi bi-x-lg'></i> Cancelar",
			reverseButtons: true
		}).then((result) => {
			if (result.isConfirmed) {
				procesarOperacion(config);
			}
		});
	}

	// Funci�n gen�rica para manejar los eventos de los botones con data-function
		function manejarEventoClick(event) {
		// Buscar el elemento m�s cercano que tenga el atributo 'data-function'
		let element = event.target.closest("[data-function]");

		if (element) {
			let nombreFunction = element.getAttribute("data-function");

			// Verificar si la funci�n existe y ejecutarla
			if (typeof window[nombreFunction] === "function") {
				window[nombreFunction]();
			} else {
				console.error(`La función ${nombreFunction} no existe.`);
			}
		} else {
			console.error('No se encontró el atributo "data-function" en el elemento clicado o en sus padres.');
		}
	}


	// Funci�n para gestionar el valor de un datalist hacia un input con cualquier dataAttribute
	function gestionarValorDatalist(inputElementId, dataListId, outputElementId, dataAttribute) {
		document.getElementById(inputElementId).addEventListener('input', function () {
			document.getElementById(outputElementId).value = "";
			const input = this.value;
			const selectedOption = Array.from(document.querySelectorAll(`#${dataListId} option`))
				.find(option => option.value === input);

			if (selectedOption) {
				document.getElementById(outputElementId).value = selectedOption.dataset[dataAttribute];
			}
		});
	}

	// Para procesos en el que se usa INNERHTML con scripts embebidos
	function ejecutarScripts(element) {
		// Buscar todas las etiquetas <script> dentro del contenido insertado
		const scripts = element.querySelectorAll("script");
		scripts.forEach((script) => {
			// Crear un nuevo script para ejecutarlo
			const newScript = document.createElement("script");
			newScript.textContent = script.textContent; // Copiar el contenido del script original

			// Si el script tiene un atributo src, lo cargamos desde la URL
			if (script.src) {
				newScript.src = script.src;
			}

			// Reinsertar el script para ejecutarlo
			document.body.appendChild(newScript);

			// Remover el script despu�s de ejecutarlo si es necesario (opcional)
			document.body.removeChild(newScript);
		});
	}

		function mostrarUbigeos(seleccionar, id = 0) {
