	function habilitarDeshabilitarCheckbox() {
		// Obtener todos los elementos con clase .chk-item y agregar el evento change
		document.querySelectorAll(".chk-item").forEach(function (btn) {
			btn.addEventListener("change", function () {
				// Obtener todos los checkboxes seleccionados
				let itemsSeleccionados = Array.from(document.querySelectorAll('.chk-item:checked'));

				if (itemsSeleccionados.length > 0) {
					// Si hay un checkbox seleccionado, deshabilitar los dem�s que no est�n seleccionados
					document.querySelectorAll(".chk-item").forEach(function (checkbox) {
						if (!checkbox.checked) {
							checkbox.setAttribute("disabled", true);
						}
					});
				} else {
					// Si no hay ning�n checkbox seleccionado, habilitar todos los checkboxes
					document.querySelectorAll(".chk-item").forEach(function (checkbox) {
						checkbox.removeAttribute("disabled");
					});
				}
			});
		});
	}

	function manejarEventoClickTabla(selectorTabla, claseBoton, callback) {
		document.querySelector(selectorTabla).addEventListener('click', function (event) {
			// Verificar si el elemento clicado tiene la clase indicada
			if (event.target.matches(claseBoton)) {
				// Ejecutar la funci�n de callback con los datos del bot�n
				callback(event.target.dataset);
			} else if (event.target.closest(claseBoton)) {
				// En caso de que se haya clicado en un elemento hijo dentro del bot�n
				let btn = event.target.closest(claseBoton);
				callback(btn.dataset);
			}
		});
	}

	function generarDesplegable(idElement, lista) {

		const select = document.getElementById(idElement);
        if (!select) {
            console.log(`Elemento con ID ${idElement} no encontrado.`);
            return;
        }
		select.innerHTML = `<option value=''>SELECCIONE</option>`;

        if (!Array.isArray(lista) || lista.length === 0) {
            console.log('Lista de datos vacía o inválida.');
            return;
		}

		lista.forEach(function (optionData) {
			//console.log(optionData);
			const option = document.createElement('option');
			option.value = optionData.Id;
			option.text = optionData.Nombre;

			// A�adir la opci�n al select
			select.appendChild(option);
		});
	}

	function insertarFila(idTabla, config) {
		let tabla = document.getElementById(idTabla).getElementsByTagName('tbody')[0];
		let nuevaFila = tabla.insertRow();          // Inserta una nueva fila

		Object.keys(config).forEach(function (td, index) {
			let nuevaCelda = nuevaFila.insertCell(index);
			nuevaCelda.innerHTML = config[td]; // Agrega el contenido de cada celda

			let inputHidden = nuevaCelda.querySelector('input[type="hidden"][data-hide-cell="true"]');
			//let modalContent = nuevaCelda.querySelector('.modal'); // Busca si contiene un modal

			if (inputHidden) {
				// Oculta la celda si contiene un input hidden
				nuevaCelda.classList.add('d-none');
			}

			// Agrega las clases 'text-center' y 'align-middle' a la celda
			nuevaCelda.classList.add('text-center', 'align-middle');
		});

		// Coloca el foco en el primer input de la nueva fila
		let primerInput = nuevaFila.querySelector('input[type="text"], textarea, select');
		if (primerInput) {
			primerInput.focus(); // Coloca el foco en el primer input o textarea o select
		}
		}

	function reordenarFilas(table) {
			let filas = document.querySelectorAll(`#${table} tbody tr`);
			filas.forEach((fila, index) => {
				// Reasignar los IDs y los names de cada input dentro de la fila
				fila.querySelectorAll('input, select, textarea, button, a').forEach(input => {
					let name = input.name;
					let id = input.id;

					// Actualizar name si existe
					if (name) {
						input.name = name.replace(/\[\d+\]/, `[${index}]`);
					}

					// Actualizar id si existe
					if (id) {
						let newId = id.replace(/_\d+$/, `_${index}`);
						input.id = newId;
					}

					// Actualizar oninput si existe
					if (input.hasAttribute('oninput')) {
						let oninputValue = input.getAttribute('oninput');
						let updatedOninputValue = oninputValue.replace(/_(\d+)/g, `_${index}`);
						input.setAttribute('oninput', updatedOninputValue);
					}

					// Actualizar onchange si existe
					if (input.hasAttribute('onchange')) {
						let onchangeValue = input.getAttribute('onchange');
						let updatedOnchangeValue = onchangeValue.replace(/_(\d+)/g, `_${index}`);
						input.setAttribute('onchange', updatedOnchangeValue);
					}

					// Actualizar onclick si existe
					if (input.hasAttribute('onclick')) {
						let onclickValue = input.getAttribute('onclick');
						let updatedOnclickValue = onclickValue.replace(/dynamicModal_\d+/g, `dynamicModal_${index}`);
						input.setAttribute('onclick', updatedOnclickValue);
					}

					// Actualizar data-target si existe
					if (input.hasAttribute('data-target')) {
						let target = input.getAttribute('data-target');
						let updatedTarget = target.replace(/_\d+$/, `_${index}`);
						input.setAttribute('data-target', updatedTarget);
					}
				});

				// Actualizar IDs de los modales asociados a la fila
				let modal = fila.querySelector('.modal'); // Si el modal está directamente en la fila
				if (modal) {
					let modalId = modal.id;
					if (modalId) {
						let newModalId = modalId.replace(/_\d+$/, `_${index}`);
						modal.id = newModalId;
					}
				}
			});

			// Actualizamos el contadorFilas al número correcto
			contadorFilas = filas.length - 1;
		}

		// Funci�n para eliminar el <td> seleccionado
		function removerFila(element) {
			const row = element.closest('tr');		// Encuentra la fila m�s cercana (<tr>) donde se hizo clic y elim�nala
			if (row) {
				row.remove(); // Elimina solo la fila espec�fica
			}
		}

		function agregarPointerNone(ids) {
			ids.forEach(function (id) {
				let elemento = document.getElementById(id);
				if (elemento) {
					// Aplicamos pointer-events: none y cambiamos el estilo visual
					elemento.style.pointerEvents = 'none';
					elemento.style.backgroundColor = '#e9ecef'; // O cualquier color para indicar deshabilitado
					elemento.style.cursor = 'not-allowed';
				} else {
					console.warn(`Elemento con ID '${id}' no encontrado.`);
				}
			});
		}

		function quitarPointerNone(ids) {
			ids.forEach(function (id) {
				let elemento = document.getElementById(id);
				if (elemento) {
					// Quitamos el pointer-events y restauramos los estilos previos
					elemento.style.pointerEvents = 'auto'; // Vuelve a habilitar la interacci�n
					elemento.style.backgroundColor = '';   // Restauramos el color original
					elemento.style.cursor = '';            // Restauramos el cursor original
				} else {
					console.warn(`Elemento con ID '${id}' no encontrado.`);
				}
			});
		}

		function quitarReadonly(ids) {
			ids.forEach(function (id) {
				let elemento = document.getElementById(id);
				if (elemento) {
					elemento.readOnly = false;
				} else {
					console.warn(`Elemento con ID '${id}' no encontrado.`);
				}
			});
		}

		function permitirValoresNumericosPositivos() {
			let campos = document.querySelectorAll('.cls-num'); // Selecciona todos los elementos con la clase 'cls-num'

			campos.forEach(function (campo) {
				campo.addEventListener('input', function () {
					var valor = campo.value;
					var regex = /^[0-9]*[.,]?[0-9]*$/; // Expresi�n regular para permitir n�meros y un solo punto decimal

					if (!regex.test(valor)) {
						// Permitir n�meros decimales y reemplazar cualquier car�cter no permitido
						campo.value = valor.replace(/[^0-9.,]/g, '').replace(/(.*)[.,](.*)[.,]/g, '$1.$2'); // Permitir solo un punto decimal
					}
				});
			});
		}

		function ocultarElementosPorId(idsArray) {
		idsArray.forEach(function (id) {
			const elemento = document.getElementById(id);
			if (elemento) {
				elemento.style.display = "none";
			}
		});
	}

		function inicializarDataTable(idTable, itemsPorPagina, conBuscador = true, conOrden = true) {
			const items = Number(itemsPorPagina)

			if ($.fn.DataTable.isDataTable(`#${idTable}`)) {
                $(`#${idTable}`).DataTable().clear().destroy();
            }

			let table = $(`#${idTable}`).DataTable({
                "searching": conBuscador,  
                "order": [],  // Desactiva ordenamiento automatico.
                "ordering": conOrden, // Iconos para ordenar todas las columnas de la tabla.
                "pageLength": items,
                "lengthMenu": [items, items * 2, items * 3, items * 4, items * 5],
                "language": {
                    "info": "Mostrando _START_ a _END_ de _TOTAL_ registros",
                    "infoEmpty": "No hay registros disponibles",
                    "infoFiltered": "(filtrado de _MAX_ registros totales)",
                    "lengthMenu": "Mostrar _MENU_ registros por página",
                    "search": "Buscar:",
                    "loadingRecords": "Cargando...",
                    "processing": "Procesando...",
                    "zeroRecords": "No se encontraron registros"
                }
            });

			table.columns.adjust().draw();
            return table; 
		}

        function soloNumerosPorClase(nombreClase) {
            const inputs = document.querySelectorAll(`.${nombreClase}`);

            inputs.forEach(input => {
                input.addEventListener('input', () => {
                    input.value = input.value.replace(/[^0-9]/g, '');
                });
            });
        }

        function generarAlerta(titulo, contenido, icono) {
            Swal.fire({
                title: titulo,
                html: contenido,
                icon: icono,
                allowEscapeKey: false,
                allowOutsideClick: false,
                showConfirmButton: true,
                confirmButtonColor: '#28a745'
            })
            return;
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>