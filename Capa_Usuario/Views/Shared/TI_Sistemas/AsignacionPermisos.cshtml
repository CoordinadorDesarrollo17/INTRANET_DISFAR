<div style="display:none;">
    @* Esto es para mantener la compatibilidad con scripts existentes que buscan el div.container *@
    <div class="container">
    </div>
</div>
<style>
    .modulo-card {
        background: #00695c;
        border-radius: 10px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        color: #fff;
        transition: box-shadow 0.2s;
    }

        .modulo-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        }

    .modulo-header {
        font-size: 1rem;
        font-weight: 500;
        background: transparent;
        border: none;
        color: #fff;
        padding: 12px 16px;
        width: 100%;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        border-radius: 10px 10px 0 0;
    }

        .modulo-header i {
            font-size: 1.1rem;
            transition: transform 0.3s;
        }

        .modulo-header.collapsed i {
            transform: rotate(0deg);
        }

        .modulo-header:not(.collapsed) i {
            transform: rotate(90deg);
        }

    .modulo-body {
        background: #fff;
        color: #333;
        border-radius: 0 0 10px 10px;
        padding: 12px 16px;
    }

    .form-check-label {
        font-size: 0.95rem;
        font-weight: 400;
        color: #333;
    }

    .form-check-input {
        accent-color: #00695c;
        width: 1rem;
        height: 1rem;
    }

    .seleccionar-todos {
        accent-color: #00695c;
    }

    .modulo-select-todos {
        margin-bottom: 12px;
        text-align: right;
    }
</style>
<div class="container">
    <div class="row mb-2">
        @{int contador = 0;}
        @foreach (var controlador in Model.Keys)
        {
            if (contador % 3 == 0 && contador != 0)
            {
                @Html.Raw("</div><div class=\"row mb-2\">");
            }
            <div class="col-lg-4 col-md-6 col-12">
                <div class="modulo-card">
                    <button type="button" class="modulo-header collapsed" data-bs-toggle="collapse" data-bs-target="#collapse_@controlador" aria-expanded="false" aria-controls="collapse_@controlador">
                        <i class="bi bi-chevron-right"></i> @controlador
                    </button>
                    <div id="collapse_@controlador" class="collapse" aria-labelledby="heading_@controlador" data-bs-parent="#accordion_@controlador">
                        <div class="modulo-body">
                            <div class="modulo-select-todos">
                                <input class="form-check-input seleccionar-todos" type="checkbox" data-grupo="grupo_@controlador" id="chk_todos_@controlador">
                                <label class="form-check-label text-primary" for="chk_todos_@controlador">Seleccionar Todos</label>
                            </div>
                            @foreach (var item in Model[controlador])
                            {
                                <div class="form-check mb-2">
                                    <input id="idOperacion_@item.Id" class="form-check-input chk-item grupo_@controlador" type="checkbox" value="@item.Id" name="idOperacion" @if (ViewBag.Operaciones.Contains(item.Id)) { Write("checked"); } />
                                    <label class="form-check-label" for="idOperacion_@item.Id">@item.Nombre</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            ++contador;
        }
    </div>
</div>
@section Scripts{
    <script>
document.addEventListener('DOMContentLoaded', function () {
    // Bootstrap 5 accordion toggle icon
    document.querySelectorAll('.modulo-header').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var icon = btn.querySelector('i');
            setTimeout(function() {
                if (!btn.classList.contains('collapsed')) {
                    icon.classList.remove('bi-chevron-right');
                    icon.classList.add('bi-chevron-down');
                } else {
                    icon.classList.remove('bi-chevron-down');
                    icon.classList.add('bi-chevron-right');
                }
            }, 350);
        });
    });
});
    </script>
}