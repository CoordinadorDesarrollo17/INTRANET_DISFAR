<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>@ViewBag.Title - COBEFAR</title>
    <link rel="icon" type="image/x-icon" href="~/Content/img/favicon-cobefar.png">
    <link href="~/Content/css/bootstrap.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/icomoon/style.css" rel="stylesheet" />
    <link href="~/Content/estilos.css" rel="stylesheet" />
    <link href="~/Content/css/jquery-ui-1.12.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            padding: 0;
            background-image: url('/Content/img/bg-cobefar-v2.png');
            background-position: center center;
            background-attachment: fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            flex-wrap: wrap;
        }
    </style>

    <script src="~/Content/js/jquery-3.6.3.js"></script>
    <script src="~/Content/js/bootstrap.bundle.js"></script>
    <script src="~/Content/js/jquery-ui-1.12.js"></script>
    <script src="~/Scripts/Frameworks/sweetalert2@11.js"></script>
    
</head>
<body>
    <div id="contenedor" class="container layout-2" style="width:100%;">
        <div class="container">
            @RenderBody()
        </div>
    </div>
</body>
</html>