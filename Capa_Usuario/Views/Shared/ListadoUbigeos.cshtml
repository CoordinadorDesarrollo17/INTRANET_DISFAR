<table id="tbl_listaUbigeos" class="table table-light table-hover" width="100%">
    <thead class="thead-dark">
        <tr>
            <th class="text-center">UBIGEO</th>
            <th class="text-center">DISTRITO</th>
            <th class="text-center">PROVINCIA</th>
            <th class="text-center">DEPARTAMENTO</th>
            @if (ViewBag.MostrarZona == "SI")
            {
                <th class="text-center">ZONA</th>
            }
            @if (ViewBag.MostrarSeleccionar == "SI")
            {
                <th></th>
            }
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var m in Model)
            {
                <tr>
                    <td class="text-center">@m.Ubigeo</td>
                    <td class="text-center">@m.Distrito</td>
                    <td class="text-center">@m.Provincia</td>
                    <td class="text-center">@m.Departamento</td>
                    @if (ViewBag.MostrarZona == "SI")
                    {
                        <td class="text-center">@m.Zona</td>
                    }

                    @if (ViewBag.MostrarSeleccionar == "SI")
                    {
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-warning" onclick="cargarUbigeo('@m.Ubigeo')"><i class="icon-arrow-right"></i> Seleccionar</button>
                        </td>
                    }
                </tr>
            }
        }
    </tbody>
</table>

<script>
    (function () {
        var table_ubig = $('#tbl_listaUbigeos').DataTable({
            pageLength: 10,                 /* PARA INICIALIZAR LA PAGINACIÓN */
            lengthMenu: [10, 20, 30],   /* RANGO PAGINACIÓN */
            deferRender: true,
        });

        table_ubig.columns.adjust().draw();
    })();
</script>