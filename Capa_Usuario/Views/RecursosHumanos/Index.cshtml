                </div>

            </div>

        </div>
    </div>
</div>

<!-- MODAL NUMEROS CORPORATIVOS -->
<div class="modal fade" id="modalAdmNumCorporativos" tabindex="1" aria-labelledby="_ModalAdmNumCorporativos" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white bg-headerModals">
                <h5 class="modal-title" id="_ModalAdmNumCorporativos">Administrar NÚMEROS CORPORATIVOS</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="row overflow-auto">
                    <div class="col-12 py-3">
                        <button type="button" id="btn_exportarExcel" class="btn btn-success" data-tipo="num-corporativos"><i class="icon-file-excel"></i> Exportar Lista</button>
                    </div>
                </div>

                <div class="row overflow-auto">
                    <div class="col-lg-3 col-xl-3 py-3 d-flex align-items-center justify-content-end">
                        <label for="numeroCorporativo" class="text-dark font-weight-bold col-form-label p-0 m-0 flex-grow-1">Número corporativo:</label>
                    </div>

                    <div class="col-lg-4 col-xl-4 py-3 d-flex align-items-center">
                        <input id="numeroCorporativo" type="text" class="form-control input-cobefar text-center mr-3" autocomplete="off" />
                    </div>

                    <div class="col-lg-5 col-xl-5 py-3 d-flex justify-content-end align-items-end">
                        <div id="div_numAsignados" class="rounded rounded-5 bg-success text-white px-2 font-weight-bold font-18  p-1 px-3 mx-1">0</div>
                        <div id="div_numNoAsignados" class="rounded rounded-5 bg-danger text-white px-2 font-weight-bold font-18  p-1 px-3 mx-1">0</div>
                    </div>
                </div>

                <div class="row overflow-auto">
                    <div class="col-lg-3 col-xl-3 py-3 d-flex align-items-center justify-content-end">
                        <label for="operadorNumero" class="text-dark font-weight-bold col-form-label p-0 m-0 flex-grow-1">Operador:</label>
                    </div>

                    <div class="col-lg-3 col-xl-3 py-3 d-flex align-items-center">
                        <select id="operadorNumero" class="form-control">
                            <option value="">SELECCIONAR</option>
                            <option value="Bitel">Bitel</option>
                            <option value="Claro">Claro</option>
                            <option value="Entel">Entel</option>
                            <option value="Movistar">Movistar</option>
                        </select>
                    </div>

                    <div class="col-lg-3 col-xl-3 py-3 d-flex align-items-center">
                        <button type="button" id="btn_agregarNumero" class="btn btn-warning"><i class="icon-plus"></i> Agregar</button>
                    </div>
                </div>


                <div class="row justify-content-center overflow-auto bg-dark pt-4">
                    <div id="div_listaNumCorporativos" class="col-12 table-responsive" data-url="@Url.Action("ListarNumerosCorporativos")"></div>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- MODAL UBIGEOS -->
<div class="modal fade" id="modalUbigeos" tabindex="1" aria-labelledby="_ModalUbigeos" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header text-white bg-headerModals">
                <h5 class="modal-title font-weight-bold" id="_ModalUbigeos">Ubigeos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>

            <div class="modal-body py-0">
                <div class="row justify-content-center overflow-auto bg-dark pt-4">
                    <div id="div_listaUbigeos" class="col-12 table-responsive"></div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn bg-cobefar-3 text-white" data-dismiss="modal"><i class="icon-cross"></i> Cerrar</button>
            </div>

        </div>
    </div>
</div>

<!-- FILTROS -->
<div class="modal fade" id="modalBusquedaFiltros" tabindex="1" aria-labelledby="_ModalBusquedaFiltros" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white bg-headerModals">
                <h5 class="modal-title" id="_ModalBusquedaFiltros">Búsqueda con filtros</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="row overflow-auto mb-2">
                    <div class="col py-3">
                        <label for="filtro_nombresApellidos" class="text-dark font-weight-bold">Nombres y Apellidos:</label>
                        <input id="filtro_nombresApellidos" type="text" class="form-control input-cobefar mr-3" autocomplete="off" />
                    </div>

                    <div class="col py-3 @if (vistaExterna) { Write("d-none"); }">
                        <label for="filtro_nroDocumento" class="text-dark font-weight-bold">DNI:</label>
                        <input id="filtro_nroDocumento" type="text" class="form-control input-cobefar mr-3" autocomplete="off" />
                    </div>
                </div>

                <div class="row overflow-auto mb-2">
                    <div class="col py-3">
                        <label for="filtro_dpto" class="text-dark font-weight-bold">Departamento:</label>
                        <select id="filtro_dpto" class="cls-select">
                            <option value="">SELECCIONAR</option>
                            @if (ViewBag.Departamentos != null)
                            {
                                foreach (var dpto in ViewBag.Departamentos)
                                {
                                    <option value="@dpto.IdDepartamento">@dpto.Nombre</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col py-3">
                        <label for="filtro_area" class="text-dark font-weight-bold">Área:</label>
                        <select id="filtro_area" class="cls-select">
                            <option value="">SELECCIONAR</option>
                        </select>
                    </div>
                </div>

                <div class="row overflow-auto mb-2">
                    <div class="col-6 py-3 @if (vistaExterna) { Write("d-none"); }">
                        <label for="filtro_cargo" class="text-dark font-weight-bold">Puesto:</label>
                        <select id="filtro_cargo" class="cls-select">
                            <option value="">SELECCIONAR</option>
                        </select>
                    </div>

                    <div class="col-6 py-3">
                        <label for="filtro_sede" class="text-dark font-weight-bold">Sede:</label>
                        <select id="filtro_sede" class="cls-select">
                            <option value="">SELECCIONAR</option>
                        </select>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" id="btn_limpiarFiltrosBusqueda" class="btn btn-outline-primary"><i class="icon-magic-wand"></i> Limpiar Filtros</button>
                    <button type="button" id="btn_filtrarEmpleado" class="btn btn-primary"><i class="icon-filter"></i> Filtrar</button>
                </div>

            </div>

        </div>
    </div>
</div>

