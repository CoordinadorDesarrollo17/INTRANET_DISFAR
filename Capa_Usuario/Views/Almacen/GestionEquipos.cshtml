@model IEnumerable<Capa_Entidad.Almacen_ENT.TablasSql.OIEQ_E>
@using Capa_Entidad.Almacen_ENT.TablasSql
@using Capa_Entidad.General_ENT.Tablas

@{
    ViewBag.Title = "GestionEquipos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    OIEQ_E f = (OIEQ_E)ViewBag.Oieq;
    List<OWHS_E> ow = (List<OWHS_E>)ViewBag.Almacenes;
}

<script>
    $(document).ready(function () {
        $('#filterModal').on('shown.bs.modal', function () {
            $('#DocEntry').focus();
        });

        $('#filterForm').on('submit', function (e) {
            e.preventDefault();
            var query = $(this).serialize();
            window.location.href = "/Almacen/GestionEquipos?" + query;
        });
    });

    function openFilterModal() {
        $('#filterModal').modal('show');
    }
</script>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ContabilizacionInventario", "Almacen")">Módulo contabilización inventario</a></li>
            <li class="current"><em>Gestión de equipos</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3">
        <h3 class="titulo-seccion">GESTIÓN DE EQUIPOS</h3>
    </div>
</div>

<div class="bg-white d-flex pl-2 w-100 py-2">
    <div class="mx-2">
        <a class="btn btn-success" href="@Url.Action("NuevoEquipo", "Almacen", new { Tipo = "Conteo" })">
            <i class="icon icon-plus"></i> Equipo Conteo
        </a>
    </div>
    <div class="mx-2">
        <a class="btn btn-warning" href="@Url.Action("NuevoEquipo", "Almacen", new { Tipo = "ReConteo" })">
            <i class="icon icon-plus"></i> Equipo ReConteo
        </a>
    </div>
    <div class="mx-2">
        <a class="btn btn-info" href="@Url.Action("NuevoEquipo", "Almacen", new { Tipo = "Analisis" })">
            <i class="icon icon-plus"></i> Equipo Análisis
        </a>
    </div>
    <div class="mx-2">
        <button class="btn btn-primary" data-toggle="modal" data-target="#filterModal">
            <i class="icon-filter"></i> Filtrar
        </button>
    </div>
</div>

@if (@OIPE_E.PeriodoSeleccionado != null)
{
    <div class="alert alert-danger mb-0" role="alert">
        @("Periodo Seleccionado: " + OIPE_E.PeriodoSeleccionado.Descripcion + " ---- Almacenes: " + OIPE_E.PeriodoSeleccionado.enlistarDetAlmacenes())
    </div>
}

<div class="bg-white bg-form-cobefar pt-3">
    <table class="table table-light table-sm table-hover cls-dataTable50" cellspacing="0" width="100%">
        <thead class="bg-cobefar-6 text-center">
            <tr>
                <th class="text-center">N°</th>
                <th class="text-center">Periodo</th>
                <th class="text-center">Nombre</th>
                <th class="text-center">Almacen</th>
                <th class="text-center">Piso</th>
                <th class="text-center">Estado</th>
                <th class="text-center">Fecha Registro</th>
                <th class="text-center"></th>
                <th class="text-center"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.DocEntry)</td>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.DescripcionPeriodo)</td>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.Nombre)</td>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.WhsCode)</td>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.Piso)</td>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.Estado)</td>
                    <td class="text-center">@Html.DisplayFor(modelItem => item.FechaRegistro)</td>
                    <td class="text-center">
                        <a href="@Url.Action("EditarEquipo", "Almacen", new { id = item.DocEntry })" class="btn btn-light text-primary" data-toggle="tooltip" data-placement="top" title="Editar equipo">
                            <i class="icon-pencil"></i>
                        </a>
                    </td>
                    <td class="text-center">
                        <a href="@Url.Action("EliminarEquipo", "Almacen", new { id = item.DocEntry })" class="btn btn-light text-danger" data-toggle="tooltip" data-placement="top" title="Eliminar equipo">
                            <i class="icon-bin"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal de Filtros -->
<div class="modal fade" id="filterModal" tabindex="-1" role="dialog" aria-labelledby="filterModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-cobefar">
                <h5 class="modal-title text-light" id="filterModalLabel">Filtrar Equipos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="filterForm">
                    <div class="form-group">
                        <label for="DocEntry">N°</label>
                        <input type="text" id="DocEntry" name="DocEntry" class="form-control" value="@f.DocEntry" />
                    </div>
                    <div class="form-group">
                        <label for="DescripcionPeriodo">Periodo</label>
                        <input type="text" id="DescripcionPeriodo" name="DescripcionPeriodo" class="form-control" value="@f.DescripcionPeriodo" />
                    </div>
                    <div class="form-group">
                        <label for="Nombre">Nombre</label>
                        <input type="text" id="Nombre" name="Nombre" class="form-control" value="@f.Nombre" />
                    </div>
                    <div class="form-group">
                        <label for="Almacen">Almacen</label>
                        <select id="Almacen" name="WhsCode" class="form-control">
                            <option value="">Seleccione</option>
                            @foreach (var obj in ow)
                            {
                                <option value="@obj.WhsCode" @(f.WhsCode == obj.WhsCode ? "selected" : "")>@obj.WhsName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="Piso">Piso</label>
                        <input type="number" id="Piso" name="Piso" class="form-control" value="@f.Piso" />
                    </div>
                    <div class="form-group">
                        <label for="Estado">Estado</label>
                        <input type="text" id="Estado" name="Estado" class="form-control" value="@f.Estado" />
                    </div>
                    <div class="form-group">
                        <label for="FechaRegistro">Fecha Registro</label>
                        <input type="date" id="FechaRegistro" name="FechaRegistro" class="form-control" value="@f.FechaRegistro" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary" form="filterForm">Aplicar Filtros</button>
            </div>
        </div>
    </div>
</div>
