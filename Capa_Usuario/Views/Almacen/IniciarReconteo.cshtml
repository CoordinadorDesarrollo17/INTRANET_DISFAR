@model Capa_Entidad.Almacen_ENT.TablasSql.OIAR_E
@using Capa_Entidad.Seguridad_ENT
@using Capa_Entidad.Almacen_ENT.TablasSql

@{
    ViewBag.Title = "IniciarReconteo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    IAR11_E iar11 = (IAR11_E)ViewBag.Iar11;
    IAR1_E iar1 = new IAR1_E();
    List<Usuario_E> u = (List<Usuario_E>)ViewBag.Miembros;

}
<script>
    $(document).ready(function () {
    });
    var contUser = 0;
    function llenarTabla(id) {
        var Usuario = $("#" + id);
        var Nombre = $("#listaApoyos option[value='" + Usuario.val() + "']").attr("nombre");
        var Observacion = $("#ObsApoyo").val();
        if (Usuario.val() == null || Usuario.val() == "") { swal.fire("No ha seleccionado un personal de apoyo", "Verifique", "warning"); return; }
        if (Nombre == null || Nombre == "") { swal.fire("Personal no existente", "Verifique", "warning"); return; }
        if (validarUnicoCampoTabla(Usuario.val(), "DetallesReconteo")) {
            $("#DetallesReconteo > tbody").append("<tr><td hidden><input class='form-control' name='DetFases[0].DetApoyos[" + contUser + "].Linea' value='" + (contUser + 1) + " ' readonly /></td>" +
                "<td><input class= 'form-control' name = 'DetFases[0].DetApoyos[" + contUser + "].Id' value = '" + Usuario.val() + "' readonly /></td >" +
                "<td><input class='form-control' name='DetFases[0].DetApoyos[" + contUser + "].Nombre' value='" + Nombre + "'  readonly /></td>" +
                "<td><input class= 'form-control' name = 'DetFases[0].DetApoyos[" + contUser + "].ObsApoyo' value = '" + Observacion + "' readonly /></td >" +
                "<td><button type='button' onclick='borrarTrTable(this)' class='btn btn-danger'>Retirar</button></td></tr>");
            contUser = contUser + 1;
        }
        $("#" + id).val("");
        $("#ObsApoyo").val("");
    }
    function borrarTrTable(dom) {
        var i = -1;
        $(dom).closest('tr').remove();
        contUser = contUser - 1;
        $("#DetallesReconteo > tbody" + " tr").each(function (index, htm) {
            iden1 = $(htm).find("td:eq(0) input");
            iden1.attr("name", "DetFases[0].DetApoyos[" + i + "].Linea");
            iden1.val(i + 1);
            iden2 = $(htm).find("td:eq(1) input");
            iden2.attr("name", "DetFases[0].DetApoyos[" + i + "].Id");
            iden3 = $(htm).find("td:eq(2) input");
            iden3.attr("name", "DetFases[0].DetApoyos[" + i + "].Nombre");
            iden3 = $(htm).find("td:eq(3) input");
            iden3.attr("name", "DetFases[0].DetApoyos[" + i + "].ObsApoyo");
            i = i + 1;
        })
    }
    function validarUnicoCampoTabla(identificador, idTabla) {
        var sinRegistro = true;
        $("#" + idTabla + " tr").find('td:eq(1) input').each(function () {
            iden = $(this).val();
            if (iden == identificador) { swal.fire("El valor ya se encuentra en la tabla", "Verifique", "warning"); sinRegistro = false; }
        })
        return sinRegistro;
    }
    function guardarReconteo() {
        var object = $("#IniciarReconteo").serialize();
        $(location).attr('href', "/Almacen/IniciarReconteoPost?" + object);
    }
    function revertirReconteo() {
        var object = $("#IniciarReconteo").serialize();
        $(location).attr('href', "/Almacen/RevertirInicioReconteo?" + object);
    }
    function validaInicioReconteo() {
        var object = $("#IniciarReconteo").serialize();
        $.ajax('/Almacen/validarInicioReconteo',
            {
                data: object,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response != "true") { swal.fire({ title: response, text: "Presione OK para continuar", icon: "warning" }); return false }
                else { guardarReconteo(); }
            });
    }
    function validaRevertirInicioReconteo() {
        var object = $("#IniciarReconteo").serialize();
        $.ajax('/Almacen/validarRevertirInicioReconteo',
            {
                data: object,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response != "true") { swal.fire({ title: response, text: "Presione OK para continuar", icon: "warning" }); return false }
                else { revertirReconteo(); }
            });
    }

</script>

