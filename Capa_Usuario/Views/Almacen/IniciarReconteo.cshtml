@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "IniciarReconteo" }))
{
    @Html.AntiForgeryToken()
<div class="bg-form-pestanas-cobefar pt-4 bg-section-form p-4 bg-form-cobefar">
    <div class="row mt-2">
        <div class="col-lg-1">
            <label for="DocEntryEqu" class="text-dark form-label font-weight-bold font-18">Equipo:</label>
            <input class="form-control border-success text-center" id="DocEntryEqu" type="text" name="DocEntryEqu" readonly value="@Model.DocEntryEqu" />
        </div>

        <div class="col-lg-2">
            <label for="WhsCode" class="text-dark form-label font-weight-bold font-18">Almacén:</label>
            <input class="form-control border-success text-center" type="text" name="WhsCode" readonly value="@Model.WhsCode" />
        </div>

        <div class="col-lg-1">
            <label for="Piso" class="text-dark form-label font-weight-bold font-18">Piso:</label>
            <input class="form-control border-success text-center" type="text" name="Piso" readonly value="@Model.Piso" />
        </div>

        <div class="col-lg-4">
            <label for="Propietario" class="text-dark form-label font-weight-bold font-18">Propietario:</label>
            <input class="form-control border-success text-center" type="text" name="Propietario" readonly value="@Model.Propietario" />
        </div>

        <input id="" type="hidden" name="DocEntryPer" value="@Model.DocEntryPer" />

        <div class="col-lg-4">
            <label for="Operario" class="text-dark form-label font-weight-bold font-18">Op Reconteo:</label>
            <input class="form-control border-success text-center" type="text" name="DetFases[0].Operario" readonly value="@if (Model.Fase > 3) { Write(Model.DetFases[2].Operario); } " />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-2">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Tiempo Inicio:</label>
            <input class="form-control border-success text-center" type="text" name="DetFases[0].FechaFase" readonly value="@if (Model.Fase > 3) { Write(Model.DetFases[2].FechaFase); }" />
        </div>

        <div class="col-lg-2">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Hora Inicio:</label>
            <input class="form-control border-success text-center" type="text" name="DetFases[0].HoraFase" readonly value="@if (Model.Fase > 3) { Write(Model.DetFases[2].HoraFase); }" />
        </div>

        <div class="col-lg-8">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Observación:</label>
            <input class="form-control border-success" type="text" name="DetFases[0].FechaFase" readonly value="@if (Model.Fase > 3) { Write(Model.DetFases[2].Observacion); }" />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-2">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">N°:</label>
            <input class="form-control border-success text-center" type="text" name="DocEntry" readonly value="@Model.DocEntry" />
        </div>

        <div class="col-lg-2">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Estado:</label>
            <input class="form-control border-success text-center" type="text" name="Estado" readonly value="@Model.Estado" />
        </div>

        <div class="col-lg-6">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Artículo:</label>
            <input class="form-control border-success text-center" type="text" name="ItemName" readonly value="@Model.ItemName" />
        </div>

        <div class="col-lg-2">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Cod. Artículo:</label>
            <input class="form-control border-success text-center" type="text" name="ItemCode" readonly value="@Model.ItemCode" />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-4">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Apoyos:</label>
            <input type="search" id="Apoyos" list="listaApoyos" class="form-control border-success text-center" />
            <datalist id="listaApoyos">

                @foreach (Usuario_E obj in u)
                {
                    <option value="@obj.Prefijo@obj.Id" nombre="@obj.Nombres  @obj.Apellidos">@obj.Nombres  @obj.Apellidos</option>
                }
            </datalist>
        </div>

        <div class="col-lg-8">
            <label for="TiempoInicio" class="text-dark form-label font-weight-bold font-18">Obs. Apoyo:</label>
            <div class="d-flex">
                <input id="ObsApoyo" type="text" value="" class="form-control border-success" />
                @if (Model.DetFases.Count == 2)
                {
                    <button type="button" class="btn btn-info" onclick="llenarTabla('Apoyos');"><i class="icon-plus"></i> Agregar</button>
                }
                
            </div>

        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-10">
            <table id="DetallesReconteo" class="table table-sm ">
                <thead class="bg-dark">
                    <tr>
                        <th class="text-center" width="220px">Usuario</th>
                        <th class="text-center">Nombre</th>
                        <th class="text-center">Observación</th>
                        <th class="text-center"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DetFases.Count > 2 && Model.DetFases[2].DetApoyos.Count > 0)
                    {
                        foreach (IAR11_E obj in Model.DetFases[2].DetApoyos)
                        {
                            <tr>
                                <td>@obj.Id</td>
                                <td>@obj.Nombre</td>
                                <td>@obj.ObsApoyo</td>
                                <td></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-6">
            <button id="accion" type="button" class="btn btn-success" onclick="validaInicioReconteo();"><i class="icon-checkmark"></i> IniciarReconteo</button>
            <button id="accion" type="button" class="btn btn-danger" onclick=" validaRevertirInicioReconteo();"><i class="icon-undo"></i> RevertirInicioReconteo</button>
        </div>
    </div>
</div>
}