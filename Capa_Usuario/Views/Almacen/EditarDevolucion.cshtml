@using Capa_Entidad.General_ENT.TablasSql;
@using Capa_Entidad.Almacen_ENT.Tablas;
@using Capa_Entidad.Almacen_ENT.TablasSql;
@{
    ViewBag.Title = "Editar Devolución";
    Layout = "~/Views/Shared/_Layout.cshtml";
    List<OWHS_E> Almacenes = (List<OWHS_E>)ViewBag.Almacenes;
    List<MotivosDevoluciones_E> MotivosDevoluciones = (List<MotivosDevoluciones_E>)ViewBag.MotivosDevoluciones;
    List<SubmotivosDevoluciones_E> Submotivos = (List<SubmotivosDevoluciones_E>)ViewBag.SubmotivosDevoluciones;
    List<OMRC_E> Laboratorios = (List<OMRC_E>)ViewBag.Laboratorios;

}

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("DevolucionMercancias", "Almacen")">Listado de devoluciones</a></li>
            <li class="current"><em>Editar Devolución</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">EDITAR DEVOLUCIÓN</h3></div>
</div>

<form action="/Almacen/EditarDevolucion" method="post" id="frmEditarDevolucion">
    <input type="hidden" id="DocEntry" name="DocEntry" value="@if (Model != null) { Write(Model.DocEntry); }" />
    <input type="hidden" id="DocNumDevolucion" name="DocNum" value="@if (Model != null) { Write(Model.DocNum); }" />
    <div class="bg-form-pestanas-cobefar pt-4 bg-section-form p-4 bg-form-cobefar">
        <div class="row mb-2">
            <div class="col-lg-4 my-2">
                <label class="text-dark form-label font-weight-bold font-18">Estado:</label>
                <input type="text" id="Estado" class="form-control border-success text-center" value="@if (Model != null) { Write(Model.Estado); }" disabled>
            </div>

            <div class="col-lg-2 my-2">
                <label class="text-dark form-label font-weight-bold font-18">Fecha:</label>
                <input type="text" id="FechaOperacion" class="form-control border-success text-center" value="@if (Model != null) { Write(Model.FechaOperacion); }" disabled>
            </div>

            <div class="col-lg-2 my-2">
                <label class="text-dark form-label font-weight-bold font-18">Retiro de mercado:</label>
                <input type="text" id="RetiroMercado" class="form-control border-success text-center" value="@if (Model != null) { if (Model.RetiroMercado == true) { Write("SI"); } else if (Model.RetiroMercado == false) {Write("NO"); }  }" disabled>
            </div>

            <div class="col-lg-3 my-2" id="div_SinEM">
                <label class="text-dark form-label font-weight-bold font-18">Entrada de mercancía:</label>
                <input type="text" id="SinEM" class="form-control border-success text-center" value="@if (Model != null) { if (Model.SinEM == false) { Write("SI"); } else if (Model.SinEM == true) {Write("NO"); }  }" disabled>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-2 my-2">
                <label class="text-dark form-label font-weight-bold font-18">RUC:</label>
                <input type="text" id="CardCode" class="form-control border-success text-center" value="@if (Model != null) { Write(Model.CardCode); }" disabled>
            </div>

            <div class="col-lg-4 my-2">
                <label for="CardName" class="text-dark form-label font-weight-bold font-18">Proveedor:</label>
                <input type="search" name="CardName" id="CardName" list='ListaClientes' class="form-control border-success text-center" value="@if (Model != null) { Write(Model.CardName); }" disabled>
                <div id="div_listaClientes"></div>
            </div>

            <div class="col-lg-2 my-2">
                <label class="text-dark form-label font-weight-bold font-18">Almacén de origen:</label>
                <input type="hidden" id="WhsCode" value="@if (Almacenes != null && Almacenes.Count >=1) { Write(Almacenes[0].WhsCode); }" />
                <input type="text" class="form-control border-success text-center" value="@if (Almacenes != null && Almacenes.Count >=1) { Write(Almacenes[0].WhsCode); }" disabled />
            </div>

            <div class="col-lg-4 my-2">
                <label class="text-dark form-label font-weight-bold font-18">Dirección Almacén:</label>
                <input type="text" id="direccion_alm" class="form-control border-success text-center" value="@Almacenes[0].Street @Almacenes[0].StreetNo" disabled>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-lg-2">
                <button type="button" id="btn_modalArticulos" data-toggle="modal" data-target="#modalArticulos" hidden></button>
                <button type="button" class="btn btn-warning" onclick="agregarArticulos();"><i class="icon icon-plus"></i> Agregar Artículos</button>
            </div>
            <div class="col-lg-2">
                <button id="btn_nuevo_articulo" type="button" class="btn btn-info" data-toggle="collapse" data-target="#div_nuevoArticulo" aria-expanded="false" aria-controls="div_nuevoArticulo"><i class="icon icon-plus"></i> Nuevo Artículo</button>
                <button type="button" class="btn btn-primary" id="btn_consultarRM" onclick="agregarArticulosRM();"><i class="icon icon-search"></i> Consultar RM </button>
                <button type="button" id="btn_modalArticulosRM" data-toggle="modal" data-target="#modalArticulosRM" hidden></button>
            </div>

            <div class="col-lg-6 d-flex align-items-center justify-content-end">
                <label for="factura_unica" class="text-dark form-label font-weight-bold font-18 mt-3 mr-3">Factura única:</label>
                <input type="text" name="CardName" id="factura_unica" class="form-control border-success text-center" value="" style="width: 300px;" autocomplete="off" onkeyup="completarRefFactura(this.value);">
            </div>
        </div>
        <div id="div_nuevoArticulo" class="collapse">
            <div class="card card-body bg-dark m-4 p-4">
                <div class="row">
                    <div class="col-lg-4">
                        <label class="text-white font-weight-bold">Laboratorio:</label>
                        <select id="lab_nuevoArticulo" class="form-control bg-cobefar text-white" onchange="$('#codprod_nuevoArticulo').val(''), $('#prod_nuevoArticulo').val(''); buscarProducto(this.id, 'div_productosNuevoArticulo');">
                            <option value="">Seleccione</option>
                            @if (Laboratorios != null && Laboratorios.Count() >= 1)
                            {
                                foreach (var lab in Laboratorios)
                                {
                                    <option value="@lab.FirmCode">@lab.U_SYP_DESC</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-lg-4">
                        <label for="prod_nuevoArticulo" class="text-white font-weight-bold">Producto:</label>
                        <input type="search" id="prod_nuevoArticulo" list='ListaProductos' class="form-control border-success" onchange="cargarItemCode()" autocomplete="off" />
                        <div id="div_productosNuevoArticulo"></div>
                    </div>

                    <div class="col-lg-2">
                        <label for="codprod_nuevoArticulo" class="text-white font-weight-bold">Cód. producto:</label>
                        <input type="text" id="codprod_nuevoArticulo" class="form-control border-success text-center" readonly />
                        <input type="hidden" id="BuyUnitMsr_nuevoArticulo" readonly />
                        <input type="hidden" id="NumInBuy_nuevoArticulo" readonly />
                        <input type="hidden" id="FirmCode_nuevoArticulo" readonly />
                        <input type="hidden" id="FirmName_nuevoArticulo" readonly />
                    </div>

                    <div class="col-lg-2 d-flex justify-content-center align-items-center">
                        <button type="button" class="btn btn-success" onclick="agregarDetalleDevolucion($('#codprod_nuevoArticulo').val(), $('#prod_nuevoArticulo').val(), $('#FirmCode_nuevoArticulo').val(), $('#FirmName_nuevoArticulo').val(), '' , '' , $('#BuyUnitMsr_nuevoArticulo').val(), '' , $('#NumInBuy_nuevoArticulo').val(), 0, 'NUEVO','','',0);"><i class='icon-plus'></i> </button>
                    </div>
                </div>
            </div>

        </div>
        <div class="row pt-4 mt-4">
            <div class="col-lg-12 table-responsive">
                <table id="tbl_detalleDevolucion" class="table table-light table-sm table-bordered table-hover" cellpadding="0" width="100%">
                    <thead class="bg-cobefar">
                        <tr>
                            <th hidden></th>
                            <th hidden></th>@*Guarda MaxQuantity*@
                            <th hidden></th>@*Guarda MaxQuantityOIBT*@
                            <th hidden></th>@*Guarda NumInBuyKey*@
                            <th hidden></th>
                            <th hidden></th>
                            <th class="text-center">Descripción del producto</th>
                            <th class="text-center">Lote</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-center">UM</th>
                            <th class="text-center">Motivo</th>
                            <th class="text-center">Submotivo</th>
                            <th class="text-center">Ref. Factura</th>
                            <th class="text-center">Observación</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.DetalleDevolucion != null)
                        {
                            int num = 0;
                            foreach (var m in Model.DetalleDevolucion)
                            {

                                <tr id="tr_@num" class="cls-filaDevolucion">
                                    <td hidden><input type="hidden" name="DetalleDevolucion[@num].ItemCode" value="@m.ItemCode" /></td>
                                    <td hidden><input type="hidden" id="MaxQuantity_@num" name="DetalleDevolucion[@num].MaxQuantity" value="@m.MaxQuantity" /></td>
                                    <td hidden><input type="hidden" id="MaxQuantityOIBT_@num" name="DetalleDevolucion[@num].MaxQuantityOIBT" value="@m.MaxQuantityOIBT" /></td>
                                    <td hidden><input type="hidden" id="NumInBuyKey_@num" name="DetalleDevolucion[@num].NumInBuyKey" value="@m.NumInBuyKey" /></td>
                                    <td hidden><input type="hidden" id="BuyUnitMsr_@num" name="DetalleDevolucion[@num].BuyUnitMsr" value="@m.BuyUnitMsr" /></td>
                                    <td hidden><input type="hidden" name="DetalleDevolucion[@num].FirmCode" value="@m.FirmCode" /></td>
                                    <td class="text-center"><input type="hidden" name="DetalleDevolucion[@num].ItemName" value="@m.ItemName" />@m.ItemName</td>
                                    <td class="text-center">
                                        <input type="hidden" id="lote" name="DetalleDevolucion[@num].BatchNum" value="@m.BatchNum" />@m.BatchNum<br />
                                        <span class="text-danger font-weight-bold">Fecha V.:</span><br /><input type="hidden" id="fechaV" name="DetalleDevolucion[@num].ExpDate" value="@m.ExpDate" />@m.ExpDate
                                    </td>
                                    <td><input type="number" id="QuantityIngresada_@num" name="DetalleDevolucion[@num].Quantity" class="form-control border-success text-center" tipoarticulo="@if (m.MaxQuantity == Convert.ToDecimal(0.00)) { Write("NUEVO"); } else { Write("BD");}" style="width: 100px;" value="@m.Quantity" min="1" required /></td>
                                    <td class="text-center">
                                        <select id="NumInBuy_@num" name="DetalleDevolucion[@num].NumInBuy" style="display: none">
                                            <option value="@m.NumInBuy" tipo="@m.BuyUnitMsr"></option>
                                        </select>
                                        @m.BuyUnitMsr
                                    </td>
                                    <td>
                                        <select id="Motivo_@num" name="DetalleDevolucion[@num].Motivo" class="form-control bg-cobefar text-white" onchange="cargarMotivos(this.id)" style="width: 200px;" required>
                                            <option value="">Seleccione</option>
                                            @if (MotivosDevoluciones != null && MotivosDevoluciones.Count() >= 1)
                                            {
                                                foreach (var md in MotivosDevoluciones)
                                                {
                                                    <option value="@md.IdMotivo" @if (m.Motivo == md.IdMotivo) { Write("selected"); }>@md.Descripcion</option>
                                                }
                                            }
                                        </select>
                                        <script>$(`#Motivo_@num`).select2();</script>
                                    </td>
                                    <td>
                                        <select name="DetalleDevolucion[@num].Submotivo" id="ListaObsxMotivo_@num" class="form-control bg-cobefar text-white cls-select2" style="width: 260px;">
                                            <option value="">Seleccione</option>
                                            @if (Submotivos != null && Submotivos.Count() >= 1)
                                            {
                                                foreach (var md in Submotivos)
                                                {
                                                    <option value="@md.IdSubmotivo" @if (m.Submotivo == md.IdSubmotivo) { Write("selected"); }>@md.Descripcion</option>
                                                }
                                            }
                                        </select>
                                        <script>$(`#ListaObsxMotivo_@num`).select2();</script>
                                    </td>
                                    <td><input type="text" name="DetalleDevolucion[@num].RefFactura" class="form-control border-success text-center cls-factura-unica" value="@m.RefFactura"></td>
                                    <td><input type="text" name="DetalleDevolucion[@num].Observacion" class="form-control border-success text-center font-14" autocomplete="off" value="@m.Observacion"></td>
                                    <td><button type="button" class="btn btn-danger" onclick="borrarFila(@num)"><i class="icon-bin"></i></button></td>
                                </tr>
                                ++num;
                            }
                        }

                    </tbody>
                </table>
            </div>
        </div>
        <div id="div_generarDev" class="row mt-4">
            <div class="col-lg-6">
                <button type="button" class="btn btn-success" onclick="validarFormulario();"><i class="icon-checkmark"></i> Editar Devolución</button>
            </div>
        </div>

    </div>
</form>

<!-- Modal -->
<div class="modal fade" id="modalArticulos" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-full-width">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">Búsqueda de artículos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div id="div_fechaEntrada" class="col-lg-2 my-2">
                        <label class="text-cobefar font-weight-bold">Fecha de entrada:</label>
                        <input type="date" id="DocDate" name="DocDate" class="form-control border-success text-center" />
                    </div>

                    <div id="div_docNum" class="col-lg-2 my-2">
                        <label for="DocNum" class="text-cobefar font-weight-bold">DocNum:</label>
                        <input type="text" id="DocNum" name="DocNum" class="form-control border-success text-center" autocomplete="off" />
                    </div>

                    <div class="col-lg-4 my-2">
                        <label class="text-cobefar font-weight-bold">Laboratorio:</label>
                        <select id="Laboratorio" name="Laboratorio" class="form-control bg-cobefar text-white" onchange="limpiarCampos(); buscarProducto(this.id, 'div_listaProductos');">
                            <option value="">Seleccione</option>
                            @if (Laboratorios != null && Laboratorios.Count() >= 1)
                            {
                                foreach (var lab in Laboratorios)
                                {
                                    <option value="@lab.FirmCode">@lab.U_SYP_DESC</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-lg-4 d-flex align-items-center justify-content-end">
                        <div id="div_sinEntradaMercancia" class="form-check mr-4">
                        </div>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-lg-4 my-2">
                        <label class="text-cobefar font-weight-bold">Producto:</label>
                        <input type="search" id="ItemName" list='ListaProductos' class="form-control border-success" onchange="cargarItemName()" autocomplete="off" />
                        <div id="div_listaProductos"></div>
                    </div>

                    <div class="col-lg-2 my-2">
                        <label for="ItemCode" class="text-cobefar font-weight-bold">Cód. producto:</label>
                        <input type="text" id="ItemCode" name="ItemCode" class="form-control border-success text-center" readonly />
                    </div>

                    <div class="col-lg-2 my-2">
                        <label class="text-cobefar font-weight-bold">Lote:</label>
                        <input type="text" id="BatchNum" name="BatchNum" list="ListaLotes" class="form-control border-success text-center" autocomplete="off" />
                        <div id="div_listaLotes"></div>
                    </div>

                    <div id="div_refFactura" class="col-lg-2 my-2">
                        <label class="text-cobefar font-weight-bold">Ref. Factura:</label>
                        <input type="text" id="NumAtCard" name="NumAtCard" class="form-control border-success text-center" autocomplete="off" />
                    </div>

                    <div class="col-lg-2 d-flex align-items-end">
                        <button type="button" class="btn btn-cobefar mb-2" onclick="filtrarArticulo()"><i class="icon-filter"></i> Filtrar</button>
                    </div>
                </div>


                <div id="div_tbl" class="row mt-4" style="display: none;">
                    <div class="col-lg-12 table-responsive">
                        <table id="tbl_listaArticulos" class="table table-bordered table-hover">
                            <thead class="bg-success">
                                <tr>
                                    <th class="text-center" style="width: 45%">Artículo</th>
                                    <th class="text-center">Lote</th>
                                    <th class="text-center">Fecha Venc</th>
                                    <th class="text-center">UM</th>
                                    <th class="text-center">Ref. Factura</th>
                                    <th class="text-center">Agregar</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>

            </div>
        </div>
    </div>
</div>
<!-- Modal RM -->
<div class="modal fade" id="modalArticulosRM" tabindex="2" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-full-width">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="exampleModalLabel">Búsqueda de artículos - RM </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-lg-3 my-2">
                        <label class="text-dark font-weight-bold">Laboratorio:</label>
                        <select id="LaboratorioRM" class="form-control bg-info text-white" onchange="limpiarCampos(); buscarProductoRM(this.id, 'div_listaProductosRM');">
                            <option value="">Seleccione</option>
                            @if (Laboratorios != null && Laboratorios.Count() >= 1)
                            {
                                foreach (var lab in Laboratorios)
                                {
                                    <option value="@lab.FirmCode">@lab.U_SYP_DESC</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-lg-3 my-2">
                        <label for="ItemNameRM" class="text-dark font-weight-bold">Producto:</label>
                        <input type="search" id="ItemNameRM" list='ListaProductosRM' class="form-control border-primary" autocomplete="off" onchange="cargarItemCodeRM()" />
                        <div id="div_listaProductosRM"></div>
                    </div>
                    <div class="col-lg-2 my-2">
                        <label for="ItemCodeRM" class="text-dark font-weight-bold">Cód. producto:</label>
                        <input type="text" id="ItemCodeRM" class="form-control border-primary text-center" readonly />
                    </div>
                    <div class="col-lg-2 my-2">
                        <label class="text-dark font-weight-bold">Lote:</label>
                        <input type="text" id="BatchNumRM" name="BatchNum" list="ListaLotes" class="form-control border-primary text-center" autocomplete="off" />
                        <input type="text" id="WhsCodeRM" value="06" hidden />
                    </div>

                    <div class="col-lg-2  d-flex align-items-end">
                        <button type="button" class="btn btn-dark mb-2" onclick="filtrarArticuloRM()"><i class="icon-filter"></i> Filtrar</button>
                    </div>
                </div>

                <div id="div_tblRM" class="row mt-4" style="display: none;">
                    <div class="col-lg-12 table-responsive">
                        <table id="tbl_listaArticulosRM" class="table table-bordered table-hover">
                            <thead class="bg-info">
                                <tr>
                                    <th class="text-center" style="width: 45%">Artículo</th>
                                    <th class="text-center">Lote</th>
                                    <th class="text-center">Fecha Venc</th>
                                    <th class="text-center">Cantidad a Dev</th>
                                    <th class="text-center">Ver Factura(s)</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btn_cerrarModalRM" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>
<div style="display: none">
    <datalist id="ListaSubmotivos">
        @if (Submotivos != null && Submotivos.Count() >= 1)
        {
            foreach (var obs in Submotivos)
            {
                <option idmotivo="@obs.IdMotivo" id="@obs.IdSubmotivo" value="@obs.Descripcion">@obs.Descripcion</option>
            }
        }
    </datalist>
</div>

<script>

    if ('@ViewBag.Mensaje' != "") {
            Swal.fire('@ViewBag.Mensaje');
        }
    $(document).ready(function () {
        reconstruirTabla();
        validarRetiroMercado($('#RetiroMercado').val());
    });
    var num = 0;
    //busca facturas solo de RM
    function buscarFacturas(ItemCode, BatchNum, Quantity) {
        Swal.fire({
            html: '<img src="/imagenes/index/ReportesDigemid/cargando.gif" />',
             //closeOnCancel: false,
            allowOutsideClick: false,
            showCancelButton: false,
            showConfirmButton: false
        });

        $.ajax({
            url: '/Almacen/BuscarFacturas',
            type: 'POST',
            dataType: 'json',
            data: {
                'ItemCode': ItemCode,
                'BatchNum': BatchNum,
                'U_COB_LUGAREN': '06',
                'Quantity': Quantity
            }
        }).done(function (response) {
            Swal.close();
            $('#btn_modalArticulos').click();
            $('#btn_cerrarModalRM').click();
            $('#div_fil_tbl').css('display', 'none');
            $('#div_tbl').css('display', 'block');
            if (response !== '') {
                $('#tbl_listaArticulos > tbody').html(response);
            } else {
                $('#tbl_listaArticulos > tbody').html('<tr><td colspan="6">Sin datos para mostrar.</td></tr>');
            }
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status, textStatus, errorThrown);
        });
    }

    function limpiarCampos(campoExcluyente = '') {
        $('#DocDate').val('');
        $('#DocNum').val('');
        $('#ItemName').val('');
        $('#ItemCode').val('');
        $('#BatchNum').val('');
        $('#ListaProductos').html('');
        $('#ListaLotes').html('');
        //si hay un laboratorio previamente buscado seguir mostrando la lista de productos para minimizar tiempos de busqueda
        if ($('#Laboratorio').val() != '') { buscarProducto('Laboratorio', 'div_listaProductos'); }
        if (campoExcluyente !== 'NumAtCard') {
            // Por solicitud, indicaron que cuando se busque por Ref. Factura no se borre lo previamente buscado
            $('#NumAtCard').val('');
            $('#tbl_listaArticulos > tbody').html('');
        }
    }

    function limpiarCamposRM() {
        $('#ItemNameRM').val('');
        $('#ItemCodeRM').val('');
        $('#BatchNumRM').val('');
