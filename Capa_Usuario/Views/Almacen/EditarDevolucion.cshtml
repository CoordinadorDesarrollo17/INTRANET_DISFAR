                $('#btn_nuevo_articulo').css('display', 'block');
                $('#factura_unica').attr('readonly', false);
                $('#div_SinEM').css('display', 'block');

            }
        }

    function cargarItemCode() {
        let itemName = $('#prod_nuevoArticulo').val();
        let itemCode = $(`#ListaProductos option[value='${itemName}']`).attr("itemcode");
        let buyUnitMsr = $(`#ListaProductos option[value='${itemName}']`).attr("buyunitmsr");
        let numInBuy = $(`#ListaProductos option[value='${itemName}']`).attr("numinbuy");
        let firmCode = $(`#ListaProductos option[value='${itemName}']`).attr("firmcode");
        let firmName = $(`#ListaProductos option[value='${itemName}']`).attr("firmname");

        // Campos hidden para que se puedan insertar en el detalle como cuando se busca por productos que están en la BD
        $('#codprod_nuevoArticulo').val(itemCode);
        $('#BuyUnitMsr_nuevoArticulo').val(buyUnitMsr);
        $('#NumInBuy_nuevoArticulo').val(numInBuy);
        $('#FirmCode_nuevoArticulo').val(firmCode);
        $('#FirmName_nuevoArticulo').val(firmName);
    }

    function cargarMotivos(idCampoMotivo = '') {
        if (idCampoMotivo != '') {
            let arrId = idCampoMotivo.split("_");
            let indice = arrId[1];
            let idMotivo = $(`#Motivo_${indice}`).val();
            let opciones = '';
            $(`#ListaObsxMotivo_${indice}`).html('');

            $(`#ListaSubmotivos option[idmotivo='${idMotivo}']`).each(function (index2, obj2) {
                opciones += `<option value="${obj2.id}">${obj2.value}</option>`;
            });

            $(`#ListaObsxMotivo_${indice}`).append(opciones);
        }

    }

    function validarFormulario() {
        //valida cantidades por detallado segun itemCode y BatchNum

        var object = $("#frmEditarDevolucion").serialize();
        $.ajax('/Almacen/ValidarDatosDevolucion',
            {
                data: object,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response != "true") { Swal.fire(response); }
                else { $("#frmEditarDevolucion").submit(); }
            });


    }

</script>

