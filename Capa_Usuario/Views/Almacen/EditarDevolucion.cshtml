    function validarFiltrosArticulo() {
        let result = false;
        //cuando el usuario elije NO en entrada mercancia este dato $('#SinEM').val() viaja como true

        //cuando es Devolucion normal sin retiro de mercado
        if ($('#RetiroMercado').val() == 'NO' && $('#SinEM').val() == 'NO' && $('#DocNum').val() == '' && $('#NumAtCard').val() == '' && ($('#ItemName').val() == '' || $('#ItemCode').val() == '' || $('#BatchNum').val() == '')) {
            $('#tbl_listaArticulos > tbody').html('');
            result = false;
            Swal.fire('Es obligatorio ingresar el DocNum o Producto o Factura');
        } else {
            //caso: sin entrada de mercancia
            if ($('#SinEM').val() == 'SI') {
                if ($('#ItemName').val() == '' || $('#ItemCode').val() == '' || $('#BatchNum').val() == '') {
                    $('#tbl_listaArticulos > tbody').html('');
                    Swal.fire('Los campos: Producto, Cód. producto y Lote son obligatorios.');
                    result = false;
                }
                else { result = true; }
            } else {
                if ($('#DocDate').val() == '' && $('#ItemCode').val() == '' && $('#DocNum').val() == '' && $('#BatchNum').val() == '' && $('#NumAtCard').val() == '') {
                    $('#tbl_listaArticulos > tbody').html('');
                    Swal.fire('Por favor, escoger el campo a filtrar: Fecha de entrada, DocNum, Producto o Lote.');
                    result = false;
                } else {
                    result = true;
                }
            }
        }
        return result;
    }

