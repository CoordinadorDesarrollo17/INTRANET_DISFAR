@model IEnumerable<Capa_Entidad.Almacen_ENT.TablasSql.OIAR_E>
@using Capa_Entidad.Almacen_ENT.TablasSql
@using Capa_Entidad.General_ENT.Tablas

@{
    ViewBag.Title = "GestionReconteos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    OIAR_E a = (OIAR_E)ViewBag.Oiar;
    List<OWHS_E> ow = (List<OWHS_E>)ViewBag.Almacenes;
}
<script>
    $(document).ready(function () {
        $('#filterModal').on('shown.bs.modal', function () {
            $('#filterModal input:first').focus();
        });
    });
    function filtrar() {
        var object = $("#filterForm").serialize();
        $(location).attr('href', "/Almacen/GestionReconteos?" + object);
    }
</script>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-dark">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ContabilizacionInventario", "Almacen")">Módulo contabilización inventario</a></li>
            <li class="current"><em>Gestión de reconteos</em></li>
        </ol>
    </nav>
</div>

<div class="bg-dark border-cabecera-seccion pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">GESTIÓN DE RECONTEOS</h3></div>
    <div class="d-flex pl-2 w-100 py-2">

        <div class="mx-2">
            <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#filterModal">
                <i class="icon icon-filter"></i> Filtrar
            </button>
        </div>
    </div>
</div>

@if (@OIPE_E.PeriodoSeleccionado != null)
{
    <div class="alert alert-danger mb-0" role="alert">
        <p>
            @OIPE_E.PeriodoSeleccionado.Descripcion
            Almacenes:
            @OIPE_E.PeriodoSeleccionado.enlistarDetAlmacenes()
        </p>
    </div>
}

<div class="bg-dark pt-4">
        <table class="table table-light table-sm table-hover cls-dataTable50" cellspacing="0" width="100%">
            <thead class="thead-dark">
                <tr>
                    <th class="text-center">
                        @Html.DisplayName("N#")
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("OpRecontador")
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("Equipo")
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("Almacen")
                    </th>
                    <th class="text-center">
                        @Html.DisplayNameFor(model => model.Piso)
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("CodArticulo")
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("Articulo")
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("Lotes")
                    </th>
                    <th class="text-center">
                        @Html.DisplayNameFor(model => model.Estado)
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("Fase")
                    </th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.DocEntry)</td>
                        <td class="text-center">
                            @if (item.DetFases != null && item.DetFases.Count > 2 && item.Fase > 3)
                            {
                                @item.DetFases[2].Operario
                            }
                            else
                            {
                                <label></label>
                            }
                        </td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.DocEntryEqu)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.WhsCode)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.Piso)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.ItemCode)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.ItemName)</td>
                        <td class="text-center">
                            @if (item.DetFases != null && item.DetFases.Count > 3)
                            {
                                @item.DetFases[3].enlistarLotes()
                            }
                        </td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.Estado)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.Fase)</td>
                        <td class="text-center">
                            @Html.ActionLink("Iniciar Reconteo", "IniciarReconteo", new { id = item.DocEntry }, new { @class = "btn btn-primary" })
                        </td>
                        @if (!item.Estado.Equals("Contado"))
                        {
                            <td class="text-center">
                                @Html.ActionLink("Terminar Reconteo", "TerminarReconteo", new { id = item.DocEntry }, new { @class = "btn btn-danger" })
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
   
</div>

<!-- Modal for filters -->
<div class="modal fade" id="filterModal" tabindex="-1" role="dialog" aria-labelledby="filterModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-light">
                <h5 class="modal-title" id="filterModalLabel">Filtros de Búsqueda</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form name="filterForm" id="filterForm">
                    <div class="form-group">
                        <label for="DocEntry">N#</label>
                        <input type="text" name="DocEntry" class="form-control" id="DocEntry" value="@a.DocEntry" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="Operario">OpRecontador</label>
                        <input type="text" name="DetFases[0].Operario" class="form-control" id="Operario" value="@if (a.DetFases != null && a.DetFases.Count > 0) { Write(a.DetFases[0].Operario); }" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="DocEntryEqu">Equipo</label>
                        <input type="text" name="DocEntryEqu" class="form-control" id="DocEntryEqu" value="@a.DocEntryEqu" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="WhsCode">Almacen</label>
                        <select name="WhsCode" id="WhsCode" class="form-control">
                            <option value="">Seleccione</option>
                            @foreach (OWHS_E obj in ow)
                            {
                                <option value="@obj.WhsCode" @if (a.WhsCode != null && a.WhsCode == obj.WhsCode) { Write("selected"); }>@obj.WhsName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="Piso">Piso</label>
                        <input type="number" name="Piso" class="form-control" id="Piso" value="@a.Piso" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="ItemCode">CodArticulo</label>
                        <input type="text" name="ItemCode" class="form-control" id="ItemCode" value="@a.ItemCode" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="ItemName">Articulo</label>
                        <input type="text" name="ItemName" class="form-control" id="ItemName" value="@a.ItemName" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="Estado">Estado</label>
                        <select name="Estado" id="Estado" class="form-control">
                            <option value="">Seleccione</option>
                            <option value="Contado" @if (a.Estado == "Contado") { Write("selected"); }>Contado</option>
                            <option value="EnReconteo" @if (a.Estado == "EnReconteo") { Write("selected"); }>EnReconteo</option>
                            <option value="Recontado" @if (a.Estado == "Recontado") { Write("selected"); }>Recontado</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="filtrar();">Aplicar Filtros</button>
            </div>
        </div>
    </div>
</div>
