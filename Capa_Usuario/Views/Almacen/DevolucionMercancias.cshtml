    function validarCambioEstadoDevolucion(docEntry, docNum, whsCode, tipoMantenimiento) {

        if (tipoMantenimiento == 'AA') {
            Swal.fire({
                title: "Esta seguro de anular devolucion?",
                text: "Este proceso es irreversible",
                input: 'text',
                inputLabel: 'text',
                inputPlaceholder: 'Ingrese su comentario',
                showCancelButton: true,
                showLoaderOnConfirm: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Almacen/CambiarEstadoDevolucion',
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            'DocEntry': docEntry, 'DocNum': docNum, 'WhsCode': whsCode, 'TipoMantenimiento': tipoMantenimiento, 'Comentario': result.value
                        }
                    }).done(function (response) {
                        $('.filtrosDevolucion').val('');
                        $('#filtro_DocNum').val(docNum);
                        $('#tbl_listaSubmotivos').DataTable().columns.adjust().draw();
                        Swal.fire(response.Mensaje);
                        $('#tbl_listaDevoluciones > tbody').html(response.Lista);

                    }).fail(function (jqXHR, textStatus, errorThrown) {
                        console.log(jqXHR.status + textStatus + errorThrown);
                    });
                }
            })
        }
