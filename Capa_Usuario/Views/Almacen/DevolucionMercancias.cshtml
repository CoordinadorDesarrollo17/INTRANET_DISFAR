@using Capa_Entidad.General_ENT.TablasSql;
@using Capa_Entidad.Almacen_ENT.Tablas;
@using Capa_Entidad.Almacen_ENT.TablasSql;
@{
    ViewBag.Title = "DevolucionMercancias";
    Layout = "~/Views/Shared/_Layout.cshtml";
    List<OWHS_E> Almacenes = (List<OWHS_E>)ViewBag.Almacenes;
    List<OMRC_E> Laboratorios = (List<OMRC_E>)ViewBag.Laboratorios;
    List<MotivosDevoluciones_E> motivos = (List<MotivosDevoluciones_E>)ViewBag.Motivos;
    List<MotivosDevoluciones_E> motivosSubmotivos = (List<MotivosDevoluciones_E>)ViewBag.ListaParaSubmotivos;
    List<SubmotivosDevoluciones_E> submotivos = (List<SubmotivosDevoluciones_E>)ViewBag.Submotivos;
}

<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li class="current"><em>Devolución de mercancías</em></li>
        </ol>
    </nav>
</div>

<form name="frm" id="frm">
    <div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
        <div class="px-3 pt-3"><h3 class="titulo-seccion">DEVOLUCIÓN DE MERCANCÍAS</h3></div>
    </div>

    <div class="bg-white d-flex w-100 py-3">
        <div class="d-flex col-lg-8 col-md-6 col-sm-12 col-6 my-lg-2 button-group">
            <a href="@Url.Action("NuevaDevolucion", "Almacen")" class="btn btn-warning mr-1 my-1" title="Nueva Devolución">
                <i class="icon icon-plus"></i> Nueva Devolución
            </a>

            <a href="@Url.Action("NuevaDevolucion", "Almacen", new { Almacen ="DEV07"})" class="btn btn-primary mx-1 my-1" title="ALM. DEV07">
                <i class="icon icon-plus"></i> DEV07
            </a>

            <button type="button" class="btn btn-success mx-1 my-1" title="Descargar Reporte Histórico" data-toggle="modal" data-target="#modalReporte" onclick="limpiarCampos()">
                <i class="icon icon-file-excel"></i> Reporte Histórico
            </button>

            <button type="button" class="btn btn-info mx-1 my-1" title="Motivos y Sub Motivos" data-toggle="modal" data-target="#modalMotivosyObs">
                <i class="icon icon-folder-open"></i> Motivos y Submotivos.
            </button>
        </div>

        <div class="d-flex col-lg-4 col-md-6 col-sm-12 col-12 mt-sm-2 justify-content-lg-end justify-content-md-end justify-content-sm-center">
            <input type="text" name="DetalleDevolucion[0].RefFactura" class="form-control text-center border-success filtrosDevolucion" placeholder="Buscar por factura..." style="width: 250px; height: 50px" value="@if (ViewBag.Devolucion.DetalleDevolucion != null && ViewBag.Devolucion.DetalleDevolucion.Count >= 1) { Write(ViewBag.Devolucion.DetalleDevolucion[0].RefFactura); }" onchange="filtrar();" />
        </div>
    </div>


    <div class="bg-white">
        <table id="tbl_listaDevoluciones" class="table table-light table-sm table-hover cls-dataTable50" cellspacing="0" width="100%">
            <thead class="bg-cobefar-6">
                <tr>
                    <th class="text-center">DocNum<br /><div class="d-flex justify-content-center"><input type="text" name="DocNum" id="filtro_DocNum" class="form-control-sm border text-center filtrosDevolucion" autocomplete="off" style="width: 100px" onchange="filtrar();" value="@if (ViewBag.Devolucion.DocNum != 0) { Write(ViewBag.Devolucion.DocNum); }" /></div></th>
                    <th class="text-center">Almacen<br /><div class="d-flex justify-content-center"><input type="text" name="WhsCode" class="form-control-sm border w-50 text-center filtrosDevolucion" autocomplete="off" style="width: 50px" onchange="filtrar();" value="@if (!string.IsNullOrEmpty(ViewBag.Devolucion.WhsCode)) { Write(ViewBag.Devolucion.WhsCode); }" /></div></th>
                    <th class="text-center">Fecha Registro</th>
                    <th class="text-center">Correlativo</th>
                    <th class="text-center">Fecha Devolución</th>
                    <th class="text-center">Proveedor<br /><div class="d-flex justify-content-center"><input type="text" name="CardName" class="form-control-sm border text-center filtrosDevolucion" autocomplete="off" style="width: 300px" onchange="filtrar();" value="@ViewBag.Devolucion.CardName" /></div></th>
                    <th class="text-center">Registrado por</th>
                    <th class="text-center">
                        Estado<br />
                        <div class="d-flex justify-content-center">
                            <select type="text" name="Estado" id="EstadoPost" class="form-control-sm border filtrosDevolucion" autocomplete="off" style="width: 200px" onchange="filtrar();">
                                <option value="">Seleccione</option>
                                <option value="PENDIENTE DE RECOJO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("PENDIENTE DE RECOJO")) { Write("selected"); }>Pendiente de recojo</option>
                                <option value="RECOGIDO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("RECOGIDO")) { Write("selected"); }>Recogido</option>
                                <option value="NC APLICADA" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("NC APLICADA")) { Write("selected"); }>NC Aplicada</option>
                                <option value="ANULADO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("ANULADO")) { Write("selected"); }>Anulado</option>
                            </select>
                        </div>
                    </th>

                    <th class="text-center"></th>
                    <th class="text-center"></th>
                    <th class="text-center"></th>
                    <th class="text-center"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var m in Model)
                    {
                        <tr>
                            <td class="text-center">@m.DocNum</td>
                            <td class="text-center">@m.WhsCode</td>
                            <td class="text-center">@m.FechaOperacion</td>
                            <td class="text-center">@m.Correlativo</td>
                            <td class="text-center">@m.FechaDevolucion</td>
                            <td class="text-center">@m.CardName</td>
                            <td class="text-center">@m.Operario</td>
                            <td class="text-center">@m.Estado</td>

                            <td class="text-center">
                                @if (m.Estado.Equals("PENDIENTE DE RECOJO"))
                                {
                                    <button type="button" class="btn btn-sm btn-light" onclick="validarCambioEstadoDevolucion(@m.DocEntry,@m.DocNum,'@m.WhsCode','AA');" data-toggle="tooltip" data-placement="top" title="Anular"> <i class="icon-bin2 text-danger"></i></button>
                                }
                                // Solo para Estado RECOGIDO y guardará "0" en el campo "SinNC" siempre y cuando no encuentre un NULL en NotaCredito línea x línea en RPD1
                                @*else if (m.Estado.Equals("RECOGIDO") && m.SinNC.Equals(0))
                                    {
                                        <button type="button" class="btn btn-sm btn-success" onclick="validarCambioEstadoDevolucion(@m.DocEntry,@m.DocNum,'@m.WhsCode','NC');"> NC Aplicada</button>
                                    }*@
                            </td>
                            <td class="text-center">
                                @if (m.Estado.Equals("RECOGIDO"))
                                {
                                    <button type="button" class="btn btn-sm btn-orange" onclick="validarCambioEstadoDevolucion(@m.DocEntry, @m.DocNum, '@m.WhsCode', 'RR')" data-toggle="tooltip" data-placement="top" title="Revertir Recojo">Rv. recojo</button>
                                }
                                @if (m.Estado.Equals("PENDIENTE DE RECOJO"))
                                {
                                    <button type="button" class="btn btn-sm btn-blue" onclick="validarCambioEstadoDevolucion(@m.DocEntry, @m.DocNum, '@m.WhsCode', 'R')" data-toggle="tooltip" data-placement="top" title="Recogido">Recogido</button>
                                }
                            </td>
                            <td class="text-center">
                                @if (m.Estado.Equals("PENDIENTE DE RECOJO"))
                                {
                                    if (m.WhsCode.Equals("DEV07"))
                                    {
                                        <a href="/Almacen/EditarDevolucion?DocEntry=@m.DocEntry&Almacen=DEV07" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Editar Devolución - ALM DEV07" > <i class="icon-pencil text-purple"></i></a>
                                    }
                                    else
                                    {
                                        <a href="/Almacen/EditarDevolucion?DocEntry=@m.DocEntry" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Editar Devolución"> <i class="icon-pencil text-primary"></i></a>
                                    }
                                }
                            </td>
                            <td class="text-center"><a href="/Almacen/SeguimientoDevolucion?DocEntry=@m.DocEntry" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Ver Devolución"> <i class="icon-search text-dark"></i></a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</form>
<form id="frmReporteHistorico">
    <!-- Modal -->
    <div class="modal fade" id="modalReporte" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-headerModals text-white">
                    <h5 class="modal-title" id="exampleModalLabel">Reporte Histórico</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true" class="text-white">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-lg-3 col-md-3">
                            <label class="text-cobefar font-weight-bold">Fecha Registro Desde:</label>
                            <input type="date" id="FechaDesde" name="FechaDesde" class="form-control border-success text-center" />
                        </div>

                        <div class="col-lg-3 col-md-3">
                            <label class="text-cobefar font-weight-bold">Fecha Registro Hasta:</label>
                            <input type="date" id="FechaHasta" name="FechaHasta" class="form-control border-success text-center" />
                        </div>

                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Estado:</label>
                            <select type="text" id="EstadoReporte" class="form-control bg-cobefar text-white" autocomplete="off" style="width: 250px">
                                <option value="">Seleccione</option>
                                <option value="PENDIENTE DE RECOJO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("PENDIENTE DE RECOJO")) { Write("selected"); }>Pendiente de recojo</option>
                                <option value="RECOGIDO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("RECOGIDO")) { Write("selected"); }>Recogido</option>
                                <option value="NC APLICADA" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("NC APLICADA")) { Write("selected"); }>NC Aplicada</option>
                                <option value="ANULADO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("ANULADO")) { Write("selected"); }>Anulado</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6">
                            <label class="text-cobefar font-weight-bold">Factura:</label>
                            <input type="text" id="RefFacturaReporte" class="form-control border-success text-center" />
                        </div>

                        <div class="col-lg-6">
                            <label class="text-cobefar font-weight-bold">Almacén:</label>
                            <select id="WhsCodeReporte" class="form-control bg-cobefar text-white border-success">
                                <option value="">Seleccione</option>
                                @if (Almacenes != null && Almacenes.Count() >= 1)
                                {
                                    foreach (var alm in Almacenes)
                                    {
                                        <option value="@alm.WhsCode">@alm.WhsName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Proveedor:</label>
                            <input type="search" id="CardNameReporte" list='ListaClientes' class="form-control border-success" onkeyup="cargarListaCliente(this.value)" autocomplete="off" />
                            <div id="div_listaClientes"></div>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Doc Num:</label>
                            <input type="text" id="DocNumReporte" class="form-control border-success" autocomplete="off" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Laboratorio:</label>
                            <input type="search" id="FirmCodeReporte" list='ListaLab' class="form-control border-success" onchange="cargarProductos(this.value)" autocomplete="off" />
                            <datalist id="ListaLab">
                                @if (Laboratorios != null && Laboratorios.Count() >= 1)
                                {
                                    foreach (var lab in Laboratorios)
                                    {
                                        <option firmcode="@lab.FirmCode" value="@lab.U_SYP_DESC"></option>
                                    }
                                }
                            </datalist>
                        </div>

                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Producto:</label>
                            <input type="text" id="ItemNameReporte" list="ListaProductos" class="form-control border-success text-center" autocomplete="off" />
                            <div id="div_listaProductos"></div>
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-lg-2 d-flex align-items-end">
                            <button type="button" class="btn btn-cobefar mb-2" onclick="ExportarReporteHistorico()"><i class="icon-filter"></i> Generar Reporte</button>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>

</form>

<!-- Modal Motivos y Submotivos -->
<div class="modal fade" id="modalMotivosyObs" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">Motivos y Submotivos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-lg-6 col-md-6 text-center">
                        <button class="btn btn-cobefar font-weight-bold mx-1 my-1" title="Nuevo Motivo" data-toggle="modal" data-target="#modalMotivo" onclick="limpiarCamposMotivo()">
                            <i class="icon icon-plus"></i> Nuevo Motivo
                        </button>
                    </div>

                    <div class="col-lg-6 col-md-6 text-center">
                        <button class="btn btn-cobefar font-weight-bold mx-1 my-1" title="Nuevo Sub Motivo" data-toggle="modal" data-target="#modalSubmotivo" onclick="limpiarCamposSubmotivo()">
                            <i class="icon icon-plus"></i> Nuevo Submotivo
                        </button>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Motivos -->
<div class="modal fade" id="modalMotivo" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">Motivos Devoluciones</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="frm_motivo">
                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Descripción:</label>
                            <input type="hidden" id="idmotivo" name="IdMotivo" />
                            <input type="text" id="desc_motivo" name="Descripcion" class="form-control border-success" autocomplete="off" />
                        </div>

                        <div class="col-lg-3 col-md-3">
                            <label class="text-cobefar font-weight-bold">Estado:</label>
                            <select id="estado_motivo" name="Estado" class="form-control bg-cobefar text-white">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>

                        <div id="div_btnAccionMotivo" class="col-lg-3 col-md-3 d-flex align-self-end">
                            <button type="button" class="btn btn-success" onclick="agregarMotivo()"><i class="icon icon-plus"></i> Agregar</button>
                        </div>
                    </div>
                </form>

                <div class="row mb-4">
                    <div class="col-lg-12 col-md-12">
                        <div class="bg-white">
                            <table id="tbl_listaMotivos" class="table table-light table-sm table-hover" cellspacing="0" width="100%">
                                <thead class="bg-cobefar-6">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th class="text-center">Motivo</th>
                                        <th class="text-center">Estado</th>
                                        <th class="text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (motivos != null && motivos.Count >= 1)
                                    {
                                        int num = 1;
                                        foreach (var m in motivos)
                                        {
                                            <tr>
                                                <td class="text-center">@num</td>
                                                <td class="text-center">@m.Descripcion</td>
                                                <td class="text-center font-weight-bold @if (m.Estado.Equals("1")) { Write("text-success"); } else { Write("text-danger"); }">@m.DescEstado</td>
                                                <td class="text-center"><button type="button" class="btn btn-sm btn-light" onclick="llenarCamposMotivo (@m.IdMotivo, '@m.Descripcion')" data-toggle="tooltip" data-placement="top" title="Editar Motivo"><i class="icon-pencil text-primary"></i></button></td>
                                            </tr>
                                            ++num;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Motivos y Submotivos -->
<div class="modal fade" id="modalMotivosyObs" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">Motivos y Submotivos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-lg-6 col-md-6 text-center">
                        <button class="btn btn-cobefar font-weight-bold mx-1 my-1" title="Nuevo Motivo" data-toggle="modal" data-target="#modalMotivo" onclick="limpiarCamposMotivo()">
                            <i class="icon icon-plus"></i> Nuevo Motivo
                        </button>
                    </div>

                    <div class="col-lg-6 col-md-6 text-center">
                        <button class="btn btn-cobefar font-weight-bold mx-1 my-1" title="Nueva Observación" data-toggle="modal" data-target="#modalSubmotivo" onclick="limpiarCamposSubmotivo()">
                            <i class="icon icon-plus"></i> Nueva Observación
                        </button>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>


<!-- Modal Motivos -->
