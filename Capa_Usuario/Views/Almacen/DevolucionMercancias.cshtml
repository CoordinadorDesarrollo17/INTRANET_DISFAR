<!-- Modal Submotivos -->
<div class="modal fade" id="modalSubmotivo" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">Submotivos Devoluciones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar" tabindex="-1"></button>
            </div>
            <div class="modal-body">
                <form id="frm_submotivo">
                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar fw-bold">Motivo:</label>
                            <select id="idmotivo_submotivo" name="IdMotivo" class="form-select bg-cobefar text-white">
                                <option value="">Seleccione</option>
                                @if (motivosSubmotivos != null && motivosSubmotivos.Count >= 1)
                                {
                                    foreach (var mot in motivosSubmotivos)
                                    {
                                        <option value="@mot.IdMotivo">@mot.Descripcion</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar fw-bold">Descripción:</label>
                            <input type="hidden" id="idsubmotivo" name="IdSubmotivo" />
                            <input type="text" id="desc_submotivo" name="Descripcion" class="form-control" autocomplete="off" />
                        </div>

                        <div class="col-lg-3 col-md-3">
                            <label class="text-cobefar fw-bold">Estado:</label>
                            <select id="estado_submotivo" name="Estado" class="form-select bg-cobefar text-white">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>

                        <div id="div_btnAccionSubmotivo" class="col-lg-3 col-md-3 d-flex align-self-end">
                            <button type="button" class="btn btn-success" onclick="agregarSubmotivo()"><i class="bi bi-plus-lg"></i> Agregar</button>
                        </div>
                    </div>
                </form>

                <div class="row mb-4">
                    <div class="col-lg-12 col-md-12">
                        <div class="bg-white">
                            <table id="tbl_listaSubmotivos" class="table table-light table-sm table-hover " cellspacing="0" width="100%">
                                <thead class="thead-cobefar">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th class="text-center">Motivo</th>
                                        <th class="text-center">Submotivo</th>
                                        <th class="text-center">Estado</th>
                                        <th class="text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (submotivos != null && submotivos.Count >= 1)
                                    {
                                        int num = 1;
                                        foreach (var o in submotivos)
                                        {
                                            <tr>
                                                <td class="text-center">@num</td>
                                                <td class="text-center">@o.DescMotivo</td>
                                                <td class="text-center">@o.Descripcion</td>
                                                <td class="text-center fw-bold @if (o.Estado.Equals("1")) { Write("text-success"); } else { Write("text-danger"); }">@o.DescEstado</td>
                                                <td class="text-center"><button type="button" class="btn btn-sm btn-light" onclick="llenarCamposSubmotivo(@o.IdSubmotivo, '@o.Descripcion', @o.IdMotivo)"><i class="bi bi-pencil text-primary"></i></button></td>
                                            </tr>
                                            ++num;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class='bi bi-x-lg'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        tippy('.cls-anular', {
            content: 'Anular devolución',
            animation: 'fade',
            placement: 'bottom'
        });

        tippy('.cls-verDatos', {
            content: 'Ver datos de devolución',
            animation: 'fade',
            placement: 'bottom'
        });

        tippy('.cls-editar', {
            content: 'Editar devolución',
            animation: 'fade',
            placement: 'bottom'
        });

        tippy('.cls-recogido', {
            content: 'Recogido ',
            animation: 'fade'
        });

        tippy('.cls-revertirRecojo', {
            content: 'Revertir Recojo',
            animation: 'fade'
        });

        inicializarDataTable('tbl_listaDevoluciones', 25, true, false);
        inicializarDataTable('tbl_listaMotivos', 10, false, false);
        inicializarDataTable('tbl_listaSubmotivos', 10, false, false);
        limitarMaxCaracteres('DocNumReporte', 6);
    });

    function limpiarCampos() {
        $('#FechaDesde').val('');
        $('#FechaHasta').val('');
        $('#RefFacturaReporte').val('');
        $('#EstadoReporte').val('');
        $('#WhsCodeReporte').val('');
        $('#CardNameReporte').val('');
        $('#FirmCodeReporte').val('');
        $('#ItemNameReporte').val('');
        $('#DocNumReporte').val('');

    }
    function filtrar() {
        var object = $("#frm").serialize();
        $(location).attr('href', "/Almacen/DevolucionMercancias?" + object);
    }
    function validarCambioEstadoDevolucion(docEntry, docNum, whsCode, tipoMantenimiento) {

        if (tipoMantenimiento == 'AA') {
            Swal.fire({
                title: "Esta seguro de anular devolucion?",
                text: "Este proceso es irreversible",
                input: 'text',
                inputLabel: 'text',
                inputPlaceholder: 'Ingrese su comentario',
                showCancelButton: true,
                showLoaderOnConfirm: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Almacen/CambiarEstadoDevolucion',
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            'DocEntry': docEntry, 'DocNum': docNum, 'WhsCode': whsCode, 'TipoMantenimiento': tipoMantenimiento, 'Comentario': result.value
                        }
                    }).done(function (response) {
                        $('.filtrosDevolucion').val('');
                        $('#filtro_DocNum').val(docNum);
                        $('#tbl_listaSubmotivos').DataTable().columns.adjust().draw();
                        Swal.fire(response.Mensaje);
                        $('#tbl_listaDevoluciones > tbody').html(response.Lista);

                    }).fail(function (jqXHR, textStatus, errorThrown) {
                        console.log(jqXHR.status + textStatus + errorThrown);
                    });
                }
            })
        }
        else if (tipoMantenimiento == 'R') {
            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success mx-4',
                    cancelButton: 'btn btn-danger mx-4'
                },
                buttonsStyling: false
            })

            swalWithBootstrapButtons.fire({
                title: '¿Está seguro(a) de cambiar el estado a RECOGIDO?',
                text: "Este proceso genera el correlativo del documento.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: "<i class='bi bi-check-lg'></i> Si, estoy seguro(a)",
                cancelButtonText: "<i class='bi bi-x-lg'></i> Cancelar",
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Almacen/CambiarEstadoDevolucion',
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            'DocEntry': docEntry, 'DocNum': docNum, 'WhsCode': whsCode, 'TipoMantenimiento': tipoMantenimiento
                        }
                    }).done(function (response) {
                        $('.filtrosDevolucion').val('');
                        $('#filtro_DocNum').val(docNum);
                        $('#tbl_listaSubmotivos').DataTable().columns.adjust().draw();
                        Swal.fire(response.Mensaje);
                        $('#tbl_listaDevoluciones > tbody').html(response.Lista);

                    }).fail(function (jqXHR, textStatus, errorThrown) {
                        console.log(jqXHR.status + textStatus + errorThrown);
                    });
                }
            });
        }
        else if (tipoMantenimiento == 'RR') {
            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success mx-4',
                    cancelButton: 'btn btn-danger mx-4'
                },
                buttonsStyling: false
            })

            swalWithBootstrapButtons.fire({
                title: '¿Está seguro(a) de REVERTIR RECOJO?',
                text: "Perdera el correlativo del documento.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: "<i class='bi bi-check-lg'></i> Si, estoy seguro(a)",
                cancelButtonText: "<i class='bi bi-x-lg'></i> Cancelar",
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Almacen/CambiarEstadoDevolucion',
                        type: 'POST',
                        dataType: 'json',
                        data: {
                            'DocEntry': docEntry, 'DocNum': docNum, 'WhsCode': whsCode, 'TipoMantenimiento': tipoMantenimiento
                        }
                    }).done(function (response) {
                        $('.filtrosDevolucion').val('');
                        $('#filtro_DocNum').val(docNum);
                        $('#tbl_listaSubmotivos').DataTable().columns.adjust().draw();
                        Swal.fire(response.Mensaje);
                        $('#tbl_listaDevoluciones > tbody').html(response.Lista);

                    }).fail(function (jqXHR, textStatus, errorThrown) {
                        console.log(jqXHR.status + textStatus + errorThrown);
                    });
                }
            });
        }
        else {
            $.ajax({
                url: '/Almacen/CambiarEstadoDevolucion',
                type: 'POST',
                dataType: 'json',
                data: {
                    'DocEntry': docEntry,
                    'DocNum': docNum,
                    'WhsCode': whsCode,
                    'TipoMantenimiento': tipoMantenimiento
                }
            }).done(function (response) {
                $('.filtrosDevolucion').val('');
                Swal.fire(response.Mensaje);
                $('#tbl_listaDevoluciones > tbody').html(response.Lista);

            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        }
    }
    function cargarProductos(valor) {
        let firmCode = $(`#ListaLab option[value='${valor}']`).attr("firmcode");

        Swal.fire({
            html: '<img src="/imagenes/index/ReportesDigemid/cargando.gif" />',
            //closeOnCancel: false,
            allowOutsideClick: false,
            showCancelButton: false,
            showConfirmButton: false
        });

        $.ajax({
            url: '/Almacen/BuscarProducto',
            type: 'POST',
            dataType: 'json',
            data: { 'FirmCode': firmCode }
        }).done(function (response) {
            swal.close();
            if (response != '') {
                $('#div_listaProductos').html(response);
            } else {
                $('#div_listaProductos').html('');
            }
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    function ExportarReporteHistorico() {
        let habilitarDescarga = true;
        if ($('#EstadoReporte').val() != 'PENDIENTE DE RECOJO') {
            if ($('#FechaDesde').val() == '' && $('#FechaHasta').val() == '' && $('#DocNumReporte').val() == '' && $('#RefFacturaReporte').val() == '') {
                Swal.fire('Por favor seleccionar el rango de fechas de devoluciones a filtrar o ref factura');
                habilitarDescarga = false;
            }
        }
        if (habilitarDescarga) {
            $.ajax({
                url: '/Almacen/VerificarExistenciaDevConFiltros',
                type: 'POST',
                dataType: 'json',
                data: {
                    'FechaDesde': $('#FechaDesde').val(), 'FechaHasta': $('#FechaHasta').val(), 'Estado': $('#EstadoReporte').val(), 'RefFactura': $('#RefFacturaReporte').val(), 'WhsCode': $('#WhsCodeReporte').val(), 'DocNum': $('#DocNumReporte').val(), 'CardName': $('#CardNameReporte').val(), 'ItemName': $('#ItemNameReporte').val()
                }
            }).done(function (response) {
                if (response.Titulo != "") {
                    Swal.fire(response.Titulo);
                } else {
                    let params = `FechaDesde=${$('#FechaDesde').val()}&FechaHasta=${$('#FechaHasta').val()}&Estado=${$('#EstadoReporte').val()}&RefFactura=${$('#RefFacturaReporte').val()}&WhsCode=${$('#WhsCodeReporte').val()}&DocNum=${$('#DocNumReporte').val()}&CardName=${$('#CardNameReporte').val()}&ItemName=${$('#ItemNameReporte').val()}`;
                    window.open(`/Almacen/ExportarReporteHistoricoDevoluciones?${params}`, '_blank', 'noopener, noreferrer');
                }
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        }
    }

    function cargarListaCliente(textoIngresado) {
        if (textoIngresado.length >= 5) {
            $.ajax({
                url: '/Ventas/BuscarCliente',
                type: 'POST',
                dataType: 'json',
                data: { 'CardName': textoIngresado, 'TipoCliente': 'P' }
            }).done(function (response) {
                $('#div_listaClientes').html(response);
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        } else {
            $('#div_listaClientes').html('');
        }
    }
    /********* MOTIVOS Y SUBMOTIVOS *********/
    function cargarMensaje() {
        Swal.fire({
            position: "top-end",
            icon: "info",
            title: "Click en Editar para guardar cambios",
            showConfirmButton: false,
            timer: 1000
        });
    }

    /********* MOTIVOS *********/
    function limpiarCamposMotivo() {
        $('#desc_motivo').val('');
        $('#estado_motivo').val('1');
        $('#div_btnAccionMotivo').html(`<button type="button" class="btn btn-success" onclick="agregarMotivo()"><i class="bi bi-plus-lg"></i> Agregar</button>`);
    }

    function agregarMotivo() {
        $.ajax({
            url: '/Almacen/NuevoMotivoDevolucion',
            type: 'POST',
            dataType: 'json',
            data: $('#frm_motivo').serialize()
        }).done(function (response) {
            $('#desc_motivo').val('');
            $('#estado_motivo').val('1');
            Swal.fire(response.Mensaje);
            $('#tbl_listaMotivos > tbody').html(response.Lista);
            $('#idmotivo_submotivo').html(response.ListaActualizadaParaObs);
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }


    function editarMotivo() {
        $.ajax({
            url: '/Almacen/EditarMotivoDevolucion',
            type: 'POST',
            dataType: 'json',
            data: $('#frm_motivo').serialize()
        }).done(function (response) {
            $('#desc_motivo').val('');
            $('#estado_motivo').val('1');
            Swal.fire(response.Mensaje);
            $('#tbl_listaMotivos > tbody').html(response.Lista);
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    function llenarCamposMotivo(id, desc) {
        cargarMensaje();
        $(`#desc_motivo`).val(desc);
        $(`#idmotivo`).val(id);
        $('#div_btnAccionMotivo').html(`<button type="button" class="btn btn-success" onclick="editarMotivo()"><i class="bi bi-pencil"></i> Editar</button>`);
    }

    /********* SUBMOTIVOS *********/
    function limpiarCamposSubmotivo() {
        $('#desc_submotivo').val('');
        $('#estado_submotivo').val('1');
        $('#idmotivo_submotivo').val('');
        $('#div_btnAccionSubmotivo').html(`<button type="button" class="btn btn-success" onclick="agregarSubmotivo()"><i class="bi bi-plus-lg"></i> Agregar</button>`);
    }

    function agregarSubmotivo() {
        if ($('#idmotivo_submotivo').val() != '' && $('#desc_submotivo').val() != '') {
            $.ajax({
                url: '/Almacen/NuevoSubmotivoDevolucion',
                type: 'POST',
                dataType: 'json',
                data: $('#frm_submotivo').serialize()
            }).done(function (response) {
                $('#desc_submotivo').val('');
                $('#estado_submotivo').val('1');
                $('#idmotivo_submotivo').val('');
                Swal.fire(response.Mensaje);
                $('#tbl_listaSubmotivos > tbody').html(response.Lista);
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        } else {
            Swal.fire('Todos los campos son obligatorios');
        }
    }

    function editarSubmotivo() {
        $.ajax({
            url: '/Almacen/EditarSubmotivoDevolucion',
            type: 'POST',
            dataType: 'json',
            data: $('#frm_submotivo').serialize()
        }).done(function (response) {
            $('#desc_submotivo').val('');
            $('#estado_submotivo').val('1');
            $('#idmotivo_submotivo').val('');
            Swal.fire(response.Mensaje);
            $('#tbl_listaSubmotivos > tbody').html(response.Lista);
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    function llenarCamposSubmotivo(idSubmotivo, desc, idMotivo) {
        cargarMensaje();
        $(`#desc_submotivo`).val(desc);
        $(`#idsubmotivo`).val(idSubmotivo);
        $(`#idmotivo_submotivo`).val(idMotivo);
        $('#div_btnAccionSubmotivo').html(`<button type="button" class="btn btn-success" onclick="editarSubmotivo()"><i class="bi bi-pencil"></i> Editar</button>`);
    }

    function redireccionar(input) {
        window.location.replace(input.dataset.ruta);
    }
</script>