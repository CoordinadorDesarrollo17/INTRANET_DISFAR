        }
    }
    function cargarProductos(valor) {
        let firmCode = $(`#ListaLab option[value='${valor}']`).attr("firmcode");

        Swal.fire({
            html: '<img src="/imagenes/index/ReportesDigemid/cargando.gif" />',
            //closeOnCancel: false,
            allowOutsideClick: false,
            showCancelButton: false,
            showConfirmButton: false
        });

        $.ajax({
            url: '/Almacen/BuscarProducto',
            type: 'POST',
            dataType: 'json',
            data: { 'FirmCode': firmCode }
        }).done(function (response) {
            swal.close();
            if (response != '') {
                $('#div_listaProductos').html(response);
            } else {
                $('#div_listaProductos').html('');
            }
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }
    function ExportarReporteHistorico() {
        let habilitarDescarga = true;
        if ($('#EstadoReporte').val() != 'PENDIENTE DE RECOJO') {
            if ($('#FechaDesde').val() == '' && $('#FechaHasta').val() == '' && $('#DocNumReporte').val() == '' && $('#RefFacturaReporte').val() == '') {
                Swal.fire('Por favor seleccionar el rango de fechas de devoluciones a filtrar o ref factura');
                habilitarDescarga = false;
            }
        }
        if (habilitarDescarga) {
            $.ajax({
                url: '/Almacen/VerificarExistenciaDevConFiltros',
                type: 'POST',
                dataType: 'json',
                data: {
                    'FechaDesde': $('#FechaDesde').val(), 'FechaHasta': $('#FechaHasta').val(), 'Estado': $('#EstadoReporte').val(), 'RefFactura': $('#RefFacturaReporte').val(), 'WhsCode': $('#WhsCodeReporte').val(), 'DocNum': $('#DocNumReporte').val(), 'CardName': $('#CardNameReporte').val(), 'ItemName': $('#ItemNameReporte').val()
                }
            }).done(function (response) {
                if (response.Mensaje != "") {
                    Swal.fire(response.Mensaje);
                } else {
                    let params = `FechaDesde=${$('#FechaDesde').val()}&FechaHasta=${$('#FechaHasta').val()}&Estado=${$('#EstadoReporte').val()}&RefFactura=${$('#RefFacturaReporte').val()}&WhsCode=${$('#WhsCodeReporte').val()}&DocNum=${$('#DocNumReporte').val()}&CardName=${$('#CardNameReporte').val()}&ItemName=${$('#ItemNameReporte').val()}`;
                    window.open(`/Almacen/ExportarReporteHistoricoDevoluciones?${params}`, '_blank', 'noopener, noreferrer');
                }
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        } 
    }
    function cargarListaCliente(textoIngresado) {
        if (textoIngresado.length >= 5) {
            $.ajax({
                url: '/Ventas/BuscarCliente',
                type: 'POST',
                dataType: 'json',
                data: { 'CardName': textoIngresado, 'TipoCliente': 'P' }
            }).done(function (response) {
                $('#div_listaClientes').html(response);
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        } else {
            $('#div_listaClientes').html('');
        }
    }
    /********* MOTIVOS Y SUBMOTIVOS *********/
    function cargarMensaje() {
        Swal.fire({
            position: "top-end",
            icon: "info",
            title: "Click en Editar para guardar cambios",
            showConfirmButton: false,
            timer: 1000
        });
    }

    /********* MOTIVOS *********/
    function limpiarCamposMotivo() {
        $('#desc_motivo').val('');
        $('#estado_motivo').val('1');
        $('#div_btnAccionMotivo').html(`<button type="button" class="btn btn-success" onclick="agregarMotivo()"><i class="icon icon-plus"></i> Agregar</button>`);
    }

    function agregarMotivo() {
        $.ajax({
            url: '/Almacen/NuevoMotivoDevolucion',
            type: 'POST',
            dataType: 'json',
            data: $('#frm_motivo').serialize()
        }).done(function (response) {
            $('#desc_motivo').val('');
            $('#estado_motivo').val('1');
            Swal.fire(response.Mensaje);
            $('#tbl_listaMotivos > tbody').html(response.Lista);
            $('#idmotivo_submotivo').html(response.ListaActualizadaParaObs);
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }


    function editarMotivo() {
        $.ajax({
            url: '/Almacen/EditarMotivoDevolucion',
            type: 'POST',
            dataType: 'json',
            data: $('#frm_motivo').serialize()
        }).done(function (response) {
            $('#desc_motivo').val('');
            $('#estado_motivo').val('1');
            Swal.fire(response.Mensaje);
            $('#tbl_listaMotivos > tbody').html(response.Lista);
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    function llenarCamposMotivo(id, desc) {
        cargarMensaje();
        $(`#desc_motivo`).val(desc);
        $(`#idmotivo`).val(id);
        $('#div_btnAccionMotivo').html(`<button type="button" class="btn btn-success" onclick="editarMotivo()"><i class="icon icon-pencil"></i> Editar</button>`);
    }

    /********* SUBMOTIVOS *********/
    function limpiarCamposSubmotivo() {
        $('#desc_submotivo').val('');
        $('#estado_submotivo').val('1');
        $('#idmotivo_submotivo').val('');
        $('#div_btnAccionSubmotivo').html(`<button type="button" class="btn btn-success" onclick="agregarSubmotivo()"><i class="icon icon-plus"></i> Agregar</button>`);
    }

    function agregarSubmotivo() {
        if ($('#idmotivo_submotivo').val() != '' && $('#desc_submotivo').val() != '') {
            $.ajax({
                url: '/Almacen/NuevoSubmotivoDevolucion',
                type: 'POST',
                dataType: 'json',
                data: $('#frm_submotivo').serialize()
            }).done(function (response) {
                $('#desc_submotivo').val('');
                $('#estado_submotivo').val('1');
                $('#idmotivo_submotivo').val('');
                Swal.fire(response.Mensaje);
                $('#tbl_listaSubmotivos > tbody').html(response.Lista);
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        } else {
            Swal.fire('Todos los campos son obligatorios');
        }
    }

    function editarSubmotivo() {
        $.ajax({
            url: '/Almacen/EditarSubmotivoDevolucion',
            type: 'POST',
            dataType: 'json',
            data: $('#frm_submotivo').serialize()
        }).done(function (response) {
            $('#desc_submotivo').val('');
            $('#estado_submotivo').val('1');
            $('#idmotivo_submotivo').val('');
            Swal.fire(response.Mensaje);
            $('#tbl_listaSubmotivos > tbody').html(response.Lista);
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    function llenarCamposSubmotivo(idSubmotivo, desc, idMotivo) {
        cargarMensaje();
        $(`#desc_submotivo`).val(desc);
        $(`#idsubmotivo`).val(idSubmotivo);
        $(`#idmotivo_submotivo`).val(idMotivo);
        $('#div_btnAccionSubmotivo').html(`<button type="button" class="btn btn-success" onclick="editarSubmotivo()"><i class="icon icon-pencil"></i> Editar</button>`);
    }
</script>