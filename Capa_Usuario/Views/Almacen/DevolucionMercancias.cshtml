@using Capa_Entidad.General_ENT.TablasSql;
@using Capa_Entidad.Almacen_ENT.Tablas;
@using Capa_Entidad.Almacen_ENT.TablasSql;
@{
    ViewBag.Title = "Devolución de Mercancías";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
    List<OWHS_E> Almacenes = (List<OWHS_E>)ViewBag.Almacenes;
    List<OMRC_E> Laboratorios = (List<OMRC_E>)ViewBag.Laboratorios;
    List<MotivosDevoluciones_E> motivos = (List<MotivosDevoluciones_E>)ViewBag.Motivos;
    List<MotivosDevoluciones_E> motivosSubmotivos = (List<MotivosDevoluciones_E>)ViewBag.ListaParaSubmotivos;
    List<SubmotivosDevoluciones_E> submotivos = (List<SubmotivosDevoluciones_E>)ViewBag.Submotivos;
}

<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li class="current"><em>Devolución de mercancías</em></li>
        </ol>
    </nav>
</div>

<form name="frm" id="frm">
    <div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
        <div class="px-3 pt-3"><h3 class="titulo-seccion">@ViewBag.Title.ToUpper()</h3></div>
        <div class="row px-3 py-2">
            <div class="col-12">
                <button type="button" id="btn_nuevaDevolucion" class="btn btn-sm btn-warning" onclick="redireccionar(this)" data-ruta="@Url.Action("NuevaDevolucion", "Almacen")" title="Nueva Devolución">
                    <i class="bi bi-plus-lg"></i> Devolución
                </button>
                <button type="button" id="btn_nuevaDevolucionDEV07" class="btn btn-sm btn-primary" onclick="redireccionar(this)" data-ruta="@Url.Action("NuevaDevolucion", "Almacen", new { Almacen ="DEV07"})" title="Nueva Devolución para DEV07">
                    <i class="bi bi-plus-lg"></i> DEV07
                </button>
                <button type="button" class="btn btn-sm btn-success" title="Descargar Reporte Histórico" data-bs-toggle="modal" data-bs-target="#modalReporte" onclick="limpiarCampos()">
                    <i class="bi bi-file-earmark-excel"></i> Reporte Histórico
                </button>
                <button type="button" class="btn btn-sm btn-outline-light" title="Motivos y Sub Motivos" data-bs-toggle="modal" data-bs-target="#modalMotivosyObs">
                    <i class="bi bi-folder2-open"></i> Motivos y Submotivos
                </button>
            </div>
        </div>
    </div>

    <div class="bg-white px-3 py-3 align-items-center">
        <div class="table-responsive shadow-sm rounded">
            <table id="tbl_listaDevoluciones" class="table table-light table-sm table-hover" cellspacing="0" width="100%">
                <thead class="thead-cobefar">
                    <tr>
                        <th class="text-center border-end border-start" >DocNum<br /><div class="d-flex justify-content-center"><input type="text" name="DocNum" id="filtro_DocNum" class="form-control border text-center filtrosDevolucion" autocomplete="off" style="width: 100px" onchange="filtrar();" value="@if (ViewBag.Devolucion.DocNum != 0) { Write(ViewBag.Devolucion.DocNum); }" /></div></th>
                        <th class="text-center border-end" style="width: 100px">
                            Almacen<br /><div class="d-flex justify-content-center">
                                <input type="text" name="WhsCode" class="form-control border text-center filtrosDevolucion" autocomplete="off" style="width: 100px" onchange="filtrar();" value="@if (!string.IsNullOrWhiteSpace(ViewBag.Devolucion.WhsCode)) { Write(ViewBag.Devolucion.WhsCode); }" />
                            </div>
                        </th>
                        <th class="text-center border-end" style="width: 100px">Fecha Registro</th>
                        <th class="text-center border-end">Correlativo</th>
                        <th class="text-center border-end" style="width: 100px">Fecha Devolución</th>
                        <th class="text-center border-end">Proveedor<br /><div class="d-flex justify-content-center"><input type="text" name="CardName" class="form-control border text-center filtrosDevolucion" autocomplete="off" style="width: 300px" onchange="filtrar();" value="@ViewBag.Devolucion.CardName" /></div></th>
                        <th class="text-center border-end">Registrado por</th>
                        <th class="text-center border-end">
                            Estado de Recojo<br />
                            <div class="d-flex justify-content-center">
                                <select type="text" name="Estado" id="EstadoPost" class="form-select border filtrosDevolucion" autocomplete="off" style="width: 200px" onchange="filtrar();">
                                    <option value="">Seleccione</option>
                                    <option value="PENDIENTE DE RECOJO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("PENDIENTE DE RECOJO")) { Write("selected"); }>Pendiente de recojo</option>
                                    <option value="RECOGIDO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("RECOGIDO")) { Write("selected"); }>Recogido</option>
                                    <option value="REVERTIDO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("REVERTIDO")) { Write("selected"); }>Revertido</option>
                                    <option value="NC APLICADA" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("NC APLICADA")) { Write("selected"); }>NC Aplicada</option>
                                    <option value="ANULADO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("ANULADO")) { Write("selected"); }>Anulado</option>
                                </select>
                            </div>
                        </th>

                        <th class="text-center"></th>
                        <th class="text-center"></th>
                        <th class="text-center"></th>
                        <th class="text-center"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var m in Model)
                        {
                            <tr>
                                <td class="text-center border-end border-start">@m.DocNum</td>
                                <td class="text-center border-end">@m.WhsCode</td>
                                <td class="text-center border-end">@m.FechaOperacion</td>
                                <td class="text-center border-end">@m.Correlativo</td>
                                <td class="text-center border-end">@m.FechaDevolucion</td>
                                <td class="text-center border-end">@m.CardName</td>
                                <td class="text-center border-end">@m.Operario</td>
                                <td class="text-center border-end">@m.Estado</td>

                                <td class="text-center">
                                    @if (m.Estado.Equals("PENDIENTE DE RECOJO"))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger cls-anular" onclick="validarCambioEstadoDevolucion(@m.DocEntry,@m.DocNum,'@m.WhsCode','AA');">
                                            <i class="bi bi-trash2-fill"></i>
                                        </button>
                                    }
                                    // Solo para Estado RECOGIDO y guardará "0" en el campo "SinNC" siempre y cuando no encuentre un NULL en NotaCredito línea x línea en RPD1
                                    @*else if (m.Estado.Equals("RECOGIDO") && m.SinNC.Equals(0))
                                        {
                                            <button type="button" class="btn btn-sm btn-success" onclick="validarCambioEstadoDevolucion(@m.DocEntry,@m.DocNum,'@m.WhsCode','NC');"> NC Aplicada</button>
                                        }*@
                                </td>
                                <td class="text-center">
                                    @if (m.Estado.Equals("RECOGIDO"))
                                    {
                                        <button type="button" class="btn btn-sm btn-orange cls-revertirRecojo" onclick="validarCambioEstadoDevolucion(@m.DocEntry, @m.DocNum, '@m.WhsCode', 'RR')">Rv. recojo</button>
                                    }
                                    @if (m.Estado.Equals("PENDIENTE DE RECOJO"))
                                    {
                                        <button type="button" class="btn btn-sm btn-blue cls-recogido" onclick="validarCambioEstadoDevolucion(@m.DocEntry, @m.DocNum, '@m.WhsCode', 'R')">Recogido</button>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (m.Estado.Equals("PENDIENTE DE RECOJO"))
                                    {
                                        if (m.WhsCode.Equals("DEV07"))
                                        {
                                            <a href="/Almacen/EditarDevolucion?DocEntry=@m.DocEntry&Almacen=DEV07" class="btn btn-sm btn-outline-primary cls-editar"> <i class="bi bi-pencil"></i></a>
                                        }
                                        else
                                        {
                                            <a href="/Almacen/EditarDevolucion?DocEntry=@m.DocEntry" class="btn btn-sm btn-outline-primary cls-editar"> <i class="bi bi-pencil"></i></a>
                                        }
                                    }
                                </td>
                                <td class="text-center"><a href="/Almacen/SeguimientoDevolucion?DocEntry=@m.DocEntry" class="btn btn-sm btn-outline-dark cls-verDatos"> <i class="bi bi-search"></i></a></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</form>
<form id="frmReporteHistorico">
    <!-- Modal -->
    <div class="modal fade" id="modalReporte" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-headerModals text-white">
                    <h5 class="modal-title" id="exampleModalLabel">Reporte Histórico</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar" tabindex="-1"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-lg-3 col-md-3">
                            <label class="fw-bold">Fecha registro desde:</label>
                            <input type="date" id="FechaDesde" name="FechaDesde" class="form-control text-center" />
                        </div>

                        <div class="col-lg-3 col-md-3">
                            <label class="fw-bold">Fecha registro hasta:</label>
                            <input type="date" id="FechaHasta" name="FechaHasta" class="form-control text-center" />
                        </div>

                        <div class="col-lg-6 col-md-6">
                            <label class="fw-bold">DocNum:</label>
                            <input type="text" id="DocNumReporte" class="form-control w-50" autocomplete="off" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6">
                            <label class="fw-bold">Factura:</label>
                            <input type="text" id="RefFacturaReporte" class="form-control" />
                        </div>

                        <div class="col-lg-6 col-md-6">
                            <label class="fw-bold">Estado de recojo:</label>
                            <select type="text" id="EstadoReporte" class="form-select" autocomplete="off" style="width: 350px">
                                <option value="">Seleccione</option>
                                <option value="PENDIENTE DE RECOJO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("PENDIENTE DE RECOJO")) { Write("selected"); }>Pendiente de recojo</option>
                                <option value="RECOGIDO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("RECOGIDO")) { Write("selected"); }>Recogido</option>
                                <option value="REVERTIDO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("REVERTIDO")) { Write("selected"); }>Revertido</option>
                                <option value="NC APLICADA" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("NC APLICADA")) { Write("selected"); }>NC Aplicada</option>
                                <option value="ANULADO" @if (ViewBag.Devolucion.Estado != null && ViewBag.Devolucion.Estado.Equals("ANULADO")) { Write("selected"); }>Anulado</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="fw-bold">Proveedor:</label>
                            <input type="search" id="CardNameReporte" list='ListaClientes' class="form-control" onkeyup="cargarListaCliente(this.value)" autocomplete="off" />
                            <div id="div_listaClientes"></div>
                        </div>

                        <div class="col-lg-6">
                            <label class="fw-bold">Almacén:</label>
                            <select id="WhsCodeReporte" class="form-select" style="width: 350px">
                                <option value="">Seleccione</option>
                                @if (Almacenes != null && Almacenes.Count() >= 1)
                                {
                                    foreach (var alm in Almacenes)
                                    {
                                        <option value="@alm.WhsCode">@alm.WhsName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="fw-bold">Laboratorio:</label>
                            <input type="search" id="FirmCodeReporte" list='ListaLab' class="form-control" onchange="cargarProductos(this.value)" autocomplete="off" />
                            <datalist id="ListaLab">
                                @if (Laboratorios != null && Laboratorios.Count() >= 1)
                                {
                                    foreach (var lab in Laboratorios)
                                    {
                                        <option firmcode="@lab.FirmCode" value="@lab.U_SYP_DESC"></option>
                                    }
                                }
                            </datalist>
                        </div>

                        <div class="col-lg-6 col-md-6">
                            <label class="fw-bold">Producto:</label>
                            <input type="text" id="ItemNameReporte" list="ListaProductos" class="form-control" autocomplete="off" />
                            <div id="div_listaProductos"></div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" id="btn_cerrarModal" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class='bi bi-x-lg'></i> Cerrar</button>
                    <button type="button" class="btn btn-cobefar" onclick="ExportarReporteHistorico()"><i class="bi bi-check-lg"></i> Generar Reporte</button>
                </div>
            </div>
        </div>
    </div>

</form>

<!-- Modal Motivos y Submotivos -->
<div class="modal fade" id="modalMotivosyObs" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-headerModals text-white">
                <h5 class="modal-title" id="exampleModalLabel">Motivos y Submotivos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar" tabindex="-1"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-lg-6 col-md-6 text-center">
                        <button class="btn btn-cobefar fw-bold mx-1 my-1" title="Nuevo Motivo" data-bs-toggle="modal" data-bs-target="#modalMotivo" onclick="limpiarCamposMotivo()">
                            <i class="bi bi-plus-lg"></i> Nuevo Motivo
                        </button>
                    </div>

                    <div class="col-lg-6 col-md-6 text-center">
                        <button class="btn btn-cobefar fw-bold mx-1 my-1" title="Nuevo Sub Motivo" data-bs-toggle="modal" data-bs-target="#modalSubmotivo" onclick="limpiarCamposSubmotivo()">
                            <i class="bi bi-plus-lg"></i> Nuevo Submotivo
                        </button>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class='bi bi-x-lg'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Motivos -->
<div class="modal fade" id="modalMotivo" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-headerModals text-white">
                <h5 class="modal-title" id="exampleModalLabel">Motivos Devoluciones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar" tabindex="-1"></button>
            </div>
            <div class="modal-body">
                <form id="frm_motivo">
                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar fw-bold">Descripción:</label>
                            <input type="hidden" id="idmotivo" name="IdMotivo" />
                            <input type="text" id="desc_motivo" name="Descripcion" class="form-control" autocomplete="off" />
                        </div>

                        <div class="col-lg-3 col-md-3">
                            <label class="text-cobefar fw-bold">Estado:</label>
                            <select id="estado_motivo" name="Estado" class="form-select">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>

                        <div id="div_btnAccionMotivo" class="col-lg-3 col-md-3 d-flex align-self-end">
                            <button type="button" class="btn btn-success" onclick="agregarMotivo()"><i class="bi bi-plus-lg"></i> Agregar</button>
                        </div>
                    </div>
                </form>

                <div class="row mb-4">
                    <div class="col-lg-12 col-md-12">
                        <div class="bg-white">
                            <table id="tbl_listaMotivos" class="table table-light table-sm table-hover" cellspacing="0" width="100%">
                                <thead class="thead-cobefar">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th class="text-center">Motivo</th>
                                        <th class="text-center">Estado</th>
                                        <th class="text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (motivos != null && motivos.Count >= 1)
                                    {
                                        int num = 1;
                                        foreach (var m in motivos)
                                        {
                                            <tr>
                                                <td class="text-center">@num</td>
                                                <td class="text-center">@m.Descripcion</td>
                                                <td class="text-center fw-bold @if (m.Estado.Equals("1")) { Write("text-success"); } else { Write("text-danger"); }">@m.DescEstado</td>
                                                <td class="text-center"><button type="button" class="btn btn-sm btn-light" onclick="llenarCamposMotivo (@m.IdMotivo, '@m.Descripcion')"><i class="bi bi-pencil text-primary"></i></button></td>
                                            </tr>
                                            ++num;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class='bi bi-x-lg'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Motivos y Submotivos -->
