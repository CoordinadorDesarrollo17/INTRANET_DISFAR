            </div>
        </div>
    </div>
</div>


<!-- Modal Submotivos -->
<div class="modal fade" id="modalSubmotivo" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">Submotivos Devoluciones</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="frm_submotivo">
                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Motivo:</label>
                            <select id="idmotivo_submotivo" name="IdMotivo" class="form-control bg-cobefar text-white">
                                <option value="">Seleccione</option>
                                @if (motivosSubmotivos != null && motivosSubmotivos.Count >= 1)
                                {
                                    foreach (var mot in motivosSubmotivos)
                                    {
                                        <option value="@mot.IdMotivo">@mot.Descripcion</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-lg-6 col-md-6">
                            <label class="text-cobefar font-weight-bold">Descripción:</label>
                            <input type="hidden" id="idsubmotivo" name="IdSubmotivo" />
                            <input type="text" id="desc_submotivo" name="Descripcion" class="form-control border-success" autocomplete="off" />
                        </div>

                        <div class="col-lg-3 col-md-3">
                            <label class="text-cobefar font-weight-bold">Estado:</label>
                            <select id="estado_submotivo" name="Estado" class="form-control bg-cobefar text-white">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>

                        <div id="div_btnAccionSubmotivo" class="col-lg-3 col-md-3 d-flex align-self-end">
                            <button type="button" class="btn btn-success" onclick="agregarSubmotivo()"><i class="icon icon-plus"></i> Agregar</button>
                        </div>
                    </div>
                </form>

                <div class="row mb-4">
                    <div class="col-lg-12 col-md-12">
                        <div class="bg-white">
                            <table id="tbl_listaSubmotivos" class="table table-light table-sm table-hover " cellspacing="0" width="100%">
                                <thead class="bg-cobefar-6">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th class="text-center">Motivo</th>
                                        <th class="text-center">Submotivo</th>
                                        <th class="text-center">Estado</th>
                                        <th class="text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (submotivos != null && submotivos.Count >= 1)
                                    {
                                        int num = 1;
                                        foreach (var o in submotivos)
                                        {
                                            <tr>
                                                <td class="text-center">@num</td>
                                                <td class="text-center">@o.DescMotivo</td>
                                                <td class="text-center">@o.Descripcion</td>
                                                <td class="text-center font-weight-bold @if (o.Estado.Equals("1")) { Write("text-success"); } else { Write("text-danger"); }">@o.DescEstado</td>
                                                <td class="text-center"><button type="button" class="btn btn-sm btn-light" onclick="llenarCamposSubmotivo(@o.IdSubmotivo, '@o.Descripcion', @o.IdMotivo)" data-toggle="tooltip" data-placement="top" title="Editar Motivo"><i class="icon-pencil text-primary"></i></button></td>
                                            </tr>
                                            ++num;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
            </div>
        </div>
    </div>
</div>



