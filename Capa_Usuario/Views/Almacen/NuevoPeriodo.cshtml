@model Capa_Entidad.Almacen_ENT.TablasSql.OIPE_E
@using Capa_Entidad.General_ENT.Tablas
@{
    ViewBag.Title = "NuevoPeriodo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script>
    $(document).ready(function () {
    });
    var contAlm = 0;
    function valorCamposSelect(id) {
        var Sel = $("#" + id);
        var SelOpt = $("#" + id + " option[value='" + Sel.val() + "']").attr("WhsName");
        if (Sel.val() == null || Sel.val() == "") { return; }
        if (validarUnicoCampoTabla(Sel.val(), "DetallesPeriodo1")) {
            $("#DetallesPeriodo1 > tbody").append("<tr><td><input class='form-control ' name='DetAlmacenes[" + contAlm + "].WhsCode' value='" + Sel.val() + "' readonly /></td><td><input class='form-control' name='DetAlmacenes[" + contAlm + "].WhsName' value='" + SelOpt + "'  readonly /></td><td>" +
                "<button type='button' onclick='borrarTrTable(this)' class='btn btn-danger'>Retirar</button></td></tr>");
            contAlm = contAlm + 1;
        }
    }
    function borrarTrTable(dom) {
        var i = -1;
        $(dom).closest('tr').remove();
        contAlm = contAlm - 1;
        $("#DetallesPeriodo1 > tbody" + " tr").each(function (index, htm) {
            iden1 = $(htm).find("td:eq(0) input");
            iden1.attr("name", "DetAlmacenes[" + i + "].WhsCode");
            iden2 = $(htm).find("td:eq(1) input");
            iden2.attr("name", "DetAlmacenes[" + i + "].WhsName");
            i = i + 1;
        })
    }
    function validarUnicoCampoTabla(identificador, idTabla) {
        var sinRegistro = true;
        $("#" + idTabla + " tr").find('td:eq(0) input').each(function () {
            iden = $(this).val();
            if (iden == identificador) { swal.fire("El valor ya se encuentra en la tabla", "Verifique", "warning"); sinRegistro = false; }
        })
        return sinRegistro;
    }
    function validarEnviarFormulario() {
        var object = $("#NuevoPeriodo").serialize();
        $.ajax('/Almacen/validarNuevoPeriodo',
            {
                data: object,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response != "true") { swal.fire({ title: response, text: "Presione OK para continuar", icon: "warning" }); return false }
                else { $("#NuevoPeriodo").submit(); }
            });
    }
</script>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="/Index/Sesion">Inicio</a></li>
            <li><a href="@Url.Action("GestionPeriodos","Almacen")">Gestión de periodos</a></li>
            <li class="current"><em>Registrar nuevo periodo</em></li>
        </ol>
    </nav>
</div>


<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">REGISTRAR NUEVO PERIODO</h3></div>
</div>


@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "NuevoPeriodo" }))
{
    @Html.AntiForgeryToken()
<div class="bg-form-pestanas-cobefar pt-4 bg-section-form p-4 bg-form-cobefar">
    <div class="row mt-4">
        <div class="col-lg-5">
            <label for="Descripcion" class="text-dark form-label font-weight-bold font-18">Descripción:</label>
            @Html.EditorFor(model => model.Descripcion, new { htmlAttributes = new { @class = "form-control border-success", @size = 60 } })
        </div>

        <div class="col-lg-2">
            <label for="FecInicioPer" class="text-dark form-label font-weight-bold font-18">Fecha Inicio:</label>
            <div id="infoFecInicioPer"><input class="form-control text-center border-success" id="FecInicioPer" type="date" name="FecIni" value="" /></div>
        </div>

        <div class="col-lg-2">
            <label for="FecFinPer" class="text-dark form-label font-weight-bold font-18">Fecha Fin:</label>
            <div id="infoFecFinPer"><input class="form-control text-center border-success" id="FecFinPer" type="date" name="FecFin" value="" /></div>
        </div>

        <div class="col-lg-3">
            <label for="Almacen" class="text-dark form-label font-weight-bold font-18">Almacén:</label>
            <select name="Almacen" id="Almacen" class="form-control bg-cobefar text-white">
                <option value="">Seleccione</option>
                @foreach (OWHS_E obj in ViewBag.Almacenes)
                {
                    <option value="@obj.WhsCode" WhsName="@obj.WhsName">@obj.WhsName</option>
                }
            </select>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-4">
            <button type="button" class="btn btn-cobefar" onclick="valorCamposSelect('Almacen');"><i class="icon icon-plus"></i> Agregar</button>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-6">
            <table id="DetallesPeriodo1" class="table table-sm  table-hover">
                <thead class="bg-success">
                    <tr>
                        <th class="text-center">ID</th>
                        <th class="text-center">Descripcion</th>
                        <th class="text-center"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        
    </div>

    <div class="row mt-4">
        <div class="col-lg-12">
            @Html.EditorFor(model => model.Observaciones, "", new { htmlAttributes = new { @class = "form-control border-success", @placeholder = "Anote aquí sus observaciones", @autocomplete = "off" } })
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-4">
            <button type="button" class="btn btn-success" onclick="validarEnviarFormulario();"><i class="icon icon-checkmark"></i> Registrar</button>
        </div>
    </div>

</div>
}