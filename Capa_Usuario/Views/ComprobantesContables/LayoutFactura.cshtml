@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.Reportes.ComprobanteDePago_E>
@{
    Layout = null;
    var Cab = Model.ToList()[0];
    var modelList = Model.ToList();
    var sumGratuita = Cab.Sum_Topgratuita(modelList);
    var sumInafecto = Cab.Sum_Tinafecto(modelList);
    var opGravadas = Math.Round(Cab.Tgrabado(sumGratuita, sumInafecto), 2).ToString("F2");
    var opExoneradas = Cab.CalcularOpExoneradas(modelList).ToString();
    var opGratuitas = Cab.F_Topgratuita(sumGratuita).ToString();
    var opInafectas = Cab.F_Tinafecto(0).ToString("F2"); //Cab.F_Tinafecto(sumInafecto).ToString();
    var anticipo = (Cab.Anticipo > 0 ? Math.Round(Cab.Anticipo, 2) : 0).ToString("F2");
    var igv = Math.Round(Cab.Impuesto, 2).ToString("F2");
    var total = Math.Round(Cab.TotalFactura(sumGratuita), 2).ToString("F2");

}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Factura Electrónica</title>
    <style>
        * {
            font-family: 'Verdana', sans-serif;
            box-sizing: border-box;
        }

        body {
            margin: 20px;
            color: #333;
            font-size: 11px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }


        /* ── INFO VENTA ── */
        .info-venta {
            border: 1px solid #b0bfc6;
            border-radius: 12px;
            margin-bottom: 8px;
            padding: 0;
            overflow: hidden;
        }

            .info-venta table {
                text-align: center;
            }

            .info-venta thead tr {
                border-bottom: 1px solid #b0bfc6;
                background-color: #fafbfc;
            }

            .info-venta thead th {
                padding: 6px;
                font-weight: bold;
                border-right: 1px solid #b0bfc6;
                font-size: 10px;
            }

                .info-venta thead th:last-child {
                    border-right: none;
                }

            .info-venta tbody td {
                padding: 8px;
                border-right: 1px solid #b0bfc6;
                font-size: 10px;
            }

                .info-venta tbody td:last-child {
                    border-right: none;
                }

        /* ── TABLA PRODUCTOS ── */
        .items-table {
            width: 100%;
            margin-bottom: 10px;
        }

            .items-table th {
                background-color: #1F4E79;
                color: white;
                font-weight: bold;
                font-size: 10px;
                padding: 6px 4px;
                border: 1px solid #1F4E79;
                text-align: center;
            }

            .items-table td {
                padding: 6px 4px;
                border: 1px solid #b0bfc6;
                text-align: center;
                font-size: 10px;
            }

        /* ── TOTALES ── */
        .totals-container {
            width: 100%;
            margin-top: 10px;
            margin-bottom: 20px;
        }

        .totals-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 4px;
        }

        .totals-label {
            background-color: #888;
            color: white;
            text-align: center;
            font-weight: bold;
            padding: 5px;
            border-radius: 6px 0 0 6px;
            font-size: 10px;
            width: 150px;
        }

        .totals-value {
            border: 1px solid #b0bfc6;
            border-left: none;
            border-radius: 0 6px 6px 0;
            text-align: right;
            padding: 5px 10px;
            background-color: white;
            font-size: 10px;
            width: 130px;
        }

        .totals-label-final {
            background-color: #1F4E79;
            color: white;
            text-align: center;
            font-weight: bold;
            padding: 7px;
            border-radius: 6px 0 0 6px;
            font-size: 11px;
        }

        .totals-value-final {
            border: 2px solid #1F4E79;
            border-left: none;
            border-radius: 0 6px 6px 0;
            text-align: right;
            padding: 7px 10px;
            font-weight: bold;
            color: #1F4E79;
            font-size: 12px;
            background-color: white;
        }

        /* ── SON ── */
        .footer-son {
            clear: both;
            border: 1px solid #b0bfc6;
            padding: 8px;
            font-size: 11px;
            margin-top: 10px;
        }
    </style>
</head>
<body>



    <!-- ══ INFO VENTA ══ -->
    <div class="info-venta">
        <table>
            <thead>
                <tr>
                    <th style="width:18%;">Fecha de Emisión:</th>
                    <th style="width:18%;">Forma de Pago:</th>
                    <th style="width:18%;">Nro. Orden de venta</th>
                    <th style="width:28%;">Vendedor</th>
                    <th style="width:18%;">N° Guía de Remisión:</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Cab.Fecha</td>
                    <td>@Cab.CondPago</td>
                    <td>@Cab.NroOrdVenta</td>
                    <td>@Cab.ElaboradoPor</td>
                    <td>@Cab.NumGuias</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- ══ TABLA PRODUCTOS ══ -->
    <table class="items-table">
        <thead>
            <tr>
                <th style="width:10%;">CÓDIGO</th>
                <th style="width:6%;">CANT.</th>
                <th style="width:8%;">UNID.</th>
                <th style="width:36%;">DESCRIPCIÓN</th>
                <th style="width:8%;">LOTE</th>
                <th style="width:8%;">F. V.</th>
                <th style="width:8%;">V. UNIT.</th>
                <th style="width:6%;">DSCTO. %</th>
                <th style="width:10%;">V.VENTA NETO</th>
                <th style="width:10%;">V. VENTA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="page-break-inside:avoid;">
                    <td>@item.ItemCode</td>
                    <td>@Math.Round(item.cantVta(), 0)</td>
                    <td>
                        @(item.UM() == "CAJA"
                        ? "CAJA x " + item.QUMVta
                        : item.QUMVta + " " + item.UM())
                    </td>
                    <td style="text-align:left;">@item.Descripcion</td>
                    <td>@item.LoteNum</td>
                    <td>@item.VctoLote</td>
                    <td>@Math.Round(item.F_ItemPrecio(), 2).ToString("F2")</td>
                    <td>@Math.Round(item.Descuento, 2).ToString("F2")</td>
                    <td>@item.PreVentaNeto.ToString("F2")</td>
                    <td>@Math.Round(item.ItemTotalxLot(), 2).ToString("F2")</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- ══ OBSERVACIONES + TOTALES ══ -->
    <table style="width:100%; margin-top:5px; margin-bottom:10px; border-collapse:collapse; page-break-inside:avoid;">
        <tr>
            <td style="vertical-align:top; padding-top:5px; font-weight:bold; color:#555;">
                @*OBSERVACIONES<br />
                <span style="font-weight:normal;">@Cab.Observacion</span>*@
            </td>
            <td style="width:290px; vertical-align:top;">
                <table class="totals-table">
                    <tr><td class="totals-label">OP. GRAVADAS</td>        <td class="totals-value">S/ @opGravadas</td></tr>
                    <tr><td class="totals-label">OP. INAFECTAS</td>       <td class="totals-value">S/ @opInafectas</td></tr>
                    <tr><td class="totals-label">OP. EXONERADAS</td>      <td class="totals-value">S/ @opExoneradas</td></tr>
                    <tr><td class="totals-label">TOTAL OP. GRATUITAS</td> <td class="totals-value">S/ @opGratuitas</td></tr>
                    <tr><td class="totals-label">DSCTOS. TOTALES</td>     <td class="totals-value">S/ 0.00</td></tr>
                    <tr><td class="totals-label">ANTICIPOS</td>           <td class="totals-value">S/ @anticipo</td></tr>
                    <tr><td class="totals-label">IGV</td>                 <td class="totals-value">S/ @igv</td></tr>
                    <tr><td class="totals-label-final">TOTAL</td>         <td class="totals-value-final">S/ @total</td></tr>
                </table>
            </td>
        </tr>
    </table>

    <!-- ══ SON ══ -->
    <div class="footer-son">
        SON: @Cab.TotalL()
    </div>


    <!-- ══ DETALLE DE ANTICIPO ══ -->
    @if (!string.IsNullOrWhiteSpace(Cab.NroAnticipo))
    {
        <div style="margin-top: 15px;">
            <div style="font-weight:bold; font-size:11px; margin-bottom:8px;">
                <u>DETALLE DE ANTICIPO</u>
            </div>
            <table style="width:40%; border-collapse:collapse; font-size:10px;">
                <thead>
                    <tr>
                        <th style="border:1px solid #b0bfc6; padding:4px 8px; text-align:center; background-color:#fafbfc;">Factura</th>
                        <th style="border:1px solid #b0bfc6; padding:4px 8px; text-align:center; background-color:#fafbfc;">Monto</th>
                        <th style="border:1px solid #b0bfc6; padding:4px 8px; text-align:center; background-color:#fafbfc;">Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="border:1px solid #b0bfc6; padding:4px 8px; text-align:center;">@Cab.NroAnticipo</td>
                        <td style="border:1px solid #b0bfc6; padding:4px 8px; text-align:center;">@Cab.AnticipoBruto.ToString("N2")</td>
                        <td style="border:1px solid #b0bfc6; padding:4px 8px; text-align:center;">@Cab.FechaAnticipo</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }


</body>
</html>
