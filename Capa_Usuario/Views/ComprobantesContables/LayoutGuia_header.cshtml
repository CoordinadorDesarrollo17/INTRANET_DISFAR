@model IEnumerable<Capa_Entidad.ComprobantesContables_ENT.Guia_Remision_E>

@{
    Layout = null;
    var Cab = Model.ToList()[0];
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LayoutGuia - Header</title>
    <style>
        * {
            font-family: 'Arial', 'Verdana', sans-serif;
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 10px;
            color: #333;
            font-size: 11px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        .border-box {
            border: 1px solid #b0bfc6;
            border-radius: 10px;
            padding: 10px;
            margin-top: 15px;
        }
    </style>
</head>
<body>

    <table>
        <tr>
            <td style="width: 60%; vertical-align: top;">
                <img src="~/imagenes/Logo - Disfar Oriente.png" width="160" height="55" style="float: left; margin-right: 15px;" />
                <div style="font-size: 11px; color: #0a3a60; font-weight: bold; margin-top: 5px;">DISFAR ORIENTE S.A.C.</div>
                <div style="font-size: 9px; color: #555; line-height: 1.3; margin-top: 3px;">
                    PJ. PROGRESO NRO. 118 (ALT CUADRA 2 VIA DEEVITAMIENTO)-MORALES-SAN MARTÍN SAN MARTÍN<br />
                    <span style="color: #777;">Morales - San Martín - San Martín</span>
                </div>
            </td>
            <td style="width: 40%; vertical-align: top;">
                <div style="border: 2px solid #0a3a60; border-radius: 15px; padding: 12px; text-align: center;">
                    <div style="font-size: 11px; color: #333; margin-bottom: 5px; font-weight: bold;">RUC: 20615244156</div>
                    <div style="font-size: 11px; font-weight: bold; color: #0a3a60; margin-bottom: 5px; line-height: 1.2;">
                        GUÍA DE REMISIÓN REMITENTE<br />ELECTRÓNICA
                    </div>
                    <div style="font-size: 11px; color: #333;">Nro. @Cab.NumAtCard</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="border-box">
        <table style="line-height: 1.6;">
            @if (ViewBag.Tipo == "T")
            {
                <tr>
                    <td style="width: 12%; font-weight: bold;">Cliente:</td>
                    <td style="width: 48%;">@Cab.NombreBD</td>
                    <td style="width: 18%; font-weight: bold;">Fecha de emisión:</td>
                    <td style="width: 22%;">@Cab.DocDate</td>
                </tr>
                <tr>
                    <td style="font-weight: bold;">RUC:</td>
                    <td>@Cab.RucBD</td>
                    <td style="font-weight: bold;">Fecha de Traslado:</td>
                    <td>@Cab.FechaTrasl</td>
                </tr>
            }
            else if (ViewBag.Tipo == "E")
            {
                <tr>
                    <td style="width: 12%; font-weight: bold;">Cliente:</td>
                    <td style="width: 48%;">@Cab.CardName</td>
                    <td style="width: 18%; font-weight: bold;">Fecha de emisión:</td>
                    <td style="width: 22%;">@Cab.DocDate</td>
                </tr>
                <tr>
                    <td style="font-weight: bold;">RUC:</td>
                    <td>
                        @(Cab.CardCode != null && Cab.CardCode.Length == 12 ? Cab.CardCode.Substring(1, 11) : Cab.CardCode)
                    </td>
                    <td style="width: 18%; font-weight: bold;">Fecha de Traslado:</td>
                    <td>@Cab.FechaTrasl</td>
                </tr>
            }
        </table>
    </div>

</body>
</html>