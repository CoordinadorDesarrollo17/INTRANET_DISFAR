@model IEnumerable<Capa_Entidad.Ventas_ENT.Tablas.NotaCreditoDebito_E>
@{
    Layout = null;
    var Cab = Model.ToList()[0];
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LayoutNotaCreditoDebito</title>
    <style>
        * {
            font-family: 'Verdana', sans-serif;
            box-sizing: border-box;
        }

        body {
            margin: 20px;
            color: #333;
            font-size: 11px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        /* ── INFO DOC ORIGEN ── */
        .info-venta {
            border: 1px solid #b0bfc6;
            border-radius: 12px;
            margin-top: 15px;
            margin-bottom: 15px;
            padding: 0;
            overflow: hidden;
        }

            .info-venta table {
                text-align: center;
            }

            .info-venta thead tr {
                border-bottom: 1px solid #b0bfc6;
                background-color: #fafbfc;
            }

            .info-venta thead th {
                padding: 6px;
                font-weight: bold;
                border-right: 1px solid #b0bfc6;
                font-size: 10px;
            }

                .info-venta thead th:last-child {
                    border-right: none;
                }

            .info-venta tbody td {
                padding: 8px;
                border-right: 1px solid #b0bfc6;
                font-size: 10px;
            }

                .info-venta tbody td:last-child {
                    border-right: none;
                }

        /* ── TABLA ITEMS ── */
        .items-table {
            width: 100%;
            margin-bottom: 15px;
        }

            .items-table th {
                background-color: #0a3a60;
                color: white;
                font-weight: bold;
                font-size: 10px;
                padding: 6px 4px;
                border: 1px solid #0a3a60;
                text-align: center;
            }

            .items-table td {
                padding: 6px 4px;
                border: 1px solid #b0bfc6;
                text-align: center;
                font-size: 10px;
            }

        /* ── TOTALES ── */
        .totals-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 4px;
        }

        .totals-label {
            background-color: #a6b1ba;
            color: white;
            text-align: center;
            font-weight: bold;
            padding: 5px;
            border-radius: 6px 0 0 6px;
            font-size: 10px;
            width: 150px;
        }

        .totals-value {
            border: 1px solid #b0bfc6;
            border-left: none;
            border-radius: 0 6px 6px 0;
            text-align: right;
            padding: 5px 10px;
            background-color: white;
            font-size: 10px;
            width: 130px;
        }

        .totals-label-final {
            background-color: #0a3a60;
            color: white;
            text-align: center;
            font-weight: bold;
            padding: 7px;
            border-radius: 6px 0 0 6px;
            font-size: 11px;
        }

        .totals-value-final {
            border: 2px solid #0a3a60;
            border-left: none;
            border-radius: 0 6px 6px 0;
            text-align: right;
            padding: 7px 10px;
            font-weight: bold;
            color: #0a3a60;
            font-size: 12px;
            background-color: white;
        }

        /* ── SON ── */
        .footer-son {
            clear: both;
            border: 1px solid #b0bfc6;
            padding: 8px;
            font-size: 11px;
            margin-top: 10px;
        }
    </style>
</head>
<body>

    <!-- ══ INFO DOC ORIGEN ══ -->
    <div class="info-venta">
        <table>
            <thead>
                <tr>
                    <th style="width:25%;">Fecha de Emisión</th>
                    <th style="width:25%;">Referencia</th>
                    <th style="width:25%;">Fecha Doc. Origen</th>
                    <th style="width:25%;">Vendedor</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Cab.DocDate</td>
                    <td>@Cab.SerieDocRel-@Cab.CorreDocRel</td>
                    <td>@Cab.DocDateRel</td>
                    <td>@Cab.ElaboradoPor</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- ══ TABLA ITEMS (según tipo) ══ -->
    @if (ViewBag.Tipo == "NC" && ViewBag.SubTipo == "S")
    {
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:10%;">CÓDIGO</th>
                    <th style="width:6%;">CANT.</th>
                    <th style="width:8%;">UNID.</th>
                    <th style="width:36%;">DESCRIPCIÓN</th>
                    <th style="width:8%;">LOTE</th>
                    <th style="width:8%;">F. V.</th>
                    <th style="width:8%;">V. UNIT.</th>
                    <th style="width:6%;">DSCTO. %</th>
                    <th style="width:10%;">V.VENTA NETO</th>
                    <th style="width:10%;">V. VENTA</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var total = item.DocTotal;
                    <tr style="page-break-inside:avoid;">
                        <td></td>
                        <td>@(item.Cantidad > 0 ? Math.Round(Convert.ToDouble(item.Cantidad), 0).ToString() : "1")</td>
                        <td></td>
                        <td style="text-align:center;">
                            @if (item.TipoDescripcionC != null && item.TipoDescripcionC.Trim() == "05")
                            {
                                <text>Descuento Especial</text>
                            }
                            else
                            {
                                @Html.DisplayFor(m => item.DescripcionLinea)
                            }
                        </td>
                        <td></td>
                        <td></td>
                        <td>@total</td>
                        <td></td>
                        <td>@total</td>
                        <td>@total</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (ViewBag.Tipo == "ND")
    {
        <table class="items-table">
            <thead>
                <tr>
                    @*<th style="width:15%;">ITEM</th>
                        <th style="width:55%;">DESCRIPCIÓN</th>
                        <th style="width:15%;">VALOR UNITARIO</th>
                        <th style="width:15%;">PRECIO VENTA</th>*@

                    <th style="width:10%;">CÓDIGO</th>
                    <th style="width:6%;">CANT.</th>
                    <th style="width:8%;">UNID.</th>
                    <th style="width:36%;">DESCRIPCIÓN</th>
                    <th style="width:8%;">LOTE</th>
                    <th style="width:8%;">F. V.</th>
                    <th style="width:8%;">V. UNIT.</th>
                    <th style="width:6%;">DSCTO. %</th>
                    <th style="width:10%;">V.VENTA NETO</th>
                    <th style="width:10%;">V. VENTA</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var total = Model.ToList()[0].DocTotal;
                    <tr style="page-break-inside:avoid;">
                        <td>@item.ItemCode</td>
                        <td>@(item.Cantidad > 0 ? Math.Round(Convert.ToDouble(item.Cantidad), 0).ToString() : "")</td>
                        <td>@item.Um</td>
                        <td style="text-align:left;">
                            @if (item.TipoDescripcionC != null && item.TipoDescripcionC.Trim() == "05")
                            {
                                <text>Descuento Especial</text>
                            }
                            else
                            {
                                @item.DescripcionLinea
                            }
                        </td>
                        <td>@item.LoteNum</td>
                        <td>@item.FechaVencimiento</td>

                        <td>@total</td>
                        <td>0.00</td>
                        <td>@total</td>
                        <td>@total</td>

                    </tr>
                }
            </tbody>
        </table>
    }
    else if (ViewBag.Tipo == "NC" && ViewBag.SubTipo == "I")
    {
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:10%;">CÓDIGO</th>
                    <th style="width:6%;">CANT.</th>
                    <th style="width:8%;">UNID.</th>
                    <th style="width:36%;">DESCRIPCIÓN</th>
                    <th style="width:8%;">LOTE</th>
                    <th style="width:8%;">F. V.</th>
                    <th style="width:8%;">V. UNIT.</th>
                    <th style="width:6%;">DSCTO. %</th>
                    <th style="width:10%;">V.VENTA NETO</th>
                    <th style="width:10%;">V. VENTA</th>
                </tr>
            </thead>
            <tbody>

                @if (Model.First().MotivoNC.ToUpper() == "DISMINUCIÓN EN EL VALOR")
                {
                    var item = Model.First();
                    var total = Math.Round(Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())), 2);
                    <tr>
                        <td></td>
                        <td>1</td>
                        <td></td>
                        <td>@item.MotivoNC.ToUpper()</td>
                        <td></td>
                        <td></td>                     
                        <td>@total</td>
                        <td>0.00</td>
                        <td>@total</td>
                        <td>@total</td>
                    </tr>
                }
                else
                {

                    //Productos normales 
                    foreach (var item in Model.Where(x => x.TipoDescripcionC == null || x.TipoDescripcionC.Trim() != "05"))
                    {
                        <tr style="page-break-inside:avoid;">
                            <td>@item.ItemCode</td>
                            <td>
                                @Math.Round(Convert.ToDouble(item.cantVta()), 0)  @if (item.UmLinea.Equals("PZA"))
                                {<span>PZA</span>}
                            </td>
                            <td>@item.UmLinea</td>
                            <td style="text-align:left;">@Html.DisplayFor(m => item.DescripcionLinea)</td>
                            <td>@Html.DisplayFor(m => item.LoteNum)</td>
                            <td>@Html.DisplayFor(m => item.VencLote)</td>
                            <td>@Math.Round(item.F_ItemPrecio(), 2)</td>
                            <td>@Html.DisplayFor(m => item.Descuento)</td>
                            <td>@Html.DisplayFor(m => item.PreVentaNeto)</td>
                            <td>@Math.Round(item.ItemTotalxLot(), 2)</td>
                        </tr>
                    }
                    // Descuento especial 05 
                    {
                        var listaSolo05 = Model.Where(x => x.TipoDescripcionC != null && x.TipoDescripcionC.Trim() == "05").ToList();
                        if (listaSolo05.Any())
                        {
                            var total = Model.ToList()[0].DocTotal;
                            <tr style="page-break-inside:avoid;">
                                <td></td>
                                <td>1</td>
                                <td></td>
                                <td style="text-align:center;"><strong>DESCUENTO ESPECIAL</strong></td>
                                <td></td>
                                <td></td>

                                <td>@total</td>
                                <td>0.00</td>
                                <td>@total</td>
                                <td>@total</td>

                                @*<td>@Math.Round(Cab.Tgrabado(Cab.Sum_Topgratuita(Model.ToList()), Cab.Sum_Tinafecto(Model.ToList())), 2)</td>
                        <td>0.00</td>
                        <td>@Math.Round(Cab.Tgrabado(Cab.Sum_Topgratuita(Model.ToList()), Cab.Sum_Tinafecto(Model.ToList())), 2)</td>
                        <td>@Math.Round(Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())), 2)</td>*@
                            </tr>
                        }
                    }

                }
            </tbody>
        </table>
    }


    <!-- ══ TOTALES ══ -->
    <table style="width:100%; margin-top:5px; margin-bottom:10px; border-collapse:collapse; page-break-inside:avoid;">
        <tr>
            <td style="vertical-align:top; padding-top:5px; font-weight:bold; color:#555;">
            </td>
            <td style="width:290px; vertical-align:top;">
                <table class="totals-table">
                    @if (ViewBag.Tipo == "NC" && ViewBag.SubTipo == "S")
                    {
                        <tr><td class="totals-label">OP. GRAVADAS</td>  <td class="totals-value">S/ @Math.Round(Cab.PreUnitSinIgv, 2).ToString("F2")</td></tr>
                        <tr><td class="totals-label">OP. INAFECTAS</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">OP. EXONERADAS</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">TOTAL OP. GRATUITAS</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">DSCTOS. TOTALES</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">IGV</td>  <td class="totals-value">S/ @Math.Round(Cab.Impuesto, 2).ToString("F2")</td></tr>
                        <tr><td class="totals-label-final">TOTAL</td> <td class="totals-value-final">S/ @Math.Round(Cab.Impuesto + Cab.PreUnitSinIgv, 2).ToString("F2")</td></tr>
                    }
                    else if (ViewBag.Tipo == "ND")
                    {
                        <tr><td class="totals-label">OP. GRAVADAS</td>   <td class="totals-value">S/ @Math.Round(Cab.PrecioLinea, 2).ToString("F2")</td></tr>
                        <tr><td class="totals-label">OP. INAFECTAS</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">OP. EXONERADAS</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">TOTAL OP. GRATUITAS</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">DSCTOS. TOTALES</td> <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">IGV</td>   <td class="totals-value">S/ @Math.Round(Cab.Impuesto, 2).ToString("F2")</td></tr>
                        <tr><td class="totals-label-final">TOTAL</td>  <td class="totals-value-final">S/ @Math.Round(Cab.DocTotal, 2).ToString("F2")</td></tr>
                    }
                    else
                    {
                        <tr><td class="totals-label">OP. GRAVADAS</td>        <td class="totals-value">S/ @Math.Round(Cab.Tgrabado(Cab.Sum_Topgratuita(Model.ToList()), Cab.Sum_Tinafecto(Model.ToList())), 2).ToString("F2")</td></tr>
                        <tr><td class="totals-label">OP. INAFECTAS</td>       <td class="totals-value">S/ @Cab.F_Tinafecto(Cab.Sum_Tinafecto(Model.ToList()))</td></tr>
                        <tr><td class="totals-label">OP. EXONERADAS</td>      <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">TOTAL OP. GRATUITAS</td>      <td class="totals-value">S/ @Cab.F_Topgratuita(Cab.Sum_Topgratuita(Model.ToList()))</td></tr>
                        <tr><td class="totals-label">DSCTOS. TOTALES</td>     <td class="totals-value">S/ 0.00</td></tr>
                        <tr><td class="totals-label">IGV</td>              <td class="totals-value">S/ @Math.Round(Cab.Impuesto, 2).ToString("F2")</td></tr>
                        <tr><td class="totals-label-final">TOTAL</td>        <td class="totals-value-final">S/ @Math.Round(Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())), 2).ToString("F2")</td></tr>
                    }
                </table>
            </td>
        </tr>
    </table>

    <!-- ══ SON ══ -->
    <div class="footer-son">
        SON: @Cab.TotalL()
    </div>



</body>
</html>
