@model IEnumerable<Capa_Entidad.Ventas_ENT.Tablas.NotaCreditoDebito_E>
@{
    Layout = null;
    var Cab = Model.ToList()[0];
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LayoutNotaCreditoDebito_header</title>
    <style>
        * {
            font-family: 'Verdana', sans-serif;
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            margin: 0;
            padding: 0 10px;
            color: #333;
            font-size: 11px;
        }

        .border-box {
            border: 1px solid #b0bfc6;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 0;
        }
    </style>
</head>
<body>

    <!-- Logo + Caja RUC -->
    <table style="width:100%; padding: 8px 0;">
        <tr>
            <td style="width:60%; vertical-align:top;">
                <img src="~/imagenes/Logo - Disfar Oriente.png" width="180" height="100"
                     style="float:left; margin-right:15px;" />
                <div style="font-size:12px; color:#0a3a60; font-weight:bold; margin-top:5px;">
                    DISFAR ORIENTE S.A.C.
                </div>
                <div style="font-size:9.5px; color:#555; line-height:1.4; margin-top:4px;">
                    JR. AMORARCA NRO. 154 INT. 2PIS BAR. ATUMPAMPA
                    <br />
                    SAN MARTIN - SAN MARTIN - TARAPOTO
                </div>
            </td>
            <td style="width:40%; vertical-align:top;">
                <div style="border:2px solid #0a3a60; border-radius:15px; padding:15px; text-align:center;">
                    <div style="font-size:12px; color:#333; margin-bottom:8px;">RUC: 20615244156</div>
                    <div style="font-size:13px; font-weight:bold; color:#0a3a60; margin-bottom:8px; line-height:1.2;">
                        @if (ViewBag.Tipo == "NC")
                        {<text>NOTA DE CRÉDITO ELECTRÓNICA</text> }
                    else if (ViewBag.Tipo == "ND")
                    { <text>NOTA DE DÉBITO ELECTRÓNICA</text>}
                    </div>
                    <div style="font-size:12px; color:#333;">N° @Cab.SerieDoc-@Cab.CorreDoc</div>
                </div>
            </td>
        </tr>
    </table>

    <!-- Datos Cliente -->
    <div class="border-box">
        <table style="table-layout:fixed; width:100%;">
            <tr>
                <td style="width:70px; font-weight:bold; padding:4px 0;">Cliente:</td>
                <td style="width:65%; padding:4px 0; word-wrap:break-word; white-space:normal;">@Cab.NombreSocio</td>
                <td style="width:55px; font-weight:bold; padding:4px 0;">Moneda:</td>
                <td style="padding:4px 0;">@Cab.MonedaLetras</td>
            </tr>
            <tr>
                <td style="font-weight:bold; padding:4px 0;">RUC:</td>
                <td style="padding:4px 0;">@Cab.Ruc</td>
                @*<td style="font-weight:bold; padding:4px 0;">IGV:</td>
                <td style="padding:4px 0;">18.00 %</td>*@
           
            </tr>
            <tr>
                <td style="width:70px; font-weight:bold; padding:4px 0;">Dirección:</td>
                <td style="width:65%; padding:4px 0; word-wrap:break-word; white-space:normal;">@Cab.DirPagar</td>
                <td style="width:55px; font-weight:bold; padding:4px 0;">Motivo:</td>
                <td style="padding:4px 0;">@Cab.Motivo</td>

            </tr>
        </table>
    </div>

    <div style="height:10px;"></div>

</body>
</html>
