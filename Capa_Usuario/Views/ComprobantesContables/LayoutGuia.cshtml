@model IEnumerable<Capa_Entidad.ComprobantesContables_ENT.Guia_Remision_E>

@{
    Layout = null;
    var Cab = Model.ToList()[0];
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LayoutGuia</title>
    <style>
        * {
            font-family: 'Verdana', sans-serif;
            font-size: 12px;
        }
        .page-break {
            page-break-before: always;
        }
        table {
            border-collapse: collapse;
            width: 100%;
        }

        td, th {
            padding: 5px;
        }

        .bordered-table {
            border-collapse: collapse;
            width: 100%;
            border-spacing: 0;
        }
    </style>
</head>
<body>
    <div>
        @if (ViewBag.Tipo == "T")
        {
            <div style="border:1px black solid">
                <table style="text-align:left" border="0">
                    <tr>
                        <td style="width:100px"><strong>Motivo de traslado : </strong></td>
                        <td>
                            @(Cab.Motivo_Trasl == "01" ? "Venta" : "Traslado entre establecimiento de la misma empresa")
                        </td>
                        <td style="width:150px"><strong>Direc. Punto partida : </strong></td>
                        <td>@Cab.DirSalida<br /></td>
                    </tr>
                    <tr>
                        <td style="width:100px"><strong>Modalidad de traslado :</strong></td>
                        <td>@(Cab.Modalidad_Trasl == "01" ? "Transporte Público" : "Transporte Privado")</td>
                        <td style="width:150px"><strong>Direc. Punto llegada : </strong></td>
                        <td>@Cab.DirLlegada</td>
                    </tr>
                </table>
            </div>
        }
        else if (ViewBag.Tipo == "E")
        {
            <div style="border:1px black solid">
                <table style="text-align:left" border="0">
                    <tr>
                        <td style="width:100px"><strong>Motivo de traslado :</strong> </td>
                        <td>
                            @(Cab.Motivo_Trasl == "01" ? "Venta" : "Traslado entre establecimiento de la misma empresa")
                        </td>
                        <td style="width:150px"><strong>Direc. Punto partida :</strong> </td>
                        <td>@Cab.DirSalida</td>
                    </tr>
                    <tr>
                        <td style="width:100px"><strong>Modalidad de traslado : </strong> </td>
                        <td>
                            @(Cab.Modalidad_Trasl == "01" ? "Transporte Público" : "Transporte Privado")
                        </td>
                        <td style="width:150px"><strong>Direc. Punto llegada :</strong> </td>
                        <td>@Cab.DirCliente</td>
                    </tr>
                </table>
            </div>
        }
    <div style="border:1px black solid;margin:20px 0 20px 0;">
        <table style="text-align:left" border="0">
            <tr><td colspan="3"><strong>DATOS DEL CONDUCTOR Y UNIDAD DE TRANSPORTE:</strong></td></tr>
            <tr>
                <td><strong>Conductor :</strong> </td>
                <td>@Cab.Conductor</td>
                <td><strong>Marca : </strong></td>
                <td>@Cab.Marca</td>
            </tr>
            <tr>
                <td><strong>DNI : </strong></td>
                <td>@Cab.DNI_Conduc</td>
                <td><strong>Placa : </strong></td>
                <td>@Cab.Placa</td>
            </tr>
            <tr>
                <td><strong>Licencia : </strong> </td>
                <td>@Cab.Licencia</td>
                <td><strong>RUC : </strong></td>
                @if (Cab.Modalidad_Trasl =="01")
                {
                    <td>@Cab.RucTransportista</td>
                }
            </tr>
            <tr>
                <td colspan="2"></td>
                <td><strong>Razón social :</strong></td>
                @if (Cab.Modalidad_Trasl == "01")
                {
                    <td>@Cab.NomTransportista</td>
                }
                <td></td>
            </tr>
        </table>
    </div>

        <table border="1" style="font-size:11px;">
            @*@{*@
            <tr>
                <th style="width: 60px;">CANT.</th>
                <th style="width: 400px;">DESCRIPCION</th>
                <th style="width: 50px;">LAB.</th>
                <th style="width: 50px;">LOTE</th>
                <th style="width: 70px;">FECHA<br /> VC.</th>
                <th style="width: 60px;">UNID.</th>
            </tr>
            @foreach (var item in Model)
            {
                <tr style="text-align:center; page-break-inside: avoid;">
                    <td style="width: 60px;">
                        @Math.Round(item.cantVta(), 0)
                        @item.UM()
                    </td>
                    <td style="width: 400px; text-align:left !important;">
                        @Html.DisplayFor(modelItem => item.DescripcionArticulo)
                    </td>
                    <td style="width: 50px;">
                        @Html.DisplayFor(modelItem => item.Laboratorio)
                    </td>
                    <td style="width: 50px;">
                        @Html.DisplayFor(modelItem => item.LoteNum)
                    </td>
                    <td style="width: 70px;">
                        @Html.DisplayFor(modelItem => item.VctoLote)
                    </td>
                    <td style="width: 60px;">
                        @Html.DisplayFor(modelItem => item.UniMedida)
                    </td>
                </tr>
            }

        </table>
        <table style="font-size:11px;margin-top:20px;" border="0">
            <tr>
                <td>
                    @if (ViewBag.Tipo == "T")
                    {<span>Peso: @(ViewBag.PesoTicket == "0" || string.IsNullOrWhiteSpace(ViewBag.PesoTicket) ? "No se registró peso" : ViewBag.PesoTicket +"Kg.")</span><br />
                        <span>Nro. de Cajas: @ViewBag.NroCajas</span>}
                    else if (ViewBag.Tipo == "E")
                    {
                        <strong>Encargado de recojo :</strong><br />
                        <span>Nombre: @ViewBag.PersonaRecojo.Item1</span><br />
                        <span>Documento: @ViewBag.PersonaRecojo.Item2</span><br />
                        <span>Telefono: @ViewBag.PersonaRecojo.Item3</span><br /><br />
                        if (ViewBag.PesoTicket != "0" && !string.IsNullOrWhiteSpace(ViewBag.PesoTicket))
                        {
                            <span>Peso: @(ViewBag.PesoTicket + "Kg.")</span><br />
                        }
                        <span>Nro. de Cajas: @ViewBag.NroCajas</span>
                    }
                </td>
            </tr>

            <tr>
                <td>
                    <p>
                        Consulte Guia de Remisión Electronica: https://www.cobefar.com.pe/
                        http://181.224.227.28/fe/
                    </p>
                </td>
            </tr>
        </table>
    </div>
</body>
</html>



