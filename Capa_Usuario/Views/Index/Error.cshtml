
@{
    ViewBag.Title = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li class="current"><em>Error de permisos</em></li>
        </ol>
    </nav>
</div>

<!-- Error 404 Template 1 - Bootstrap Brain Component -->
<section class="py-3 py-md-5 min-vh-100 d-flex justify-content-center align-items-center">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="text-center">
                    <h2 class="d-flex justify-content-center align-items-center gap-2 mb-4">
                        <span class="display-1 fw-bold bsb-flip-h text-danger">Lo sentimos :(</span>
                    </h2>
                    <h3 class="h2 mb-2">No tiene permiso para acceder a esta página</h3>
                    <p class="mb-5">Por favor, contáctese con el Área de Sistemas.</p>
                    <a class="btn bsb-btn-5xl btn-dark rounded-pill px-5 fs-6 m-0" href="@Url.Action("Sesion", "Index")" role="button">Ir a Inicio</a>
                </div>
            </div>
        </div>
    </div>
</section>