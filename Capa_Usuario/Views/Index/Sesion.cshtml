@{
    ViewBag.Title = "Sesion";
    Layout = "~/Views/Shared/_Layout_inicial.cshtml";
}

<style>
    .dropdown-submenu {
        position: relative;
    }

        .dropdown-submenu > .dropdown-menu {
            top: 0;
            left: 100%;
            margin-top: -1px;
            display: none;
            position: absolute;
        }

        .dropdown-submenu:hover > .dropdown-menu {
            display: block;
        }

    #mobileMenu button.mobile-toggle {
        background: none;
        border: none;
        padding: 0.5rem 0;
        font-weight: 500;
    }

    #mobileMenu ul li a {
        padding: 0.25rem 0.5rem;
        display: block;
    }

    .navbar .dropdown-menu {
        display: none;
    }

        .navbar .dropdown-menu.show {
            display: block;
        }

</style>

<div class="container-body justify-content-center">
    <div class="container-fluid" style="box-shadow: rgba(0, 0, 0, 0.19) 0px 10px 20px, rgba(0, 0, 0, 0.23) 0px 6px 6px;">
        <div class="d-none d-md-block row bg-cobefar-degradado-1">
            <div class="col-12">
                <div class="row py-2">
                    <div class="col-6 d-flex justify-content-start">
                        <img src="~/Content/img/logo-cobefar.png" height="50">
                    </div>

                    <div class="col-6 d-flex align-content-center  justify-content-end">
                        <div class="font-14 text-white mx-3 mt-3">Bienvenido(a): <span class="font-weight-bold font-14">@ViewBag.NombreUsuario</span></div>
                        <a class="text-white font-weight-bold mt-2" href="@Url.Action("LogOut", "Index")" title="Cerrar Sesión">
                            <i class="bi bi-box-arrow-right font-24"></i>
                        </a>

                        @*<button class="navbar-toggler d-none d-lg-block" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon text-white d-block d-sm-block d-md-block d-lg-none d-xl-none"><i class="bi bi-list"></i></span>
            </button>*@
                    </div>
                </div>
            </div>
        </div>

        <!-- MÓVIL -->
        <div class="d-block d-lg-none d-md-none row bg-cobefar">
            <div class="col-12">
                <div class="row pb-3">
                    <div class="col-12 text-center">
                        <div class="p-3">
                            <img src="~/Content/img/logo-cobefar.png" height="50">
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 font-14 text-white">Bienvenido(a):</div>
                    <div class="col-12 font-weight-bold font-14 text-white">@ViewBag.NombreUsuario</div>
                </div>

                <hr class="text-white" />

                <div class="row pb-3">
                    <div class="col-12 d-flex justify-content-end">
                        <a class="btn btn-sm btn-light" href="@Url.Action("LogOut", "Index")" title="Cerrar Sesión"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row bg-white">
            <!-- MENÚ DESKTOP -->
            <nav class="d-none d-lg-block navbar navbar-expand-lg">
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav mr-auto">
                        @foreach (var item in Model)
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button"
                               data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="@item.Icono"></i> @item.Nombre
                            </a>
                            <div class="dropdown-menu">
                                @foreach (var sm in item.SubMenus)
                                    {
                                @Html.Partial("_MenuSistemaItem", (Capa_Entidad.General_ENT.TablasSql.MenuSistema_E)sm);
                                    }
                            </div>
                        </li>
                        }
                    </ul>
                </div>
            </nav>

            <!-- MENÚ MÓVIL -->
            <nav class="d-lg-none p-3 bg-light border-bottom w-100" id="mobileMenu">
                <ul class="list-unstyled">
                    @foreach (var item in Model)
                    {
                    <li class="mb-2">
                        <button class="btn w-100 text-start d-flex justify-content-between align-items-center mobile-toggle" data-bs-target="#submenu-@item.Id">
                            <span><i class="@item.Icono me-2"></i> @item.Nombre</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>

                        @if (item.SubMenus != null && item.SubMenus.Count > 0)
                            {
                        <ul class="list-unstyled ps-2 collapse" id="submenu-@item.Id">
                            @foreach (var sm in item.SubMenus)
                                    {
                                        var uniqueId = "submenu-" + Guid.NewGuid().ToString("N");
                            @Html.Partial("_MenuSistemaItemMobile", (Capa_Entidad.General_ENT.TablasSql.MenuSistema_E)sm, new ViewDataDictionary(ViewData)
                            {
                                { "Level", 1 },
                                { "UniqueId", uniqueId }
                            });
                                    }

                        </ul>
                            }
                    </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // --- Menú móvil ---
        document.querySelectorAll('.mobile-toggle').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                const targetId = this.getAttribute('data-bs-target');
                const submenu = document.querySelector(targetId);
                if (submenu) submenu.classList.toggle('show');
            });
        });

        // --- Menú tablet/escritorio táctil ---
        const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

        if (isTouchDevice) {
            document.querySelectorAll('.navbar .dropdown-toggle').forEach(dropdownToggle => {
                dropdownToggle.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const dropdownMenu = this.nextElementSibling;

                    // Cierra todos los otros menús abiertos, excepto el actual
                    document.querySelectorAll('.navbar .dropdown-menu.show').forEach(openMenu => {
                        if (openMenu !== dropdownMenu) {
                            openMenu.classList.remove('show');
                        }
                    });

                    dropdownMenu.classList.toggle('show');
                });
            });

            // Cierra dropdown solo si se hace clic fuera de toggle o dropdown-menu
            document.addEventListener('click', function (e) {
                const isClickInsideMenu = e.target.closest('.navbar .dropdown-menu') || e.target.closest('.navbar .dropdown-toggle');
                if (!isClickInsideMenu) {
                    document.querySelectorAll('.navbar .dropdown-menu.show').forEach(menu => {
                        menu.classList.remove('show');
                    });
                }
            });
        }
    });

</script>
