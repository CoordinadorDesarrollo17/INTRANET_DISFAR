                                    <tr id="reg@(det.Linea)" style="@style">
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Linea' type='hidden' class="form-control border-success" value='@det.Linea' style='width:40px;' readonly />@det.Linea</td>
                                        <td hidden><input name='DetRRU0[@(det.Linea - 1)].DocEntryTicket' type='text' class="form-control border-success" value='@det.DocEntryTicket' style='width:80px;' readonly /></td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].DocNumTicket' id="DocNumTDet@(det.Linea)" type='hidden' class="form-control border-success" value='@det.DocNumTicket' readonly />@det.DocNumTicket</td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Socio' type='hidden' class="form-control border-success" value='@det.Socio' style='width:100px;' readonly />@det.Socio</td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Guias' type='hidden' class="form-control border-success" value='@det.Guias' style='width:100px;' readonly />@det.Guias</td>
                                        <td class="text-center"><input name='DetRRU0[@(det.Linea - 1)].Cajas' type='hidden' class="form-control border-success" value='@det.Cajas' readonly />@det.Cajas</td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Observaciones' type='hidden' class="form-control border-success" value='@det.Observaciones' style='width:100px;' readonly />@det.Observaciones</td>
                                        <td><textarea name='DetRRU0[@(det.Linea - 1)].Direcciones' class="form-control border-success" readonly>@det.Direcciones</textarea></td>
                                        <td class="text-center"><input name='DetRRU0[@(det.Linea - 1)].MontoFinal' type='hidden' class="form-control border-success" value='@det.MontoFinal' style='width:90px;' readonly />@det.MontoFinal</td>
                                        <td class="text-center"><input name='DetRRU0[@(det.Linea - 1)].Envio' type='hidden' class="form-control border-success" value='@det.Envio' style='width:50px;' readonly />@det.Envio</td>
                                        <td><a href='SeguimientoDeTicket?DocEntry=@det.DocEntryTicket' target='_blank' class="btn btn-sm btn-primary" style='cursor:pointer' onclick="window.open(this.href,this.target,'width=500,height=350,top=120,left=100,toolbar=no,location=no,status=no,menubar=no');"><i class="icon-truck"></i></a></td>
                                        <td class="d-flex justify-content-center" colspan="3"><button type='button' class='btn btn-sm btn-blue' onclick='liberarTrTable1(@det.DocEntry,@det.Linea,@det.DocEntryTicket,"reg@(det.Linea)")'><i class="icon icon-unlocked">  </i>Liberar</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            }

            if (Model.DetRRU1 != null && Model.DetRRU1.Count > 0)
            {
                <table class="table table-light table-sm table-hover table-responsive table-bordered" cellspacing="0" width="100%" id="Detalles1">
                    <tr class="bg-cobefar">
                        <th class="text-center">#</th>
                        <th class="text-center">Guia</th>
                        <th class="text-center">NroSap</th>
                        <th class="text-center">Cajas</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Verif.</th>
                    </tr>
                    @{string style1 = "";}
                    @foreach (var det in Model.DetRRU1)
                    {
                        if (det.Estado == "LIBERADO") { style1 = "background:lightgray;"; } else { style1 = ""; }
                        <tr id="reg@(det.Linea)" class="cls-colorFilaGuia" style="@style1" onclick="listarDetalleGuia(@det.DocEntry, @det.Linea, this.id, @btnEditarDetalle)">
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Linea' type='hidden' value='@det.Linea' readonly />@det.Linea</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Guia' type='hidden' value='@det.Guia' readonly />@det.Guia</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].NroSap' type='hidden' value='@det.NroSap' readonly />@det.NroSap</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Cajas' type='hidden' value='@det.Cajas' readonly />@det.Cajas</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Estado' type='hidden' value='@det.Estado' readonly />@det.Estado</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Verificado' type='checkbox' style='width:50px;' readonly /></td>
