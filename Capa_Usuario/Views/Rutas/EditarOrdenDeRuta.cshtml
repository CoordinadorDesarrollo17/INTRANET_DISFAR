                <div class="col-lg-2 p-2">
                    <div class="mt-lg-4"><button type="button" class="btn btn-success" onclick="validarEnviarFormulario('@Model.Estado');"><i class="icon icon-pencil"></i> Editar Encabezado</button></div>
                </div>
            </div>


            if (Model.DetRRU0 != null && Model.DetRRU0.Count > 0)
            {
                <div class="container">
                    <div class="row">
                        <div class="col-md-3">
                            <input type="checkbox" id="chk_verifTodos" onclick="seleccionarVerif()" /> <label for="chk_verifTodos" class="text-dark font-weight-bold">Seleccionar Todos</label>
