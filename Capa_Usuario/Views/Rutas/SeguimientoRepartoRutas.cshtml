<script>
    function abrirModalImp(docEntryRuta, docEntryTicket) {
        var modalId = "ModalImpresion" + docEntryTicket;
        if ($("#" + modalId).length) {
            // Si el modal ya existe, solo lo mostramos
            $("#" + modalId).modal('show');
        } else {
            crearModal(docEntryRuta, docEntryTicket, function (htmlTableDocumentos) {
                var docNum = docEntryTicket + 2000000000;
                var modalHtml = "<div class='modal' id='" + modalId + "' tabindex='-1' role='dialog' aria-labelledby='" + modalId + "Label' aria-hidden='true'>" +
                    "<div class='modal-dialog modal-dialog-centered modal-lg' role='document'>" +
                    "<div class='modal-content'>" +
                    "<div class='modal-header bg-cobefar text-white'>" +
                    "<h5 class='modal-title' id='" + modalId + "Label'>COMPROBANTES ELECTRÓNICOS IMPRIMIBLES <br>NroTicket : " + docNum + "</h5>" +
                    "<button type='button' class='close' data-dismiss='modal' aria-label='Close'>" +
                    "<span aria-hidden='true'>&times;</span>" +
                    "</button>" +
                    "</div>" +
                    "<div class='modal-body'>" +
                    htmlTableDocumentos +
                    "</div>" +
                    "<div class='modal-footer'>" +
                    "<button type='button' class='btn btn-secondary' data-dismiss='modal'>Cerrar</button>" +
                    "<button type='button' class='btn btn-blue' id='btnImp" + docEntryTicket + "' onclick='ImprimirMasivamenteDocumentos(" + docEntryTicket + ",\"" + modalId + "\")'>" +
                    "<i class=''icon icon-printer'> </i> Imprimir todo" +
                    "</button>" +
                    "</div>" +
                    "</div>" +
                    "</div>" +
                    "</div>";
                $("body").append(modalHtml);
                $("#" + modalId).modal('show');
            });
        }
    } 
    function crearModal(docEntryRuta, docEntryTicket,callback){
        //buscar documentos comprobantes desde RRU01
        if (docEntryRuta >0 && docEntryTicket >0) {
            var parametros = { "DocEntryTicket": docEntryTicket };
            $.ajax({
                url: '/Rutas/buscarDocumentosRuta',
                data: parametros,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
                .done(function (response) {
                    // Llama al callback y pasa el resultado de la solicitud AJAX como argumento
                    callback(response);
                });
        }
    }
