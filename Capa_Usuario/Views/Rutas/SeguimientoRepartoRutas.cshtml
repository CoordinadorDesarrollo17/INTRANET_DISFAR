    function ImprimirUnitarioDocumento(NumAtCard, DocNumTicket, Masivo) {
        return new Promise(function (resolve, reject) {
           /* if (Masivo == false) {
                var loadingSwal = Swal.fire({
                    title: 'Imprimiendo...',
                    text: 'Por favor, espera mientras se imprime el documento.',
                    imageUrl: '/imagenes/index/ReportesDigemid/impresion.gif',
                    imageWidth: 500,
                    imageHeight: 400,
                    allowEscapeKey: false,
                    allowOutsideClick: false,
                    showConfirmButton: false
                });
            }*/
            var MensajeImpresion = "";
            var parametros = {
                "NumAtCard": NumAtCard,
                "DocNumTicket": DocNumTicket,
                "Impresora": $("#Impresora").val()
            };
            $.ajax({
                url: '/Rutas/PdfComprobanteSap',
                data: parametros,
                dataType: 'json',
                cache: false,
                type: 'post'
            }).done(function (response) {
                MensajeImpresion = response.Mensaje;
                if (Masivo) {
                    if (MensajeImpresion != "" && MensajeImpresion != "undefined") {
                        resolve(MensajeImpresion);
                    } else {
                        resolve(null);
                    }
                } else {
                    if (MensajeImpresion != "" && MensajeImpresion != "undefined") {
                       // loadingSwal.close();
                        Swal.fire({
                            icon: 'warning',
                            title: 'Aviso de impresión',
                            text: 'Se termino la impresión. ' + MensajeImpresion,
                            showConfirmButton: true
                        }).then(function () {
                            resolve('success');
                        });

                    }
                    /**else {
                        loadingSwal.close();
                        Swal.fire({
                            icon: 'success',
                            title: 'Aviso de impresión',
                            text: 'Se imprimió el documento. ',
                            showConfirmButton: true
                        }).then(function () {
                            resolve('success');
                        });

                    }*/
                }
            }).fail(function (jqXHR, textStatus, errorThrown) {
                reject(textStatus || errorThrown);
            });
        });
    }
    async function ImprimirMasivamenteDocumentos(docEntryTicket, idModal) {
        if (docEntryTicket > 0) {
            var parametros = { "DocEntryTicket": docEntryTicket };
            var MensajeImpresionMasivo = null;
            /*
            Swal.fire({
                title: 'Imprimiendo...',
                text: 'Por favor, espera mientras se imprimen los documentos.',
                imageUrl: '/imagenes/index/ReportesDigemid/impresion.gif',
                imageWidth: 500,
                imageHeight: 400,
                allowEscapeKey: false,
                allowOutsideClick: false,
                showConfirmButton: false
            });
            */
            $('#btnImp' + docEntryTicket).prop('disabled', true);

            try {
                var response = await $.ajax({
                    url: '/Rutas/buscarComprobantesTicket',
                    data: parametros,
                    dataType: 'json',
                    cache: false,
                    type: 'post'
                });

                var DocNumTicket = docEntryTicket + 2000000000;

                for (const correlativo of response) {
                    try {
                        await ImprimirUnitarioDocumento(correlativo, DocNumTicket, true);
                    } catch (error) {
                        console.error("Error ImprimirUnitarioDocumento:", error);
                        $('#btnImp' + docEntryTicket).prop('disabled', false);
                    }
                }

                $('#' + idModal).modal('hide');
                $('#btnImp' + docEntryTicket).prop('disabled', false);

            } catch (error) {
                console.error("Error ImprimirMasivamenteDocumentos:", error);
                $('#btnImp' + docEntryTicket).prop('disabled', false);
                MensajeImpresionMasivo = "Error en la impresión masiva: " + error;
            } finally {
              //  Swal.close(); // Cierra alerta con imagen de impresión
                if (MensajeImpresionMasivo != null && MensajeImpresionMasivo != "") {
                    Swal.fire({
                        icon: 'warning',
                        text: 'Los documentos se han impreso exitosamente. ' + MensajeImpresionMasivo,
                        showConfirmButton: false,
                        timer: 3000,
                    });
                } /*else {
                    Swal.fire({
                        icon: 'success',
                        text: 'Los documentos se han impreso exitosamente. ',
                        showConfirmButton: false,
                        timer: 2000,
                    });
                }*/
            }
        }
    }

    </script>
