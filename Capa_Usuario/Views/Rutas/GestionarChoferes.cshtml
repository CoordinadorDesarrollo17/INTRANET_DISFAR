@model IEnumerable<Capa_Entidad.General_ENT.TablasSql.OCHO_E>
@using Capa_Entidad.General_ENT.TablasSql

@{
    ViewBag.Title = "GestionarChoferes";
    Layout = "~/Views/Shared/_Layout.cshtml";
    OCHO_E e = new OCHO_E();
}
<script>
    $(document).ready(function () {
    });
    function registrarChofer() {
        var object = $("#frm1").serialize();
        $.ajax('/Rutas/validarNuevoChofer',
            {
                data: object,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response != "true") {
                    Swal.fire({
                        icon: '',
                        text: response
                    });
                    return false
                }
                else { $(location).attr('href', "/Rutas/RegistrarChofer?" + object); }
            });
    }
    function eliminarChofer(Code,TipoRep) {
         Swal.fire({
            title: 'Esta seguro/a de eliminar chofer?',
            text: "Este proceso es irreversible!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Si'
        }).then((result) => {
            if (result.isConfirmed) {
                $(location).attr('href', "/Rutas/EliminarChofer?DocEntry=" + Code + "&TipoRep=" +TipoRep);
            }
        })
    }
    
    function filtrar() {
        var object = $("#frm2").serialize();
        $(location).attr('href', "/Rutas/GestionarChoferes?" + object);
    }
    function valorCampoList(idLista, idLabel, idCampo, atrib) {
        $("#" + idCampo).val(
            $("#" + idLista + " option[value='" + $("#" + idLabel).val() + "']").attr(atrib)
        );
    }
</script>


<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="/Index/Sesion">Inicio</a></li>

            @if (ViewBag.TipoRep == "Re")
            {
                <li><a href="@Url.Action("ListadoRepartos", "Rutas")">Listado de Repartos</a></li>
            }
            else
            {
                <li><a href="@Url.Action("ListadoRutas", "Rutas")">Listado de Rutas</a></li>
            }

            <li class="current"><em>Entrega Repartos</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">GESTIONAR CHOFERES</h3></div>
</div>

<div class="bg-form-pestanas-cobefar pt-4 bg-section-form p-4 bg-form-cobefar">

    <form name="frm1" id="frm1">
        <div class="row mt-2">
            <div class="col-lg-4">
                <label class="text-dark form-label font-weight-bold font-18">Nombres:</label>
                <input class="form-control-sm border border-success" type="search" list="Lista" name="U_SYP_CHNO" id="U_SYP_CHNO" autocomplete="off" onChange="valorCampoList('Lista','U_SYP_CHNO','Code','id');">
                <datalist id="Lista">
                    @foreach (var c in ViewBag.ListaOpRepartos)
                    {
                        <option value="@c.Nombres @c.Apellidos" id="@c.Prefijo@c.Id" U_SYP_CHNO="@c.Nombres @c.Apellidos"></option>
                    }
                </datalist>
            </div>

            <div class="col-lg-3">
                <input name="TipoRep" value="@ViewBag.TipoRep" type="hidden" readonly />
                <label class="text-dark form-label font-weight-bold font-18">Usuario:</label>
                <input type="text" class="form-control-sm border border-success" id="Code" name="Code" readonly>
            </div>

            <div class="col-lg-2">
                <label class="text-dark form-label font-weight-bold font-18">DNI:</label>
                <input type="text" class="form-control-sm border border-success" name="Name">
            </div>

            <div class="col-lg-3">
                <label class="text-dark form-label font-weight-bold font-18">Licencia:</label>
                <input type="text" class="form-control-sm border border-success" name="U_SYP_CHLI">
            </div>


        </div>

        <div class="row mt-4">
            <div class="col-lg-4"><button type="button" class="btn btn-success" onclick="registrarChofer();"><i class="icon icon-plus"></i> Agregar</button></div>
        </div>
    </form>

    <div class="mt-4 bg-light bg-form-cobefar">
        <form name="frm2" id="frm2">
            <table class="table table-light table-sm table-hover cls-dataTable" cellspacing="0" width="100%">
                <thead class="bg-cobefar-6">
                    <tr>
                        <th class="text-center">
                            <input name="TipoRep" value="@ViewBag.TipoRep" type="hidden" readonly />
                            @Html.DisplayName("Usuario")<br />
                            @if (ViewBag.Ocho != null && ViewBag.Ocho.Code != null)
                            {
                                <input class="form-control-sm border" type="text" name="Code" onchange="filtrar();" value="@ViewBag.Ocho.Code" />
                            }
                            else
                            { <input class="form-control-sm border" type="text" name="Code" onchange="filtrar();" />}

                        </th>
                        <th class="text-center">
                            @Html.DisplayName("DNI")<br />
                            @if (ViewBag.Ocho != null && ViewBag.Ocho.Name != null)
                            {
                                <input class="form-control-sm border" type="text" name="Name" onchange="filtrar();" value="@ViewBag.Ocho.Name" />
                            }
                            else
                            { <input class="form-control-sm border" type="text" name="Name" onchange="filtrar();" />}

                        </th>
                        <th class="text-center">
                            @Html.DisplayName("Licencia")<br />
                            @if (ViewBag.Ocho != null && ViewBag.Ocho.U_SYP_CHLI != null)
                            {
                                <input class="form-control-sm border" type="text" name="U_SYP_CHLI" onchange="filtrar();" value="@ViewBag.Ocho.U_SYP_CHLI" />
                            }
                            else
                            { <input class="form-control-sm border" type="text" name="U_SYP_CHLI" onchange="filtrar();" />}

                        </th>
                        <th>
                            @Html.DisplayName("Nombres")<br />
                            @if (ViewBag.Ocho != null && ViewBag.Ocho.U_SYP_CHNO != null)
                            {
                                <input class="form-control-sm border w-100" type="text" name="U_SYP_CHNO" onchange="filtrar();" value="@ViewBag.Ocho.U_SYP_CHNO" />
                            }
                            else
                            { <input class="form-control-sm border w-100" type="text" name="U_SYP_CHNO" onchange="filtrar();" />}

                        </th>
                        <th></th>
                    </tr>

                </thead>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">
                            @Html.DisplayFor(modelItem => item.Code)
                        </td>
                        <td class="text-center">
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td class="text-center">
                            @Html.DisplayFor(modelItem => item.U_SYP_CHLI)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.U_SYP_CHNO)
                        </td>
                        <td class="text-center">
                            <a href="#" onclick="eliminarChofer('@item.Code','@ViewBag.TipoRep')" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Eliminar Chofer"><i class="icon icon-bin2 text-danger"></i> </a>
                        </td>
                    </tr>
                }

            </table>
        </form>
    </div>
    

</div>

<script>
    if ('@ViewBag.Mensaje' != "") {
        Swal.fire({
            icon: '',
            text: `@ViewBag.Mensaje`
        })
    }
</script>
