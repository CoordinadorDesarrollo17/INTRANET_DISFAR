@model Capa_Entidad.Rutas_ENT.TablasSql.ORRU_E
@using Capa_Entidad.General_ENT.TablasSql
@{
    ViewBag.Title = "Editar Solicitud de Devolución";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // --- RECUPERAR NOMBRE SOCIO ---
    string nombreSocio = Model.CardName;

    // Si la cabecera no tiene nombre, lo sacamos del primer detalle
    if (string.IsNullOrEmpty(nombreSocio) && Model.DetRRU0 != null && Model.DetRRU0.Count > 0)
    {
        nombreSocio = Model.DetRRU0[0].Socio;
    }

    string codigoSocio = Model.CardCode;

    List<OWHS_E> lstOriDest = (List<OWHS_E>)ViewBag.ListaOrigenesDestinos;
    List<Capa_Entidad.Repartos_ENT.TablasHana.SYP_VEHICU_E> Vehiculos = (List<Capa_Entidad.Repartos_ENT.TablasHana.SYP_VEHICU_E>)ViewBag.ListaVehiculos;
    List<string> Conductores = new List<string>(ViewBag.Conductores);
    List<string> Copilotos = new List<string>(ViewBag.ListaCopilotos);

    string urlAction = Url.Action("HojaRuta", "AtencionCliente");
}

<style>
    /* ESTILOS IGUALES A LA VISTA DE CREACIÓN */
    .form-label-custom {
        font-weight: bold;
        color: #333;
        font-size: 13px;
        margin-bottom: 2px;
    }

    .form-control-custom {
        border: 1px solid #28a745;
        border-radius: 4px;
        height: calc(1.5em + 0.5rem + 2px);
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
        background-color: #f8f9fa; /* Readonly visual */
    }

    .bg-green-custom {
        background-color: #1b5e20;
        color: white;
    }

    /* Tablas */
    .table-auto th, .table-auto td {
        white-space: nowrap;
        vertical-align: middle !important;
        padding: 5px !important;
        font-size: 12px;
    }

    .table-fixed {
        table-layout: fixed;
        width: 100%;
    }

        .table-fixed th, .table-fixed td {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            vertical-align: middle !important;
            padding: 5px !important;
            font-size: 12px;
        }

    /* Inputs transparentes */
    .input-readonly-table {
        background-color: transparent !important;
        border: none;
        width: 100%;
        text-align: center;
        font-size: 12px;
        font-weight: bold;
    }

    .textarea-readonly-table {
        background-color: transparent;
        border: none;
        resize: none;
        width: 100%;
        font-size: 11px;
        overflow: hidden;
        white-space: normal;
        line-height: 1.1;
        height: 25px;
    }

    .cls-chkVerif {
        width: 18px;
        height: 18px;
        vertical-align: middle;
        cursor: pointer;
    }

    /* Spinner pequeño para carga de código */
    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
        border-width: 0.15em;
    }
</style>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@urlAction">Listado de rutas</a></li>
            <li class="current"><em>Editar Devolución</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="d-flex justify-content-between px-3 pt-3">
        <h3 class="titulo-seccion">EDITAR SOLICITUD DE DEVOLUCIÓN (N° @Model.DocNum)</h3>
    </div>
</div>

<div class="bg-form-pestanas-cobefar">
    <div class="bg-section-form p-4 bg-form-cobefar">

        @using (Html.BeginForm("EditarHojaDeReparto", "Rutas", FormMethod.Post, new { id = "form" }))
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input name="DocEntry" id="doc_entry" type="hidden" value="@Model.DocEntry" readonly />
            <input name="DocNum" type="hidden" value="@Model.DocNum" readonly />
            <input name="TipoRep" type="hidden" value="DE" readonly />
            <input name="TipoRuta" type="hidden" value="DE" readonly />
            <div class="row mb-2">
                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Tipo de ruta:</label>
                    <select class="form-control form-control-custom bg-green-custom border-0" disabled>
                        <option>Devolución</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Estado:</label>
                    @Html.EditorFor(model => model.Estado, new { htmlAttributes = new { @class = "form-control form-control-custom font-weight-bold text-center text-primary", @readonly = "true" } })
                </div>

                <div class="col-lg-6 col-md-6">
                    <label class="form-label-custom">Cliente (Asignado):</label>
                    <input type="text" id="CardName" name="CardName"
                           class="form-control form-control-custom font-weight-bold text-dark"
                           value="@nombreSocio" readonly />
                </div>

                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Código:</label>
                    <div class="input-group">
                        <input type="text" id="CardCode" name="CardCode"
                               class="form-control form-control-custom text-center bg-light"
                               value="@codigoSocio" readonly />
                        <div class="input-group-append d-none" id="loadingCode">
                            <span class="input-group-text bg-white border-0"><i class="spinner-border spinner-border-sm text-success"></i></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Fecha:</label>
                    <input type="date" name="FechaCont" id="FechaSapTicket" class="form-control form-control-custom"
                           value="@(Model.FechaCont.HasValue ? Model.FechaCont.Value.ToString("yyyy-MM-dd") : "")" />
                </div>
                <div class="col-lg-4 col-md-4">
                    <label class="form-label-custom">Almacén Destino:</label>
                    <input type="hidden" id="AlmDestinoCod" name="AlmDestinoCod" value="@Model.AlmDestinoCod" />
                    <input type="hidden" id="AlmDestinoDesc2" name="AlmDestinoDesc2" value="@Model.AlmDestinoDesc2" />
                    <select name="AlmDestinoDesc" id="AlmDestinoDesc" class="form-control form-control-custom bg-green-custom border-0">
                        <option value="DOMICILIOS" almdestinocod="08" almdestinodesc2="" @if (Model.AlmDestinoDesc == "DOMICILIOS") { Write("selected"); }>DOMICILIOS</option>
                        @foreach (var l in lstOriDest.Where(x => x.WhsCode == "09" || x.WhsCode == "01"))
                        {
                            <option value="@l.WhsName" almdestinocod="@l.WhsCode" almdestinodesc2="@(l.Street+" "+l.StreetNo+" "+l.Building+" "+l.Block+" "+l.City+" "+l.County)" @if (Model.AlmDestinoDesc == l.WhsName) { Write("selected"); }>@l.WhsName</option>
                        }
                        @foreach (var l in lstOriDest.Where(x => x.WhsCode == "16" || x.WhsCode == "ALM07" || x.WhsCode == "03"))
                        {
                            <option value="@l.WhsName" almdestinocod="@l.WhsCode" almdestinodesc2="@(l.Street+" "+l.StreetNo+" "+l.Building+" "+l.Block+" "+l.City+" "+l.County)" @if (Model.AlmDestinoDesc == l.WhsName) { Write("selected"); }>@l.WhsName</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-2">
                    <label class="form-label-custom">Placa:</label>
                    <select name="Placa" id="Placa" class="form-control form-control-custom bg-green-custom border-0">
                        <option value="">Seleccione</option>
                        @foreach (var t in Vehiculos)
                        {
                            <option value="@t.U_SYP_VEPL" data-code="@t.Code" data-marca="@t.U_SYP_VEMA" data-modelo="@t.U_SYP_VEMO" @if (Model.Placa == t.U_SYP_VEPL) { Write("selected"); }>@t.U_SYP_VEPL</option>
                        }
                    </select>
                    <input type="hidden" id="VehiculoCod" name="VehiculoCod" value="@Model.VehiculoCod" />
                    <input type="hidden" id="Marca" name="Marca" value="@Model.Marca" />
                    <input type="hidden" id="Modelo" name="Modelo" value="@Model.Modelo" />
                </div>
                <div class="col-lg-4 col-md-3">
                    <label class="form-label-custom">Conductor:</label>
                    <select name="TransDesc" id="TransDesc" class="form-control form-control-custom bg-green-custom border-0">
                        <option value="">Seleccione</option>
                        @foreach (var x in Conductores)
                        {
                            <option value="@x" @if (Model.TransDesc == x) { Write("selected"); }>@x</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Tiempo Pactado:</label>
                    <input type="datetime-local" class="form-control form-control-custom text-center" name="TiempoPac" id="TiempoPac"
                           value="@(Model.TiempoPac.HasValue ? Convert.ToDateTime(Model.TiempoPac).ToString("yyyy-MM-ddTHH:mm:ss") : "")" />
                </div>

                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Copiloto 1:</label>
                    @Html.EditorFor(model => model.CopilDesc, new { htmlAttributes = new { @class = "form-control form-control-custom", @list = "ListaCopilotos" } })
                    <datalist id="ListaCopilotos">
                        @foreach (var x in Copilotos)
                        {
                            <option value="@x.ToUpper()"></option>
                        }
                    </datalist>
                </div>

                <div class="col-lg-2 col-md-3">
                    <label class="form-label-custom">Copiloto 2:</label>
                    @Html.EditorFor(model => model.Copil2Desc, new { htmlAttributes = new { @class = "form-control form-control-custom", @list = "ListaCopilotos" } })
                </div>

                <div class="col-lg-1 col-md-2">
                    <label class="form-label-custom"># Bultos:</label>
                    <input id="TotalBultos" type="text" class="form-control form-control-custom text-center bg-light" readonly value="@Model.TotCajas()" />
                    <input id="TotalCajas" type="hidden" />
                </div>

                <div class="col-lg-5 col-md-4">
                    <label class="form-label-custom">Observaciones:</label>
                    @Html.EditorFor(model => model.Observaciones, new { htmlAttributes = new { @class = "form-control form-control-custom", @autocomplete = "off" } })
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <input type="checkbox" id="chk_verifTodos" class="cls-chkVerif mr-1" />
                    <label for="chk_verifTodos" class="text-primary cursor-pointer mb-0 font-weight-bold">Seleccionar Todos</label>
                </div>
                <div>
                    <button type="button" class="btn btn-warning btn-sm px-4" onclick="cargarOrdenesDevolucion()">
                        <i class="icon icon-search"></i> Buscar Pendientes
                    </button>
                    <button type="button" class="btn btn-info btn-sm px-4 ml-2" id="btn-Agregar">
                        <i class="icon icon-plus"></i> Agregar
                    </button>
                    <button type="button" class="btn btn-cobefar-2 btn-sm px-4 ml-2" onclick="validarEnviarFormulario()">
                        <i class="icon icon-checkmark2"></i> Guardar Cambios
                    </button>
                </div>
            </div>

            <div class="table-responsive-custom mb-4">
                <table id="detalleRuta" class="table table-bordered table-sm table-hover table-auto">
                    <thead class="bg-green-custom text-white">
                        <tr>
                            <th class="text-center" style="width:30px">?</th>
                            <th class="text-center" style="width:30px">#</th>
                            <th class="text-center">DocNumSap</th>
                            <th>Socio</th>
                            <th>Guías</th>
                            <th>Conductor/Placa</th>
                            <th class="text-center">Bultos</th>
                            <th>Almacen</th>
                            <th class="text-center">Monto</th>
                            <th hidden>DocEntry</th>
                            <th hidden>CodSocio</th>
                            <th hidden>Obs</th>
                            <th hidden>Direcciones</th>
                            <th hidden>Envio</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <h5 class="text-cobefar font-weight-bold border-bottom pb-2">DETALLE DE DEVOLUCIONES REGISTRADAS</h5>

            <div id="divDetalleRuta">
                <div class="table-responsive-custom">
                    <table id="Detalles" class="table table-bordered table-sm table-hover table-fixed">
                        <thead class="bg-secondary text-white">
                            <tr>
                                <th class="text-center" style="width:35px">#</th>
                                <th class="text-center" style="width:90px">DocNumSap</th>
                                <th style="width:22%">Socio</th>
                                <th style="width:15%">Guías</th>
                                <th style="width:20%">Conductor/Placa</th>
                                <th class="text-center" style="width:60px">Bultos</th>
                                <th style="width:18%">Obs</th>
                                <th class="text-center" style="width:80px">Monto</th>
                                <th class="text-center" style="width:90px">Liberar</th>
                                <th hidden>DocEntryT</th>
                                <th hidden>Direcciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DetRRU0 != null && Model.DetRRU0.Count > 0)
                            {
                                int i = 0;
                                foreach (var det in Model.DetRRU0)
                                {
                                    <tr id="reg@(i)">
                                        <td class="text-center">
                                            <input name="DetRRU0[@i].Linea" type="hidden" value="@(i + 1)" />@(i + 1)
                                        </td>
                                        <td>
                                            <input name="DetRRU0[@i].DocNumTicket" type="hidden" value="@det.DocNumTicket" />
                                            @det.DocNumTicket
                                        </td>
                                        <td>
                                            <input name="DetRRU0[@i].Socio" type="hidden" value="@det.Socio" />
                                            @det.Socio
                                        </td>
                                        <td>
                                            <input name="DetRRU0[@i].Guias" type="hidden" value="@det.Guias" />
                                            @det.Guias
                                        </td>
                                        <td>
                                            <input name="DetRRU0[@i].ConducYPlaca" type="hidden" value="@det.ConducYPlaca" />
                                            @det.ConducYPlaca
                                        </td>
                                        <td class="text-center">
                                            <input name="DetRRU0[@i].Cajas" class="input-readonly-table" readonly value="@det.Cajas" />
                                        </td>
                                        <td>
                                            <input name="DetRRU0[@i].Observaciones" type="hidden" value="@det.Observaciones" />
                                            <textarea class="textarea-readonly-table" readonly>@det.Observaciones</textarea>
                                        </td>
                                        <td class="text-right">
                                            <input name="DetRRU0[@i].MontoFinal" type="hidden" value="@det.MontoFinal" />@det.MontoFinal
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger font-weight-bold" onclick="borrarLineaTabla(this)">
                                                <i class="icon icon-lock"></i> Liberar
                                            </button>
                                        </td>
                                        <td hidden><input name="DetRRU0[@i].DocEntryTicket" class="DocEntryClass" type="hidden" value="@det.DocEntryTicket" /></td>
                                        <td hidden><input name="DetRRU0[@i].Direcciones" type="hidden" value="@det.Direcciones" /></td>
                                    </tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(ViewBag.Mensaje))
{
    <script>
        $(document).ready(function() {
            var mensaje = '@Html.Raw(ViewBag.Mensaje)';
            Swal.fire({
                title: 'Atención',
                text: mensaje,
                icon: 'error',       // Ícono rojo de error
                confirmButtonText: 'Entendido',
                confirmButtonColor: '#d33',
                timer: null          // Se elimina el timer para que NO se cierre solo
            });
        });
    </script>
}
<script>
    var contDet = @(Model.DetRRU0 != null ? Model.DetRRU0.Count : 0);
    var tablaDetalleRuta;

    $(document).ready(function () {
        configurarEventos();
        calcularTotalBultos();

        // --- LÓGICA DE RECUPERACIÓN DE CÓDIGO CLIENTE ---
        var nombreSocio = $("#CardName").val();
        var codigoSocio = $("#CardCode").val();
        var fecha = $("#FechaSapTicket").val();

        if(nombreSocio && !codigoSocio && fecha) {
            buscarCodigoAutomatico(nombreSocio, fecha);
        }
    });

    function configurarEventos() {
        $("#Placa").on('change', function () {
            var selected = $(this).find('option:selected');
            $("#VehiculoCod").val(selected.attr('data-code'));
            $("#Marca").val(selected.attr('data-marca'));
            $("#Modelo").val(selected.attr('data-modelo'));
        });

        $("#FechaSapTicket").on('change', function () {
            if(tablaDetalleRuta) tablaDetalleRuta.clear().draw();
        });

        $("#btn-Agregar").on('click', function () {
            agregarTicketsDetalle();
        });

        $("#chk_verifTodos").on('click', function(){
            var checked = $(this).is(':checked');
            $('.cls-chkVerif').prop('checked', checked);
        });
    }

    // --- BUSCAR CÓDIGO AUTOMÁTICO ---
    function buscarCodigoAutomatico(nombre, fecha) {
        $("#loadingCode").removeClass("d-none");
        $.ajax({
            url: '@Url.Action("ListarClientesPorFechaHana", "Rutas")',
            data: { "Fecha": fecha },
            dataType: 'json', type: 'post',
            success: function (response) {
                $("#loadingCode").addClass("d-none");
                if (response.success && response.data) {
                    var clienteEncontrado = response.data.find(c => c.CardName === nombre);
                    if (clienteEncontrado) {
                        $("#CardCode").val(clienteEncontrado.CardCode);
                    }
                }
            },
            error: function() { $("#loadingCode").addClass("d-none"); }
        });
    }

    // --- CARGAR PENDIENTES ---
    function cargarOrdenesDevolucion() {
      var CardCode = $("#CardCode").val();
        var fecha = $('#FechaSapTicket').val();

        if (!CardCode) { Swal.fire('Error', 'No se encontró el código del cliente. Verifique la fecha.', 'error'); return; }
        if (!fecha) { Swal.fire('Atención', 'Seleccione una fecha.', 'warning'); return; }

 $.ajax({
            url: '@Url.Action("ListarOrdenesDevolucionHana", "Rutas")',
          data: { "CardCode": CardCode, "Fecha": fecha },
      dataType: 'json', type: 'post',
        beforeSend: function () { Swal.showLoading(); }
        }).done(function (response) {
   Swal.close();
   // ? DEBUG: Ver qué trae desde el servidor
    console.log('=== RESPUESTA COMPLETA ===', response);
      if (response.success && response.data) {
      console.log('=== DATOS RECIBIDOS ===', response.data);
      // Ver el primer elemento para diagnosticar
  if (response.data.length > 0) {
            console.log('=== PRIMER ELEMENTO ===', response.data[0]);
    console.log('U_BPP_FECINITRA:', response.data[0].U_BPP_FECINITRA);
   }
            inicializarTablaOrdenes(response.data);
       } else {
         Swal.fire('Info', 'No hay órdenes pendientes para este cliente.', 'info');
     }
        });
    }

    function inicializarTablaOrdenes(data) {
        if ($.fn.DataTable.isDataTable('#detalleRuta')) {
            tablaDetalleRuta = $('#detalleRuta').DataTable();
            tablaDetalleRuta.clear();
        } else {
            tablaDetalleRuta = $('#detalleRuta').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.10.21/i18n/Spanish.json" },
                "paging": false, "searching": false, "info": false, "autoWidth": true,
                "columnDefs": [{ "visible": false, "targets": [9, 10, 11, 12, 13] }]  // ? Columnas ocultas (ya no incluye columna 14)
            });
        }

        $.each(data, function (i, item) {
            var conductorPlaca = (item.Conductor || '') + ' / ' + (item.Placa || '');
            var chk = '<input type="checkbox" class="cls-chkVerif" />';
            tablaDetalleRuta.row.add([
                chk, (i + 1), item.DocNum, item.CardName, (item.NumAtCard || ''),
                conductorPlaca, item.Bultos, item.Agencia, parseFloat(item.DocTotal).toFixed(2),
                item.DocEntry, item.CardCode, item.Comments, item.Address, '0'
                // ? YA NO agregamos U_BPP_FECINITRA como columna 14
        ]);
        });
        tablaDetalleRuta.draw();
    }

    function agregarTicketsDetalle() {
        if (!tablaDetalleRuta) return;
        var rows = tablaDetalleRuta.rows().nodes();
        var checkboxes = $(rows).find('.cls-chkVerif:checked');
        if (checkboxes.length === 0) { Swal.fire('Error', 'Seleccione al menos un item.', 'warning'); return; }

        checkboxes.each(function () {
            var row = tablaDetalleRuta.row($(this).closest('tr'));
         var data = row.data();
      // ? YA NO pasamos data[14] (U_BPP_FECINITRA) porque no se usa
   var agregado = agregarItem(data[9], data[2], data[3], data[4], data[5], data[6], data[11], data[12], data[8]);
            if(agregado) row.remove();
        });

        tablaDetalleRuta.draw();
     $("#chk_verifTodos").prop('checked', false);
        Swal.fire({ icon: 'success', title: 'Agregado', timer: 1000, showConfirmButton: false });
    }

    function agregarItem(docEntry, docNum, cardName, guias, conducyPlaca, bultos, obs, direcciones, docTotal) {
        if (!validarUnico(docEntry)) return false;
        var guiasF = guias ? guias.replace(/,/g, '\n') : '';

        // ? ELIMINADO: Ya NO autocompletamos TiempoPac desde JavaScript
        // El campo TiempoPac se llena desde el servidor en modo CREAR (desde HANA)
        // En modo EDITAR, ya viene precargado desde SQL (ORRU.TiempoPac)

        var fila = "<tr id='regNuevo" + contDet + "'>" +
     "<td class='text-center'><input name='DetRRU0[" + contDet + "].Linea' type='hidden' value='" + (contDet + 1) + "'/>" + (contDet + 1) + "</td>" +
     "<td><input name='DetRRU0[" + contDet + "].DocNumTicket' type='hidden' value='" + docNum + "'/>" + docNum + "</td>" +
            "<td><input name='DetRRU0[" + contDet + "].Socio' type='hidden' value='" + cardName + "'/>" + cardName + "</td>" +
      "<td><input name='DetRRU0[" + contDet + "].Guias' type='hidden' value='" + guiasF + "'/>" + guiasF + "</td>" +
            "<td><input name='DetRRU0[" + contDet + "].ConducYPlaca' type='hidden' value='" + (conducyPlaca || '') + "'/>" + (conducyPlaca || '') + "</td>" +
       "<td class='text-center'><input name='DetRRU0[" + contDet + "].Cajas' class='input-readonly-table' readonly value='" + bultos + "'/></td>" +
            "<td><input name='DetRRU0[" + contDet + "].Observaciones' type='hidden' value='" + obs + "'/><textarea class='textarea-readonly-table' readonly>" + (obs || '') + "</textarea></td>" +
   "<td class='text-right'><input name='DetRRU0[" + contDet + "].MontoFinal' type='hidden' value='" + docTotal + "'/>" + docTotal + "</td>" +
   "<td class='text-center'>" +
      "<button type='button' class='btn btn-sm btn-outline-danger font-weight-bold' onclick='borrarLineaTabla(this)'>" +
         "<i class='icon icon-lock'></i> Liberar" +
      "</button>" +
            "</td>" +
         "<td hidden><input name='DetRRU0[" + contDet + "].DocEntryTicket' class='DocEntryClass' type='hidden' value='" + docEntry + "' /></td>" +
      "<td hidden><input name='DetRRU0[" + contDet + "].Direcciones' type='hidden' value='" + direcciones + "'/></td>" +
        "</tr>";

        $("#Detalles tbody").append(fila);
        calcularTotalBultos();
     contDet++;
        return true;
    }

    function borrarLineaTabla(btn) {
      Swal.fire({
            title: '¿Liberar ítem?',
            text: "El ítem será removido de esta lista y quedará disponible.",
       icon: 'warning',
        showCancelButton: true,
      confirmButtonText: 'Sí, liberar',
            cancelButtonText: 'Cancelar'
        }).then((res) => {
     if (res.isConfirmed) {
      // Obtener la fila
                var $fila = $(btn).closest('tr');

          // Obtener DocEntry y Linea de los inputs hidden
var docEntry = $fila.find('input[name$=".DocEntryTicket"]').val();
         var linea = $fila.find('input[name$=".Linea"]').val();

       // Marcar como LIBERADO en el backend
    $.ajax({
           url: '/Rutas/liberarRRU0',
            type: 'POST',
    data: {
     DocEntry: $('#doc_entry').val(),  // DocEntry de ORRU
                Linea: linea,
   DocEntryTicket: docEntry,
              comentarioLiberado: 'LIBERADO DESDE EDICIÓN'
   },
         success: function(response) {
    if (response === 'ok') {
         // Eliminar la fila del DOM
  $fila.remove();
       calcularTotalBultos();

               Swal.fire({
           icon: 'success',
       title: 'Ítem liberado',
    text: 'El ítem ha sido liberado correctamente',
      timer: 2000,
      showConfirmButton: false
      });
   } else {
      Swal.fire('Error', response, 'error');
         }
      },
 error: function() {
      Swal.fire('Error', 'No se pudo liberar el ítem', 'error');
            }
              });
       }
        });
    }

    function validarUnico(docEntry) {
        var existe = false;
        $('.DocEntryClass').each(function() { if ($(this).val() == docEntry) { existe = true; return false; } });
        if(existe) return false; return true;
    }

    function calcularTotalBultos() {
        var t = 0;
  $('input[name$=".Cajas"]').each(function() { t += (parseInt($(this).val()) || 0); });
        $("#TotalBultos").val(t); $("#TotalCajas").val(t);
    }

    function validarEnviarFormulario() {
        // 1️⃣ Validar que existan detalles
        if ($("#Detalles tbody tr").length === 0) {
            Swal.fire('Sin detalles', 'Debe agregar al menos una orden al detalle antes de guardar.', 'warning');
            return false;
        }

        // 2️⃣ Validar campos obligatorios
        var fecha = $("#FechaSapTicket").val();
        var placa = $("#Placa").val();
        var conductor = $("#TransDesc").val();
        var almacenDestino = $("#AlmDestinoDesc").val();
        var tiempoPac = $("#TiempoPac").val();

        var errores = [];
        if (!fecha) {
            $("#FechaSapTicket").addClass('bg-danger text-white');
            errores.push('Fecha');
        }
        if (!placa) {
            $("#Placa").addClass('bg-danger text-white');
            errores.push('Placa');
        }
        if (!conductor) {
            $("#TransDesc").addClass('bg-danger text-white');
            errores.push('Conductor');
        }
        if (!almacenDestino) {
            $("#AlmDestinoDesc").addClass('bg-danger text-white');
            errores.push('Almacén Destino');
        }
        if (!tiempoPac) {
            $("#TiempoPac").addClass('bg-danger text-white');
            errores.push('Tiempo Pactado');
        }

        if (errores.length > 0) {
            Swal.fire('Campos requeridos', 'Complete los siguientes campos: ' + errores.join(', '), 'error');
            return false;
        }

        // 3️⃣ Confirmar envío
        Swal.fire({
            title: '¿Confirmar cambios?',
            text: 'Se actualizará la hoja de devolución',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#28a745',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, guardar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                $("#form").submit();
            }
        });
    }
</script>