                @if (Model.TiempoTerEn != null && Model.TiempoTerEn.Trim() != "")
                {
                    <td><font size="@ViewBag.Letra">@Model.TiempoTerEn.ToString().Substring(10, 8)</font></td>
                }
                else
                {
                    <td></td>
                }
                <td colspan=10><font size="@ViewBag.Letra">CONDICIÓN ALMACENAMIENTO : T° 15°C-25°C</font></td>
            </tr>
            <tr>
                <td><font size="@ViewBag.Letra"><strong>ALM-ORIGEN: </strong></font></td>
                <td colspan="6">
                    <font size="@ViewBag.Letra">
                        <strong style="margin-right:30px">
                            @if (Model2.AlmOrigenDesc.Equals("FACTURACION") || Model2.AlmOrigenDesc.Equals("PICKING"))
                            {
                                @:ALMACEN N°8
                            }
                            else
                            {
                                @Model2.AlmOrigenDesc
                            }
