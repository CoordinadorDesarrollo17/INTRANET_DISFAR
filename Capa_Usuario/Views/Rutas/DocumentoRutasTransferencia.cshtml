                </td>
                <td></td>
                <td><font size="@ViewBag.Letra"><strong>ALM-DESTINO: </strong></font></td>
                <td colspan=6><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.AlmDestinoDesc)<br />@Html.DisplayFor(model2 => model2.AlmDestinoDesc2)</font></td>
