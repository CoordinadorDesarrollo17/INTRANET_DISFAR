                    </tr>
                </table>
            </div>
            <div style="width:50%;">
                <table border=1 style="width:100%;float:left;">
                    <tr>
                        <th width=2%><font size="@ViewBag.Letra">#</font></th>
                        <th align=center width=5%><font size="@ViewBag.Letra">NRO. TICKET</font></th>
                        <th align=center width=10%><font size="@ViewBag.Letra">RAZÓN SOCIAL-RUC</font></th>
                        <th align=center width=12%><font size="@ViewBag.Letra">DIRECCIÓN-TELÉFONO</font></th>
                        <th align=center width=8%><font size="@ViewBag.Letra">OPERARIO DE VENTAS</font></th>
                        <th align=center width=5%><font size="@ViewBag.Letra">REGALO</font></th>
                        <th align=center width=5%><font size="@ViewBag.Letra">DESCRIPCION</font></th>
                        <th align=center width=25%><font size="@ViewBag.Letra">FIRMA Y/O SELLO DE RECIBIDO</font></th>

                    </tr>
                    @foreach (var det in Model2.DetRRU0.Where(x => x.Ticket.Det5 != null && x.Ticket.Det5.Count > 0 && x.Ticket.Det5[0].RegCant > 0))
                    {
                        <tr>
                            <td><font size="@ViewBag.Letra">@det.Linea</font></td>
                            <td><font size="@ViewBag.Letra">@det.DocNumTicket</font></td>
                            <td style='text-align: justify; word-wrap: break-word;'>
                                <font size="@ViewBag.Letra">
                                    @det.Ticket.CardName<br>
                                    RUC: @det.Ticket.CardCode
                                </font>
                            </td>

                            <td style='text-align: justify; word-wrap: break-word;'>
                                <font size="@ViewBag.Letra">
                                    @det.Ticket.DirDestino<br>
                                    @if (det.Ticket.Det1 != null && det.Ticket.Det1.Count > 0)
                                    {
                                        <p>TELEF: @det.Ticket.Det1[0].TelfPer</p>
                                    }
                                </font>
                            </td>
                            <td><font size="@ViewBag.Letra">@det.Ticket.Vendedor</font></td>
                            <td style='text-align: center;'><font size="@ViewBag.Letra">@Math.Round(det.Ticket.Det5[0].RegCant, 0)</font></td>
                            <td style='text-align: center;'><font size="@ViewBag.Letra"><strong>@(det.Ticket.Det5[0].RegCate + "  " + det.Ticket.Det5[0].RegTipo)</strong></font></td>
                            <td style='text-align: justify; word-wrap: break-word;'><font size="@ViewBag.Letra">_________________________</font></td>

                        </tr>

                    }
                </table>
            </div>
            <div style="margin-left:40px;padding-top:20px; display: inline-block;width:22%;">
                <table border=1>
                    <tr>
                        <th align=center width=10%><font size="@ViewBag.Letra">TIPO</font></th>
                        <th align=center width=8%><font size="@ViewBag.Letra">CATEGORIA</font></th>
                        <th align=center width=5%><font size="@ViewBag.Letra">SUBTOTAL</font></th>
                    </tr>
                    @foreach (OREG_E det in lstReg)
                    {
                        <tr>
                            <td><font size="@ViewBag.Letra">@det.Categoria</font></td>
                            <td><font size="@ViewBag.Letra">@det.Tipo</font></td>
                            <td style='text-align: center;'><font size="@ViewBag.Letra">@Math.Round(det.StockDisp, 0)</font></td>
                        </tr>
                    }

                </table>
            </div>
            <div style="clear:both;"></div>

            <br /><br />
            <div>
                <table>
                    <tr>
                        <td width=100px><font size="@ViewBag.Letra"></font></td>
                        <td><font size="@ViewBag.Letra">__________________</font></td>
                        <td><font size="@ViewBag.Letra"></font></td>
                        <td width=600px><font size="@ViewBag.Letra"></font></td>
                        <td><font size="@ViewBag.Letra">__________________</font></td>
                        <td><font size="@ViewBag.Letra"></font></td>
                    </tr>
                    <tr>
                        <td><font size="@ViewBag.Letra"></font></td>
                        <td><font size="@ViewBag.Letra">TRANSPORTISTA </font></td>
                        <td><font size="@ViewBag.Letra"></font></td>
                        <td><font size="@ViewBag.Letra"></font></td>
                        <td><font size="@ViewBag.Letra">VIGILANCIA</font></td>
                        <td><font size="@ViewBag.Letra"></font></td>
                    </tr>
                </table>
            </div>
        </div>
    }
</body>
</html>


