@model Capa_Entidad.Rutas_ENT.TablasSql.ORRU_E
@using Capa_Entidad.Rutas_ENT.TablasSql
@using Capa_Entidad.Ventas_ENT.TablasSql
@{
    Layout = null;
    var Model2 = Model;
    List<OREG_E> lstReg = new List<OREG_E>();

    if (Model.DetRRU0 != null && Model.DetRRU0.Count >= 1)
    {
        foreach (var d in Model.DetRRU0)
        {
            if (d.Ticket.Det5 != null && d.Ticket.Det5.Count >= 1)
            {
                if (d.Ticket.Det5[0].IdReg > 0 && d.Ticket.Det5[0].RegCant > 0)
                {
                    if (lstReg.Find(x => x.Id == d.Ticket.Det5[0].IdReg) == null)
                    {
                        lstReg.Add(new OREG_E() { Id = (int)d.Ticket.Det5[0].IdReg, Categoria = d.Ticket.Det5[0].RegCate, Tipo = d.Ticket.Det5[0].RegTipo, StockDisp = d.Ticket.Det5[0].RegCant });
                    }
                    else
                    {
                        lstReg.Find(x => x.Id == d.Ticket.Det5[0].IdReg).StockDisp += d.Ticket.Det5[0].RegCant;
                    }
                }
            }

        }
    }

}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>DocumentoRutasTransferencia</title>
</head>
<body>
    <div style='page-break-after:always;'>
        <table border=0 style="width: 1275px">
            <tr>
                <td colspan=15 width=850px><img width="90" height="30" src='~/Content/img/logo-drogueria-cobefar.jpg' /></td>
            </tr>
            <tr>
                <td colspan=14 align=center><font size="@(ViewBag.Letra+1)"><strong>REGISTRO DE RUTAS TRANSFERENCIAS</strong></font></td>
                <td align=right><font size="@(ViewBag.Letra+1)">F/DBT-002</font></td>
            </tr>
            <tr>
                <td><font size="@ViewBag.Letra" px><strong>TRANSPORTISTA: </strong></font></td>
                <td colspan=3><font size="@ViewBag.Letra+px">@Html.DisplayFor(model2 => model2.TransDesc)</font></td>
                <td colspan="8"></td>
                <td><font size="@ViewBag.Letra"><strong>DOCUMENTO Nro. </strong></font></td>
                <td width=70px colspan=2><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.DocNum)</font></td>
            </tr>
            <tr>
                <td><font size="@ViewBag.Letra"><strong>AUXILIAR DE DESPACHO 1: </strong></font></td>
