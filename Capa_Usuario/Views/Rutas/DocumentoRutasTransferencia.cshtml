                <th align=center width=70px><font size="@ViewBag.Letra">Nro.TICKET</font></th>
                <th align="center" width="300px"><font size="@ViewBag.Letra">REFERENCIA</font></th>
                <th align=center width=250px><font size="@ViewBag.Letra">Nro. DE GUIAS</font></th>
                <th align=center width=40px><font size="@ViewBag.Letra">MONTO</font></th>
                <th align=center width=200px><font size="@ViewBag.Letra">OPERARIO DE VENTAS</font></th>
                <th align=center width=40px><font size="@ViewBag.Letra"># CAJAS</font></th>
                <th align=center width=40px><font size="@ViewBag.Letra">VISTO</font></th>
            </tr>
            @if (Model2.DetRRU0 != null && Model2.DetRRU0.Count >= 1)
            {
                foreach (var det in Model2.DetRRU0.Where(x => x.Estado != "LIBERADO").OrderBy(x => x.Linea))
                {
                    <tr>
                        <td><font size="@ViewBag.Letra">@det.Linea</font></td>
                        <td><font size="@ViewBag.Letra">@det.Ticket.DocNum</font></td>
                        <td><font size="@ViewBag.Letra">@det.Ticket.CardName</font></td>
                        <td><font size="@ViewBag.Letra">@det.Guias</font></td>
                        <td style='text-align: center;'><font size="@ViewBag.Letra">S/@det.Ticket.MontoFinal</font></td>
                        <td><font size="@ViewBag.Letra">@det.Ticket.Vendedor</font></td>
                        <td style='text-align: center;'><font size="@ViewBag.Letra">@det.Ticket.Cajas</font></td>
                        <td><font size="@ViewBag.Letra"></font></td>
                    </tr>
                }
            }

        </table>
        <table border=0>
            <tr>
                <td height=35px colspan="4"></td>
                <td align=right><font size="@ViewBag.Letra">ENTREGA</font></td>
                <td></td>
                <td align=right><font size="@ViewBag.Letra">TOTAL CAJAS : @Model.DetRRU0.Where(x => x.Estado != "LIBERADO").Sum(x => x.Cajas)</font></td>
            </tr>
            <tr>
                <td width=250px align=right><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td width=200px><font size="@ViewBag.Letra"></font></td>
                <td width=200px align=right><font size="@ViewBag.Letra"></font></td>
                <td width=200px colspan=3><font size="@ViewBag.Letra"></font></td>
            </tr>
            <tr>
                <td align=right><font size="@ViewBag.Letra"></font></td>
                <td colspan=3><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra">1._____________</font></td>
                <td><font size="@ViewBag.Letra">3._____________</font></td>
            </tr>
            <tr>
                <td align=right><font size="@ViewBag.Letra">_________________</font></td>
                <td colspan=2><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra">________________</font></td>
            </tr>
            <tr>
                <td align=right><font size="@ViewBag.Letra">TRANSPORTISTA</font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra">VIGILANCIA</font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra"></font></td>
            </tr>
            <tr>
                <td align=right><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra"></font></td>
                <td><font size="@ViewBag.Letra">2._____________</font></td>
                <td><font size="@ViewBag.Letra">4._____________</font></td>
            </tr>
        </table>
    </div>
    @if (lstReg.Count > 0)
    {
        <div style='page-break-after:always;'>
            <div>
                <table border=0 style=' width: 1275px'>
                    <tr>
                        <td colspan=2 width=150px><img width=90px height=30px src='/imagenes/index/encabezado/logoC.jpg' /></td>
                    </tr>
                    <tr>
                        <td colspan=5 align=center><font size="@(ViewBag.Letra+1)"><strong>RUTAS REGALOS</strong></font></td>
                        <td align=right><font size="@(ViewBag.Letra+1)">REG-031-01</font></td>
                    </tr>
                    <tr>
                        <td><font size="@ViewBag.Letra"><strong>TRANSPORTISTA:</strong></font></td>
                        <td width=190px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.TransDesc)</font></td>
                        <td></td>
                        <td></td>
                        <td><font size="@ViewBag.Letra"><strong>DOCUMENTO Nro.</strong></font></td>
                        <td width=200px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.DocNum)</font></td>
                    </tr>
                    <tr>
                        <td><font size="@ViewBag.Letra"><strong>COPILOTO: </strong></font></td>
                        <td width=150px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.CopilDesc)</font></td>
                        <td><font size="@ViewBag.Letra"><strong>COPILOTO2: </strong></font></td>
                        <td width=150px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.Copil2Desc)</font></td>
                    </tr>
                    <tr>
                        <td><font size="@ViewBag.Letra"><strong>COPILOTO3: </strong></font></td>
                        <td width=150px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.Copil3Desc)</font></td>
                        <td><font size="@ViewBag.Letra"><strong>COPILOTO4: </strong></font></td>
                        <td width=150px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.Copil4Desc)</font></td>
                    </tr>
                    <tr>
                        <td><font size="@ViewBag.Letra"><strong>PLACA: </strong></font></td>
                        <td width=150px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.Placa)</font></td>
                        <td><font size="@ViewBag.Letra"><strong>FECHA: </strong></font></td>
                        <td width=270px><font size="@ViewBag.Letra">@Model2.FechaCont</font></td>
                    </tr>
                    <tr>
                        <td><font size="@ViewBag.Letra"><strong>HORA INICIO: </strong></font></td>
                        <td width=150px><font size="@ViewBag.Letra">@Html.DisplayFor(model2 => model2.TiempoIniEn)</font></td>

