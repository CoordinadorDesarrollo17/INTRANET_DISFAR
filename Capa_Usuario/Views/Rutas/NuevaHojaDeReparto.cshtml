@model Capa_Entidad.Rutas_ENT.TablasSql.ORRU_E
@using Capa_Entidad.General_ENT.TablasSql
@using Capa_Entidad.Rutas_ENT.TablasSql
@{
    ViewBag.Title = "Nueva Hoja De Reparto";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
    List<OWHS_E> lstOriDest = (List<OWHS_E>)ViewBag.ListaOrigenesDestinos;
    List<Capa_Entidad.Repartos_ENT.TablasHana.SYP_VEHICU_E> Vehiculos = (List<Capa_Entidad.Repartos_ENT.TablasHana.SYP_VEHICU_E>)ViewBag.ListaVehiculos;
    List<string> Conductores = new List<string>(ViewBag.Conductores);
    List<ProvedorTrans> Provedor = new List<ProvedorTrans>(ViewBag.Provedor);
    List<string> Copilotos = new List<string>(ViewBag.ListaCopilotos);
    List<UBIG_E> Ubigeos = ViewBag.Ubigeos as List<UBIG_E> ?? new List<UBIG_E>();

    string urlAction = Url.Action("ListadoRutas", "Rutas"), tituloListado = "Listado de rutas", tituloTipoRep = "";
    if (ViewBag.TipoRep == "Re")
    {
        urlAction = Url.Action("ListadoRepartos", "Rutas");
        tituloListado = "Listado de repartos";
        tituloTipoRep = "Registrar Hoja de Reparto";
    }
    else if (ViewBag.TipoRep == "Ru")
    {
        tituloTipoRep = "Registrar Hoja de Ruta";
    }

}

<style>
    #Detalles textarea {
        font-size: 12px;
        white-space: pre-line;
        overflow-wrap: break-word;
        resize: none; /* Evita que el usuario cambie el tamaño */
    }

    /* Estilos para las columnas de la tabla */
    #detalleRuta th:nth-child(7), /* Guías */
    #Detalles th:nth-child(5) { /* Guías en tabla detalle */
        width: 200px !important;
        max-width: 200px;
    }

    #detalleRuta th:nth-child(8), /* Conductor/Placa */
    #Detalles th:nth-child(6) { /* Conductor/Placa en tabla detalle */
        width: 350px !important;
        max-width: 350px;
    }

    #detalleRuta td:nth-child(7), /* Guías */
    #Detalles td:nth-child(5) { /* Guías en tabla detalle */
        white-space: pre-line;
        word-break: break-word;
        font-size: 11px;
    }

    #detalleRuta td:nth-child(8), /* Conductor/Placa */
    #Detalles td:nth-child(6) { /* Conductor/Placa en tabla detalle */
        white-space: pre-line;
        word-break: break-word;
        font-size: 11px;
        line-height: 1.4;
    }
</style>
<script>
    var contDet = 0;

    // Ajustar altura de textareas automáticamente
    function ajustarAlturaTextareas() {
        document.querySelectorAll('#Detalles textarea').forEach(function (textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = textarea.scrollHeight + 'px';
        });
    }

    // Ejecutar cuando cargue la página
    window.addEventListener('DOMContentLoaded', ajustarAlturaTextareas);

    // Observar cambios en la tabla
    const observer = new MutationObserver(ajustarAlturaTextareas);
    document.addEventListener('DOMContentLoaded', function () {
        observer.observe(document.querySelector('#Detalles tbody'), { childList: true });
    });
</script>
<script src="~/Scripts/Rutas/HojaDeReparto.js?v=@DateTime.Now.Ticks>" defer></script>

