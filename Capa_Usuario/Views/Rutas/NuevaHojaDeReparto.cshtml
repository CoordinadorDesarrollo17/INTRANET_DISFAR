        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const tipoRutaSelect = document.getElementById('TipoRuta');
                const zonaSelect = document.getElementById('Zona');

                function actualizarOpcionesZona() {
                    // Mostrar todas las opciones primero
                    Array.from(zonaSelect.options).forEach(opt => {
                        opt.hidden = false;
                    });

                    // Si es Domicilio, ocultar AGENCIA y ARRIOLA
                    if (tipoRutaSelect.value === 'VD') {
                        Array.from(zonaSelect.options).forEach(opt => {
                            if (opt.value === 'AGENCIA' || opt.value === 'ARRIOLA') {
                                opt.hidden = true;
                                // Si está seleccionada, resetea el select
                                if (zonaSelect.value === opt.value) zonaSelect.value = '';
                            }
                        });
                    }
                }
                tipoRutaSelect.addEventListener('change', actualizarOpcionesZona);
                // Ejecutar al cargar por si hay valor inicial
                actualizarOpcionesZona();
            });
        </script>


        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const tipoRuta = document.getElementById('TipoRuta');
                const ProvedorDiv = document.getElementById('ProvedorDiv');
                const DepartamentoDiv = document.getElementById('DepartamentoDiv');
                const ProvinciaDiv = document.getElementById('ProvinciaDiv');
                const DistritoDiv = document.getElementById('DistritoDiv');
                const TipoEnvio = document.getElementById('TipoEnvioDiv')

                function toggleConductor() {
                    // Mostrar solo si es VG (Agencia)
                    const mostrar = tipoRuta.value === 'VG';
                    ProvedorDiv.style.display = mostrar ? 'block' : 'none';
                    DepartamentoDiv.style.display = mostrar ? 'block' : 'none';
                    ProvinciaDiv.style.display = mostrar ? 'block' : 'none';
                    DistritoDiv.style.display = mostrar ? 'block' : 'none';
                    TipoEnvio.style.display = mostrar ? 'block' : 'none';
                }

                tipoRuta.addEventListener('change', toggleConductor);
                // Ejecutar al cargar para estado inicial
                toggleConductor();
            });
        </script>
        <script>
    // Script para manejar los cambios en los selects de departamento, provincia y distrito
    document.addEventListener('DOMContentLoaded', function () {
        const depto = document.getElementById('Departamento');
        const prov = document.getElementById('Provincia');
        const dist = document.getElementById('Distrito');

        function clearSelect(sel, placeholder) {
            sel.innerHTML = '';
            const opt = document.createElement('option');
            opt.value = '';
            opt.textContent = placeholder || 'Seleccione';
            sel.appendChild(opt);
        }

        depto.addEventListener('change', function () {
            clearSelect(prov, 'Seleccione');
            clearSelect(dist, 'Seleccione');
            const departamento = depto.value;
            if (!departamento) return;
            $.ajax({
                url: '@Url.Action("ListarProvinciasPorDepartamento", "Rutas")',
                type: 'POST',
                dataType: 'json',
                data: { departamento: departamento }
            }).done(function (res) {
                if (res && res.success) {
                    res.data.forEach(function (p) {
                        const opt = document.createElement('option');
                        opt.value = p;
                        opt.textContent = p;
                        prov.appendChild(opt);
                    });
                }
            });
        });

        prov.addEventListener('change', function () {
            clearSelect(dist, 'Seleccione');
            const departamento = depto.value;
            const provincia = prov.value;
            if (!departamento || !provincia) return;
            $.ajax({
                url: '@Url.Action("ListarDistritosPorProvDep", "Rutas")',
                type: 'POST',
                dataType: 'json',
                data: { departamento: departamento, provincia: provincia }
            }).done(function (res) {
                if (res && res.success) {
                    res.data.forEach(function (d) {
                        const opt = document.createElement('option');
                        opt.value = d;
                        opt.textContent = d;
                        dist.appendChild(opt);
                    });
                }
            });
        });
    });
        </script>
