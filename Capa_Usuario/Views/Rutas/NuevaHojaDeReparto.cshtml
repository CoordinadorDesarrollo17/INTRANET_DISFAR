                    <label for="Departamento" class="text-dark form-label font-weight-bold font-18">Departamento:</label>
                    <select id="Departamento" name="Departamento" class="form-control form-select border-success" onchange="listarTickets('');">
                        <option value="">Seleccione</option>
                        @foreach (var dep in Ubigeos.Select(u => u.Departamento).Distinct().OrderBy(u => u))
                        {
                            <option value="@dep">@dep</option>
                        }
                    </select>
                </div>

                <div class="col-lg-2" id="ProvinciaDiv">
