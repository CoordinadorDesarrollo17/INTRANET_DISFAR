@model Capa_Entidad.Rutas_ENT.TablasSql.ORRU_E
@using Capa_Entidad.General_ENT.TablasSql
@using Capa_Entidad.Seguridad_ENT
@{
    ViewBag.Title = "EditarOrdenDeRuta _TA";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string tituloHoja = string.Empty, tituloListado = string.Empty, urlActionBreadcrumb = string.Empty;
    int btnEditarDetalle = 0;

    List<OWHS_E> lstOriDest = (List<OWHS_E>)ViewBag.ListaOrigenesDestinos;
    List<OVEH_E> Vehiculos = (List<OVEH_E>)ViewBag.ListaVehiculos;
    List<COUR_E> Agencias = new List<COUR_E>(ViewBag.Agencias);
    List<OCHO_E> Choferes = new List<OCHO_E>(ViewBag.ListaChoferes);
    List<Usuario_E> Copilotos = new List<Usuario_E>(ViewBag.ListaCopilotos);

    if (Model.Propietario == ViewBag.UsuarioSesion)
    {
        btnEditarDetalle = 1;
    }

    if (ViewBag.TipoRep == "Re")
    {
        tituloHoja = "Editar Hoja de Reparto";
        tituloListado = "Listado de repartos";
        urlActionBreadcrumb = Url.Action("ListadoRepartos", "Rutas");
    }
    else
    {
        tituloHoja = "Editar Hoja de Ruta";
        tituloListado = "Listado de rutas";
        urlActionBreadcrumb = Url.Action("ListadoRutas", "Rutas");
    }
}
<style>
    #Detalles input, #Detalles textarea, #Detalles td {
        font-size: 12px;
    }
</style>
<script>
    $(document).ready(function () {
        $("#btn-NoEnviados").hide();
        validarTipoRuta('@Model.TipoRuta','@Model.Estado');
    });

    function borrarTrTable1(dom) {
        Swal.fire({
            title: '¿Estás seguro?',
            text: 'Esta acción no se puede deshacer.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                var i = -1;
                var docEntryTicketToDelete = $(dom).closest('tr').find("td:eq(1) input").val();
                var modalIdToDelete = "ModalImpresion" + docEntryTicketToDelete;

                $(dom).closest('tr').remove();

                contDet = contDet - 1;
                $("#Detalles tr").each(function (index, htm) {
                    iden1 = $(htm).find("td:eq(0) input");
                    iden1.attr("name", "DetRRU0[" + i + "].Linea");
                    iden1.val(i + 1);
                    iden1 = $(htm).find("td:eq(1) input");
                    iden1.attr("name", "DetRRU0[" + i + "].DocEntryTicket");
                    iden1 = $(htm).find("td:eq(2) input");
                    iden1.attr("name", "DetRRU0[" + i + "].DocNumTicket");
                    iden1 = $(htm).find("td:eq(3) input");
                    iden1.attr("name", "DetRRU0[" + i + "].Socio");
                    iden1 = $(htm).find("td:eq(4) textarea");
                    iden1.attr("name", "DetRRU0[" + i + "].Guias");
                    iden1 = $(htm).find("td:eq(5) input");
                    iden1.attr("name", "DetRRU0[" + i + "].Cajas");
                    iden1 = $(htm).find("td:eq(6) input");
                    iden1.attr("name", "DetRRU0[" + i + "].Observaciones");
                    iden1 = $(htm).find("td:eq(7) textarea");
                    iden1.attr("name", "DetRRU0[" + i + "].Direcciones");
                    iden1 = $(htm).find("td:eq(8) input");
                    iden1.attr("name", "DetRRU0[" + i + "].MontoFinal");
                    iden1 = $(htm).find("td:eq(9) input");
                    iden1.attr("name", "DetRRU0[" + i + "].Envio");
                    i = i + 1;
                });
                calcularTotalCajas();
                // Eliminamos el modal correspondiente al DocEntryTicket eliminado
                $("#" + modalIdToDelete).remove();
                //Swal.fire('Eliminado', 'El item ha sido eliminado correctamente.', 'success');
            }
        });
    }

</script>
<script src="~/Scripts/Rutas/HojaDeReparto.js"></script>
<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@urlActionBreadcrumb">@tituloListado</a></li>
            <li class="current"><em>Editar Documento</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="d-flex justify-content-between px-3 pt-3">
        <h3 class="titulo-seccion">@tituloHoja.ToUpper()</h3>
        <div class="col-md-4 text-right">
            <div class="alert alert-danger text-center text-primary" role="alert" id="btn-NoEnviados">
                <a href="#" onclick="verTicketsNoEnviados()"></a>
            </div>
        </div>
    </div>
</div>


<div class="bg-form-pestanas-cobefar">

    <div class="bg-section-form p-4 bg-form-cobefar">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "form" }))
        {
            
            <input name="TipoRep" type="hidden" value="@ViewBag.TipoRep" readonly />
            <input name="DocEntry" id="doc_entry" type="hidden" value="@Model.DocEntry" readonly />
            <div class="row mb-4 mt-4">
                <div class="col-lg-2">
                    <label for="TipoRuta" class="text-dark form-label font-weight-bold font-18">Tipo de Ruta:</label>
                    <input type="text" value="@Model.TipoRuta" id="TipoRuta" name="TipoRuta" class="text-center form-control border-success" readonly />
                </div>
                <div class="col-lg-2">
                    <label for="FechaSapTicket" class="text-dark form-label font-weight-bold font-18">Fecha de tickets:</label>
                    <input type="date" class="text-center form-control border-success" name="FechaCont" id="FechaSapTicket" value="@String.Format("{0:yyyy-MM-dd}", Model.FechaCont)" onchange="listarTickets();" />
                </div>

                <div class="col-lg-2">
                    <label for="DocNum" class="text-dark form-label font-weight-bold font-18">Número documento:</label>
                    @Html.EditorFor(model => model.DocNum, new { htmlAttributes = new { @class = "text-center form-control border-success", @readonly = "true" } })
                </div>
                <div class="col-lg-2">
                    <label class="text-dark form-label font-weight-bold font-18">Fecha de registro:</label>
                    <input type="date" class="text-center form-control border-success" name="FechaDoc" value="@String.Format("{0:yyyy-MM-dd}", Model.FechaDoc)" readonly />
                </div>

                <div class="col-lg-2">
                    <label for="Estado" class="text-dark form-label font-weight-bold font-18">Estado:</label>
                    @Html.EditorFor(model => model.Estado, new { htmlAttributes = new { @class = "text-center form-control border-success", @readonly = "true" } })
                </div>

            </div>
            <div class="row mt-lg-4">
                <div class="col-lg-2" id="div_almacen-origen">
                    <label class="text-dark form-label font-weight-bold font-18">Almacén de Origen:</label>
                    <select name="AlmOrigenDesc" id="AlmOrigenDesc" class="form-control bg-cobefar text-white" onchange="enviarValSelect('AlmOrigenDesc', 'AlmOrigenCod', 'AlmOrigenCod'); enviarValSelect('AlmOrigenDesc', 'AlmOrigenDesc2', 'AlmOrigenDesc2'); listarTickets(); ">
                        <option value="">Seleccione</option>
                        @foreach (var l in lstOriDest.Where(x => x.WhsCode != "00" && x.WhsCode != "05"))
                        {
                            <option value="@l.WhsName" AlmOrigenCod="@l.WhsCode"
                                    AlmOrigenDesc2="@(l.Street+" "+l.StreetNo+" "+l.Building+" "+l.Block+" "+l.City+" "+l.County)" @if (Model.AlmOrigenCod == l.WhsCode) { Write("selected"); }>
                                @l.WhsName
                            </option>
                        }
                    </select>
                    @Html.EditorFor(model => model.AlmOrigenCod, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                    @Html.EditorFor(model => model.AlmOrigenDesc2, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                </div>

                
                <div class="col-lg-2" id="div_almacen-destino">
                    <label class="text-dark form-label font-weight-bold font-18">Almacén de Destino:</label>
                    <select name="AlmDestinoDesc" id="AlmDestinoDesc" class="form-control bg-cobefar text-white" onchange="enviarValSelect('AlmDestinoDesc', 'AlmDestinoCod', 'almdestinocod'); enviarValSelect('AlmDestinoDesc', 'AlmDestinoDesc2', 'almdestinodesc2'); listarTickets();">
                        <option value="">Seleccione</option>
                        @foreach (var l in lstOriDest.Where(x => x.WhsCode != "00" && x.WhsCode != "05"))
                        {
                            <option value="@l.WhsName" almdestinocod="@l.WhsCode"
                                    almdestinodesc2="@(l.Street+" "+l.StreetNo+" "+l.Building+" "+l.Block+" "+l.City+" "+l.County)" @if (Model.AlmDestinoCod == l.WhsCode) { Write("selected"); }>
                                @l.WhsName
                            </option>
                        }
                    </select>
                    @Html.EditorFor(model => model.AlmDestinoCod, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                    @Html.EditorFor(model => model.AlmDestinoDesc2, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                </div>
                <div class="col-lg-2">
                    <label for="Placa" class="text-dark form-label font-weight-bold font-18">Placa:</label>
                    <select name="Placa" id="Placa" class="form-control bg-cobefar text-white border-success"
                            onchange="enviarValSelect('Placa', 'VehiculoCod', 'Code');
                                        enviarValSelect('Placa', 'Marca', 'U_SYP_VEMA');
                                        enviarValSelect('Placa', 'Modelo', 'U_SYP_VEMO');">
                        <option value="">Seleccione</option>
                        @foreach (var t in Vehiculos)
                        {
                            <option value="@t.U_SYP_VEPL" Code="@t.Code" U_SYP_VEMA="@t.U_SYP_VEMA" U_SYP_VEMO="@t.U_SYP_VEMO" @if (Model.Placa == t.U_SYP_VEPL) { Write("selected"); }>@t.U_SYP_VEPL</option>
                        }
                    </select>
                    @Html.EditorFor(model => model.Marca, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                    @Html.EditorFor(model => model.Modelo, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                    @Html.EditorFor(model => model.VehiculoCod, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                </div>

                <div class="col-lg-3">
                    <label for="Propietario" class="text-dark form-label font-weight-bold font-18">Propietario:</label>
                    @Html.EditorFor(model => model.Propietario, new { htmlAttributes = new { @class = "text-center form-control border-success", @readonly = "true" } })
                </div>
            </div>
            <div class="row mt-lg-4">
                <div class="col-lg-3">
                    <label for="TransDesc" class="text-dark form-label font-weight-bold font-18">Conductor:</label>
                    @if (Model.TipoRuta == "AC")
                    {
                        @Html.EditorFor(model => model.TransDesc, new { htmlAttributes = new { @class = "text-center form-control border-success", @autocomplete = "off" } })
                    }
                    else
                    {
                        <select name="TransDesc" id="TransDesc" class="form-control bg-cobefar text-white" onchange="enviarValSelect('TransDesc', 'TransCod','Code');">
                            <option value="" TransCod="">Seleccione</option>
                            @foreach (var t in Choferes)
                            {
                                <option value="@t.U_SYP_CHNO" Code="@t.Code" @if (Model.TransCod == t.Code) { Write("selected"); }>@t.U_SYP_CHNO</option>
                            }
                        </select>
                        @Html.EditorFor(model => model.TransCod, new { htmlAttributes = new { @class = "form-control ", @type = "hidden", @readonly = "true" } })
                    }
                </div>

                @if (Model.TipoRuta != "AC")
                {

                    <div class="col-lg-3">
                        <label for="CopilDesc" class="text-dark form-label font-weight-bold font-18">Copiloto 1:</label>
                        @Html.EditorFor(model => model.CopilDesc, new { htmlAttributes = new { @class = "text-center form-control border-success", @type = "search", @list = "ListaCopilotos" } })
                        <datalist id="ListaCopilotos">
                            @foreach (var c in Copilotos)
                            {
                                <option value="@(c.Nombres +" "+c.Apellidos)"></option>
                            }
                        </datalist>
                    </div>

                }
                <div class="col-lg-3">
                    <label for="Copil2Desc" class="text-dark form-label font-weight-bold font-18">Copiloto 2:</label>
                    @Html.EditorFor(model => model.Copil2Desc, new
                    {
                        htmlAttributes = new
                        {
                            @type = "search",
                            @class = "text-center form-control border-success",
                            @list = "ListaCopilotos"@*, @onchange = "enviarValList('Copil2Desc','ListaCopilotos','Copil2Cod','CopilCod');"*@}
})
                </div>


            </div>
            if (Model.TipoRuta == "AC")
            {
                <div class="row mt-lg-4">
                    <div class="col-lg-3">
                        <label for="Agencia" class="text-dark form-label font-weight-bold font-18">Agencia:</label>
                        <select name="Agencia" id="Agencia" class="form-control bg-cobefar text-white" onchange="enviarValSelect('Agencia', 'RucAgencia', 'ruc'); listarTickets(); ">
                            <option value="">Seleccione</option>
                            @foreach (var i in Agencias)
                            {
                                <option ruc="@i.Ruc" value="@i.Nombre" @if (Model.Agencia == i.Nombre) { Write("selected"); }>@i.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label for="RucAgencia" class="text-dark form-label font-weight-bold font-18">RUC:</label>
                        <input name="RucAgencia" id="RucAgencia" class="text-center form-control border-success" value=@Model.RucAgencia readonly />
                    </div>
                </div>
            }
            <div class="row mt-lg-4 mb-4">
                <div class="col-lg-3">
                    <label class="text-dark form-label font-weight-bold font-18">Tiempo de entrega pactado: </label>
                    <input type="datetime-local" class="text-center form-control border-success" name="TiempoPac" id="TiempoPac" value="@Convert.ToDateTime(Model.TiempoPac).ToString("yyyy-MM-ddTHH:mm:ss")" />
                </div>
                <div class="col-lg-2">
                    <label for="TotalCajas" class="text-dark form-label font-weight-bold font-18">Total de cajas:</label>
                    <input id="TotalCajas" type="text" class="text-center form-control border-success" value="@Model.TotCajas()" readonly />
                </div>
                <div class="col-lg-5">
                    <label for="Observaciones" class="text-dark form-label font-weight-bold font-18">Observaciones:</label>
                    @Html.EditorFor(model => model.Observaciones, new { htmlAttributes = new { @class = "form-control border-success" } })
                </div>
                <div class="col-lg-2 p-2">
                    <div class="mt-lg-4"><button type="button" class="btn btn-success" onclick="validarEnviarFormulario('@Model.Estado');"><i class="icon icon-pencil"></i> Editar Encabezado</button></div>
                </div>
            </div>


            if (Model.DetRRU0 != null && Model.DetRRU0.Count > 0)
            {
                <div class="container">
                    <div class="row">
                        <div class="col-md-3">
                            <input type="checkbox" id="chk_verifTodos" onclick="seleccionarVerif()" /> <label for="chk_verifTodos" class="text-dark font-weight-bold">Seleccionar Todos</label>
                        </div>
                        <div class="col-md-9 text-right">
                            <button type="button" class="btn btn-sm btn-blue" id="btn-Agregar" onclick="agregarTicketsDetalle()"><i class="icon icon-plus">    </i> Agregar ticket(s)</button>
                        </div>
                    </div>
                </div>
                <div class="mt-2">
                    <div class="col-lg-12 bg-dark p-3">
                        <table id="detalleRuta" class="table table-light table-sm table-hover cls-dataTable font-14" cellspacing="0" width="100%">
                            <thead class="bg-cobefar text-white">
                                <tr>
                                    <th class="text-center"></th>
                                    <th class="text-center">#</th>
                                    <th hidden>DocEntryTicket</th>
                                    <th class="text-center">NroTicket</th>
                                    <th hidden>CodSocio</th>
                                    <th class="text-center" style="width:250px">Socio</th>
                                    <th class="text-center" style="width:450px">Guías</th>
                                    <th class="text-center">Cajas</th>
                                    <th hidden>Obs.</th>
                                    <th hidden>Direcciones</th>
                                    <th class="text-center" style="width:70px">Agencia</th>
                                    <th class="text-center">Monto final</th>
                                    <th hidden>Envio</th>
                                    <th class="text-center">Tipo de venta</th>
                                    <th class="text-center">Estado de pago</th>
                                </tr>
                            </thead>

                        </table>
                    </div>
                </div>


                <h3 class="text-cobefar font-weight-bold mt-2">
                    DETALLE DE RUTA<br /><small class="font-14 text-danger">* El ticket impreso se colorea de fondo azul claro</small>
                </h3>
                <div id="divDetalleRuta">
                    <div class="mt-2">
                        <table id="Detalles" class="table table-light table-md table-hover" cellspacing="0" width="100%">
                            <thead class="bg-success">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th hidden>DocEntryT</th>
                                    <th class="text-center">NroTicket</th>
                                    <th class="text-center">Socio</th>
                                    <th class="text-center">Guias</th>
                                    <th class="text-center">Cajas</th>
                                    <th class="text-center">Obs.</th>
                                    <th class="text-center">Direcciones</th>
                                    <th class="text-center">MontoFinal</th>
                                    <th class="text-center">Envio</th>
                                    <th class="text-center"></th>
                                    <th class="text-center"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ string style = "";}
                                @foreach (var det in Model.DetRRU0)
                                {
                                    if (det.Estado == "LIBERADO") { style = "background:lightgray;"; } else { style = ""; }
                                    <tr id="reg@(det.Linea)" style="@style">
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Linea' type='hidden' class="form-control border-success" value='@det.Linea' style='width:40px;' readonly />@det.Linea</td>
                                        <td hidden><input name='DetRRU0[@(det.Linea - 1)].DocEntryTicket' type='text' class="form-control border-success" value='@det.DocEntryTicket' style='width:80px;' readonly /></td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].DocNumTicket' id="DocNumTDet@(det.Linea)" type='hidden' class="form-control border-success" value='@det.DocNumTicket' readonly />@det.DocNumTicket</td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Socio' type='hidden' class="form-control border-success" value='@det.Socio' style='width:100px;' readonly />@det.Socio</td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Guias' type='hidden' class="form-control border-success" value='@det.Guias' style='width:100px;' readonly />@det.Guias</td>
                                        <td class="text-center"><input name='DetRRU0[@(det.Linea - 1)].Cajas' type='hidden' class="form-control border-success" value='@det.Cajas' readonly />@det.Cajas</td>
                                        <td><input name='DetRRU0[@(det.Linea - 1)].Observaciones' type='hidden' class="form-control border-success" value='@det.Observaciones' style='width:100px;' readonly />@det.Observaciones</td>
                                        <td><textarea name='DetRRU0[@(det.Linea - 1)].Direcciones' class="form-control border-success" readonly>@det.Direcciones</textarea></td>
                                        <td class="text-center"><input name='DetRRU0[@(det.Linea - 1)].MontoFinal' type='hidden' class="form-control border-success" value='@det.MontoFinal' style='width:90px;' readonly />@det.MontoFinal</td>
                                        <td class="text-center"><input name='DetRRU0[@(det.Linea - 1)].Envio' type='hidden' class="form-control border-success" value='@det.Envio' style='width:50px;' readonly />@det.Envio</td>
                                        <td><a href='SeguimientoDeTicket?DocEntry=@det.DocEntryTicket' target='_blank' class="btn btn-sm btn-primary" style='cursor:pointer' onclick="window.open(this.href,this.target,'width=500,height=350,top=120,left=100,toolbar=no,location=no,status=no,menubar=no');"><i class="icon-truck"></i></a></td>
                                        <td class="d-flex justify-content-center" colspan="3"><button type='button' class='btn btn-sm btn-blue' onclick='liberarTrTable1(@det.DocEntry,@det.Linea,@det.DocEntryTicket,"reg@(det.Linea)")'><i class="icon icon-unlocked">  </i>Liberar</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            }

            if (Model.DetRRU1 != null && Model.DetRRU1.Count > 0)
            {
                <table class="table table-light table-sm table-hover table-responsive table-bordered" cellspacing="0" width="100%" id="Detalles1">
                    <tr class="bg-cobefar">
                        <th class="text-center">#</th>
                        <th class="text-center">Guia</th>
                        <th class="text-center">NroSap</th>
                        <th class="text-center">Cajas</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Verif.</th>
                    </tr>
                    @{string style1 = "";}
                    @foreach (var det in Model.DetRRU1)
                    {
                        if (det.Estado == "LIBERADO") { style1 = "background:lightgray;"; } else { style1 = ""; }
                        <tr id="reg@(det.Linea)" class="cls-colorFilaGuia" style="@style1" onclick="listarDetalleGuia(@det.DocEntry, @det.Linea, this.id, @btnEditarDetalle)">
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Linea' type='hidden' value='@det.Linea' readonly />@det.Linea</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Guia' type='hidden' value='@det.Guia' readonly />@det.Guia</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].NroSap' type='hidden' value='@det.NroSap' readonly />@det.NroSap</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Cajas' type='hidden' value='@det.Cajas' readonly />@det.Cajas</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Estado' type='hidden' value='@det.Estado' readonly />@det.Estado</td>
                            <td class="text-center"><input name='DetRRU1[@(det.Linea-1)].Verificado' type='checkbox' style='width:50px;' readonly /></td>
                        </tr>

                    }

                </table>
            }
            <script>
                contDet=@Model.DetRRU0.Count
            </script>


        }

        @if (Model.DetRRU11 != null && Model.DetRRU11.Count > 0)
        {
            <form id="frm_detalle" name="frm_detalle">
                <input type="hidden" id="baselinea_RRU11" name="baselinea_RRU11" value="" />
                @if (btnEditarDetalle == 1)
                {
                    <div class="row mt-lg-4">
                        <div class="col-lg-12 d-flex justify-content-end">
                            <button type="button" class="btn btn-success" onclick="editarDetalle();"><i class="icon icon-pencil"></i> Editar Detalle</button>
                        </div>
                    </div>
                }
                <div class="row  mt-lg-4">
                    <div class="col-lg-12">

