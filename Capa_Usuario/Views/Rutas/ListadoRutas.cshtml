@model IEnumerable<Capa_Entidad.Rutas_ENT.TablasSql.ORRU_E>
@using Capa_Entidad.Rutas_ENT.TablasSql;
@using Capa_Entidad.General_ENT.TablasSql
@{
    ViewBag.Title = "ListadoRutas";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ORRU_E o = (ORRU_E)ViewBag.Orru;
    List<string> Conductores = (List<string>)ViewBag.Conductores;
    List<OVEH_E> listaVeh = (List<OVEH_E>)ViewBag.listaVeh;
}

<script>
    $(document).ready(function () { });

    function filtrar() {
        var object = $("#filterForm").serialize();
        $(location).attr('href', "/Rutas/ListadoRutas?" + object);
    }

    // --- FUNCIONES ESTÁNDAR (RUTAS NORMALES) ---
    function iniciarReparto() {
        var o = $("#formIni").serialize();
        $(location).attr('href', "/Rutas/IniciarReparto?" + o);
    }

    function terminarReparto() {
        var o = $("#formTer").serialize();
        $(location).attr('href', "/Rutas/TerminarReparto?" + o);
    }

    function llenarModal1(DocEntry, DocNum, Cajas, Tickets) {
        $("#M1DocNum").text("Nro: " + DocNum);
        $("#M1DocEntry").val(DocEntry);
        $("#M1Cajas").text(Cajas);
        $("#M1Tickets").text(Tickets);
    }

    function llenarModal2(DocEntry, DocNum) {
        $("#M2DocNum").text("Nro: " + DocNum); $("#M2DocEntry").val(DocEntry);
    }

    function GenerarReporteTemp() {
        var o = $("#frmReporteTemp").serialize();
        window.open("/Rutas/RptControlTemperaturaHumedad?" + o, "_blank");
    }

    // --- FUNCIONES AJAX PARA DEVOLUCIONES (SIN SALIR DE LA PANTALLA) ---

    // 1. Recibir Devolución (Fin del proceso)
    function confirmarRecepcionDevolucion(docEntry) {
        Swal.fire({
            title: '¿Recibir Devolución?',
            text: "¿Confirma la recepción y cierre de esta devolución?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#28a745', // Verde
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="icon-checkmark"></i> Sí, Recibir',
            cancelButtonText: 'Cancelar',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                $.get("/Rutas/RecibirDevolucion", { DocEntry: docEntry })
                    .done(function() {
                        location.reload(); // Recarga la página al terminar
                    })
                    .fail(function() {
                        Swal.fire('Error', 'No se pudo procesar la solicitud.', 'error');
                    });
            }
        })
    }

    // 2. Iniciar Devolución (Inicio Rápido - Sin Modal Temperatura)
    function iniciarDevolucionRapida(docEntry) {
        Swal.fire({
            title: '¿Iniciar Recojo?',
            text: "Se iniciará la ruta de devolución (Estado -> ENVIADO).",
            icon: 'info',
            showCancelButton: true,
            confirmButtonColor: '#28a745',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, Iniciar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                // Envía Temp=0 por AJAX
                $.get("/Rutas/IniciarReparto", { DocEntry: docEntry, TempI1: 0, TempI2: 0 })
                    .done(function() {
                        location.reload(); // Recarga la página al terminar
                    })
                    .fail(function() {
                        Swal.fire('Error', 'No se pudo iniciar la ruta.', 'error');
                    });
            }
        })
    }
</script>

<style>
    .modal-body {
        position: relative;
        -ms-flex: 1 1 auto;
        flex: 1 1 auto;
        padding: 1rem;
    }

    .modal-backdrop {
        background-color: transparent;
    }

    label {
        color: black;
    }

    /* Estilos Móvil */
    .btn-mobile-block {
        display: block;
        width: 100%;
        margin-bottom: 5px;
        font-weight: bold;
        text-align: center;
        padding: 8px;
    }

    @@media (max-width: 768px) {
        .botones-superiores .btn {
            display: block;
            width: 100%;
            margin-left: 0 !important;
            margin-bottom: 5px;
        }

        .botones-superiores {
            padding-left: 1rem !important;
        }
    }
</style>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li class="current"><em>Listado de rutas</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">LISTADO DE RUTAS</h3></div>
    <div class="w-100 p-3 botones-superiores">
        <div class="row mx-0">
            <a href="@Url.Action("NuevaHojaDeReparto", "Rutas",new {TipoRep="Re" })" class="btn btn-success ml-2">Hoja de reparto</a>
            <a href="@Url.Action("NuevaTransferenciaEntreAlmacenes", "Rutas",new {TipoRep="Re" })" class="btn btn-success ml-2">Orden entre almacenes</a>
            <a href="@Url.Action("SolicitudDevolucion", "Rutas",new {TipoRep="Re" })" class="btn btn-success ml-2">Solicitud Devolución</a>
            <button data-toggle="modal" href="#ModalGestion" class="btn btn-warning d-none d-lg-block d-xl-block ml-2"><span>Módulo Gestión</span></button>
            <button type="button" class="btn btn-warning d-none d-lg-block d-xl-block ml-2" data-toggle="modal" data-target="#exampleModal">ReporteTemp</button>
        </div>
    </div>
</div>

<div class="modal" id="ModalGestion" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border border-secondary">
            <div class="modal-header bg-headerModals text-white">
                <h5 class="modal-title" id="moduloGestionModal">MÓDULO PARA GESTIÓN</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span class="text-white" aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body bg-light">
                <div class="d-flex justify-content-center">
                    <a href="@Url.Action("GestionarAgencias", "Repartos",new {TipoRep="Re" })" class="btn bg-cobefar-6 text-white d-none d-lg-block d-xl-block m-1"><i class="icon-home"></i> Agencias</a>
                    <a href="@Url.Action("GestionarOficinas", "Rutas",new {TipoRep="Re" })" class="btn bg-cobefar-6 text-white d-none d-lg-block d-xl-block m-1"><i class="icon-office"></i> Oficinas Courier</a>
                    <a href="@Url.Action("GestionarTarifarios", "Rutas",new {TipoRep="Re" })" class="btn bg-cobefar-6 text-white d-none d-lg-block d-xl-block m-1"><i class="icon-book"></i> Tarifario</a>
                    <a href="@Url.Action("GestionarVehiculos", "Rutas")" class=" btn bg-cobefar-6 text-white d-none d-lg-block d-xl-block m-1"><i class="icon-truck"></i> Vehículos</a>
                </div>
            </div>
        </div>
    </div>
</div>

<form name="frm" id="filterForm">
    <div class="bg-white bg-form-cobefar p-3">
        <table class="table table-light table-sm table-hover cls-dataTable50" cellspacing="0" width="100%">
            <thead class="bg-cobefar-6">
                <tr>
                    <th class="text-center">
                        @Html.DisplayNameFor(model => model.DocNum)<br />
                        @if (o != null && o.DocNum > 0)
                        {<input class="form-control-sm border" type="text" name="DocNum" onchange="filtrar();" value="@o.DocNum" /> }
                        else
                        { <input class="form-control-sm border" type="text" name="DocNum" onchange="filtrar();" />}
                    </th>
                    <th class="text-center">
                        @Html.DisplayName("Tipo")<br />
                        <select name="TipoRuta" class="form-control-sm border" onchange="filtrar();">
                            <option value=""></option>
                            <option value="VC" @if (o != null && o.TipoRuta == "VC") { Write("selected"); }>CENTRO</option>
                            <option value="VD" @if (o != null && o.TipoRuta == "VD") { Write("selected"); }>DOMICILIO</option>
                            <option value="TA" @if (o != null && o.TipoRuta == "TA") { Write("selected"); }>TRASLADOS</option>
                            <option value="VA" @if (o != null && o.TipoRuta == "VA") { Write("selected"); }>ARRIOLA</option>
                            <option value="DE" @if (o != null && o.TipoRuta == "DE") { Write("selected"); }>DEVOLUCION</option>
                        </select>
                    </th>
                    <th class="text-center">
                        Conductor<br />
                        <select name="TransDesc" class="form-control-sm border" onchange="filtrar();">
                            <option value=""></option>
                            @foreach (var x in Conductores)
                            {
                                <option value="@x" @if (o != null && o.TransDesc == x) { Write("selected"); }>@x</option>
}
                        </select>
                    </th>
                    <th class="text-center">
                        @Html.DisplayNameFor(model => model.TiempoPac)<br />
                        @if (o != null && o.TiempoPac != null)
                        {<input type="date" name="TiempoPac" class="form-control-sm border text-center" value="@Convert.ToDateTime(o.TiempoPac).ToString("yyyy-MM-dd")" onchange="filtrar();" /> }
                        else
                        { <input type="date" name="TiempoPac" class="form-control-sm border text-center" onchange="filtrar();" />}
                    </th>
                    <th class="text-center">
                        @Html.DisplayNameFor(model => model.Estado)<br />
                        <select name="Estado" class="form-control-sm border" onchange="filtrar();">
                            <option value=""></option>
                            <option value="CREADO" @if (o != null && o.Estado == "CREADO") { Write("selected"); }>CREADO</option>
                            <option value="ENVIADO" @if (o != null && o.Estado == "ENVIADO") { Write("selected"); }>ENVIADO</option>
                            <option value="TERMINADO" @if (o != null && o.Estado == "TERMINADO") { Write("selected"); }>TERMINADO</option>
                            <option value="DEVUELTO" @if (o != null && o.Estado == "DEVUELTO") { Write("selected"); }>DEVUELTO</option>
                            <option value="ANULADO" @if (o != null && o.Estado == "ANULADO") { Write("selected"); }>ANULADO</option>
                        </select>
                    </th>
                    <th class="text-center">Cajas</th>
                    <th class="text-center" style="width: 200px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Where(x => x.TipoRuta != "VG"))
                {
                    // Limpieza de variables
                    string tipoRuta = (item.TipoRuta ?? "").Trim();
                    string estado = (item.Estado ?? "").Trim();

                    <tr>
                        <td class="text-center @if (ViewBag.DocNum == item.DocNum) { Write("bg-success"); } ">
                            @Html.DisplayFor(modelItem => item.DocNum)
                        </td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.TipoRuta)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.TransDesc)</td>
                        <td class="text-center">
                            @Convert.ToDateTime(item.TiempoPac).ToString("dd/MM/yyyy") <br class="d-md-none" />@Convert.ToDateTime(item.TiempoPac).ToString("HH:mm")
                        </td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.Estado)</td>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.TotalCajas)</td>

                        <td class="text-center" style="min-width: 150px;">
                            @{
                                // --- REGLAS DE VISIBILIDAD ---
                                bool esDE = tipoRuta == "DE";
                                bool esEnviado = estado == "ENVIADO";
                                bool tieneCajas = item.TotalCajas > 0;
                                bool esCreado = estado == "CREADO";

                                bool showIniciar = esCreado;
                                // Botones operativos: Se ocultan en devoluciones
                                bool showEntrega = esEnviado && tieneCajas && !esDE;
                                bool showTerminar = esEnviado && tieneCajas && !esDE;
                                // Botón Recibir: Solo en devoluciones
                                bool showRecibir = esEnviado && esDE;
                            }

                            @* ============================================================ *@
                            @* VISTA MÓVIL (Visible solo d-block d-lg-none)                 *@
                            @* ============================================================ *@
                            <div class="d-block d-lg-none w-100">

                                @* 1. INICIAR (Ancho Completo) *@
                                @if (showIniciar)
                                {
                                    if (esDE)
                                    {
                                        <button type="button" class="btn btn-success btn-block font-weight-bold mb-2 shadow-sm"
                                                onclick="iniciarDevolucionRapida(@item.DocEntry);">
                                            <i class="icon-play"></i> INICIAR RECOJO
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-success btn-block font-weight-bold mb-2 shadow-sm"
                                                data-toggle="modal" data-target="#M1"
                                                onclick="llenarModal1(@item.DocEntry,@item.DocNum,0,0);">
                                            <i class="icon-play"></i> INICIAR
                                        </button>
                                    }
                                }

                                @* 2. ENTREGA (Amarillo) y TERMINAR (Gris) -> 50% / 50% *@
                                @if (showEntrega || showTerminar)
                                {
                                    <div class="d-flex mb-2">
                                        @if (showEntrega)
                                        {
                                            <a href="@Url.Action("ListadoEntregaRepartos", "Rutas", new {TipoRep="Re", DocEntry = item.DocEntry })"
                                               class="btn btn-warning text-dark font-weight-bold flex-fill shadow-sm @(showTerminar ? "mr-1" : "")">
                                                <i class="icon-truck"></i> ENTREGA
                                            </a>
                                        }

                                        @if (showTerminar)
                                        {
                                            <button type="button"
                                                    class="btn btn-secondary font-weight-bold flex-fill shadow-sm @(showEntrega ? "ml-1" : "")"
                                                    data-toggle="modal" data-target="#M2" onclick="llenarModal2(@item.DocEntry, @item.DocNum);">
                                                <i class="icon-flag"></i> TERMINAR
                                            </button>
                                        }
                                    </div>
                                }

                                @* 3. RECIBIR (Verde) -> Ancho Completo (Solo Devoluciones) *@
                                @if (showRecibir)
                                {
                                    <button type="button" class="btn btn-success btn-block font-weight-bold shadow-sm mb-2"
                                            onclick="confirmarRecepcionDevolucion(@item.DocEntry);">
                                        <i class="icon-checkmark"></i> RECIBIR DEVOLUCIÓN
                                    </button>
                                }
                            </div>

                            @* ============================================================ *@
                            @* VISTA ESCRITORIO (Visible solo d-none d-lg-block)            *@
                            @* ============================================================ *@
                            <div class="d-none d-lg-block">
                                @* Solo iconos administrativos. Los botones operativos (Ent, Ter, Recibir) están ocultos aquí *@

                                @if (esCreado || esEnviado)
                                {
                                    <a href="@Url.Action("EditarHojaDeReparto", "Rutas", new { DocEntry = item.DocEntry, TipoRep = "Re" })" class="btn btn-light btn-sm rounded-circle shadow-sm mx-1" data-toggle="tooltip" title="Editar"><i class="icon-pencil text-primary"></i></a>
                                }

                                <a href="@Url.Action( "DocumentoRutas", "Rutas", new { DocEntry = item.DocEntry, TipoRuta = item.TipoRuta } )" class="btn btn-light btn-sm rounded-circle shadow-sm mx-1" data-toggle="tooltip" title="Pdf"><i class="icon-file-pdf text-danger"></i></a>

                                <a href="@Url.Action("SeguimientoRepartoRutas", "Rutas", new { DocEntry = item.DocEntry, Vista="REPARTOS" })" class="btn btn-light btn-sm rounded-circle shadow-sm mx-1 text-dark" data-toggle="tooltip" title="Seguimiento"><i class="icon-truck"></i></a>

                                @if (tipoRuta == "TA")
                                {
                                    <a href="@Url.Action( "AnularOrdenDeRuta", "Rutas", new { DocEntry = item.DocEntry,TipoRep="Re", Estado = item.Estado } )" class="btn btn-light btn-sm mx-1" title="Anular"><i class="icon-blocked text-danger"></i></a>
                                }

                                @if (tipoRuta == "AC" && estado != "TERMINADO")
                                {
                                    <a href="@Url.Action( "TerminarHojaCargo", "Rutas", new { DocEntry = item.DocEntry,TipoRep="Re", Estado = item.Estado } )" class="btn btn-danger btn-sm mx-1"><i title="Terminar HC" class="icon-checkmark"></i></a>
                                }

                                @if (tipoRuta == "AC")
                                {
                                    <a href="@Url.Action("ManifiestoCourier", "Rutas", new { DocEntry = item.DocEntry, Estado = item.Estado})" class="btn btn-danger btn-sm mx-1"><i title="Manifiesto" class="icon-file-pdf"></i></a>
                                    <a href="@Url.Action("AnularHojaCargo", "Rutas", new { DocEntry = item.DocEntry,TipoRep="Re", Estado = item.Estado } )" class="btn btn-orange btn-sm mx-1"><i title="Anular Hoja Cargo" class="icon-blocked"></i></a>
                                }
                            </div>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@* MODAL INICIAR (Para rutas normales) *@
<div class="modal" id="M1" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-headerModals text-white">
                <h5 class="modal-title" id="exampleModalLabel">INICIAR REPARTO</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span class="text-white" aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body bg-light">
                <form id="formIni">
                    <div class="form-group text-center">
                        <label class="bg-cobefar text-white font-weight-bold px-3 py-2 font-18 rounded" id="M1DocNum"></label>
                        <input type="hidden" name="DocEntry" id="M1DocEntry" readonly>
                    </div>
                    <div class="form-group">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="border p-3 rounded bg-white">
                                    <label class="d-block font-weight-bold text-center mb-2">TERMOHIGROMETRO 1</label>
                                    <div class="form-group">
                                        <label for="TempI1" class="font-weight-bold">Temperatura Inicial 1:</label>
                                        <input id="TempI1" type="number" step="0.1" class="form-control border-success" name="TempI1">
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="border p-3 rounded bg-white">
                                    <label class="d-block font-weight-bold text-center mb-2">TERMOHIGROMETRO 2</label>
                                    <div class="form-group">
                                        <label for="TempI2" class="font-weight-bold">Temperatura Inicial 2:</label>
                                        <input id="TempI2" type="number" step="0.1" class="form-control border-success" name="TempI2">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-cobefar" onclick="iniciarReparto();"><i class="icon-checkmark"></i> Sí</button>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="icon-cross"></i> No</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* MODAL TERMINAR *@
<div class="modal" id="M2" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">¿Terminar Reparto?</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span class="text-white" aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body bg-light">
                <form id="formTer">
                    <div class="form-group">
                        <label class="col-form-label" id="M2DocNum"></label><br />
                        <input class="form-control" name="DocEntry" id="M2DocEntry" type="hidden" readonly>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-success" onclick="terminarReparto();"><i class="icon-checkmark"></i> SI</button>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="icon-cross"></i> NO</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* MODAL REPORTE TEMP *@
<form id="frmReporteTemp" method="post">
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-cobefar text-white">
                    <h5 class="modal-title" id="exampleModalLabel">Reporte de control temperatura y humedad</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body text-center">
                    <span style="float:left;margin-left:50px;"><strong>Vehículo</strong></span>
                    <div style="float:right;margin-right:50px;">
                        <select type="text" name="Placa" class="form-control">
                            <option value="">Seleccione</option>
                            @foreach (OVEH_E obj in listaVeh)
                            {
                                <option value="@obj.U_SYP_VEPL">@obj.U_SYP_VEPL</option>
}
                        </select>
                    </div>
                    <br /><br />
                    <span style="float:left;margin-left:50px;"><strong>Fecha Entrega</strong></span>
                    <div style="float:right;margin-right:50px;"><input name="FechaTerEn" type="date" class="form-control" /></div>
                    <br /><br />
                    <span style="float:left;margin-left:50px;"><strong>Termohigrómetro</strong></span>
                    <div style="float:right;margin-right:50px;">
                        <select name="Serie" class="form-control">
                            <option value="SerieT1" selected>T1</option>
                            <option value="SerieT2">T2</option>
                        </select>
                    </div>
                    <br /><br /><br />
                    <div style="float:right;margin-right:50px;">
                        <button type="button" class="btn btn-success" onclick="GenerarReporteTemp();">Generar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    if ('@ViewBag.Mensaje' != "") {
        Swal.fire({ icon: 'info', text: `@ViewBag.Mensaje` })
    }
</script>