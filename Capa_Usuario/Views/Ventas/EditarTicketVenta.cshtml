                                <td>@o.Provincia</td>
                                <td>@o.Departamento</td>
                                <td><button class="btn btn-primary btn-sm" data-dismiss="modal" onclick="agregarDatos('@o.Ubigeo','@o.Distrito','@o.Provincia','@o.Departamento','@o.Zona')">Seleccionar</button></td>
                            </tr>
                        </tbody>

                    }

                </table>
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" data-dismiss="modal" onclick="$('#DirDestino2').val('').prop('readonly', true);$('#Ubigeo2').val('');$('#Distrito2').val('');$('#Provincia2').val('');$('#Departamento2').val(''); reubicarZona('@Model.DirDestino');">Limpiar datos</button>
                <button type="button" class="btn btn-info" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalOficinas" tabindex="-1" role="dialog" aria-labelledby="modalOficinasLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="d-flex mb-4 justify-content-center">
                    <div class="px-2 pt-2 bg-light" style="border-radius: 10px;">
                        <input type="checkbox" id="chk_buscarxdistritoOficicnas" class="form-check-inline" onclick="busqueda($('#busqueda_oficinas').val(),'Oficinas');" /><label for="chk_buscarxdistritoOficicnas" class="text-dark font-weight-bold">Buscar por Distrito</label>
                    </div>

                    <div class="px-2 pt-2 ml-5 bg-light" style="border-radius: 10px;">
                        <input type="checkbox" id="chk_buscarxprovinciaOficinas" class="form-check-inline" onclick="busqueda($('#busqueda_oficinas').val(),'Oficinas');" /><label for="chk_buscarxprovinciaOficinas" class="text-dark font-weight-bold">Buscar por Provincia</label>
                    </div>

                    <div class="px-2 pt-2 ml-5 bg-light" style="border-radius: 10px;">
                        <input type="checkbox" id="chk_buscarxdepartamentoOficinas" class="form-check-inline" onclick="busqueda($('#busqueda_oficinas').val(),'Oficinas');" /><label for="chk_buscarxdepartamentoOficinas" class="text-dark font-weight-bold">Buscar por Departamento</label>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-9"> <input type="text" id="busqueda_oficinas" class="form-control" placeholder="Digite su busqueda" onkeyup="busqueda(this.value,'Oficinas');" /></div>
                    <div class="col-md-3"><button class="btn btn-success" data-dismiss="modal" onclick="$('#DirDestino2').val('');$('#Ubigeo2').val('');$('#Distrito2').val('');$('#Provincia2').val('');$('#Departamento2').val('');">Limpiar datos</button></div>
                </div>
                <br />

                <table id="Oficinas" class="table table-light table-bordered table-hover table-sm text-center table-responsive-md">
                    <thead>
                        <tr style="background-color:steelblue;color:white">
                            <th>Calle</th>
                            <th>Distrito</th>
                            <th>Provincia</th>
                            <th>Departamento</th>
                            <th>Ubigeo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Oficinas)
                        {
                            <tr>
                                <td>@o.Calle</td>
                                <td>@o.Distrito</td>
                                <td>@o.Provincia</td>
                                <td>@o.Departamento</td>
                                <td>@o.Ubigeo</td>
                                <td><button class="btn btn-primary btn-sm" data-dismiss="modal" onclick="agregarDatosOficina('@o.Calle','@o.Ubigeo','@o.Distrito','@o.Provincia','@o.Departamento')">Seleccionar</button></td>
                            </tr>


                        }
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" data-dismiss="modal" onclick="$('#DirDestino2').val('');$('#Ubigeo2').val('');$('#Distrito2').val('');$('#Provincia2').val('');$('#Departamento2').val('');">Limpiar datos</button>
                <button type="button" class="btn btn-info" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
