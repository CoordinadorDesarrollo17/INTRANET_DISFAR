                    <div class="col-md-3"><button class="btn btn-success" data-dismiss="modal" onclick="$('#DirDestino2').val('').prop('readonly', true);$('#Ubigeo2').val(''); $('#Distrito2').val(''); $('#Provincia2').val(''); $('#Departamento2').val(''); reubicarZona('@Model.DirDestino');">Limpiar datos</button></div>
