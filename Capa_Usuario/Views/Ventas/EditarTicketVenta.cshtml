@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E
@using Capa_Entidad.Ventas_ENT.TablasSql;
@using Capa_Entidad.General_ENT.TablasSql;

@{
    ViewBag.Title = "EditarTicketVenta";
    Layout = "~/Views/Shared/_Layout.cshtml";
    OCLR_E clr = (OCLR_E)ViewBag.ClienteRegalo;
    List<UBIG_E> Ubigeos = new List<UBIG_E>(ViewBag.Ubigeos);
    List<OUR1_E> Oficinas = new List<OUR1_E>(ViewBag.Oficinas);
    List<COUR_E> Agencias = new List<COUR_E>(ViewBag.Agencias);
    var usuario = ViewBag.Usuario;
}

<script>
    $(document).ready(function () {
        //verifica los datos del ticket apenas carga la pagina por si hubiera algun error desde la creacion
        verificacionDatos('@Model.Estado');
        //segun el ruc del cliente trae  el desplegable de sus direcciones SAP
        validacionDirDestino('@Model.Estado');
        verificarReclamos();
        //si no existe direccion 2 en la creacion, campo debe estar inhabilitado
        if ($("#Ubigeo2").val()=='') {
             $("#DirDestino2").attr('readonly', true);
        }
        //solo para Agencia, Agencia courier o Domicilio se ocultan o muestran
        //los div que contienen sus datos
        if ("@(Model.LugarDestino)" == 'Agencia'||"@(Model.LugarDestino)" == 'Agencia Courier' ) {
            $("#CamposAgDom").show(); $("#CamposAgencia").show();
        }
        else if ("@(Model.LugarDestino)" == 'Domicilio') {
            $("#CamposAgDom").show(); $("#CamposAgencia").hide();
        }
        else {
            $("#CamposAgDom").hide();
        }

        //considerar la vinculacion de tickets para que sea visible la tabla
        var vinculado = $("#VinculacionTicket").val(); var LugarDestino = $("#LugarDestino").val();
        if (vinculado === "SI" && (LugarDestino === 'Domicilio' || LugarDestino === 'Agencia')) { $("#divVinculados").show(); }
        else { $("#divVinculados").hide(); }

        //Zona pachacamac y lima
        if ($("#Distrito2").val() === 'Pachacamac' || $("#Distrito2").val() === 'Lima' ) {
            $("#Zona").prop("readonly", false);
            if ($("#Distrito2").val() === 'Pachacamac') {
                $("#Zona").attr("list", "opcionesZonaPachacamac");
            }
            else if ($("#Distrito2").val() === 'Lima') {
                $("#Zona").attr("list", "opcionesZonaLima");
            }
        } else {
            $("#Zona").prop("readonly", true);
        }

        //Caso especial para trabajar con Agencia Courier (solo contempla CRUZ DEL SUR):
        if ($("#Agencia").val() == 'CRUZ DEL SUR' && $("#EnvioAgencia").val() == 'Oficina de agencia') {
            $("#btnOficinas").show();
            $("#btn_verTarifario").show();
            $("#btnUbigeo").hide();
        } else {
            $("#btnOficinas").hide();
            $("#btn_verTarifario").hide();
            $("#btnUbigeo").show();
        }
    });

    if ('@ViewBag.Mensaje' != "") {
        Swal.fire('@ViewBag.Mensaje');
    }
    function enviarFormulario() {
        var tipoVenta = $("#TipoVenta").val();
        var lugarDestino = $("#LugarDestino").val();
        var te = $("#TiempoEntrega").val();
        var coordinaciones = $("#Observaciones").val();
        var agencia = $("#Agencia").val();
        var envioagencia = $("#EnvioAgencia").val();
        var referencia = $("#Referencia").val();
        var mensaje = '<div class="my-swal-text">Tipo de Venta: <strong>' + tipoVenta + '</strong><br>Lugar de Destino: <strong>' + lugarDestino + '</strong><br>Coordinaciones: <strong>' + coordinaciones + '</strong><br>T.E: <strong>' + te + '</strong></div>';
        if (lugarDestino === 'Agencia') {

            mensaje = '<div class="my-swal-text">Tipo de Venta: <strong>' + tipoVenta + '</strong><br>Lugar de Destino: <strong>' + lugarDestino + '</strong><br>Coordinaciones: <strong>' + coordinaciones + '</strong><br>T.E: <strong>' + te + '</strong><br>Agencia: <strong>' + agencia + '</strong><br>Modo de envio: <strong>' + envioagencia + '</strong><br>Referencia: <strong>' + referencia + '</strong></div>';
        }
        // Mostrar aviso
        Swal.fire({
            title: 'Confirmación de envío',
            html: mensaje,
            icon: 'info',
            showCancelButton: true,
            confirmButtonText: 'Si, enviar',
            cancelButtonText: 'No, corregir',
            reverseButtons: true,
            showLoaderOnConfirm: true,
            preConfirm: function () {
                $("#EditaTicketVenta").submit();
            },
            allowOutsideClick: () => !Swal.isLoading()
        }).then(function (result) {
            if (result.dismiss === Swal.DismissReason.cancel) {
                Swal.fire({
                    title: 'Cancelado',
                    text: 'Se ha cancelado el envío de datos.',
                    icon: 'error'
                });
            }
        });
    }
    //reclamos ( atencion al cliente )
    function verificarReclamos() {
        var parametros = { "CardCode": $("#CardCode").val(), "DocNumTicket": $("#DocNum").val() };
        $.ajax('/Ventas/comprobarReclamosCliente',
            {
                data: parametros,
                dataType: 'json',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response.length > 0) {
                    $("#ReporteReclamos").html("<button type='button' class='btn btn-danger' onclick='reporteReclamosCliente();'><i class='icon-folder-open''></i> Reclamos</button>")
                }
                else {
                    $("#ReporteReclamos").html("");
                }
            });
    }

    function reporteReclamosCliente() {
        window.open(
            "/Ventas/ReporteReclamosCliente?CardCode=" + $("#CardCode").val() + "&DocNumTicket=" + $("#DocNum").val(),
            null,
            'width=1080,height=450,top=100,left=100,toolbar=no,location=no,status=no,menubar=no'
        );
    }


    function setNroSolicitudReclamo(jsonLista) {
        var lista = JSON.parse(jsonLista);
        document.getElementById('NroSolicitudReclamo').value = lista.join(', ');
        document.getElementById('SolicitudesReclamoSeleccionadas').value = lista.join(',');
    }
</script>
<script src="~/Scripts/Ventas/TicketDeVenta.js"></script>
<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ListadoTicketsVenta", "Ventas")">Listado de tickets</a></li>
            <li class="current"><em>Editar ticket de venta</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">EDITAR TICKET DE VENTA</h3></div>
</div>

<div class="bg-form-pestanas-cobefar pt-4">
    <nav>
        <div class="nav nav-tabs" id="nav-tab" role="tablist">
            <a class="nav-link active" id="nav-datos-pedidos-tab" data-toggle="tab" href="#nav-datos-pedidos" role="tab" aria-controls="nav-datos-pedidos" aria-selected="true">
                Datos Pedido
            </a>
            <a class="nav-link" id="nav-especif-recojo-tab" data-toggle="tab" href="#nav-especif-recojo" role="tab" aria-controls="nav-especif-recojo" aria-selected="false">
                Especificaciones de Recojo
            </a>
            <a class="nav-link" id="nav-det-pedidos-tab" data-toggle="tab" href="#nav-det-pedidos" role="tab" aria-controls="nav-det-pedidos" aria-selected="false">
                Detalles de Pedidos
            </a>
            <a class="nav-link" id="nav-caja-tab" data-toggle="tab" href="#nav-caja" role="tab" aria-controls="nav-caja" aria-selected="false">
                Caja
            </a>
        </div>
    </nav>

    @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "EditaTicketVenta" }))
    {
        
        <div class="tab-content" id="nav-tabContent">

            <div class="tab-pane fade show active" id="nav-datos-pedidos" role="tabpanel" aria-labelledby="nav-datos-pedidos-tab">
                <div class="bg-section-form p-4 bg-form-cobefar">
                    <h2 class="mt-4 text-cobefar font-weight-bold">DATOS PEDIDO</h2>
                    <div class="form-group row pt-4">
                        <div id="infoFechaTicket" class="col-lg-2">
                            <label for="FechaSapTicket" class="text-dark form-label font-weight-bold font-18">@Html.DisplayNameFor(m => m.FechaSapTicket):</label>
                            <input id="FechaSapTicket" type="date" name="FechaSapTicket" value="@Model.FechaSapTicket" class="form-control text-center border-success" readonly>
                        </div>
                        <div class="col-lg-8"></div>
                        <div class="col-lg-2">
                            <label></label>
                            <input type="hidden" id="DocEntry" name="DocEntry" value="@Model.DocEntry" readonly />
                            <input type="text" name="Estado" value="@Model.Estado" class="form-control text-center bg-warning" readonly />
                        </div>
                    </div>

                    <div class="row mt-4">                       

                        <div class="col-lg-2">
                            <label for="DocNum" class="text-dark form-label font-weight-bold font-18">DocNum Ticket:</label>
                            <input type="text" name="DocNum" id="DocNum" value="@Model.DocNum" class="form-control text-center border-success" readonly />
                        </div>

                        <div class="col-lg-2">
                            <label for="TipoVenta" class="text-dark form-label font-weight-bold font-18">Tipo de Venta:</label>
                            @if (usuario == "VENTAS32" || usuario == "VENTAS05")
                            {
                                <select name="TipoVenta" id="TipoVenta" class="form-control bg-cobefar text-white">
                                    <option value="">Seleccione</option>
                                    <option value="Normal" @{ if (Model.TipoVenta == "Normal") { Write("selected"); } }>Normal</option>
                                    <option value="ContraEntrega" @{ if (Model.TipoVenta == "ContraEntrega") { Write("selected"); } }>ContraEntrega</option>
                                    <option value="Credito" @{ if (Model.TipoVenta == "Credito") { Write("selected"); } }>Credito</option>
                                </select>
                            }
                            else
                            {
                                if (Model.TipoVenta != "Credito")
                                {
                                    <select name="TipoVenta" id="TipoVenta" class="form-control bg-cobefar text-white">
                                        <option value="">Seleccione</option>
                                        <option value="Normal" @{ if (Model.TipoVenta == "Normal") { Write("selected"); } }>Normal</option>
                                        <option value="ContraEntrega" @{ if (Model.TipoVenta == "ContraEntrega") { Write("selected"); } }>ContraEntrega</option>
                                    </select>
                                }
                                else
                                { <input type="text" name="TipoVenta" id="TipoVenta" class="form-control text-center border-success" value="@Model.TipoVenta" readonly>}
                            }
                        </div>

                        <div class="col-lg-2">
                            <label for="Embalaje" class="text-dark form-label font-weight-bold font-18">Embalaje:</label>
                            <select name="Embalaje" id="Embalaje" class="form-control  bg-cobefar text-white border-success">
                                <option value="">Seleccione</option>
                                <option value="CL" @{ if (Model.Embalaje == "CL") { Write("selected"); } }>Caja Lima</option>
                                <option value="CP" @{ if (Model.Embalaje == "CP") { Write("selected"); } }>Caja Provincia</option>
                            </select>
                        </div>

                        <div class="col-lg-2">
                            <label for="LugarDestino" class="text-dark form-label font-weight-bold font-18">Lugar destino:</label>
                            <select name="LugarDestino" id="LugarDestino" class="form-control bg-cobefar text-white border-success" onchange="muestraCampo();mostrarOficinas();mostrarTableTicketsVinculados($('#selectVinculado').val()); validarLugarDestino(this.value)">
                                <option value="">Seleccione</option>
                                <option value="Arriola" @{ if (Model.LugarDestino == "Arriola") { Write("selected"); } }>Para Arriola</option>
                                <option value="Agencia" @{ if (Model.LugarDestino == "Agencia") { Write("selected"); } }>Para Agencia</option>
                                <option value="Domicilio" @{ if (Model.LugarDestino == "Domicilio") { Write("selected"); } }>Para Domicilio</option>
                                <option value="Centro" @{ if (Model.LugarDestino == "Centro") { Write("selected"); } }>Para Centro</option>
                                <option value="Agencia Courier" @{ if (Model.LugarDestino == "Agencia Courier") { Write("selected"); } }>
                                    Para Agencia Courier
                                </option>
                            </select>
                        </div>

                        <div id="div_AlmProcedencia" class="col-lg-2" style="@if (Model.AlmProcedencia != null && Model.AlmProcedencia != "") { Write("display: block"); } else { Write("display: none"); } ">
                            <label for="AlmProcedencia" class="text-dark form-label font-weight-bold font-18">Alm. de procedencia:</label>
                            <select name="AlmProcedencia" id="AlmProcedencia" class="form-control bg-cobefar text-white">
                                <option value="">Seleccione</option>
                                <option value="ALM07" @if (Model.AlmProcedencia == "ALM07") { Write("selected"); }>Almacén Nro 6</option>
                                <option value="16" @if (Model.AlmProcedencia == "16") { Write("selected"); }>Almacén Nro 8</option>
                            </select>
                        </div>

                        <div class="col-lg-1">
                            <label for="Presupuesto" class="text-dark form-label font-weight-bold font-18">Presupuesto:</label>
                            <select name="Presupuesto" id="Presupuesto" class="form-control bg-cobefar text-white">
                                <option value="SI" @{ if (Model.Presupuesto == "SI") { Write("selected"); } }>SI</option>
                                <option value="NO" @{ if (Model.Presupuesto == "NO") { Write("selected"); } }>NO</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div id="infoListaClientes" class="col-lg-7">
                            <label for="CardName" class="text-dark form-label font-weight-bold font-18">Cliente:</label>
                            <input type="search" id="CardName" name="CardName" list='ListaClientes' class="form-control border-success" value="@Model.CardName" onchange="buscarClienteRegalo(); verificarReclamos();" autocomplete="off">
                            @if (Request["Tipo"] != null && Request["Tipo"].Equals("PedidoOnline"))
                            {
                                <span class="text-cobefar font-weight-bold">Ticket separado para: </span><span class="text-danger font-weight-bold">@Model.CardName</span>
                            }
                        </div>

                        <div id="infoCliente" class="col-lg-2">
                            <label for="CardCode" class="text-dark form-label font-weight-bold font-18">Código Cliente:</label>
                            <input type="text" id="CardCode" name="CardCode" class="form-control text-center border-success" readonly value="@Model.CardCode">
                        </div>
                    </div>

                    <div id="CamposAgDom">
                        <div class="row mt-4" id="CamposAgencia">
                            <div class="col-lg-3">
                                <label class="text-dark form-label font-weight-bold font-18">Modo de envío:</label>
                                <select name="EnvioAgencia" id="EnvioAgencia" class="form-control bg-cobefar text-white" onchange="mostrarOficinas();">
                                    <option value="">Seleccione</option>
                                    <option value="Oficina de agencia" @{ if (Model.EnvioAgencia == "Oficina de agencia") { Write("selected"); } }>Oficina de agencia</option>
                                    <option value="Domicilio de cliente" @{ if (Model.EnvioAgencia == "Domicilio de cliente") { Write("selected"); } }>Domicilio de cliente</option>
                                </select>
                            </div>

                            <div class="col-lg-3">
                                <label class="text-dark form-label font-weight-bold font-18">Agencia:</label>
                                <input type="text" name="Agencia" id="Agencia" value="@Model.Agencia" class="form-control border-success" list="ListAgencias" autocomplete="off" />
                                <datalist id="ListAgencias">
                                    @foreach (var i in Agencias)
                                    {
                                        <option value="@i.Nombre" />
                                    }
                                </datalist>

                            </div>

                        </div>

                        <div class="row mt-4">
                            <div class="col-lg-9">
                                <label for="DirDestino" class="text-dark form-label font-weight-bold font-18">DirDestino:</label>
                                <select name="DirDestino" id="DirDestino" class="form-control bg-cobefar text-white border-success"
                                        onchange="enviarValSelect('DirDestino', 'Distrito', 'Distrito');enviarValSelect('DirDestino', 'Provincia', 'Provincia');enviarValSelect('DirDestino', 'Departamento', 'Departamento');enviarValSelect('DirDestino', 'Ubigeo', 'Ubigeo');enviarValSelect('DirDestino', 'Calle', 'Calle');enviarValSelect('DirDestino', 'Zona', 'Zona');">
                                    <option value="">Seleccione</option>
                                </select>
                                <input type="hidden" id="Calle" name="Det3[0].Calle" />
                                <input type="hidden" id="Ubigeo" name="Det3[0].Ubigeo" />
                                <input type="hidden" id="Distrito" name="Det3[0].Distrito" />
                                <input type="hidden" id="Provincia" name="Det3[0].Provincia" />
                                <input type="hidden" id="Departamento" name="Det3[0].Departamento" />
                            </div>
                            <div class="col-lg-3">
                                <label class="text-dark form-label font-weight-bold font-18">Zona: </label> @Model.Zona
                                <div class="input-group">
                                    <input type="text" id="Zona" name="Zona" class="form-control text-center border-success" value="@Model.Zona" autocomplete="off">
                                    <div class="input-group-append">
                                        <button type="button" id="borrarZona" onclick="$('#Zona').val('');" class="btn btn-outline-danger">
                                            <i class="icon icon-bin2"></i>
                                        </button>
                                    </div>
                                </div>
                                <datalist id="opcionesZonaPachacamac">
                                    <option value="CONO ESTE2">
                                    <option value="CONO SUR">
                                </datalist>
                                <datalist id="opcionesZonaLima">
                                    <option value="CALLAO">
                                    <option value="CONO CENTRO">
                                </datalist>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-lg-7">
                                <label class="text-dark form-label font-weight-bold font-18">DirDestino2:</label>
                                <input type="text" name="Det3[1].Calle" id="DirDestino2" class="form-control border-success" value="@if (Model.Det3 != null && Model.Det3.Count >= 2 && Model.Det3[1].Calle != null) { Write(Model.Det3[1].Calle); }" autocomplete="off" onkeyup="validarDirDestino2(this.value);" />
                            </div>
                            <div class="col-lg-3 d-flex align-items-end">
                                <button id="btnUbigeo" type="button" class="btn btn-warning mx-2" data-toggle="modal" data-target="#modalUbigeo"><i class="icon icon-location"></i> Selec. Ubigeo</button>
                                <button id="btnOficinas" type="button" class="btn btn-warning mx-2" data-toggle="modal" data-target="#modalOficinas" onclick="buscarOficina()"><i class="icon icon-office"></i> Selec.  Oficina</button>
                                <button id="btn_verTarifario" type="button" class="btn btn-warning mx-2" onclick="verTarifario()"><i class="icon icon-book"></i> Ver Tarifario</button>
                            </div>
                        </div>

                        <div class="row mt-4">

                            @if (Model.Det3 != null && Model.Det3.Count > 1)
                            {
                                if (Model.Det3[1].Ubigeo != null)
                                {
                                    <div class="col-lg-3">
                                        <input type="text" name="Det3[1].Distrito" id="Distrito2" value="@if (Model.Det3.Count >= 1) { Write(Model.Det3[1].Distrito); }" class="form-control text-center border-success" readonly />
                                    </div>
                                    <div class="col-lg-3">
                                        <input type="text" name="Det3[1].Provincia" id="Provincia2" value="@if (Model.Det3.Count >= 1) { Write(Model.Det3[1].Provincia); }" class="form-control text-center border-success" readonly />
                                    </div>
                                    <div class="col-lg-3">
                                        <input type="text" name="Det3[1].Departamento" id="Departamento2" value="@if (Model.Det3.Count >= 1) { Write(Model.Det3[1].Departamento); }" class="form-control text-center border-success" readonly />
                                    </div>
                                    <div class="col-lg-3">
                                        <input type="text" name="Det3[1].Ubigeo" id="Ubigeo2" value="@if (Model.Det3.Count >= 1) { Write(Model.Det3[1].Ubigeo); }" class="form-control text-center border-success" readonly />
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="col-lg-3">
                                    <input type="text" name="Det3[1].Distrito" id="Distrito2" value="" class="form-control text-center border-success" readonly />
                                </div>
                                <div class="col-lg-3">
                                    <input type="text" name="Det3[1].Provincia" id="Provincia2" value="" class="form-control text-center border-success" readonly />
                                </div>
                                <div class="col-lg-3">
                                    <input type="text" name="Det3[1].Departamento" id="Departamento2" value="" class="form-control text-center border-success" readonly />
                                </div>
                                <div class="col-lg-3">
                                    <input type="text" name="Det3[1].Ubigeo" id="Ubigeo2" value="" class="form-control text-center border-success" readonly />
                                </div>
                            }



                        </div>

                        <div class="row mt-4">
                            <div class="col-lg-12">
                                <label class="text-dark form-label font-weight-bold font-18">Referencia:</label>
                                <input type="text" name="Referencia" placeholder="Referencia" id="Referencia" class="form-control border-success" value="@Model.Referencia" />
                            </div>
                        </div>

                    </div>
                </div>
            </div><!-- // TAB 1 -->


            <div class="tab-pane fade" id="nav-especif-recojo" role="tabpanel" aria-labelledby="nav-especif-recojo-tab">
                <div class="bg-section-form p-4 bg-form-cobefar">
                    <h2 class="mt-4 text-cobefar font-weight-bold">ESPECIFICACIONES DE RECOJO</h2>
                    <div class="row mt-4">
                        <input type="hidden" name="Det1[0].Linea" value="1" />
                        <input type="hidden" name="Det1[0].DocEntry" value="@Model.DocEntry" />
                        <div class="col-lg-5">
                            <label for="NombrePer" class="text-dark form-label font-weight-bold font-18">Nombres:</label>
                            <input class="form-control border-success" id="Det1_NombrePer_0" name="Det1[0].NombrePer" type="text" value="@if (Model.Det1 != null && Model.Det1.Count >= 1) { Write(Model.Det1[0].NombrePer); }">
                        </div>

                        <div class="col-lg-2">
                            <label for="TelfPer" class="text-dark form-label font-weight-bold font-18">Teléfono:</label>
                            <input type="number" id="TelfPer" name="Det1[0].TelfPer" class="form-control text-center border-success" value="@if (Model.Det1 != null && Model.Det1.Count >= 1) { Write(Model.Det1[0].TelfPer); }" />
                        </div>

                        <div class="col-lg-3">
                            <label for="TipoDocPer" class="text-dark form-label font-weight-bold font-18">Tipo de Doc:</label>
                            <select name="Det1[0].TipoDocPer" id="TipoDocPer" class="form-control bg-cobefar text-white border-success">
                                <option value="">Seleccione</option>
                                <option value="DNI" @{ if (Model.Det1 != null && Model.Det1.Count >= 1) { if (Model.Det1[0].TipoDocPer == "DNI") { Write("selected"); } } }>DNI</option>
                                <option value="RUC" @{ if (Model.Det1 != null && Model.Det1.Count >= 1) { if (Model.Det1[0].TipoDocPer == "RUC") { Write("selected"); } } }>RUC</option>
