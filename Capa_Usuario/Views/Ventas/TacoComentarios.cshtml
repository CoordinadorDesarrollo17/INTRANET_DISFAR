@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E
@using Capa_Entidad.Ventas_ENT.TablasSql
@{
    Layout = null;
    string fondo = "";
    if (Model.LugarDestino == "Centro")
    {
        fondo = "#90FBED";
    }
    else if (Model.LugarDestino == "Agencia" || Model.LugarDestino == "Agencia Courier" || Model.LugarDestino == "Domicilio")
    {
        fondo = "#F3FF00";
    }
    else if (Model.LugarDestino == "Arriola")
    {
        fondo = "#FD932A";
    }
    // Lista de destinos que requieren Film para MARVISUR
    var destinosFilm = new[] { "TINGO MARÍA", "TOCACHE", "AGUAYTÍA", "PUCALLPA",
                               "CHACHAPOYAS", "RIOJA", "TARAPOTO", "JUANJUÍ",
                               "YURIMAGUAS", "NAUTA", "IQUITOS" };

    // Obtenemos el distrito actual
    string distritoDestino = "";
    if (Model.Det3 != null && Model.Det3.Count > 0)
    {
        // Ajusta el índice si tu distrito está en Det3[1]
        distritoDestino = Model.Det3[0].Distrito?.ToUpper().Trim() ?? "";
    }

    bool esDestinoEspecial = destinosFilm.Contains(distritoDestino);
    bool mostrarObligatorio = false;

    // Caso normal: si isFill == 1, mostrar obligatorio
    if (Model.LugarDestino == "Agencia" && Model.isFill == 1)
    {
        mostrarObligatorio = true;
    }

    // Si es MARVISUR y NO está en la lista → NO obligatorio
    if (Model.LugarDestino == "Agencia" && Model.Agencia == "MARVISUR" && !esDestinoEspecial)
    {
        mostrarObligatorio = false;
    }

    // Si es MARVISUR y está en la lista → SÍ obligatorio (aunque isFill sea 0)
    if (Model.LugarDestino == "Agencia" && Model.Agencia == "MARVISUR" && esDestinoEspecial)
    {
        mostrarObligatorio = true;
    }
}
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" charset="utf-8" />
    <title>TacoComentarios</title>
</head>
<body>
    <table border="1" width="100%">
        <tr style="background:@fondo">
            <td>
                <strong>@Html.DisplayNameFor(model => model.LugarDestino): </strong>

                @if (Model.LugarDestino == "Agencia" && !string.IsNullOrWhiteSpace(Model.Agencia))
                {
                    @Model.LugarDestino <span> - </span> @Model.Agencia
                }
                else
                {
                    @Html.DisplayFor(model => model.LugarDestino)
                }
            </td>
            <td style="text-align:center;"><strong>@Html.DisplayNameFor(model => model.Zona): </strong><br />@Model.Zona</td>
        </tr>

        @if (mostrarObligatorio)
        {
            <tr style="background:@fondo">
                <td colspan="2" style="text-align:center;">
                    <strong>Film: </strong>
                    <span style="color:red;font-weight:bold;">OBLIGATORIO</span>
                </td>
            </tr>
        }

        <tr style="background:@fondo">
            <td width="30%"><strong>@Html.DisplayNameFor(model => model.DocNum): </strong></td>
            <td width="75%">@Html.DisplayFor(model => model.DocNum)</td>
        </tr>
        <tr style="background:@fondo">
            <td><strong>@Html.DisplayNameFor(model => model.CardName): </strong></td>
            <td>@Html.DisplayFor(model => model.CardName)</td>
        </tr>
        <tr style="background:@fondo">
            <td><strong>@Html.DisplayNameFor(model => model.TiempoEntrega): </strong></td>
            <td>@Convert.ToDateTime(Model.TiempoEntrega).ToString("dd/MM/yyyy hh:mm tt")</td>
        </tr>
        <tr style="background:@fondo">
            <td><strong>@Html.DisplayNameFor(model => model.MontoTotal): </strong></td>
            <td>S/ @Html.DisplayFor(model => model.MontoTotal)</td>
        </tr>
        <tr style="background:@fondo">
            <td><strong>OrdenesVenta(@Model.Det2.Count()): </strong></td>
            <td>
                @foreach (RTV2_E d in Model.Det2)
                {
                    @(d.NroSap + ", ")
                }
            </td>
        </tr>
        <tr style="background:@fondo">
            <td><strong>@Html.DisplayNameFor(model => model.Embalaje): </strong></td>
            @if (Model.Embalaje != null)
            {
                if (Model.Embalaje.Equals("CP"))
                {
                    <td>Caja provincia</td>
                }
                else if (Model.Embalaje.Equals("CL"))
                {
                    <td>Caja lima</td>
                }
            }
        </tr>
        <tr>
            <td><strong>@Html.DisplayNameFor(model => model.Vendedor): </strong></td>
            <td>@Html.DisplayFor(model => model.Vendedor)</td>
        </tr>
        <tr style="background:@fondo">
            <td><strong>@Html.DisplayNameFor(model => model.Observaciones): </strong></td>
            <td width="50%">@Html.DisplayFor(model => model.Observaciones)/@Html.DisplayFor(model => model.Observaciones3)</td>
        </tr>
        <tr>
            <td><strong>Sacador: </strong></td>
            <td>@Html.DisplayFor(model => model.OpSacando)</td>
        </tr>
        <tr>
            <td><strong>Verificador: </strong></td>
            <td>@Html.DisplayFor(model => model.OpVerificado)</td>
        </tr>
        <tr>
            <td><strong>Empacador: </strong></td>
            <td>@Html.DisplayFor(model => model.OpEmpacado)</td>
        </tr>
        <tr>
            <td><strong># Mesa: </strong></td>
            <td></td>
        </tr>

        @if (Model.LugarDestino != "Centro" && Model.Det3 != null && Model.Det3.Count >= 2)
        {
            if (!string.IsNullOrWhiteSpace(Model.Det3[1].Calle) && Model.Det3[1].Calle.Length > 0)
            {
                if (Model.LugarDestino == "Agencia" || Model.LugarDestino == "Agencia Courier")
                {
                    if (Model.EnvioAgencia == "Oficina de agencia")
                    {
                        <tr>
                            <td colspan="2">
                                @Model.Det3[1].Distrito-@Model.Det3[1].Provincia-@Model.Det3[1].Departamento
                                @if (Model.Referencia != null)
                                {<b>REF.: @Model.Referencia.ToUpper()</b>}
                            else if (Model.Det3[1].Calle != null)
                            { @Model.Det3[1].Calle.ToUpper()}
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td colspan="2">
                                @Model.Det3[1].Calle  @if (Model.Referencia != null)
                                {<b>REF.:@Model.Referencia.ToUpper()</b>}
                            </td>
                        </tr>
                    }
                }
                else
                {

                    if (Model.EnvioAgencia == "Oficina de agencia")
                    {
                        if (Model.Det3 != null && Model.Det3.Count > 0)
                        {
                            <tr>
                                <td colspan="2">@Model.Det3[0].Distrito - @Model.Det3[0].Provincia - @Model.Det3[0].Departamento </td>
                            </tr>
                        }
                    }
                    else
                    {
                        if (Model.Det3 != null && Model.Det3.Count > 1)
                        {
                            <tr>
                                <td colspan="2">@Model.Det3[1].Distrito - @Model.Det3[1].Provincia - @Model.Det3[1].Departamento </td>
                            </tr>
                        }
                    }
                }
            }

        }
        else if (!string.IsNullOrWhiteSpace(Model.DirDestino) && Model.DirDestino.Length > 0)
        {
            if (Model.LugarDestino == "Agencia" || Model.LugarDestino == "Agencia Courier")
            {
                if (Model.EnvioAgencia == "Oficina de agencia")
                {
                    if (Model.Det3 != null && Model.Det3.Count > 0)
                    {
                        <tr>
                            <td colspan="2">
                                @Model.Det3[0].Distrito - @Model.Det3[0].Provincia - @Model.Det3[0].Departamento
                                @if (Model.Referencia != null)
                                {<b>REF.: @Model.Referencia.ToUpper()</b>}
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2">
                            @Model.DirDestino @if (Model.Referencia != null)
                            {<b>REF.: @Model.Referencia.ToUpper()</b>}
                        </td>
                    </tr>
                }
            }
            else
            {
                if (Model.EnvioAgencia == "Oficina de agencia")
                {
                    if (Model.Det3 != null && Model.Det3.Count > 0)
                    {
                        <tr>
                            <td colspan="2">@Model.Det3[0].Distrito-@Model.Det3[0].Provincia-@Model.Det3[0].Departamento</td>
                        </tr>
                    }

                }
                else
                {
                    <tr>
                        <td colspan="2">@Model.DirDestino</td>
                    </tr>
                }

            }
        }

        <tr>
            <td><strong>@Html.DisplayNameFor(model => model.Comentario): </strong></td>
            <td width="50%">@Html.DisplayFor(model => model.Comentario)</td>
        </tr>

        @if (Model.Det5 != null && Model.Det5.Count >= 1)
        {
            if (Model.Det5[0].IdReg > 0)
            {
                string fondoReg = "";
                if (Model.Det5[0].RegTipo.ToLower() == "a") { fondoReg = "#C8E3F3"; }
                else if (Model.Det5[0].RegTipo.ToLower() == "b") { fondoReg = "#F2F526"; }
                else if (Model.Det5[0].RegTipo.ToLower() == "c") { fondoReg = "#F1EFDD"; }
                else if (Model.Det5[0].RegTipo.ToLower() == "d") { fondoReg = "#D6B581"; }
                else if (Model.Det5[0].RegTipo.ToLower() == "e") { fondoReg = "skyblue"; }
                <tr style="background:@fondoReg">
                    <td>
                        <strong>Regalo</strong>
                    <td>
                        @if (Model.Det5[0].IdReg == 16)
                        {
                            @(Math.Round(Model.Det5[0].RegCant, 0) + " " + Model.Det5[0].RegCate + " (X 6 UND)")
                        }
                        else
                        {
                            @(Math.Round(Model.Det5[0].RegCant, 0) + " " + Model.Det5[0].RegCate + " " + Model.Det5[0].RegTipo)
                        }
                    </td>

                </tr>
            }
        }
    </table>

</body>
</html>