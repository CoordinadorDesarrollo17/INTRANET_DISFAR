                        <td style="@styleEmitirGuias">
                            <a href="@Url.Action( "SeguimientoDeTicket", "Ventas", new { DocEntry = item.DocEntry  } )" type="button" target="_blank" class="btn btn-sm btn-light" title="Seguimiento de ticket" data-toggle="tooltip" data-placement="top"
                               onclick="window.open(this.href,this.target,'width=1200,height=650,top=120,left=100,toolbar=no,location=no,status=no,menubar=no'); return false;">
                                <i class="icon-truck"></i>
                            </a>
                        </td>
                        <td style="@styleEmitirGuias">
                            @if (item.EstadoFacturacion == "GRE EMITIDA" || item.EstadoFacturacion == "FACTURADO")
                            {
                                <button type="button" class="btn btn-sm btn-light" onclick="abrirModalGuias(@item.DocEntry)" data-toggle="tooltip" data-placement="top" title="Ver Guías">
                                    <span class="text-orange">Guia</span>
                                </button>
                            }
                        </td>
                        <td style="@styleEmitirGuias">
                            @if (item.EstadoFacturacion == "FACTURADO")
                            {
                                <button type="button" class="btn btn-sm btn-light" onclick="abrirModalFB(@item.DocEntry)" data-toggle="tooltip" data-placement="top" title="Ver Facturas">
                                    <span class="text-darkblue">Factura</span>
                                </button>
                            }
                        </td>
                        <td style="@styleEmitirGuias">
                            @{
                                var validStates = new List<string> { "PICKEANDO", "VERIFICANDO", "EMPACANDO", "EMPACADO", "PREENVIO", "ENVIADO", "PESADO", "ENTREGADO" };
                                if (item.LugarDestino != null && validStates.Contains(item.Estado))
                                {

                                    <button type="button" onclick="generarHtmlComprobantes(@item.DocEntry,'@item.Estado','@item.LugarDestino');"
                                            class="btn btn-light btn-sm text-danger"
                                            data-placement="top"
                                            title="Descargar Comprobantes"
                                            data-toggle="tooltip">
                                        <i class="icon icon-download"></i>
                                    </button>
                                }
                            }
                        </td>
                        <td style="@styleEmitirGuias">
                            <a href="#" class="btn btn-light" data-toggle="tooltip" data-placement="top" title="Imprimir" onclick="abrirModalImpresion(@item.DocEntry, '@item.Estado', '@item.LugarDestino');">
                                <i class="icon-printer text-cobefar"></i>
                            </a>
                        </td>
                        <td style="@styleEmitirGuias">
                            <a href="#" class="btn btn-light" data-toggle="tooltip" data-placement="top" title="Observación" onclick="cargarObservacion(@item.DocEntry); $('#modalObservacion_@item.DocEntry').modal('show'); return false;">
                                <span class="icon icon-bubble2 text-primary"></span>
                            </a>
                            <!-- Modal Observación -->
                            <div class="modal fade" id="modalObservacion_@item.DocEntry" tabindex="-1" role="dialog" aria-labelledby="modalObservacionLabel_@item.DocEntry" aria-hidden="true">
                                <div class="modal-dialog" role="document">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalObservacionLabel_@item.DocEntry">Observación para Ticket @item.DocNum</h5>
                                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                <span aria-hidden="true">&times;</span>
                                            </button>
                                        </div>
                                        <div class="modal-body">
                                            <textarea class="form-control" id="observacion_@item.DocEntry" rows="3" placeholder="Ingrese su observación aquí..." maxlength="400" oninput="validarObservacionInput(@item.DocEntry)"></textarea>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-primary" onclick="guardarObservacion(@item.DocEntry)">Guardar</button>
                                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @* 🆕 BOTÓN INDEPENDIENTE: FACTURAR SIN GUÍAS *@
                            @if (item.ProductoPendiente == 0 && (item.EstadoFacturacion == "PENDIENTE"))
                            {
                                <a class="btn btn-sm btn-outline-warning ms-1"
                                   data-bs-toggle="tooltip"
                                   title="Facturar sin validar guías (casos especiales)"
                                   onclick="confirmarFacturarSinGuias(@item.DocEntry)">
                                    <i class="bi bi-exclamation-triangle"></i>
                                </a>

                            }
                        </td>
                        <td style="@styleEmitirGuias"></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>


<!-- Modal de documentos contables -->
<div id="comprobantesModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header bg-headerModals text-light">
                <h5 class="modal-title"><strong>Documentos de ticket</strong></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-light">&times;</span>
                </button>
            </div>
            <div id="modal-body-comprobantes" class="modal-body">
                @*Contenido de modal llega desde function js*@
            </div>
        </div>
    </div>
</div>


<!-- Modal de Impresión -->
<div id="modalImpresion" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title"><strong>Seleccionar Tipo de Impresión</strong></h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center">
                <p class="mb-4">¿Qué documento desea imprimir?</p>
                <div class="btn-group-vertical w-100" role="group">
                    <button type="button" class="btn btn-outline-primary btn-lg mb-2" onclick="imprimirDocumento('guia')">
                        <i class="icon icon-file-text2"></i> Imprimir Guía
                    </button>
                    <button type="button" class="btn btn-outline-success btn-lg" onclick="imprimirDocumento('factura')">
                        <i class="icon icon-file-text2"></i> Imprimir Factura
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>