                                }
                                else
                                {
                                    if (item.Estado.Equals("EMPACADO") || item.Estado.Equals("PESADO"))
                                    {
                                        <a href="#" class="btn btn-danger btn-sm" onclick="cancelarTicket(@item.DocEntry);"><i title="CANCELAR" class="icon-cross text-light"></i></a>
                                    }
                                }
                            }
                        </td>*@
                        <td>
                            @if ((item.Estado.Equals("PICKEANDO")|| item.Estado.Equals("VERIFICANDO")|| item.Estado.Equals("EMPACANDO") || item.Estado.Equals("EMPACADO") || item.Estado.Equals("PESADO") || item.Estado.Equals("PREENVIO") || item.Estado.Equals("ENVIADO") || item.Estado.Equals("ENTREGADO")) && item.LugarDestino.Equals("Agencia"))
                            {
                                <a href="@Url.Action( "PdfRotuladoTicket", "Ventas", new { DocEntry = item.DocEntry  } )" title="Rotulado">
                                    <i class="icon-file-pdf text-danger bordered mt-2 font-30"></i>
                                </a>
                            }
                            else if ((item.Estado.Equals("EMPACADO") || item.Estado.Equals("PREENVIO") || item.Estado.Equals("ENVIADO") || item.Estado.Equals("ENTREGADO")) && !item.LugarDestino.Equals("Agencia"))
                            {
                                <a href="@Url.Action( "PdfTacoEmpaque", "Ventas", new { DocEntry = item.DocEntry  } )" title="TacoEmpaque">
                                    <i class="icon-file-pdf text-danger bordered mt-2 font-30"></i>
                                </a>
                            }
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action( "SeguimientoDeTicket", "Ventas", new { DocEntry = item.DocEntry  } )" type="button" target="_blank" class="btn btn-dark btn-sm"
                               onclick="window.open(this.href,this.target,'width=1200,height=650,top=120,left=100,toolbar=no,location=no,status=no,menubar=no');return false;">
                                <i title="Seguimiento de ticket" class="icon-truck"></i>
                            </a>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </form>

    <!-- Modal -->
    <div class="modal fade" id="modalReporte" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-cobefar text-white">
                    <h5 class="modal-title" id="exampleModalLabel">Reporte - Errores de Picking</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true" class="text-white">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="frm_rptErroresPicking">
                        <div class="row mb-4">
                            <div class="col-lg-3 col-md-3">
                                <label class="text-cobefar font-weight-bold">Fecha Ticket Desde:</label>
                                <input type="date" id="FechaTicketDesdeEP" name="FechaTicketDesdeEP" class="form-control border-success text-center" />
                            </div>

                            <div class="col-lg-3 col-md-3">
                                <label class="text-cobefar font-weight-bold">Fecha Ticket Hasta:</label>
                                <input type="date" id="FechaTicketHastaEP" name="FechaTicketHastaEP" class="form-control border-success text-center" />
                            </div>

                            <div class="col-lg-3 col-md-3">
                                <label class="text-cobefar font-weight-bold">Estado:</label>
                                <select type="text" id="EstadoEP" name="EstadoEP" class="form-control bg-cobefar text-white" autocomplete="off">
                                    <option value="1">Activos</option>
                                    <option value="0">Inactivos</option>
                                    <option value="">Todos</option>
                                </select>
                            </div>

                            <div class="col-lg-3">
                                <label class="text-cobefar font-weight-bold">Nro Ticket:</label>
                                <input type="text" id="DocNumTicketEP" name="DocNumTicketEP" class="form-control border-success text-center cls-numeric" />
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-lg-12 d-flex justify-content-end">
                                <button type="button" class="btn btn-cobefar mb-2" onclick="validarFiltrosReporte()"><i class="icon-checkmark"></i> Generar Reporte</button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btn_cerrarModal" class="btn btn-secondary" data-dismiss="modal"><i class='icon-cross'></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>

