@model IEnumerable<dynamic>
@{
    ViewBag.Title = "ListadoTicketsAutorizacionRegularizar";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
}
<script>
    function autorizarContraEntrega(docNumTicket, idOtc) {
        var data = {
            idOTC: idOtc,
            docNum: docNumTicket
        };

        $.ajax({
            type: 'POST',
            url: '@Url.Action("RegularizarAutorizacion", "Ventas")',
            data: data,
            success: function (response) {
                Swal.fire({
                    icon: 'success',
                    title: response.Mensaje,
                    showConfirmButton: false,
                    timer: 1500
                }).then(() => {
                    location.reload();
                });
            }
        });
    }
</script>

<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ListadoTicketsVenta", "Ventas")">Listado de Tickets</a></li>
            <li class="current"><em>Listado de Tickets por regularizar</em></li>
        </ol>
    </nav>
</div>
<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">

    <div class="mx-2 d-flex justify-content-between px-3 pt-3">
        <div>
            <h3 class="titulo-seccion">TICKETS POR REGULARIZAR AUTORIZACION</h3>
        </div>
    </div>

</div>
<div class="bg-white px-3 py-3 align-items-center">
    <div class="bg-white bg-form-cobefar pt-2">
        <table class="table table-hover table-sm table-hover cls-dataTable50 font-14 w-100" cellspacing="0" width="100%" style="border-radius:8px; border-collapse:separate; ">
            <thead class="thead-cobefar bg-cobefar-6 text-white">
                <tr>
                    <th class="text-center border-end border-start">Ticket</th>
                    <th class="text-center border-end">Cliente</th>
                    <th class="text-center border-end">TipoPago</th>
                    <th class="text-center border-end">Estado</th>
                    <th class="text-center border-end">Monto Efectivo</th>
                    <th class="text-center border-end">Monto Deposito</th>
                    <th class="text-center border-end">Suma</th>
                    <th class="text-center border-end">Registro</th>
                    <th class="text-center border-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center border-end border-start">@item.DocNumTicket</td>
                        <td class="text-center border-end" style="max-width:200px">@item.CardName</td>
                        <td class="text-center border-end">@item.TipoPago</td>
                        <td class="text-center border-end">@item.Estado</td>
                        <td class="text-center border-end">@item.MontoRecibidoEfectivo</td>
                        <td class="text-center border-end">@item.MontoRecibidoDeposito</td>
                        <td class="text-center border-end">@item.Suma</td>
                        <td class="text-center border-end">@item.Registro.Substring(0, Math.Min(10, @item.Registro.Length))</td>
                        <td class="text-center border-end">
                            <a href="#" onclick="autorizarContraEntrega(@item.DocNumTicket,@item.IdOTC);" class="btn btn-light" data-bs-toggle="tooltip" data-bs-placement="top" title="Autorizar">
                                <i class="bi bi-check-lg text-success"></i>
                            </a>
                        </td>                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>



