@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E
@using Capa_Entidad.Ventas_ENT.TablasSql;
@using Capa_Entidad.Seguridad_ENT
@{
    ViewBag.Title = "SeguimientoDeTicket";
    Layout = "~/Views/Shared/_Layout.cshtml";
    Usuario_E user = (Usuario_E)Session["UsuarioId"];
    Dictionary<string, CC_ORTV_E> flujoEstados = new Dictionary<string, CC_ORTV_E>(ViewBag.flujoEstadosTicket);
}

<script>
    $(document).ready(function () {
        $("#btnEdit").hide();
        if (@user.IdRol== 1 || @user.IdRol== 6) {
            $("#btnEdit").show();
        }
        var vinculado = $("#VinculacionTicket").val();
        if (vinculado == "SI") { $("#divVinculados").show(); }
        else { $("#divVinculados").hide(); }
    });
</script>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-dark">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ListadoTickets", "Ventas")">Listado de tickets</a></li>
            <li class="current"><em>Seguimiento de ticket</em></li>
        </ol>
    </nav>
</div>

<div class="bg-dark border-cabecera-seccion pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">SEGUIMIENTO DE TICKET</h3></div>
    <div class="d-flex pl-2 w-100 py-2">

        <div id="btnEdit" class="mx-2">
            <a class="btn btn-warning" href="@Url.Action("EditarTicketVentaSup", "Ventas", new { DocEntry=Model.DocEntry})">
                <i class="icon icon-pencil"></i><span class="font-weight-bold"> Editar Encabezado</span>
            </a>
        </div>

        @if (@Request["view"] == "despacho" && @ViewBag.BtnNuevaSolicitud == true)
        {
            <div class="mx-2">
                <a class="btn btn-info" href="@Url.Action("NuevaSolicitud", "AtencionCliente", new { DocNumTicket = Model.DocNum})" target="_blank">
                    <i class="icon icon-plus"></i><span class="font-weight-bold"> Nueva Solicitud</span>
                </a>
            </div>
        }

    </div>
</div>


<div class="bg-form-pestanas-cobefar pt-4">
    <nav>
        <div class="nav nav-tabs" id="nav-tab" role="tablist">
            <a class="nav-link active" id="nav-flujo-estados-tab" data-toggle="tab" href="#nav-flujo-estados" role="tab" aria-controls="nav-flujo-estados" aria-selected="true">
                Flujo de Estados
            </a>
            <a class="nav-link" id="nav-datos-pedidos-tab" data-toggle="tab" href="#nav-datos-pedidos" role="tab" aria-controls="nav-datos-pedidos" aria-selected="false">
                Datos Pedido
            </a>
            <a class="nav-link" id="nav-especif-recojo-tab" data-toggle="tab" href="#nav-especif-recojo" role="tab" aria-controls="nav-especif-recojo" aria-selected="false">
                Especificaciones de Recojo
            </a>
            <a class="nav-link" id="nav-det-pedidos-tab" data-toggle="tab" href="#nav-det-pedidos" role="tab" aria-controls="nav-det-pedidos" aria-selected="false">
                Detalles de Pedidos
            </a>
            <a class="nav-link" id="nav-caja-tab" data-toggle="tab" href="#nav-caja" role="tab" aria-controls="nav-caja" aria-selected="false">
                Caja
            </a>
        </div>
    </nav>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
