                                        <div class="bg-danger text-center font-12">
                                            <p class="text-white">Ticket CANCELADO</p>
                                        </div>
                                        <div class="timestamp">
                                            <span class="author font-12 text-danger font-weight-bold">@flujoEstados["CANCELAR"].Operario.Substring(0, 12) </span>
                                            <span class="date text-center font-12"><i class="icon icon-calendar text-danger"></i> @flujoEstados["CANCELAR"].FechaOperacion<br /><i class="icon icon-clock text-danger"></i> @flujoEstados["CANCELAR"].HoraOperacion</span>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    }

