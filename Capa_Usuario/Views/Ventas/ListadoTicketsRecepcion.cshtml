@model IEnumerable<Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E>
@using Capa_Entidad.Ventas_ENT.TablasSql
@{
    ViewBag.Title = "ListadoTicketsRecepcion";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";

    String bgEstadoPago = "bg-cobefar-6 text-white", bgLugarDestino = "bg-cobefar-6 text-white", bgAlmProcedencia = "bg-cobefar-6 text-white";

    if (ViewBag.Ortv.EstadoPago != "" && ViewBag.Ortv.EstadoPago != null)
    {
        bgEstadoPago = "bg-warning";
    }

    if (ViewBag.Ortv.LugarDestino != "" && ViewBag.Ortv.LugarDestino != null)
    {
        bgLugarDestino = "bg-warning";
    }
    if (ViewBag.Ortv.AlmProcedencia != "" && ViewBag.Ortv.AlmProcedencia != null)
    {
        bgAlmProcedencia = "bg-warning";
    }

}
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/slim-select@2.13.1/dist/slimselect.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/slim-select@2.13.1/dist/slimselect.umd.js"></script>
<script>
    // Filtra los resultados del formulario
    function filtrar() {
        var form = document.getElementById("frm");
        var params = new URLSearchParams(new FormData(form)).toString();
        window.location.href = "/Ventas/ListadoTicketsRecepcion?" + params;
    }

    // Muestra confirmación y cancela el ticket si se confirma
    function cancelarTicket(docEntry) {
        const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
                confirmButton: 'btn btn-success mx-4',
                cancelButton: 'btn btn-danger mx-4'
            },
            buttonsStyling: false
        });

        swalWithBootstrapButtons.fire({
            title: '¿Está seguro(a) de cancelar el ticket?',
            text: "Este proceso es irreversible",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: "<i class='bi bi-check-lg'></i> Si, estoy seguro(a)",
            cancelButtonText: "<i class='bi bi-x-lg'></i> No",
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Ventas/CancelarTicket?DocEntry=' + docEntry + '&vista=ListadoTicketsRecepcion';
            }
        });
    }

    // Muestra mensaje si existe
    if ('@ViewBag.Mensaje' !== "") {
        Swal.fire('@ViewBag.Mensaje');
    }

    // Descarga el PDF de Taco Comentarios
    function descargarTacoComentarios(docEntry) {
        window.location.href = '/Ventas/PdfTacoComentarios?DocEntry=' + docEntry;
    }

    // Inicialización robusta de SlimSelect para los filtros cuando el DOM esté listo
    document.addEventListener("DOMContentLoaded", function () {
        console.log("DOM completamente cargado");
        if (document.getElementById('EstadoPago')) {
            new SlimSelect({
                select: '#EstadoPago',
                settings: { showSearch: false },
                events: { afterChange: filtrar }
            });
        }
        if (document.getElementById('LugarDestino')) {
            new SlimSelect({
                select: '#LugarDestino',
                settings: { showSearch: false },
                events: { afterChange: filtrar }
            });
        }
        if (document.getElementById('AlmProcedencia')) {
            new SlimSelect({
                select: '#AlmProcedencia',
                settings: { showSearch: false },
                events: { afterChange: filtrar }
            });
        }
    });
</script>



<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ListadoTicketsRecepcion", "Ventas")">Listado tickets recepción</a></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion"> LISTADO TICKETS RECEPCIÓN</h3></div>
</div>
<div class="bg-white px-3 py-3 align-items-center">
    <div class="col-12">
        <form id="frm">
            <div class="row justify-content-start align-items-center">
                <div class="col-md-2 col-sm-6 mb-2">
                    <select name="EstadoPago" id="EstadoPago" class="form-control form-control-sm">
                        <option value="">Estado Pago</option>
                        <option value="PENDIENTE" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.EstadoPago == "PENDIENTE") { Write("selected"); } }>Pendiente</option>
                        <option value="PAGADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.EstadoPago == "PAGADO") { Write("selected"); } }>Pagado</option>
                    </select>
                </div>
                <div class="col-md-2 col-sm-6 mb-2">
                    <select name="LugarDestino" id="LugarDestino" class="form-control form-control-sm ">
                        <option value="">Lugar de Destino</option>
                        <option value="Arriola" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.LugarDestino == "Arriola") { Write("selected"); } }>Arriola</option>
                        <option value="Agencia" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.LugarDestino == "Agencia") { Write("selected"); } }>Agencia</option>
                        <option value="Domicilio" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.LugarDestino == "Domicilio") { Write("selected"); } }>Domicilio</option>
                        <option value="Centro" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.LugarDestino == "Centro") { Write("selected"); } }>Centro</option>
                    </select>
                </div>
                <div class="col-md-3 col-sm-6 mb-2">
                    <select name="AlmProcedencia" id="AlmProcedencia" class="form-control form-control-sm ">
                        <option value="">Almacén de procedencia</option>
                        <option value="16" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.AlmProcedencia == "16") { Write("selected"); } }>ALMACÉN Nº5</option>
                        <option value="ALM07" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.AlmProcedencia == "ALM07") { Write("selected"); } }>ALMACÉN Nº3</option>
                        <option value="03" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.AlmProcedencia == "03") { Write("selected"); } }>ALMACÉN Nº1</option>
                    </select>
                </div>
            </div>
            <div class="bg-white bg-form-cobefar">
                <table class="table table-sm table-hover cls-dataTable50 font-14" width="100%" cellspacing="0">
                    <thead class="thead-cobefar bg-cobefar-6 text-white">
                        <tr>
                            <th class="text-center border-start border-end">
                                @Html.DisplayNameFor(model => model.DocNum)
                                <br />
                                @if (ViewBag.Ortv != null && ViewBag.Ortv.DocNum > 0)
                                {
                                    <input type="text" name="DocNum" class="form-control-sm border w-75" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" value="@ViewBag.Ortv.DocNum" autocomplete="off" />
                                }
                                else
                                {
                                    <input type="text" name="DocNum" class="form-control-sm border w-75" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" />
                                }
                            </th>
                            <th class="text-center border-end">
                                Fecha ticket
                                <br />
                                @if (ViewBag.Ortv != null && ViewBag.Ortv.FechaSapTicket != null)
                                {
                                    <input type="date" name="FechaSapTicket" style="font-size:12px;" class="form-control-sm border" value="@ViewBag.Ortv.FechaSapTicket" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" />
                                }
                                else
                                {
                                    <input type="date" name="FechaSapTicket" style="font-size:12px;" class="form-control-sm border" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" />
                                }
                            </th>
                            <th class="text-center border-end">
                            <span class="pl-2">@Html.DisplayNameFor(model => model.CardName)</span>
                                @if (ViewBag.Ortv != null && ViewBag.Ortv.CardName != null)
                                {
                                    <input type="text" name="CardName" class="form-control-sm border w-100" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" value="@ViewBag.Ortv.CardName" autocomplete="off" />
                                }
                                else
                                {
                                    <input type="text" name="CardName" class="form-control-sm border w-100" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" />
                                }
                            </th>
                            <th class="text-center border-end">Orden de venta SAP</th>
                            <th class="text-center border-end">
                                @Html.DisplayNameFor(model => model.Vendedor)
                                <br />
                                @if (ViewBag.Ortv != null && ViewBag.Ortv.Vendedor != null)
                                {
                                    <input type="text" name="Vendedor" class="form-control-sm border" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" value="@ViewBag.Ortv.Vendedor" />
                                }
                                else
                                {
                                    <input type="text" name="Vendedor" class="form-control-sm border" onchange="filtrar();" onkeypress="if(event.keyCode==13){filtrar();return false;}" />
                                }
                            </th>
                            <th class="text-center border-end">
                                Monto total
                            </th>
                            <th class="text-center border-end">
                                @Html.DisplayNameFor(model => model.Estado)
                                <br />
                                <select name="Estado" id="Estado" class="form-control-sm border" onchange="filtrar();">
                                    <option value=""></option>
                                    <option value="ABIERTO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "ABIERTO") { Write("selected"); } }>ABIERTO</option>
                                    <option value="RECIBIDO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "RECIBIDO") { Write("selected"); } }>RECIBIDO</option>
                                    <option value="PICKEANDO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "PICKEANDO") { Write("selected"); } }>PICKEANDO</option>
                                    <option value="VERIFICANDO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "VERIFICANDO") { Write("selected"); } }>VERIFICANDO</option>
                                    <option value="EMPACANDO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "EMPACANDO") { Write("selected"); } }>EMPACANDO</option>
                                    <option value="EMPACADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "EMPACADO") { Write("selected"); } }>EMPACADO</option>
                                    <option value="PESADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "PESADO") { Write("selected"); } }>PESADO</option>
                                    <option value="PREENVIO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "PREENVIO") { Write("selected"); } }>PREENVIO</option>
                                    <option value="ENVIADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "ENVIADO") { Write("selected"); } }>ENVIADO</option>
                                    <option value="ENTREGADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "ENTREGADO") { Write("selected"); } }>ENTREGADO</option>
                                    <option value="ANULADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "ANULADO") { Write("selected"); } }>ANULADO</option>
                                    <option value="CANCELADO" @{ if (ViewBag.Ortv != null && ViewBag.Ortv.Estado == "CANCELADO") { Write("selected"); } }>CANCELADO</option>
                                </select>
                            </th>
                            <th class="text-center border-end">
                                Fecha y hora<br />abierto
                            </th>
                            <th class="text-center border-end">Tipo venta</th>
                            <th class="text-center border-end">Estado pago</th>
                            <th class="text-center border-end">@Html.DisplayNameFor(model => model.LugarDestino)</th>
                            <th class="bg-success text-center text-white border-end">Recibir</th>
                            <th class="bg-danger text-center text-white border-end">Anular<br /> Recibir</th>
                            <th class="text-center text-white border-end">PDF</th>
                            <th class="text-center text-white border-end">Cancelar</th>
                            <th class="text-center text-white border-end">Seguimiento</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark">
                        @foreach (var item in Model)
                        {
                            bool condRecibir = false, condAnularRecibir = false;
                            String styleEstado = "";
                            if (item.Estado == "ABIERTO")
                            {
                                condRecibir = true;
                            }
                            if (item.Estado == "RECIBIDO")
                            {
                                condAnularRecibir = true;
                            }

                            if (item.Estado != null && item.Estado.Equals("ABIERTO"))
                            {
                                styleEstado = "style=background-color:gold";
                            }
                            else if (item.Estado != null && item.Estado.Equals("RECIBIDO"))
                            {
                                styleEstado = "style=background-color:greenyellow;font-weight:bold";
                            }
                            <tr id="fila">
                                <td class="text-center border-end border-start">@item.DocNum</td>
                                <td class="text-center border-end">@item.FechaSapTicket</td>
                                <td class="text-center border-end"><span class="pl-2">@Html.DisplayFor(modelItem => item.CardName)</span></td>
                                <td class="text-center border-end">
                                    @if (item.Det2 != null)
                                    {
                                        foreach (RTV2_E d in item.Det2)
                                        {
                                            @d.NroSap<br />
                                        }
                                    }
                                </td>
                                <td class="text-center border-end">
                                    @Html.DisplayFor(modelItem => item.Vendedor)
                                </td>
                                <td class="text-center border-end">
                                    @Html.DisplayFor(modelItem => item.MontoTotal)
                                </td>
                                <td class="text-center border-end" @styleEstado>@Html.DisplayFor(modelItem => item.Estado)</td>
                                <td class="text-center border-end">
                                    <span class="">@item.FechaAbierto</span>
                                </td>
                                <td class="text-center border-end">@item.TipoVenta</td>
                                <td class="text-center border-end">
                                    @Html.DisplayFor(modelItem => item.EstadoPago)
                                </td>
                                <td class="text-center border-end">
                                    @Html.DisplayFor(modelItem => item.LugarDestino)
                                </td>

                                <td class="text-center border-end">
                                    @if (condRecibir == true)
                                    {
                                        <a href="@Url.Action("RecibirTicketVenta", "Ventas", new { DocEntry = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Recibir">
                                            <i class="bi bi-check-lg text-success"> </i>
                                        </a>
                                    }
                                </td>
                                <td class="text-center border-end">
                                    @if (condAnularRecibir == true)
                                    {
                                        <a href="@Url.Action( "AnularRecibirTicketVenta", "Ventas", new { DocEntry = item.DocEntry  } )" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Anular Recibir">
                                            <i class="bi bi-slash-circle text-danger"></i>
                                        </a>
                                    }
                                </td>
                                <td class="text-center border-end">
                                    @if (item.Estado.Equals("ABIERTO"))
                                    {
                                        <a class="btn btn-sm btn-light" href="@Url.Action("PdfTacoComentarios", "Ventas", new { DocEntry = item.DocEntry }, protocol: "https")" data-toggle="tooltip" data-placement="top" title="PDF Taco Comentarios">
                                            <i class="bi bi-file-earmark-pdf text-danger bordered"></i>
                                        </a>
                                    }
                                    <input type="hidden" id="pdf_taco_comentarios" value="@item.DocEntry" />
                                </td>
                                <td class="text-center border-end">
                                    @if ((item.Estado.Equals("RECIBIDO") || item.Estado.Equals("PICKEANDO") || item.Estado.Equals("VERIFICANDO") || item.Estado.Equals("EMPACANDO")) && (ViewBag.IdRol == 1 || ViewBag.IdRol == 5))
                                    {
                                        <a href="#" class="btn btn-sm btn-light" onclick="cancelarTicket(@item.DocEntry);" data-toggle="tooltip" data-placement="top" title="Cancelar"><i class="bi bi-x-lg text-danger"></i></a>
                                    }
                                </td>
                                <td class="text-center border-end">
                                    <a href="@Url.Action( "SeguimientoDeTicket", "Ventas", new { DocEntry = item.DocEntry  } )" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Seguimiento de Ticket" type="button" target="_blank"
                                       onclick="window.open(this.href,this.target,'width=1200,height=650,top=120,left=100,toolbar=no,location=no,status=no,menubar=no');return false;">
                                        <i class="bi bi-truck text-dark"></i>
                                    </a>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </form>
    </div>
</div>

@if (Request["DescargarPDF"] == "1")
{
    <script>
        Swal.fire('En breve se descargará el TacoComentario.pdf');
        document.addEventListener("DOMContentLoaded", function () {
            setTimeout(function () {
                var docEntry = document.getElementById('pdf_taco_comentarios').value;
                window.open('/Ventas/PdfTacoComentarios?DocEntry=' + docEntry, '_blank');
            }, 3000);
        });
    </script>
}