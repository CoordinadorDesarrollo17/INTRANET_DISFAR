@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E

@{
    Layout = null;

    string tipoEntrega = string.Empty;
    if (Model != null && Model.LugarDestino == "Arriola")
    {
        tipoEntrega = "PRESENCIAL - LIMA";
    }
    else if (Model != null && Model.LugarDestino == "Centro")
    {
        tipoEntrega = "TRANSF - ALMACEN N°1";
    }
    else if (Model != null && (Model.LugarDestino == "Agencia" || Model.LugarDestino == "Agencia Courier"))
    {
        tipoEntrega = "PRESENCIAL - PROVINCIA";
    }
    else if (Model != null && Model.LugarDestino == "Domicilio")
    {
        tipoEntrega = "DOMICILIO";

    }
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" charset="utf-8" />
    <title>TacoEmpaque</title>
    <style type="text/css">
        .text-center {
            text-align: center;
        }

        tr, td, font, span {
            font-family: Verdana;
            
        }
        td {
            padding: 2px;
        }

        .v-top {
            vertical-align: top;
        }
    </style>
</head>

<body>
    <div id='c_tablas' style='float: left;  background: white; width:100%;'>
        <table border="1" cellspacing="0" width="100%" >
            <tr>
                <td colspan="7" style="text-align:center"><img width="100" height="30" src='/imagenes/logoventa2.jpg' /></td>
                <td colspan="5" class="text-center"><font size="@ViewBag.Letra" px><strong>ANEXO-008-03</strong></font></td>
            </tr>
            <tr>
                <td colspan="12">
                    <span><strong>Nro. Ticket: </strong></span><span style="font-weight: bold; text-align: center;font-size:26px">@Html.DisplayFor(model => model.DocNum)</span>
                </td>
            </tr>
            <tr>
                <td colspan="12">
                    <strong>Cliente: </strong><span style="font-weight: bold; font-size: 16px">@Html.DisplayFor(model => model.CardName)</span>
                </td>
            </tr>
            <tr>
                <td colspan="8" rowspan="2" height="20" width="100%" class="v-top">
                    <span style="font-weight:600;">
                       Documentos: <br />@ViewBag.Guias
                    </span>
                </td>
                <td colspan="4">
                    <span><strong>@Html.DisplayNameFor(model => model.MontoTotal):</strong><br /></span> <span style="font-weight: bold; text-align: center;font-size:18px">S/ @Html.DisplayFor(model => model.MontoTotal)</span>
                </td>
            </tr>
            <tr>
                <td colspan="4"><span><strong>Temperatura 15°C - 25°C</strong></span></td>
            </tr>
            <tr>
                <td colspan="12">
                    @if (Model != null && Model.Embalaje == "CL")
                    {<div><span><strong>@Html.DisplayNameFor(model => model.Embalaje): </strong> CAJA LIMA</span></div>}
                    @if (Model != null && Model.Embalaje == "CP")
                    {<span><strong>@Html.DisplayNameFor(model => model.Embalaje): CAJA PROVINCIA</strong></span>}
                </td>
            </tr>
            <tr>
                <td colspan="12">
                    <span><strong>Tipo de Entrega: </strong>@tipoEntrega</span>
                </td>
            </tr>
            <tr>
                <td colspan="12">
                    <span>
                        <strong>Asesor de Ventas: </strong>
                        <br>@Html.DisplayFor(model => model.Vendedor)
                    </span>
                </td>
            </tr>
            <tr>
                <td colspan="12">
                    <span><strong>Auxiliar de Almacén (Verificador): </strong></span>
                    <br>@if (!string.IsNullOrEmpty(Model.OpVerificado))
                    {@String.Join(", ", Model.OpVerificado)}
                    @if (Model.OpVerificadoApoyo != null && Model.OpVerificadoApoyo.Count > 0)
                    {
                        <text>, </text> @String.Join(", ", Model.OpVerificadoApoyo)
                    }
                </td>
            </tr>
            <tr>
                <td colspan="12">
                    <span>
                        <strong>Auxiliar de Almacén (Embalaje): </strong>
                    </span>
                    <br> @if (!string.IsNullOrEmpty(Model.OpEmpacado))
                    {@String.Join(", ", Model.OpEmpacado)}

                    @if (Model.OpEmpacadoApoyo != null && Model.OpEmpacadoApoyo.Count > 0)
                    {
                        <text>, </text> @String.Join(", ", Model.OpEmpacadoApoyo)
                    }
                </td>
            </tr>
            <tr>
                <td colspan="4" height="20">
                    <strong>Fecha Embalaje</strong>
                    <br />@Html.DisplayFor(model => model.FechaEmpacado)
                </td>
                <td colspan="4" >
                    <strong>Fecha Entrega</strong>
                    @{
                        // Convertimos TiempoEntrega en String para luego separarlo en por el espacio y así tener en un índice la fecha y en el otro índice la hora
                        string[] subF = Model.TiempoEntrega.ToString().Split(' ');
                    }
                    <br />@subF[0]
                </td>
                <td colspan="4" class="v-top" style="border-bottom-style: hidden;">
                        <strong>Cajas:</strong>
                </td>
            </tr>
            <tr>
                <td colspan="4" >
                    <span><strong>Hora Embalaje</strong></span>
                    <br />@Html.DisplayFor(model => model.HoraEmpacado)
                </td>
                <td colspan="4">
                    <span>
                        <strong>Hora Entrega</strong>
                    </span>
                    @{
                        // Convertimos TiempoEntrega en String para luego separarlo en por el espacio y así tener en un índice la fecha y en el otro índice la hora
                        string[] subH = Model.TiempoEntrega.ToString().Split(' ');
                    }
                    <br />@subH[1]
                </td>
                <td colspan="4" class="text-center v-top"  style="border-top-style: hidden;">
                    <span style="font-weight: bold; text-align: center;font-size:20px">@Html.DisplayFor(model => model.Cajas)</span>
                </td>
            </tr>

            @if (Model.Comentario != null)
            {
                <tr>
                    <td colspan="12"><font>@Html.DisplayNameFor(model => model.Comentario): @Html.DisplayFor(model => model.Comentario)</font></td>
                </tr>
            }

        </table>
    </div>
</body>
</html>