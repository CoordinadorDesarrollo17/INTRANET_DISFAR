@model IEnumerable<Capa_Entidad.AtencionCliente_ENT.TablasSql.OSAT_E>

@{
    ViewBag.Title = "ReporteReclamosCliente";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2 pt-3">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">REPORTE RECLAMOS CLIENTE</h3></div>
</div>
<div class="mt-4 mb-3">
    <button id="btnAgregarSeleccionados" class="btn btn-primary" type="button" onclick="agregarSeleccionados()">Agregar</button>

    <button id="cancelar" class="btn btn-secondary" type="button" onclick="cancelarSeleccion()">Cancelar</button>
</div>
<table class="table table-light table-sm table-hover">
    <thead class="thead-dark">
        <tr>
            <th class="text-center">
                <input type="checkbox" id="checkAll" onclick="toggleAllChecks(this)" title="Seleccionar todos" />
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.DocEntry)
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.DocNum)
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.Resultado)
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.TipoSolucion)
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.Solucion)
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="text-center">
                    <input type="checkbox" class="checkFila" value="@item.DocNum" />
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.DocEntry)
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.DocNum)
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.Estado)
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.Resultado)
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.TipoSolucion)
                </td>
                <td class="text-center">
                    @Html.DisplayFor(modelItem => item.Solucion)
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function toggleAllChecks(source) {
        var checkboxes = document.querySelectorAll('.checkFila');
        for (var i = 0; i < checkboxes.length; i++) {
            checkboxes[i].checked = source.checked;
        }
    }

    function agregarSeleccionados() {
        var seleccionados = [];
        document.querySelectorAll('.checkFila:checked').forEach(function (cb) {
            seleccionados.push(cb.value);
        });

        if (seleccionados.length === 0) {
            alert('Debe seleccionar al menos un reclamo.');
            return;
        } else if (window.opener && !window.opener.closed) {
            // Enviar como JSON string
            window.opener.setNroSolicitudReclamo(JSON.stringify(seleccionados));
            window.close();
        }
    }

    function cancelarSeleccion() {
        if (window.opener && !window.opener.closed) {
            window.opener.document.getElementById('NroSolicitudReclamo').value = '';
            window.close();
        }
    }


</script>


