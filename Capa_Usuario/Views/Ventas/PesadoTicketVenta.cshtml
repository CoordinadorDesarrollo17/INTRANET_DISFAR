@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E
@using Capa_Entidad.Ventas_ENT.TablasSql

@{
    ViewBag.Title = "PesadoTicketVenta";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ORTV_E e = (ORTV_E)Model;
}

<script>
    $(document).ready(function () {
        if ("@(e.Estado)" == "PESADO") {

            @if (e.Det6 != null)
            {
                foreach (var i in e.Det6)
                {
                    e.PesoTotal += i.Peso;
                }
            }

            $('#PesoTotal').val(@e.PesoTotal);
        }
        setInterval(pesar, 1000);
    });
    function pesar() {
        let Ip = $("#cb_Balanza").val();
        if (Ip != "") {
        $.ajax(Ip,
            {
                data: {},
                dataType: 'json',
                cache: false,
                type: 'get'
            })
            .done(function (response) {
                $('#Balanza').val(response);

            });
        }
    }
    function verificaPesos() {
        var object = $("#PesadoTicketVenta").serialize();
        $.ajax('/Ventas/CalcularPesoTotal',
            {
                data: object,
                dataType: 'json',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                $('#PesoTotal').val(response.PesoTotal);
            });
    }
    function traerDatos(id) {
        $('#Peso' + id).val($('#Balanza').val());
    }
    function SelTod(ind) {
        checkboxes = $('input[type=checkbox]');
        for (var i = 0, n = checkboxes.length; i < n; i++) {
            checkboxes[i].checked = ind.checked;
        }
        verificaPesos();
    }
</script>
<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ListadoTicketsDespacho", "Ventas")">Listado de tickets de despacho</a></li>
            <li class="current"><em>Pesado ticket de venta</em></li>
        </ol>
    </nav>
</div>

