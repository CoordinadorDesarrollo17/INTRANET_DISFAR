@using Capa_Entidad.ReportesDigemid_ENT

@{
    Layout = null;
    decimal totalFaltantes = 0;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link href="~/Content/css/bootstrap.css" rel="stylesheet" type="text/css" />
    <title>FORMATO DE ORDEN DE VENTA - COBEFAR S.A.C</title>
    <style>
        html, body, table, td, th {
            font-family: Helvetica, Arial, sans-serif !important;
            font-size: 14px !important;
        }

        /* Evita quiebres en medio de filas */
        tr, td, th {
            page-break-inside: avoid !important;
        }

        /* Bordes estándar */
        .border {
            border: 1px solid black !important;
        }

        /* Padding uniforme en celdas */
        #cuerpoDetalle td,
        #cuerpoDetalle th {
            /*padding: 10px !important;*/
            vertical-align: middle !important;
        }

        /* Ancho y fondo del contenedor */
        .impresion {
            width: 100%;
            background-color: white;
        }

        /* Agrupación del pie de tabla si se requiere */
        tfoot {
            display: table-row-group;
        }

        /* Centrado de texto */
        .text-center {
            text-align: center !important;
        }

        .titulo-celda {
            font-size: 16px !important;
            font-weight: bold !important;
        }

        .titulo-celda-sinbold {
            font-size: 16px !important;
        }
    </style>
</head>
<body>
    <div class="impresion mt-4 ml-0 mr-0 pl-0 pr-0" style="width: 100%">
        <div>
            <table id="cabecera" width="100%">
                <tr>
                    <td colspan="4" class="text-center font-weight-bold" style="font-size: 14px !important;">FORMATO DE ORDEN DE VENTA</td>
                </tr>
                <tr>
                    <td colspan="4" class="text-center titulo-celda">N° @Model[0].DocNum</td>
                </tr>
                <tr>
                    <td class="titulo-celda" style="width: 10%;">FECHA:</td>
                    <td class="titulo-celda-sinbold" style="width: 50%;">@Model[0].Fecha</td>
                    <td class="titulo-celda text-left" style="width: 10%; ">ALMACÉN:</td>
                    <td class="titulo-celda" style="width: 30%;">
                        @if (new List<string> { "01", "09" }.Contains(Model[0].Almacen)) { Write(ViewBag.AlmProcedencia); }
                        else { Write(Model[0].Almacen); }
                    </td>
                </tr>
                <tr>
                    <td class="titulo-celda" style="width: 10%;">CLIENTE:</td>
                    <td class="titulo-celda" style="width: 50%;">@Model[0].CardName</td>
                    <td class="titulo-celda text-left" style="width: 10%;">VENDEDOR:</td>
                    <td class="titulo-celda-sinbold" style="width: 30%;">
                        @if (!string.IsNullOrEmpty(Model[0].SlpName) && Model[0].SlpName.Length > 15) { Write(Model[0].SlpName.Substring(0, 15)); }
                        else { Write(Model[0].SlpName); }
                    </td>
                </tr>
            </table>
        </div>
        <div style="margin-top: 10px;">
            <table width="100%" id="cuerpoDetalle">
                <thead>
                    <tr>
                        <th class="text-center border text-dark font-weight-bold">UBICACIÓN</th>
                        <th class="text-center border text-dark font-weight-bold">SKU</th>
                        <th class="text-center border text-dark font-weight-bold">DESCRIPCIÓN</th>
                        <th class="text-center border text-dark font-weight-bold">CANT.</th>
                        <th class="text-center border text-dark font-weight-bold">VALID.</th>
                        <th class="text-center border text-dark font-weight-bold">LOTE</th>
                        <th class="text-center border text-dark font-weight-bold">F. VCTO</th>

                        <th class="text-center border text-dark font-weight-bold">OBS.</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        List<string> listaCodigos = new List<string>();

                        foreach (var item in Model[0].ItemCodeDetalle)
                        {                           
                            //decimal cantidadSolicitadaVentas = 0;
                            decimal cantidadFaltante = 0;
                            foreach (var item2 in item.LoteDetalle)
                            {
                                //cantidadSolicitadaVentas += item2.CantidadSolicitadaVenta;
                                //cantidadFaltante = cantidadSolicitadaVentas - item.TotalUnidadesVendidas;
                                cantidadFaltante = item2.CantidadSolicitadaVenta - item.TotalUnidadesVendidas;
                                <tr>
                                    <td class="p-1 border">
                                        @if (item.Ubicaciones != null)
                                        {
                                            foreach (var ubicacion in item.Ubicaciones)
                                            {
                                                <div>@ubicacion.Replace("PICKING-", "")</div>
                                            }
                                        }
                                    </td>
                                    <td class="p-1 border">@item.Codigo</td>
                                    <td class="p-1 border">@item.Producto</td>
                                    <td class="text-center p-1 border font-weight-bold">@item2.UniMedidVend @item2.NumUnidVend</td>
                                    <td class="text-center p-1 border"></td>
                                    <td class="text-center p-1 border font-weight-bold">@item2.Lote</td>
                                    <td class="text-center p-1 border font">@item2.FechaVenc</td>
                                    <td class="text-center p-1 border">
                                        @if (cantidadFaltante > 0 && !listaCodigos.Contains(item.Codigo))
                                        {
                                            @Convert.ToInt32(cantidadFaltante)
                                            listaCodigos.Add(item.Codigo);
                                            totalFaltantes += cantidadFaltante;
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    }
                    <tr>
                        <td style="border: none !important;" colspan="5"></td>
                        <td class="p-1 font-weight-bold"></td>
                        <td class="p-1 border text-center">@Convert.ToInt32(totalFaltantes)</td>
                    </tr>
                </tbody>
            </table>
            <table width="100%" class="align-content-between" style="margin-top: 10px;">
                <tr>
                    <td class="font-weight-bold text-left" style="width: 100px;"></td>
                    <td class="text-left" style="width: 450px;"></td>
                    <td class="titulo-celda text-left" style="width: 300px;">TOTAL GENERAL:</td>
                    <td class="titulo-celda text-left" style="width: 250px;">S/ @Model[0].DocTotal.ToString("F2")</td>
                </tr>
            </table>
        </div>
    </div>
    <div style="page-break-after: always"></div>

</body>
</html>