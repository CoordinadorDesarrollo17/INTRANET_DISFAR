<table class="table-responsive" id="detallesPedidos">
    <tr><td colspan="10" style="color: aquamarine; text-shadow: 2px 2px 1px rgba(0,0,0,0.7); "><strong>DETALLES DE PEDIDOS</strong></td></tr>    <tr style="background-color:darkgreen">
        <th>#</th>
        <th>Monto</th>
        <th>Nro SAP</th>
        <th>TipoComprobante</th>
        <th>Vendedor</th>
        <th>LugarDeEntrega</th>
        <th>Obs</th>
    </tr>
    @foreach (RTV1_E dt in Model.Det)
    {
        <tbody class="table-light">
            <tr>
                <td>@Html.DisplayFor(model => dt.Linea)</td>
                <td>@Html.DisplayFor(model => dt.Monto)</td>
                <td>@Html.DisplayFor(model => dt.NroSap)</td>
                <td>@Html.DisplayFor(model => dt.TipoComprobante)</td>
                <td>@Html.DisplayFor(model => dt.Vendedor)</td>
                <td>@Html.DisplayFor(model => dt.LugarDeEntrega)</td>
                <td>@Html.DisplayFor(model => dt.Observaciones)</td>
            </tr>
        </tbody>
    }
</table>

