@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E
@using Capa_Entidad.Ventas_ENT.TablasSql
@{
    ViewBag.Title = "EnviarProtocoloTicket";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4>REALIZAR PROTOCOLO DE TICKET</h4>
<p style="color:yellow; font-weight:700">@ViewBag.Mensaje</p>
<a id="accion" href="@Url.Action("ListadoTicketsProtocolos", "Ventas")" class="btn btn-light">
    <span>Volver Atras</span>
</a>
<br />
<br />
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <table class="table-responsive">
        <tr>
            <th>Protocolo:</th>
            <td>@Html.EditorFor(model => model.Protocolo, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })</td>
            <th>Correo:</th>
            <td>@Html.EditorFor(model => model.Correo, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })</td>
            <th>Estado Protocolo:</th>
            <td>@Html.EditorFor(model => model.EstadoProtocolo, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })</td>
        </tr>
        <tr>
            <th>OpProtocolo:</th>
            <td>@Html.EditorFor(model => model.OpProtocolo, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })</td>
            <th>FechaProtocolo:</th>
            <td>@Html.EditorFor(model => model.FechaProtocolo, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })</td>
            <th>HoraProtocolo:</th>
            <td>@Html.EditorFor(model => model.HoraProtocolo, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })</td>
        </tr>
        <tr>
            <th>Ordenes de Venta:  </th>
            <td>
                @foreach (RTV1_E dt in Model.Det)
                {
                    @Html.ActionLink(dt.NroSap.ToString() + ", ", "OrdenDeVenta", new { DocNum = dt.NroSap }, htmlAttributes: new { @target = "_blank",@style="color:white" });
                }
            </td>
        </tr>
        <tr>
            <th><input type="submit" class="btn btn-success" value="Realizar Protocolo" /></th>
        </tr>
    </table>
    <br />
}

