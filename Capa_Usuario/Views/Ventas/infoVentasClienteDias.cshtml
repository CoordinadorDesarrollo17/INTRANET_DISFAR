
@{
    Layout = null;
}

<script>
    $(document).ready(function () { });
    function rpt() {
        $('#Reporte').html('<img src="/imagenes/index/ReportesDigemid/cargando.gif" />');
        var parametros = $("#frm").serialize();
        $.ajax('/Ventas/RptVentasClienteDias',
            {
                data: parametros,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                $('#Reporte').html(response);
            });
    }
</script>
<div class="container" style="padding: 2%; background-color: rgb(220, 220, 220);">
    <h3 class="text-cobefar font-weight-bold text-center">VENTAS CLIENTE DÍAS</h3>

    <form id="frm">
        @Html.AntiForgeryToken()
        <div class="row mt-4">
            <div class="col-lg-3">
                <label for="Fecha" class="text-dark font-weight-bold font-18">Fecha Ticket:</label>
                <input name="Fecha" type="date" class="form-control border-success" />
            </div>

            <div class="col-lg-4">
                <label for="Fecha" class="text-dark font-weight-bold font-18">Cliente Desde:</label>
                <input type="search" list="ListaClientes" name="CardCodeIni" class="form-control border-success">
                <datalist id="ListaClientes">
                    @foreach (var obj in ViewBag.Clientes)
                    {
                        <option CardCode="@obj.CardCode" value="@obj.CardCode">@obj.CardName</option>
                    }
                </datalist>
            </div>

            <div class="col-lg-4">
                <label for="Fecha" class="text-dark font-weight-bold font-18">Cliente Hasta:</label>
                <input type="search" list="ListaClientes" name="CardCodeFin" class="form-control border-success">
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-lg-6">
                <button id="Generar" type="button" class="btn btn-success" onclick="rpt();"><i class="icon-checkmark"></i> Generar</button>
            </div>
        </div>

    </form>
</div>