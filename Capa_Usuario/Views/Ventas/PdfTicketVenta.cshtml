@model Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E

@{
    Layout = null;
    string styleBgTicket = ViewBag.ColorTicket;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed&display=swap" rel="stylesheet">
</head>
<body>
    <div style="margin-left:40%;">
        <table border="0" style="font-family:'Roboto Condensed', sans-serif">
            <tr>
                <td colspan="2" align="center"><img src="~/imagenes/logoventa2.jpg" style="width:150px;height:50px;" /></td>
            </tr>
            <tr style="background-color: @styleBgTicket">
                <th colspan="2" align="center" style="font-size:20px; padding:8px 8px 8px 8px; ">Ticket: @Model.DocNum</th>
            </tr>
            <tr>
                <th colspan="2" align="center" style="font-size:19px;padding-bottom:8px;">T.E.: @Model.TiempoEntrega</th>
            </tr>
            <tr>
                <th align="left" colspan="2" width="250px" style="font-size:16px;">@Model.CardName</th>
            </tr>
            <tr>
                <td colspan="2">--------------------------------------------------------------</td>
            </tr>
            <tr>
                <td align="left" style="font-size:15px;">M.T: </td>
                <td align="right" style="font-size: 15px;">@Model.MontoTotal</td>
            </tr>
            <tr>
                <td align="left" style="font-size:15px;">FLETE (+): </td>
                <td align="right" style="font-size:15px;">@Model.Flete</td>
            </tr>
            <tr>
                <td align="left" style="font-size:15px;">ENVIO (+): </td>
                <td align="right" style="font-size:15px;">@Model.GastoEnvio</td>
            </tr>
            <tr>
                <td align="left" style="font-size:15px;">DEU.CLI. (+):</td>
                <td align="right" style="font-size:15px;">@Model.DeudaCliente</td>
            </tr>
            <tr>
                <td align="left" style="font-size:15px;">DESC. NC. (-): </td>
                <td align="right" style="font-size:15px;">@Model.DescuentoNC</td>
            </tr>
            <tr>
                <td align="left" style="font-size:15px;">DEU. EMP. (-): </td>
                <td align="right" style="font-size:15px;">@Model.DeudaEmpresa</td>
            </tr>
            <tr>
                <td align="center" colspan="2">--------------------------------------------------------------</td>
            </tr>
            <tr>
                <td align="left" style="font-size:19px;font-weight:bold;">M. FINAL: </td>
                <td align="right" style="font-size:19px; font-weight:bold;">@(Model.MontoFinal)</td>
            </tr>
            <tr>
                <td>@Model.Embalaje </td>
                <th>@Model.Vendedor</th>
            </tr>
        <tr>
            <td colspan="3">@Model.Comentario</td>
        </tr>
        @if (Model.Det5 != null && Model.Det5.Count >= 1)
        {
            if (Model.Det5.Count > 0 && Model.Det5[0].RegCant > 0)
            {
                <tr>
                    <th colspan="3" style="vertical-align:auto;">
                        <img style="width:70px; height:70px;" src="~/imagenes/index/Ventas/TicketVenta/regalo.jpg" />
                        <label style="font-size:25px;margin-left:40px;">@(Math.Round(Model.Det5[0].RegCant, 0) + "  " + Model.Det5[0].RegCate)</label>
                    </th>

                </tr>
            }
        }

        <tr>
            <th colspan="2" style="font-size:11px;font-weight:bold;">CUENTAS CORRIENTE DROGUERIA COBEFAR S.A.C.</th>
        </tr>
        <tr>
            <th colspan="2" align="left"><label style="font-size: 11px;">LIMA:</label></th>
        </tr>
        <tr>
            <td style="font-size:12px;">BBVA</td>
            <td align="right" style="font-size:12px;" colspan="2">0011-0346-0100016305</td>
        </tr>
        <tr>
            <td style="font-size:12px;">BCP</td>
            <td align="right" style="font-size:12px;" colspan="2">191-22473540-44</td>
        </tr>
        <tr>
            <td style="font-size:12px;">InterBank</td>
            <td align="right" style="font-size:12px;" colspan="2">001-3001880907</td>
        </tr>
        <tr>
            <td style="font-size:12px;">ScotiaBank</td>
            <td align="right" style="font-size:12px;" colspan="2">000-6285309</td>
        </tr>
        <tr>
            <th colspan="3" align="left"><label style="font-size: 11px;">PROVINCIA</label></th>
        </tr>
        <tr>
            <td style="font-size:12px;">BCP provincia</td>
            <td align="right" style="font-size:12px;">191-2449021-0-85</td>
        </tr>
        <tr>
            <td style="font-size:12px;">Banco de la Nacion</td>
            <td align="right" style="font-size:12px;">00015-056061</td>
        </tr>
        <tr>
            <td align="center" colspan="2" style="font-size:10px;font-weight:bold">www.cobefar.com.pe</td>
        </tr>
    </table>

</div>
<div style="margin-left:4px;margin-top:4px;">
    <table style="border:double" border="0">
    </table>
</div>
</body>
</html>
