@model IEnumerable<Capa_Entidad.Ventas_ENT.TablasSql.ORTV_E>
@using Capa_Entidad.Ventas_ENT.TablasSql
@using Capa_Entidad.Seguridad_ENT

@{
    ViewBag.Title = "ListadoTicketsVenta";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
    var hoy = DateTime.Now;
    ORTV_E a = (ORTV_E)ViewBag.Ortv;
    List<Usuario_E> usuarios = (List<Usuario_E>)ViewBag.Vendedores;
}

@section Styles{
    <link href="~/Content/css/alertify.min.css" rel="stylesheet" />
    <link href="~/Content/css/semantic.min.css" rel="stylesheet" />
}

@section Scripts{
    <script src="~/Content/js/alertify.min.js"></script>
}

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Enfocar el primer input al mostrar el modal de filtros
    var filterModal = document.getElementById('filterModal');
    if (filterModal) {
        filterModal.addEventListener('shown.bs.modal', function () {
            var firstInput = filterModal.querySelector('input');
            if (firstInput) firstInput.focus();
        });
    }
});

// Serializa el formulario como query string
function serializeForm(form) {
    var params = [];
    Array.from(form.elements).forEach(function (el) {
        if (!el.name || el.disabled) return;
        if ((el.type === 'checkbox' || el.type === 'radio') && !el.checked) return;
        if (el.tagName === 'SELECT' && el.multiple) {
            Array.from(el.selectedOptions).forEach(function (opt) {
                params.push(encodeURIComponent(el.name) + '=' + encodeURIComponent(opt.value));
            });
        } else {
            params.push(encodeURIComponent(el.name) + '=' + encodeURIComponent(el.value));
        }
    });
    return params.join('&');
}

function filtrar() {
    var form = document.getElementById('filterForm');
    var query = serializeForm(form);
    window.location.href = "/Ventas/ListadoTicketsVenta?" + query;
}

function limpiarFiltros() {
    const formulario = document.getElementById('filterForm');
    // Limpiar inputs
    const inputs = formulario.querySelectorAll('input[type="text"], input[type="date"], input[type="number"], textarea');
    inputs.forEach(input => {
        input.value = '';
    });
    // Deseleccionar los valores de los select
    const selects = formulario.querySelectorAll('select');
    selects.forEach(select => {
        select.selectedIndex = 0;
    });
    // Llama la función anterior para mandar al post
    filtrar();
}

function seleccionarVendedor(CodigoSap) {
    var select = document.getElementById('selectVendedores');
    var selected = select.options[select.selectedIndex];
    var nombres = selected.getAttribute('data-nombres') || '';
    var apellidos = selected.getAttribute('data-apellidos') || '';
    document.getElementById('CodigovendedorInput').value = CodigoSap;
    document.getElementById('NombresvendedorInput').value = nombres;
    document.getElementById('ApellidosvendedorInput').value = apellidos;
}

function enviarDatosTicketReemplazo() {
    var codigoVendedor = document.getElementById('CodigovendedorInput').value;
    var nombreVendedor = document.getElementById('NombresvendedorInput').value;
    var apellidoVendedor = document.getElementById('ApellidosvendedorInput').value;
    var data = {
        CodigoSap: codigoVendedor,
        Nombres: nombreVendedor,
        Apellidos: apellidoVendedor
    };

    Swal.fire({
        title: 'Enviando datos...',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });

    var url = '@Url.Action("CreaTicketVenta", "Ventas")';
    var params = Object.keys(data).map(function (k) {
        return encodeURIComponent(k) + '=' + encodeURIComponent(data[k]);
    }).join('&');

    var xhr = new XMLHttpRequest();
    xhr.open('GET', url + '?' + params, true);
    xhr.onreadystatechange = function () {
        if (xhr.readyState === 4) {
            Swal.close();
            if (xhr.status >= 200 && xhr.status < 300) {
                console.log('Datos enviados correctamente.');
                document.getElementById('modalVendedores').style.display = 'none';
                location.reload();
                Swal.fire({
                    icon: 'success',
                    title: 'Datos enviados correctamente',
                    showConfirmButton: false,
                    timer: 1500
                });
            } else {
                console.error('Error al enviar datos:', xhr.statusText);
                Swal.fire({
                    icon: 'error',
                    title: 'Error al enviar datos',
                    text: 'Por favor, inténtelo de nuevo más tarde.',
                    showConfirmButton: true
                });
            }
        }
    };
    xhr.send();
}
</script>

<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li class="current"><em>Listado de Tickets</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
