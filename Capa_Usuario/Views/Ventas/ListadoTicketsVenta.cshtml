                                   onclick="window.open(this.href,this.target,'width=1200,height=650,top=120,left=100,toolbar=no,location=no,status=no,menubar=no');return false;">
                                    <i title="Seguimiento de ticket" class="bi bi-truck text-dark"></i>
                                </a>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.Estado != "SEPARADO")
                            {
                                <a href="@Url.Action( "GenerarPDF", "Ventas", new { DocEntry = item.DocEntry  } )" target="_blank" class="btn btn-light" data-toggle="tooltip" data-placement="top" title="PDF de ticket">
                                    <i class="bi bi-file-earmark-pdf text-danger"></i>
                                </a>
                            }
