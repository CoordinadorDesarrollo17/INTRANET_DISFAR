                    <option value="SEPARADO" @(a.Estado == "SEPARADO" ? "selected" : "")>SEPARADO</option>
                    <option value="ABIERTO" @(a.Estado == "ABIERTO" ? "selected" : "")>ABIERTO</option>
                    <option value="RECIBIDO" @(a.Estado == "RECIBIDO" ? "selected" : "")>RECIBIDO</option>
                    <option value="PICKEANDO" @(a.Estado == "PICKEANDO" ? "selected" : "")>PICKEANDO</option>
                    <option value="VERIFICANDO" @(a.Estado == "VERIFICANDO" ? "selected" : "")>VERIFICANDO</option>
                    <option value="EMPACANDO" @(a.Estado == "EMPACANDO" ? "selected" : "")>EMPACANDO</option>
                    <option value="EMPACADO" @(a.Estado == "EMPACADO" ? "selected" : "")>EMPACADO</option>
                    <option value="PESADO" @(a.Estado == "PESADO" ? "selected" : "")>PESADO</option>
                    <option value="PREENVIO" @(a.Estado == "PREENVIO" ? "selected" : "")>PREENVIO</option>
                    <option value="ENVIADO" @(a.Estado == "ENVIADO" ? "selected" : "")>ENVIADO</option>
                    <option value="ENTREGADO" @(a.Estado == "ENTREGADO" ? "selected" : "")>ENTREGADO</option>
                    <option value="ANULADO" @(a.Estado == "ANULADO" ? "selected" : "")>ANULADO</option>
