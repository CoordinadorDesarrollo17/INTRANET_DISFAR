                        <td class="text-center border-end">
                            @if (item.Estado == "ENTREGADO")
                            {
                                <a href="@Url.Action( "EvidenciaReparto", "Rutas", new { DocEntry = item.DocEntry , TipoRuta="Ventas"} )" class="btn btn-light" data-toggle="tooltip" data-placement="top" title="Evidencia">
                                    <i class="bi bi-image text-primary"></i>
                                </a>
                            }
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Modal para listar vendedores -->
    <div id="modalVendedores" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header bg-cobefar text-white">
                    <h5 class="modal-title" id="exampleModalLabel">Selecciona vendedor</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span class="text-white" aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <label for="selectVendedores">Seleccionar vendedor:</label>
                    <select id="selectVendedores" class="form-control" onchange="seleccionarVendedor(this.value)">
                        <option value="">Seleccione..</option>
                        @foreach (var vendedor in usuarios)
                        {
                            <option value="@vendedor.CodigoSap" data-nombres="@vendedor.Nombres" data-apellidos="@vendedor.Apellidos">@vendedor.Nombres @vendedor.Apellidos</option>
                        }
                    </select>
                    <br />
                    <input type="text" id="CodigovendedorInput" class="form-control bg-success text-white font-weight-bold" readonly>
                    <br />
                    <input type="text" id="NombresvendedorInput" class="form-control bg-success text-white font-weight-bold" readonly>
                    <br />
                    <input type="text" id="ApellidosvendedorInput" class="form-control bg-success text-white font-weight-bold" readonly>
                </div>
                <div class="modal-footer">
                    <a id="accion" onclick="enviarDatosTicketReemplazo();" class="btn btn-secondary font-weight-bold text-white">
                        Enviar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

    <style>
        .alertify-notifier .ajs-message.ajs-success {
            background-color: #6495ED;
        }

        .alertify-notifier .ajs-message.ajs-warning {
            background-color: #FFD700;
        }
    </style>
    <script>
document.addEventListener('DOMContentLoaded', function () {
    // --- CONSULTAR NUEVAS SOLICITUDES ---
    function consultarNuevasSolicitudes() {
        alertify.set('notifier', 'position', 'top-right');
        alertify.set('notifier', 'delay', 15);
        $.ajax({
            url: '/Caja/ObtenerSolicitudesAutorizar',
            type: 'POST',
            dataType: 'json',
        }).done(function (response) {
            var contador = 0;
            if (response.Datos.length >= 1) {
                response.Datos.forEach(function (solicitud) {
                    if (contador < 7) {
                        var mensaje = `<div style="font-size: 11px;margin: 0;padding:0;">
                            <div style="text-align:center;font-weigth:600">
                            <button class="btn btn-success" id="autorizar-${solicitud.DocNumTicket}" style="font-size: 12px; margin-left: 5px;  color: white; border: none; padding: 3px 8px; border-radius: 3px;"><i class="bi bi-search-heart"></i></button>
                            Autorizar ticket N° ${solicitud.DocNumTicket}<br>
                            ${solicitud.Vendedor}
                            </div>
                            </div>`;
                        var msj = alertify.warning(mensaje);

                        $(`#autorizar-${solicitud.DocNumTicket}`).on('click', function () {
                            var url = `/Ventas/AutorizarTicketReparto?DocEntry=${solicitud.DocEntryTicket}&IdOTC=${solicitud.IdOTC}`;
                            window.open(url, '_blank', 'width=1200,height=720,top=120,left=100,toolbar=no,location=no,status=no,menubar=no');
                        });
                        $(`#cerrar-${solicitud.DocNumTicket}`).on('click', function () {
                            msj.close();
                        });
                        contador++;
                    } else {
                        return false;
                    }
                });
            }
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    // --- CONSULTAR PRESUPUESTOS ---
    function consultarPresupuestos() {
        alertify.set('notifier', 'position', 'bottom-right');
        alertify.set('notifier', 'delay', 15);

        var docEntryUsuario = @ViewBag.DocEntryUsuario;
        $.ajax({
            url: '/Ventas/ListarTicketsPresupuestoPagados',
            type: 'POST',
            dataType: 'json',
            data: { DocEntryUsuario: docEntryUsuario },
        }).done(function (response) {
            var contador = 0;
            if (response.Datos.length >= 1) {
                response.Datos.forEach(function (tk) {
                    if (contador < 7) {
                        var mensaje = `<div style="font-size: 13px;margin: 0;padding:0;">
                        <div style="text-align:center;font-weigth:700:">
                                <button class="btn btn-success" id="ver-${tk.DocNum}" style="font-size: 12px; margin-left: 5px;  color: white; border: none; padding: 3px 8px; border-radius: 3px;"><i class="icon icon-search"></i></button>
                                Abrir Ticket N° ${tk.DocNum}
                                </div>
                           </div>`;
                        var msj = alertify.success(mensaje);

                        $(`#ver-${tk.DocNum}`).on('click', function () {
                            var modalHtml = `
                            <div class="modal fade" id="modal-${tk.DocNum}" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
                                <div class="modal-dialog" role="document">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="exampleModalLabel">Confirmación</h5>
                                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                <span aria-hidden="true">&times;</span>
                                            </button>
                                        </div>
                                        <div class="modal-body">
                                            ¿Desea que recepción visualice ticket Nro ${tk.DocNum}?
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" id="modal-si-button-${tk.DocNum}" class="btn btn-primary">Sí</button>
                                            <button type="button" id="modal-no-button-${tk.DocNum}" class="btn btn-secondary" data-dismiss="modal">No</button>
                                        </div>
                                    </div>
                                </div>
                            </div>`;

                            $('body').append(modalHtml);

                            $('#modal-' + tk.DocNum).modal('show');

                            $(document).on('click', `#modal-si-button-${tk.DocNum}`, function () {
                                $.ajax({
                                    url: '/Ventas/CambiarPresupuestoTicket?DocEntry=' + tk.DocEntry,
                                    type: 'POST',
                                    dataType: 'json'
                                }).done(function (response) {
                                    location.reload();
                                }).fail(function (jqXHR, textStatus, errorThrown) {
                                    console.log(jqXHR.status + textStatus + errorThrown);
                                });

                                $('#modal-' + tk.DocNum).modal('hide');
                            });
                            $(document).on('click', `#modal-no-button-${tk.DocNum}`, function () {
                                $('#modal-' + tk.DocNum).modal('hide');
                            });
                        });
                        $(`#cerrar2-${tk.DocNum}`).on('click', function () {
                            msj.close();
                        });
                        contador++;
                    } else {
                        return false;
                    }
                });
            }
        }).fail(function (jqXHR, textStatus, errorThrown) {
            console.log(jqXHR.status + textStatus + errorThrown);
        });
    }

    // --- INTERVALOS DE CONSULTA SEGÚN ROL ---
    if (@ViewBag.IdRol == 1 || @ViewBag.IdRol == 6 || @ViewBag.IdRol == 7) {
        setInterval(consultarPresupuestos, 20000);
        if (@ViewBag.IdRol == 1 || @ViewBag.IdRol == 6) {
            setInterval(consultarNuevasSolicitudes, 20000);
        }
    }

    // --- MENSAJE DE ALERTA INICIAL ---
    if ('@ViewBag.Mensaje' != "") {
        Swal.fire('@ViewBag.Mensaje');
    }

    // --- CONSULTA DE ÓRDENES DE VENTA ---
    var btnOrdenesVenta = document.getElementById('btn_ordenesVenta');
    if (btnOrdenesVenta) {
        btnOrdenesVenta.addEventListener('click', function () {
            let codSapVendedor = btnOrdenesVenta.dataset.codsapvendedor;
            window.location.href = '@Url.Action("ListadoOrdenesDeVenta", "DireccionTecnica")?SlpCode=' + codSapVendedor;
        });
    }
});

// --- FUNCIONES GLOBALES ---
function openPreliminar(docEntry) {
    var url = '@Url.Action("PreliminarLayoutOV_Ticket", "Ventas")' + '?DocEntry=' + docEntry;
    bloquearBotonesImprimir();
    window.open(url, '_blank', 'noopener,noreferrer');
    darVisibilidadTicket(docEntry);
}

function bloquearBotonesImprimir() {
    document.querySelectorAll('#boton_imprimir').forEach(boton => {
        boton.setAttribute('disabled', true);
    });
}

function darVisibilidadTicket(DocEntry) {
    $.ajax({
        url: '/Ventas/CambiarVisibilidadTicket?docEntry=' + DocEntry + '&proceso=PI',
        type: 'POST',
        dataType: 'json'
    }).done(function (response) {
        desbloquearBotonesImprimir();
    }).fail(function (jqXHR, textStatus, errorThrown) {
        console.log(jqXHR.status + textStatus + errorThrown);
    });
}

function desbloquearBotonesImprimir() {
    document.querySelectorAll('#boton_imprimir').forEach(boton => {
        boton.removeAttribute('disabled');
    });
}

function cancelarTicket(DocEntry) {
    const swalWithBootstrapButtons = Swal.mixin({
        customClass: {
            confirmButton: 'btn btn-success mx-4',
            cancelButton: 'btn btn-danger mx-4'
        },
        buttonsStyling: false
    });

    swalWithBootstrapButtons.fire({
        title: '¿Está seguro(a) de cancelar el ticket?',
        text: "Este proceso es irreversible",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: "<i class='icon-checkmark'></i> Si, estoy seguro(a)",
        cancelButtonText: "<i class='icon-cross'></i> No",
        reverseButtons: true
    }).then((result) => {
        if (result.isConfirmed) {
            location.href = '/Ventas/CancelarTicket?DocEntry=' + DocEntry + '&vista=ListadoTicketsVenta';
        }
    });
}

function redirigirListadoRegularizar() {
    window.location.href = '@Url.Action("ListadoTicketsAutorizacionRegularizar", "Ventas")';
}
    </script>
