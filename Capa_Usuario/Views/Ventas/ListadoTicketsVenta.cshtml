                                    <i class="bi bi-pencil-square text-primary"></i>
                                </a>
                            }
                        </td>
                        <td class="text-center">
                            @if (((item.Estado.Equals("SEPARADO") || item.Estado.Equals("ABIERTO")) && (ViewBag.IdRol == 1 || ViewBag.IdRol == 6 || ViewBag.IdRol == 7 || ViewBag.IdRol == 12)) && item.EstadoPago != ("PAGADO"))
                            {
                                <a href="#" onclick="cancelarTicket(@item.DocEntry);" class="btn btn-light" data-toggle="tooltip" data-placement="top" title="Cancelar ticket">
