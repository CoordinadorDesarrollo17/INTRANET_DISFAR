                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="container-fluid">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="FechaSapTicket" class="form-label">Fecha del Ticket</label>
                                    <input type="date" id="FechaSapTicket" name="FechaSapTicket" class="form-control" value="@a.FechaSapTicket" autocomplete="off" />
                                </div>
                                <div class="col-md-4">
                                    <label for="MontoFinal" class="form-label">Monto Final</label>
                                    <input type="text" id="MontoFinal" name="MontoFinal" class="form-control" value="@(a.MontoFinal == 0 ? "" : a.MontoFinal.ToString())" autocomplete="off" />
                                </div>
                                <div class="col-md-4">
                                    <label for="LugarDestino" class="form-label">Lugar de Destino</label>
                                    <select id="LugarDestino" name="LugarDestino" class="form-select">
