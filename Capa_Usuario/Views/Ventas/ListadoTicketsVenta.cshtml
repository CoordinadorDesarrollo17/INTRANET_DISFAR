                {
                    string stylePresupuesto = "";
                    if (!string.IsNullOrEmpty(item.Presupuesto) && item.Presupuesto.Equals("SI"))
                    {
                        stylePresupuesto = "bg-skyblue";

                    }
                    <tr id="fila" class="@stylePresupuesto">
