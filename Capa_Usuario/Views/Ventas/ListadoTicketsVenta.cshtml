                                        <option value="Arriola" @{ if (a.LugarDestino == "Arriola") { Write("selected"); } }>Arriola</option>
                                        <option value="Agencia" @{ if (a.LugarDestino == "Agencia") { Write("selected"); } }>Agencia</option>
                                        <option value="Domicilio" @{ if (a.LugarDestino == "Domicilio") { Write("selected"); } }>Domicilio</option>
                                        <option value="Centro" @{ if (a.LugarDestino == "Centro") { Write("selected"); } }>Centro</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="EstadoPago" class="form-label">Estado de Pago</label>
                                    <select id="EstadoPago" name="EstadoPago" class="form-select">
                                        <option value=""></option>
                                        <option value="PENDIENTE" @{ if (a.EstadoPago == "PENDIENTE") { Write("selected"); } }>PENDIENTE</option>
                                        <option value="PAGADO" @{ if (a.EstadoPago == "PAGADO") { Write("selected"); } }>PAGADO</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="EstadoGasto" class="form-label">Estado de Gasto</label>
                                    <select id="EstadoGasto" name="EstadoGasto" class="form-select">
                                        <option value=""></option>
                                        <option value="PENDIENTE" @{ if (a.EstadoGasto == "PENDIENTE") { Write("selected"); } }>PENDIENTE</option>
                                        <option value="CONFIRMADO" @{ if (a.EstadoGasto == "CONFIRMADO") { Write("selected"); } }>CONFIRMADO</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="PagoEnv" class="form-label">Pago Envío</label>
                                    <select id="PagoEnv" name="PagoEnv" class="form-select">
                                        <option value="0.00" @{ if (a.PagoEnv == 0.00M) { Write("selected"); } }></option>
                                        <option value="0.01" @{ if (a.PagoEnv == 0.01M) { Write("selected"); } }>SI</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="Presupuesto" class="form-label">Presupuesto</label>
                                    <select id="Presupuesto" name="Presupuesto" class="form-select">
                                        <option value=""></option>
                                        <option value="SI" @{ if (a.Presupuesto == "SI") { Write("selected"); } }>SI</option>
                                        <option value="NO" @{ if (a.Presupuesto == "NO") { Write("selected"); } }>NO</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="Visible" class="form-label">Impreso</label>
                                    <select id="Visible" name="Visible" class="form-select">
                                        <option value=""></option>
                                        <option value="SI" @{ if (a.Visible == "SI") { Write("selected"); } }>SI</option>
                                        <option value="PI" @{ if (a.Visible == "PI") { Write("selected"); } }>EN PROCESO</option>
                                        <option value="NO" @{ if (a.Visible == "NO") { Write("selected"); } }>NO</option>
