                        @Html.DisplayNameFor(model => model.DocNum)
                    </th>
                    <th class="text-center border-end">
                        Fecha Ticket
                    </th>
                    <th class="text-center border-end">
                        @Html.DisplayNameFor(model => model.HoraRegistro)
                    </th>
                    <th class="text-center border-end">
                        @Html.DisplayNameFor(model => model.CardName)
                    </th>
                    <th class="text-center border-end">
                        @Html.DisplayNameFor(model => model.Vendedor)
                    </th>
                    <th class="text-center border-end">
                        Monto Final
                    </th>
                    <th class="text-center border-end">
                        @Html.DisplayNameFor(model => model.LugarDestino)
                    </th>
                    <th class="text-center border-end">
                        @Html.DisplayNameFor(model => model.Estado)
                    </th>
                    <th class="text-center border-end">
                        Estado Pago
                    </th>
                    <th class="text-center border-end">
                        Estado Gasto
                    </th>
                    <th class="text-center border-end">
                        Pago Envio
                    </th>
                    <th class="text-center border-end">
                        Impreso
                    </th>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
