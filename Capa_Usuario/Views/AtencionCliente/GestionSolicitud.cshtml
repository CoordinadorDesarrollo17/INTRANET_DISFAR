@model IEnumerable<Capa_Entidad.AtencionCliente_ENT.TablasSql.OSAT_E>
@using Capa_Entidad.AtencionCliente_ENT.TablasSql
@{
    ViewBag.Title = "MÓDULO GESTIÓN DE SOLICITUDES";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
    OSAT_E f = (OSAT_E)ViewBag.Osat;
}

<style>
    .input_cls-estandar {
        height: 30px;
        font-size: 13px;
    }

    a {
        text-decoration: none;
        color: #000000;
    }

        a:hover {
            text-decoration: none;
            color: orangered;
        }

    .detalle {
        border-color: red;
    }

    .disabled {
        cursor: not-allowed;
        pointer-events: none;
    }

    #tablaNotificaciones thead th,
    #tablaDetalleNotificaciones thead th {
        background: #e9ecef !important;
        color: #212529 !important;
        font-weight: bold !important;
        border: 1px solid #dee2e6 !important;
        visibility: visible !important;
        display: table-cell !important;
    }

    #tablaDetalleNotificaciones td {
        text-align: center;
        vertical-align: middle;
    }

    .text-rojo {
        color: red !important;
        font-weight: bold;
    }

    .tabla-detalle-solicitud {
        width: 100% !important;
        table-layout: fixed;
        border-collapse: collapse;
        margin-bottom: 0;
        word-wrap: break-word;
    }

        .tabla-detalle-solicitud th,
        .tabla-detalle-solicitud td {
            border: 1px solid #dee2e6 !important;
            padding: 6px 8px !important;
            font-size: 13px;
            height: 36px;
            vertical-align: middle !important;
            text-align: center;
            background-color: #f8f9fa;
            word-break: break-word;
        }

        .tabla-detalle-solicitud th {
            background-color: #28a745 !important;
            color: #fff !important;
            font-weight: bold;
        }

    #tbl_ListadoSolicitudes {
        border-collapse: collapse !important;
    }

        #tbl_ListadoSolicitudes th,
        #tbl_ListadoSolicitudes td {
            border: 1px solid #dee2e6 !important;
            text-align: center !important;
            vertical-align: middle !important;
        }

    .btn-group-inline {
        display: flex;
        flex-direction: row;
        gap: 4px;
        flex-wrap: nowrap;
        align-items: center;
    }
</style>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li class="current">
                <a href="@Url.Action("GestionSolicitud", "AtencionCliente")">
                    Módulo gestión de solicitudes
                </a>
            </li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="row px-3 pt-3 mb-2">
        <h3 class="titulo-seccion">@ViewBag.Title.ToUpper()</h3>
    </div>
    <div class="mx-2 mb-2 d-flex align-items-center justify-content-between">
        <div class="d-flex">
            <a href="@Url.Action("NuevaSolicitud", "AtencionCliente")" class="btn btn-warning d-flex align-items-center ms-2">
                <i class="bi bi-plus-lg mr-2"></i> Nueva Solicitud
            </a>
            <button type="button" class="btn btn-outline-success d-flex justify-content-center align-items-center ms-2" onclick="excel();">
                <i class="bi bi-file-earmark-excel mr-2"></i> Exportar a Excel
            </button>
        </div>
        <div class="ml-auto" style="display:inline-block; min-width:120px; min-height:60px; background:#fff3cd; border:2px solid #ffeeba; border-radius:8px; margin:0 15px 10px 0; padding:10px; text-align:center;">
            <span style="font-size:16px; color:#b94a48; font-weight:bold;">
                Críticos: <span id="contadorRojo">@ViewBag.ContadorCriticos</span>
            </span>
            <div style="font-size:12px; color:#856404;">
                Registros con más de 2 días de retraso
            </div>
        </div>
    </div>
</div>

<div class="bg-white px-3 py-3 align-items-center">
    <div class="table-responsive">
        <form name="frm" id="frm">
            <table id="tbl_ListadoSolicitudes" class="dt-container dt-empty-footer table table-sm table-hover font-14">
                <thead class="thead-cobefar">
                    <tr>
                        <th class="text-center border-end">
                            @Html.DisplayNameFor(model => model.DocNum)<br />
                            <input type="text" name="DocNum" class="form-control-sm border w-100" onchange="filtrar();" value="@ViewBag.Osat.DocNum" />
                        </th>
                        <th class="text-center border-end">
                            TiempoRegistro<br />
                            <input type="date" name="FechaRegistro" class="form-control-sm border" onchange="filtrar();" value="@f.FechaRegistro" />
                        </th>
                        <th class="text-center border-end">
                            N° Ticket<br />
                            <input type="text" name="DocNumTicket" class="form-control-sm border w-100" onchange="filtrar();" value="@(ViewBag.Osat.DocNumTicket >= 1 ? ViewBag.Osat.DocNumTicket : "")" />
                        </th>
                        <th class="text-center border-end">
                            Cliente<br />
                            <input type="text" name='DetORTV[CardName]' class="form-control-sm border w-100" onchange="filtrar();" value="@(f.DetORTV != null ? f.DetORTV["CardName"] : "")" />
                        </th>
                        <th class="text-center border-end">
                            LugarDestino<br />
                            <select name='DetORTV[LugarDestino]' class="form-control-sm border" onchange="filtrar();">
                                <option value="">Seleccione</option>
                                <option value="DOMICILIO" @(f.DetORTV != null && f.DetORTV["LugarDestino"] == "DOMICILIO" ? "selected" : "")>DOMICILIO</option>
                                <option value="PROVINCIA" @(f.DetORTV != null && f.DetORTV["LugarDestino"] == "PROVINCIA" ? "selected" : "")>PROVINCIA</option>
                            </select>
                        </th>
                        <th class="text-center border-end">
                            @Html.DisplayNameFor(model => model.Estado)<br />
                            <select name="Estado" class="form-control-sm border" onchange="filtrar();">
                                <option value="">Seleccione</option>
                                <option value="Registrado" @(f.Estado == "Registrado" ? "selected" : "")>Registrado</option>
                                <option value="Proceso" @(f.Estado == "Proceso" ? "selected" : "")>Proceso</option>
                                <option value="Atendido" @(f.Estado == "Atendido" ? "selected" : "")>Atendido</option>
                                <option value="Culminado" @(f.Estado == "Culminado" ? "selected" : "")>Culminado</option>
                                <option value="Anulado" @(f.Estado == "Anulado" ? "selected" : "")>Anulado</option>
                            </select>
                        </th>
                        <th class="text-center border-end">Resultado</th>
                        <th class="text-center border-end">Dias Retraso</th>
                        <th class="text-center border-end">
                            @Html.DisplayNameFor(model => model.Tipo)<br />
                            <select name="Tipo" class="form-control-sm border" onchange="filtrar();">
                                <option value="">Seleccione</option>
                                <option value="Devolucion" @(ViewBag.Osat.Tipo == "Devolucion" ? "selected" : "")>Devolucion</option>
                                <option value="Reclamo" @(ViewBag.Osat.Tipo == "Reclamo" ? "selected" : "")>Reclamo</option>
                                <option value="SolicitudInterna" @(ViewBag.Osat.Tipo == "SolicitudInterna" ? "selected" : "")>Solicitud Interna</option>
                            </select>
                        </th>
                        <th class="text-center border-end">
                            @Html.DisplayNameFor(model => model.Factor)<br />
                            <select name="Factor" class="form-control-sm border" onchange="filtrar();">
                                <option value="">Seleccione</option>
                                <option value="Interno" @(ViewBag.Osat.Factor == "Interno" ? "selected" : "")>Interno</option>
                                <option value="Externo" @(ViewBag.Osat.Factor == "Externo" ? "selected" : "")>Externo</option>
                                <option value="Interno-Externo" @(ViewBag.Osat.Factor == "Interno-Externo" ? "selected" : "")>Interno-Externo</option>
                            </select>
                        </th>
                        <th>
                            DocFact<br />
                            <input type="text" name="DocFact" id="doc_fact" style="width: 150px;" class="form-control-sm border input_cls-estandar" onchange="filtrar();" value="@f.DocFact" />
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="fila-principal" data-docentry="@item.DocEntry" data-detalle="@Json.Encode(item.Det)">
                            <td class="text-center">@Html.DisplayFor(modelItem => item.DocNum)</td>
                            <td class="text-center">@item.FechaRegistro</td>
                            <td class="text-center">@Html.DisplayFor(modelItem => item.DocNumTicket)</td>
                            <td class="text-center">@(item.DetORTV != null ? item.DetORTV["CardName"] : "")</td>
                            <td class="text-center">@(item.DetORTV != null ? item.DetORTV["LugarDestino"] : "")</td>
                            <td class="text-center">@Html.DisplayFor(modelItem => item.Estado)</td>
                            <td class="text-center">@Html.DisplayFor(modelItem => item.Resultado)</td>
                            <td class="text-center @(((item.Estado == "Registrado" || item.Estado == "Proceso" || item.Estado == "Atendido") && item.DiasRetraso > 2) ? "text-rojo" : "")">@item.DiasRetraso</td>
                            <td class="text-center">@Html.DisplayFor(modelItem => item.Tipo)</td>
                            <td class="text-center">@Html.DisplayFor(modelItem => item.Factor)</td>
                            <td class="text-center">@item.enlistarDetSolicitudes()</td>
                            <td style="width: 20px">
                                <div class="btn-group-inline">
                                    <a href="@Url.Action("DetallesSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Detalles Solicitud">
                                        <i class="bi bi-search text-primary"></i>
                                    </a>
                                    @if (item.Estado.Equals("Registrado"))
                                    {
                                        <a href="@Url.Action("EditarSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Editar Solicitud">
                                            <i class="bi bi-pencil text-purple"></i>
                                        </a>
                                        <a href="@Url.Action("ProcesarSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Procesar Solicitud">
                                            <i class="bi bi-clock-history"></i>
                                        </a>
                                        <button style="border: none; background:none;" type="button" onclick="anular(@item.DocEntry);" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Anular Solicitud">
                                            <i class="bi bi-trash text-danger"></i>
                                        </button>
                                    }
                                    else if (item.Estado.Equals("Proceso"))
                                    {
                                        <a href="@Url.Action("ProcesarSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Procesar Solicitud">
                                            <i class="bi bi-clock-history"></i>
                                        </a>
                                        <a href="@Url.Action("AtenderSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Atender Solicitud">
                                            <i class="bi bi-clipboard"></i>
                                        </a>
                                    }
                                    else if (item.Estado.Equals("Atendido"))
                                    {
                                        <a href="@Url.Action("AtenderSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Atender Solicitud">
                                            <i class="bi bi-clipboard"></i>
                                        </a>
                                        <a href="@Url.Action("CulminarSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Culminar Solicitud">
                                            <i class="bi bi-pin"></i>
                                        </a>
                                    }
                                    else if (item.Estado.Equals("Culminado"))
                                    {
                                        <a href="@Url.Action("CulminarSolicitud", "AtencionCliente", new { id = item.DocEntry })" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Culminar Solicitud">
                                            <i class="bi bi-pin"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </form>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function filtrar() {
        var object = $("#frm").serialize();
        $(location).attr('href', "/AtencionCliente/GestionSolicitud?" + object);
    }
    function excel() {
        var object = $("#frm").serialize();
        $(location).attr('href', "/AtencionCliente/ExportarExcel?" + object);
    }
    function anular(id) {
        Swal.fire({
            title: '¿Esta seguro de anular?',
            text: "Luego no puede modificar los datos!",
            type: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: '¡Si, anular!'
        }).then(result => {
            if (result.value) {
                var parametros = { "DocEntry": id };
                $.ajax('/AtencionCliente/AnularSolicitud', {
                    data: parametros,
                    dataType: 'json',
                    cache: false,
                    type: 'post'
                })
                $(location).attr('href', "/AtencionCliente/GestionSolicitud");
            }
        });
    }
    function verMasNotificacion(CardCode) {
        var $tbody = $('#tablaDetalleNotificaciones tbody');
        $tbody.html('<tr><td colspan="4">Cargando...</td></tr>');
        $('#modalDetalleNotificacion').modal('show');
        $.ajax({
            url: '@Url.Action("ObtenerNotificadoClienteDetalle", "AtencionCliente")',
            type: 'GET',
            data: { CardCode: CardCode },
            dataType: 'json',
            success: function (data) {
                $tbody.empty();
                if (data && data.length > 0) {
                    for (var i = 0; i < data.length; i++) {
                        $tbody.append(
                            '<tr>' +
                                '<td>' + data[i].FechaSapTicket + '</td>' +
                                '<td>' + data[i].DocNumVt + '</td>' +
                                '<td>' + data[i].EstadoVt + '</td>' +
                                '<td>' + data[i].Vendedor + '</td>' +
                            '</tr>'
                        );
                    }
                } else {
                    $tbody.html('<tr><td colspan="4">No hay tickets abiertos para este cliente.</td></tr>');
                }
            },
            error: function () {
                $tbody.html('<tr><td colspan="4">Error al cargar los datos.</td></tr>');
            }
        });
        @{
            // Pintar de rojo mayor a 2 dias
            string estadoFiltro = f.Estado;
            var estadosValidos = new[] { "Registrado", "Proceso", "Atendido" };
            int contadorRojo = Model.Count(x =>
                estadosValidos.Contains(string.IsNullOrEmpty(estadoFiltro) ? x.Estado : estadoFiltro)
                && x.DiasRetraso > 2
            );
        }
    }

    $(document).ready(function () {
        // Evita que el clic en botones/links dentro de la fila principal dispare el evento de la fila
        $(document).on('click', '.fila-principal a, .fila-principal button', function (e) {
            e.stopPropagation();
        });
        // Maneja el clic en la fila principal
        $(document).on('click', '.fila-principal', function () {
            var docEntry = $(this).data('docentry');
            var $detalle = $('#detalle-' + docEntry);
            // Oculta todos los detalles excepto el seleccionado
            $('.fila-detalle').not($detalle).hide();
            // Alterna el detalle seleccionado
            $detalle.toggle();
        });
    });

    document.addEventListener('DOMContentLoaded', function () {
        var table = inicializarDataTable('tbl_ListadoSolicitudes', 20, true, false);
        $('#tbl_ListadoSolicitudes tbody').on('click', 'tr.fila-principal', function () {
            var tr = $(this);
            var row = table.row(tr);
            if (row.child.isShown()) {
                row.child.hide();
                tr.removeClass('shown');
            } else {
                // Obtiene los detalles desde el atributo data-detalle
                var detalles = JSON.parse(JSON.stringify(tr.data('detalle')));
                var html = '<table class="tabla-detalle-solicitud"><thead><tr><th>Código</th><th>Descripción</th><th>Lote</th><th>Fec. Ven</th></tr></thead><tbody>';
                for (var i = 0; i < detalles.length; i++) {
                    html += `<tr>
                          <td>${detalles[i].ItemCode}</td>
                          <td>${detalles[i].Dscription}</td>
                          <td>${detalles[i].BatchNum}</td>
                          <td>${detalles[i].ExpDate}</td>
                       </tr>`;
                }
                html += '</tbody></table>';
                row.child(html).show();
                tr.addClass('shown');
            }
        });
    });
</script>