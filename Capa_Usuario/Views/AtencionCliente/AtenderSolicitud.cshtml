@model Capa_Entidad.AtencionCliente_ENT.TablasSql.OSAT_E
@using Capa_Entidad.AtencionCliente_ENT.TablasSql
@using Capa_Entidad.General_ENT.Tablas
@using Capa_Entidad.Ventas_ENT.TablasSql
@{
    ViewBag.Title = "AtenderSolicitud";
    Layout = "~/Views/Shared/_Layout.cshtml";
    List<CC_OSAT_E> DatosAtencion = (List<CC_OSAT_E>)ViewBag.DatosAtencion;
    Dictionary<int, string> Adjuntos = (Dictionary<int, string>)ViewBag.Adjuntos;
    int cantidadAdjuntos = (Adjuntos != null) ? Adjuntos.Count() : 0;
}
<style>
    #Articulos td {
        font-size: 13px;
    }

    th {
        padding: 10px;
    }
</style>
<script>
    $(document).ready(function () {
        // Seteamos el valor TipoError
        $('#TipoError').val("@Model.Det[0].TipoError");
    });

    function enviarValorEscogido(valor, id) {
        $(`.cls-${id}`).val(valor);
    }

    function atenderSolicitud() {
        var object = $("#AtenderSolicitud").serialize();

        $.ajax('/AtencionCliente/validarAtenderSolicitud',
            {
                data: object,
                dataType: 'html',
                cache: false,
                type: 'post'
            })
            .done(function (response) {
                if (response != "true") { swal.fire({ title: response, text: "Presione OK para continuar", icon: "warning" }); return false }
                else { $("#AtenderSolicitud").submit(); }
            });
    }

    function revertirAtenderSolicitud() {
        var object = $("#AtenderSolicitud").serialize();
        Swal.fire({
            title: '¿Está seguro(a) de revertir la atención?',
            text: "Se restauraran los datos del último cambio",
            type: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Si, estoy seguro(a)',
            cancelButtonText: 'Cancelar'

        }).then(result => {
            if (result.value) {
                var form = $("#AtenderSolicitud");
                form.attr('action', '/AtencionCliente/RevertirAtenderSolicitud');
                form.submit();
            }
        });
    }

    $(document).ready(function () {
        $('#ErrorAlmacen').on('change', function () {
            if ($(this).val() === 'OTROS') {
                $('#div_comentario_otros').show();
            } else {
                $('#div_comentario_otros').hide();
                $('#ComentarioErrorAlmacen').val('');
            }
        });
    });
</script>

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("GestionSolicitud", "AtencionCliente")">Módulo gestión de solicitudes</a></li>
            <li class="current"><em>Atender solicitud</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">ATENDER SOLICITUD</h3></div>
</div>

<div class="bg-form-pestanas-cobefar">
    @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "AtenderSolicitud", enctype = "multipart/form-data" }))
    {

        <div class="bg-section-form p-4 bg-form-cobefar">
            @Html.EditorFor(model => model.DocEntry, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })

            <div class="row">
                @Html.EditorFor(model => model.DocEntry, new { htmlAttributes = new { @type = "hidden", @readonly = "true" } })
                <div class="col-lg-3">
                    <label for="Tipo" class="text-dark form-label font-weight-bold font-18">Tipo:</label>
                    @Html.EditorFor(model => model.Tipo, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>

                <div class="col-lg-3">
                    <label for="Estado" class="text-dark form-label font-weight-bold font-18">Estado:</label>
                    @Html.EditorFor(model => model.Estado, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-3">
                    <label for="DocNum" class="text-dark form-label font-weight-bold font-18">N° Solicitud:</label>
                    @Html.EditorFor(model => model.DocNum, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>

                @if (Model.Tipo != null && !Model.Tipo.Equals("Reclamo"))
                {
                    <div class="col-lg-3">
                        <label for="TipoVenta" class="text-dark form-label font-weight-bold font-18">Tipo de Venta:</label>
                        <input type="text" class="form-control text-center" id="TipoVenta" name="TipoVenta" readonly value="@ViewBag.TipoVenta">
                    </div>

                    <div class="col-lg-3">
                        <label for="CanalVenta" class="text-dark form-label font-weight-bold font-18">Canal de Venta:</label>
                        <input type="text" class="form-control text-center" id="CanalVenta" name="CanalVenta" readonly value="@ViewBag.CanalVenta">
                    </div>
                }

                <div class="col-lg-3">
                    <label for="Factor" class="text-dark form-label font-weight-bold font-18">Factor:</label>
                    @Html.EditorFor(model => model.Factor, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-3">
                    <label for="DocNumTicket" class="text-dark form-label font-weight-bold font-18">N° Ticket:</label>
                    @Html.EditorFor(model => model.DocNumTicket, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>

                <div class="col-lg-3">
                    <label for="Resultado" class="text-dark form-label font-weight-bold font-18">Resultado:</label>
                    @if (Model.Estado == "Atendido")
                    {
                        @Html.EditorFor(model => model.Resultado, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                    }
                    else if (Model.Estado == "Proceso")
                    {
                        <select name="Resultado" id="Resultado" class="form-control bg-cobefar text-white">
                            <option value="">Seleccione</option>
                            <option value="Pendiente" @if (Model.Resultado == "Pendiente") { Write("selected"); }>Pendiente</option>
                            <option value="Procede" @if (Model.Resultado == "Procede") { Write("selected"); }>Procede</option>
                            <option value="NoProcede" @if (Model.Resultado == "NoProcede") { Write("selected"); }>No Procede</option>
                            <option value="Parcial" @if (Model.Resultado == "Parcial") { Write("selected"); }>Parcial</option>
                        </select>
                    }
                </div>

                <div class="col-lg-3">
                    <label for="TipoSolucion" class="text-dark form-label font-weight-bold font-18">Tipo Solución:</label>
                    @if (Model.Estado == "Atendido")
                    {
                        @Html.EditorFor(model => model.TipoSolucion, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                    }
                    else if (Model.Estado == "Proceso")
                    {
                        <select name="TipoSolucion" id="TipoSolucion" class="form-control bg-cobefar text-white">
                            <option value="">Seleccione</option>
                            <option value="Regalo">Regalo</option>
                            <option value="Intercambio">Intercambio</option>
                            <option value="Envio">Envio</option>
                            <option value="NotaDeCredito">Nota De Credito</option>
                            <option value="NCPorDesc">Nota De Credito por Descuento</option>
                            <option value="Otros">Otros</option>
                        </select>
                    }
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-12">
                    <label for="Solucion" class="text-dark form-label font-weight-bold font-18">Solución:</label>
                    @if (Model.Estado == "Atendido")
                    {
                        @Html.EditorFor(model => model.Solucion, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                    }
                    else if (Model.Estado == "Proceso")
                    {
                        @Html.EditorFor(model => model.Solucion, new { htmlAttributes = new { @class = "form-control" } })
                    }
                </div>
            </div>

            <div class="row mt-4 mb-4">
                <div class="col-lg-3">
                    <label for="FechaAtencion" class="text-dark form-label font-weight-bold font-18">Fecha de atención:</label>
                    <input id="FechaAtencion" name="FechaAtencion" class="form-control text-center" value="@DatosAtencion[0].FechaOperacion" readonly />
                </div>

                <div class="col-lg-4">
                    <label for="OpAtencion" class="text-dark form-label font-weight-bold font-18">Op Atención:</label>
                    <input id="OpAtencion" name="OpAtencion" class="form-control text-center" value="@DatosAtencion[0].Operario" readonly />
                </div>

                <div class="col-lg-3">
                    <label for="LugarDestino" class="text-dark form-label font-weight-bold font-18">Lugar de Destino:</label>
                    @Html.EditorFor(model => model.DetORTV["LugarDestino"], new { htmlAttributes = new { @class = "form-control text-center", @readonly = "true" } })
                </div>
            </div>

            <hr />
            <h4 class="text-cobefar font-weight-bold">DATOS DEL CLIENTE</h4>

            <div class="row mt-4">
                <div class="col-5">
                    <label for="Contacto" class="text-dark form-label font-weight-bold font-18">Contacto:</label>
                    @Html.EditorFor(model => model.Contacto, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>

                <div class="col-5">
                    <label for="Correo" class="text-dark form-label font-weight-bold font-18">Correo:</label>
                    @Html.EditorFor(model => model.Correo, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>

                <div class="col-2">
                    <label for="Telefono" class="text-dark form-label font-weight-bold font-18">Teléfono:</label>
                    @Html.EditorFor(model => model.Telefono, new { htmlAttributes = new { @class = "form-control text-center", @readonly = true } })
                </div>

            </div>

            <div class="row mt-4">
                <div class="col-lg-10">
                    <label for="DireccionRecojo" class="text-dark form-label font-weight-bold font-18">Dirección:</label>
                    @Html.EditorFor(model => model.DireccionRecojo, new { htmlAttributes = new { @class = "form-control ", @readonly = true } })
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-4">
                    <label for="TipoError" class="text-dark form-label font-weight-bold font-18">Tipo de Error:</label>
                    <input type="text" id="TipoError" name="TipoError" class="form-control text-center" value="@Model.Det[0].TipoError" readonly />
                </div>

                <div class="col-lg-4">
                    <label for="Problema" class="text-dark form-label font-weight-bold font-18">Problema:</label>
                    <input type="text" id="Problema" name="Problema" class="form-control text-center" value="@Model.Det[0].Problema" readonly />
                </div>

                @if (Model.Estado == "Atendido" && Model.Det[0].TipoError == "ErrorAlmacen")
                {
                    <div class="col-lg-3">
                        <label class="text-dark form-label font-weight-bold font-18">Error de almacén:</label>
                        <input type="text" class="form-control text-center border-success" readonly
                               value="@(Model.Det[0].ErrorAlmacen == "ARECEP3" ? "Área de Recepción 3" :
                        Model.Det[0].ErrorAlmacen == "ARECEP5" ? "Área de Recepción 5" :
                        Model.Det[0].ErrorAlmacen == "ARECEP6" ? "Área de Recepción 6" :
                        Model.Det[0].ErrorAlmacen == "ARECEP7" ? "Área de Recepción 7" :
                        Model.Det[0].ErrorAlmacen == "ARECEP8" ? "Área de Recepción 8" :
                        Model.Det[0].ErrorAlmacen == "ADESP"   ? "Área de Despacho" :
                        Model.Det[0].ErrorAlmacen == "AVERIF"  ? "Área de Verificación" :
                        Model.Det[0].ErrorAlmacen == "AEMB"    ? "Área de Embalaje" :
                        Model.Det[0].ErrorAlmacen == "APICK"   ? "Área de Picking" :
                        Model.Det[0].ErrorAlmacen == "AFACT"   ? "Área de Facturación" :
                        Model.Det[0].ErrorAlmacen == "AING"    ? "Área de Ingreso" :
                        Model.Det[0].ErrorAlmacen == "OTROS"   ? "Otros" : "")" />
                    </div>

                    <div class="col-lg-4 mt-3">
                        @if (Model.Det[0].ErrorAlmacen == "OTROS")
                        {
                            <div style="margin-top:8px;">
                                <label class="text-dark form-label font-weight-bold font-18">Comentario (obligatorio si selecciona Otros):</label>
                                @Html.EditorFor(model => @Model.Det[0].ErrAlmOtrCom, new { htmlAttributes = new { @class = "form-control border-success text-center", @readonly = true } })
                            </div>
                        }
                    </div>


                }
                else
                {
                    <div id="div_errorAlmacen" class="col-lg-3" style="display: none">
                        <label for="ErrorAlmacen" class="text-dark form-label font-weight-bold font-18">Error de almacén:</label>
                        <select class="form-control bg-cobefar text-white" id="ErrorAlmacen" name="ErrorAlmacen" onchange="enviarValorEscogido(this.value, this.id)">
                            <option value=''>Seleccione</option>
                            <option value='ARECEP3'>Área de Recepción 3</option>
                            <option value='ARECEP6'>Área de Recepción 6</option>
                            <option value='ARECEP8'>Área de Recepción 8</option>
                            <option value='ADESP'>Área de Despacho</option>
                            <option value='AVERIF'>Área de Verificación</option>
                            <option value='AEMB'>Área de Embalaje</option>
                            <option value='APICK'>Área de Picking</option>
                            <option value='AFACT'>Área de Facturación</option>
                            <option value='AING'>Área de Ingreso</option>
                            <option value='OTROS'>Otros</option>
                        </select>
                        <div id="div_comentario_otros" style="display:none; margin-top:8px;">
                            <label for="ErrAlmOtrCom" class="form-label font-weight-bold">Comentario (obligatorio si selecciona Otros):</label>
                            <textarea class="form-control" id="ErrAlmOtrCom" name="ErrAlmOtrCom" rows="2" maxlength="250"></textarea>
                        </div>
                    </div>
                }
            </div>

            <div class="row mt-4 ">
                <div class="col-lg-12 ">
                    <table id="ArtAten" class="table table-light table-hover table-bordered table-responsive">
                        <thead class="thead-cobefar">
                            <tr>
                                <th class="text-center" style="width:50px">Nro Sap</th>
                                <th class="text-center" style="width:50px">Código</th>
                                <th class="text-center" style="width:250px">Descripción</th>
                                <th class="text-center" style="width:110px">Lote</th>
                                <th class="text-center" style="width:80px">Fecha Ven</th>
                                <th class="text-center" style="width:50px">UmVend</th>
                                <th class="text-center" style="width:50px">CantVend</th>
                                <th class="text-center" style="width:50px">Precio</th>
                                <th class="text-center" style="width:50px">UM Rec</th>
                                <th class="text-center" style="width:50px">CantRec</th>
                                <th class="text-center" style="width:50px">Total</th>
                                <th class="text-center" style="width:150px">Operario Responsable</th>
                                <th class="text-center" style="width:100px">Comentario</th>
                                <th class="text-center" style="width:100px">Regalo</th>
                                <th class="text-center" style="width:100px">Motivo Regalo</th>
                                <th class="text-center">Tarea Fact</th>
                                <th class="text-center" style="width:100px">Comprobante Vinc.</th>
                                <th class="text-center" style="width:100px">Alm Transf</th>
                                <th class="text-center" style="width:80px">Alm Venta</th>
                            </tr>
                        </thead>
                        <tbody class="bg-light">
                            @{
                                int i = 0;
                                Dictionary<string, string> unitMsrF = new Dictionary<string, string>();
                                unitMsrF.Add("C", "CAJA");
                                unitMsrF.Add("P", "PIEZA");
                            }
                            @foreach (var obj in Model.Det)
                            {
                                <tr>
                                    <td class="text-center">
                                        <input type='hidden' name='Det[@i].Linea' value='@obj.Linea' readonly />
                                        <input type='hidden' name='Det[@i].Problema' id='Det@(i)Problema' value='@obj.Problema' readonly />
                                        <input type='hidden' name='Det[@i].TipoError' id='Det@(i)TipoError' value='@obj.TipoError' readonly />
                                        <input type='hidden' class="cls-ErrorAlmacen" name='Det[@i].ErrorAlmacen' id='Det@(i)ErrorAlmacen' value='' readonly />
                                        <input type='hidden' name='Det[@i].NroSap' value='@obj.NroSap' readonly />
                                        @obj.NroSap
                                    </td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].ItemCode' value='@obj.ItemCode' readonly />@obj.ItemCode</td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].Dscription' value='@obj.Dscription' readonly />@obj.Dscription</td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].BatchNum' value='@obj.BatchNum' readonly />@obj.BatchNum</td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].ExpDate' value='@obj.ExpDate' readonly />@obj.ExpDate</td>
                                    <td class="text-center">
                                        <input type='hidden' name='Det[@i].unitMsr' value='@obj.UnitMsr' readonly />@obj.UnitMsr
                                        <input type='hidden' name='Det[@i].NumPerMsr' id='Det@(i)NumPerMsr' value='@obj.NumPerMsr' readonly />
                                    </td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].Quantity' value='@((int)obj.Quantity)' readonly />@((int)obj.Quantity)</td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].PriceAfVAT' id='Det@(i)PriceAfVAT' value='@((double)obj.PriceAfVAT)' readonly />@((double)obj.PriceAfVAT)</td>
                                    <td class="text-center"><input type='hidden' name='Det[@i].unitMsrF' value="@obj.unitMsrF" readonly />@unitMsrF[obj.unitMsrF]</td>
                                    <td class="text-center"><input type="hidden" name='Det[@i].QuantityF' value="@((int)obj.QuantityF)" id='Det@(i)QuantityF' readonly>@Convert.ToInt32(obj.QuantityF).ToString()</td>
                                    <td class="text-center"><input type="hidden" name='Det[@i].LineTotalF' value="@((double)obj.LineTotalF)" id='Det@(i)LineTotalF' readonly />@Convert.ToDouble(obj.LineTotalF).ToString()</td>
                                    <td class="text-center"><input type="hidden" name='Det[@i].OpResponsable' value='@obj.OpResponsable' readonly />@obj.OpResponsable</td>

                                    @if (Model.Estado == "Atendido")
                                    {
                                        <td class="text-center">
                                            <input class='form-control' type='text' name='Det[@i].Comentario' value='@obj.Comentario' style='width: 200px; ' readonly />
                                        </td>
                                    }
                                    else if (Model.Estado == "Proceso")
                                    {
                                        <td class="text-center"><input class='form-control' type='text' name='Det[@i].Comentario' value='@obj.Comentario' style='width: 200px' autocomplete="off" /></td>
                                    }
                                    @if (Model.Estado == "Atendido")
                                    {
                                        <td class="text-center">
                                            <input class='form-control' type='text' name='Det[@i].Regalo' value='@obj.Regalo' style='width: 280px;' readonly />
                                        </td>
                                    }
                                    else if (Model.Estado == "Proceso")
                                    {
                                        <td class="text-center">
                                            <input type="text" class='form-control' name='Det[@i].Regalo' list="listaRegalos" style='width: 280px;' autocomplete="off">
                                            <datalist id="listaRegalos">
                                                <option value="">Seleccione</option>
                                                @foreach (OREG_E bean in ViewBag.Regalos)
                                                {
                                                    <option value="@(bean.Categoria+' '+bean.Tipo)">@(bean.Categoria + ' ' + bean.Tipo)</option>
                                                }
                                            </datalist>
                                        </td>
                                    }
                                    @if (Model.Estado == "Atendido")
                                    {
                                        <td class="text-center">
                                            <input class="form-control" type="text" name="Det[@i].MotRegalo" value="@obj.MotRegalo" style="width: 280px;" readonly />
                                        </td>
                                    }
                                    else if (Model.Estado == "Proceso")
                                    {
                                        <td class="text-center"><input class="form-control" type="text" name="Det[@i].MotRegalo" value="@obj.MotRegalo" style="width: 280px;" /></td>
                                    }
                                    @if (Model.Estado == "Atendido")
                                    {
                                        <td class="text-center">
                                            <input class='form-control' type='text' name='Det[@i].TareaFact' value='@obj.TareaFact' style="width: 180px" readonly />
                                        </td>
                                    }
                                    else if (Model.Estado == "Proceso")
                                    {
                                        <td class="text-center">
                                            <select class='form-control' name='Det[@i].TareaFact' id='Det@(i)TareaFact' style="width: 180px">
                                                <option value=''>Seleccione</option>
                                                @if (obj.TareaFact == "N.C.")
                                                {
                                                    <option value='N.C.' selected>Nota de Credito</option>
                                                }
                                                else
                                                {
                                                    <option value='N.C.'>Nota de Credito</option>
                                                }
                                            </select>
                                        </td>
                                    }
                                    @if (Model.Estado == "Atendido")
                                    {
                                        <td class="text-center">
                                            <div>
                                                <input class="form-control" type="text" name="Det[@i].ComprobanteVinc" value="@obj.ComprobanteVinc" style="width: 230px" readonly />
                                            </div>

                                            @if (obj.ReferenciaNC_ND != null && obj.NuevoPrecioArticulo != null)
                                            {
                                                <div>
                                                    <div class="mt-3">
                                                        <label class="form-label font-weight-bold">Nuevo precio artículo:</label>
                                                        <input type="text" name="Det[@i].NuevoPrecioArticulo" class="form-control cls-num text-right" value="@((double)obj.NuevoPrecioArticulo)" readonly />
                                                    </div>
                                                    <div class="mt-3">
                                                        <label class="form-label font-weight-bold">Referencia NC/ND:</label>
                                                        <input type="text" name="Det[@i].ReferenciaNC_ND" class="form-control" value="@obj.ReferenciaNC_ND" readonly />
                                                    </div>
                                                </div>
                                            }
                                        </td>
                                    }
                                    else if (Model.Estado == "Proceso")
                                    {
                                        <td class="text-center">
                                            <div>
                                                <select class="form-control cls-comprobanteVinc" name="Det[@i].ComprobanteVinc" id="Det@(i)ComprobanteVinc" onchange="actualizarClaseSelect(this, '@i')" style="width: 230px">
                                                    <option value=''>Seleccione</option>
                                                    @foreach (var item in obj.ComprobantesVinculados)
                                                    {
                                                        <option value="@item.Key" data-tiponota="@item.Value.TipoNota" data-nronota="@item.Value.NroNota">@item.Key @item.Value.TipoNota</option>
                                                    }
                                                </select>
                                            </div>

                                            <div id="div_FacturaNC_ND_@i" hidden>
                                                <div class="mt-3">
                                                    <label class="form-label font-weight-bold">Nuevo precio artículo:</label>
                                                    <input type="text" name="Det[@i].NuevoPrecioArticulo" id="Det@(i)NuevoPrecioArticulo" class="form-control cls-num" value="" />
                                                </div>
                                                <div class="mt-3">
                                                    <label class="form-label font-weight-bold">Referencia NC/ND:</label>
                                                    <input type="text" name="Det[@i].ReferenciaNC_ND" id="ReferenciaNC_ND_@(i)" class="form-control" value="" readonly />
                                                </div>
                                            </div>
                                        </td>
                                    }
                                    @if (Model.Estado == "Atendido")
                                    {
                                        <td class="text-center">
                                            <input class='form-control' type='text' name='Det[@i].AlmTransf' value='@obj.AlmTransf' style="width: 270px;" readonly />
                                        </td>
                                    }
                                    else if (Model.Estado == "Proceso")
                                    {
                                        <td class="text-center">
                                            <select class='form-control' name='Det[@i].AlmTransf' id="Almacen" style="width: 270px; ">
                                                <option value="">Seleccione</option>
                                                @foreach (OWHS_E bean in ViewBag.Almacenes)
                                                {
                                                    <option value="@bean.WhsCode" WhsName="@bean.WhsName">@bean.WhsName</option>
                                                }
                                            </select>
                                        </td>
                                    }
                                    <td class="text-center"><input type='hidden' name='Det[@i].AlmVenta' value='@obj.AlmVenta' readonly />@obj.AlmVenta</td>
                                </tr>

                                { i++; }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (cantidadAdjuntos >= 1)
            {
                foreach (KeyValuePair<int, string> adj in Adjuntos)
                {
                    <div class="row mt-3">
                        <div class="col-lg-4">
                            <div class="d-flex">
                                <input class='form-control' value='@adj.Value' readonly />
                                <a href="@Url.Action("ArchivoSolicitud", "AtencionCliente" , new { id = Model.DocEntry, linea = adj.Key } )" class="btn btn-cobefar"><i class="icon-folder-download"></i> Descargar</a>
                            </div>

                        </div>
                    </div>
                }
            }
            <div class="row mt-3">
                <div class="col-lg-6">
                    <label for="UrlArchivo" class="text-dark form-label font-weight-bold font-18">Url Drive:</label>
                    @Html.EditorFor(model => model.UrlArchivo, new { htmlAttributes = new { @class = "form-control", @readonly = true } })
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-6">
                    <button type="button" class="btn btn-success" onclick="atenderSolicitud();"><i class="icon icon-checkmark"></i> Atender</button>
                    @if (Model.Estado == "Atendido")
                    {
                        <button type="button" class="btn btn-outline-danger" onclick="revertirAtenderSolicitud();"><i class="icon icon-undo"></i> Revertir</button>
                    }
                </div>
            </div>

        </div>

    }
</div>

<script>
    if ('@ViewBag.Mensaje' != "") {
        swal.fire({
            title: "@ViewBag.Mensaje",
            text: "Presione OK para continuar",
            icon: "warning"
        })
    };

    document.addEventListener('DOMContentLoaded', function () {
        permitirValoresNumericosPositivos();
    });

    document.getElementById("Resultado").addEventListener("change", (event) => {
        let tipoError = document.getElementById("TipoError").value;
        let errorAlmacen = document.getElementById("ErrorAlmacen").value;

        if (event.target.value != '' && event.target.value != 'NoProcede' && tipoError == 'ErrorAlmacen') {
            document.getElementById("div_errorAlmacen").style.display = "block";
            $('.cls-ErrorAlmacen').val(errorAlmacen);
        } else {
            document.getElementById("div_errorAlmacen").style.display = "none";
            $('.cls-ErrorAlmacen').val('');
        }
    });

    function actualizarClaseSelect(input, id) {
        const selectedOption = input.options[input.selectedIndex];
        const tipoNota = selectedOption.getAttribute('data-tiponota');
        const nroNota = selectedOption.getAttribute('data-nronota');

        if (input.value !== '' && tipoNota !== '') {
            input.classList.add('bg-danger', 'text-white');
            document.querySelector(`#div_FacturaNC_ND_${id}`).hidden = false;
            document.querySelector(`#ReferenciaNC_ND_${id}`).value = nroNota;
        } else {
            input.classList.remove('bg-danger', 'text-white');
            document.querySelector(`#div_FacturaNC_ND_${id}`).hidden = true;
            document.querySelector(`#ReferenciaNC_ND_${id}`).value = '';
        }
    }
</script>