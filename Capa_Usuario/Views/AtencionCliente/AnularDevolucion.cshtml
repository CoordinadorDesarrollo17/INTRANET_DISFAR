@model Capa_Entidad.Rutas_ENT.TablasSql.ORRU_E
@using Capa_Entidad.Rutas_ENT.TablasSql
@using Capa_Entidad.Seguridad_ENT
@{
    ViewBag.Title = "Anulación de Hoja de Ruta - Devolución";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
    var usuario = (Usuario_E)Session["UsuarioId"];
}

<div class="pt-4">
  <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
          <li><a href="@Url.Action("HojaRuta", "AtencionCliente")">Hoja de Ruta - Devoluciones</a></li>
     <li class="current"><em>Anulación de devolución</em></li>
   </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="d-flex flex-column">
    <div class="row px-3 pt-3 mb-3">
            <h3 class="titulo-seccion">@ViewBag.Title.ToUpper()</h3>
        </div>
    </div>
</div>

<div class="bg-form-pestanas-cobefar pt-4 bg-section-form p-4 bg-form-cobefar">
    <h3 class="text-cobefar font-weight-bold">HOJA DE RUTA DE DEVOLUCIÓN</h3>

    @using (Html.BeginForm())
    {
        @Html.Hidden("DocEntry", Model.DocEntry)
 
     <div class="card mb-4 shadow-sm">
            <div class="card-body">
        <div class="row align-items-center">
          <div class="col-lg-8">
             <h5 class="mb-0 text-danger font-weight-bold">żEstá seguro que desea anular la Hoja de Ruta de Devolución?</h5>
         </div>
        <div class="col-lg-4 text-right">
      <button type="submit" class="btn btn-danger btn-lg px-4">
      <i class="icon-blocked mr-2"></i> Anular Devolución
      </button>
       </div>
     </div>
      </div>
        </div>
 }

    <div class="card mb-4">
   <div class="card-header bg-cobefar-degradado-1 text-white font-weight-bold">Datos Generales</div>
        <div class="card-body">
            <div class="row mb-2">
       <div class="col-md-4">
           <label class="fw-bold">Tipo de Ruta:</label>
        <span class="ml-2">@(Model.TipoRuta == "DE" ? "DEVOLUCIÓN" : Model.TipoRuta)</span>
    </div>
                <div class="col-md-4">
        <label class="fw-bold">Estado de documento:</label>
       <span class="ml-2 badge badge-warning">@Model.Estado</span>
           </div>
    <div class="col-md-4">
         <label class="fw-bold">N° Documento:</label>
  <span class="ml-2">@Model.DocNum</span>
       </div>
            </div>
            <div class="row mb-2">
    <div class="col-md-4">
         <label class="fw-bold">Conductor:</label>
     <span class="ml-2">@Model.TransDesc</span>
     </div>
                <div class="col-md-4">
                 <label class="fw-bold">Placa:</label>
    <span class="ml-2">@Model.Placa</span>
        </div>
         <div class="col-md-4">
         <label class="fw-bold">Fecha Documento:</label>
       <span class="ml-2">@(Model.FechaDoc != null ? Model.FechaDoc.Value.ToString("dd/MM/yyyy") : "-")</span>
         </div>
        </div>
       <div class="row mb-2">
           <div class="col-md-4">
               <label class="fw-bold">Hora Registro:</label>
               <span class="ml-2">
                   @if (!string.IsNullOrEmpty(Model.HoraRegistro))
                   {
                       @Model.HoraRegistro.Substring(0, 8) @* Tomar solo HH:mm:ss *@
                   }
                   else
                   {
                       <text>-</text>
                   }
               </span>
           </div>
     <div class="col-md-4">
    <label class="fw-bold">@Html.DisplayNameFor(model => model.AlmDestinoDesc):</label>
      <span class="ml-2">@Model.AlmDestinoDesc</span>
   </div>
     <div class="col-md-4">
         <label class="fw-bold">Fecha Contable:</label>
      <span class="ml-2">@(Model.FechaCont != null ? Model.FechaCont.Value.ToString("dd/MM/yyyy") : "-")</span>
    </div>
    </div>
        </div>
</div>

    <div class="card mb-4">
        <div class="card-header bg-cobefar-degradado-1 text-white font-weight-bold">Tripulación</div>
        <div class="card-body">
      <div class="row mb-2">
           <div class="col-md-3">
            <label class="fw-bold">Copiloto 1:</label>
      <span class="ml-2">@Model.CopilDesc</span>
     </div>
      <div class="col-md-3">
         <label class="fw-bold">Copiloto 2:</label>
     <span class="ml-2">@Model.Copil2Desc</span>
      </div>
     <div class="col-md-3">
  <label class="fw-bold">Copiloto 3:</label>
    <span class="ml-2">@Model.Copil3Desc</span>
    </div>
           <div class="col-md-3">
  <label class="fw-bold">Copiloto 4:</label>
          <span class="ml-2">@Model.Copil4Desc</span>
              </div>
     </div>
 </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-cobefar-degradado-1 text-white font-weight-bold">Otros Datos</div>
      <div class="card-body">
  <div class="row mb-2">
    <div class="col-md-4">
           <label class="fw-bold">Operario:</label>
<span class="ml-2">@Model.Operario</span>
     </div>
     <div class="col-md-8">
         <label class="fw-bold">Observaciones:</label>
        <span class="ml-2">@Model.Observaciones</span>
                </div>
      </div>
  <div class="row mb-2">
      <div class="col-md-4">
      <label class="fw-bold">Tiempo Pactado:</label>
    <span class="ml-2">@(Model.TiempoPac != null ? Model.TiempoPac.Value.ToString("dd/MM/yyyy HH:mm") : "-")</span>
          </div>
     <div class="col-md-4">
             <label class="fw-bold">Total de Cajas:</label>
     <span class="ml-2">@Model.TotalCajas</span>
       </div>
            </div>
      </div>
    </div>

  <div class="card mb-4">
        <div class="card-header bg-cobefar-degradado-1 text-white font-weight-bold">
       Detalle de Órdenes de Devolución
   </div>
    <div class="card-body p-0">
     <div class="table-responsive">
      <table class="table table-sm table-hover table-bordered mb-0">
     <thead class="bg-danger text-white">
   <tr>
        <th class="text-center font-weight-bold" style="width: 5%;">#</th>
 <th class="text-center font-weight-bold" style="width: 15%;">Ticket</th>
  <th class="text-center font-weight-bold" style="width: 25%;">Cliente</th>
        <th class="text-center font-weight-bold" style="width: 25%;">Guías</th>
  <th class="text-center font-weight-bold" style="width: 10%;">Cajas</th>
     <th class="text-center font-weight-bold" style="width: 15%;">Estado</th>
       </tr>
 </thead>
           <tbody>
   @if (Model.DetRRU0 != null && Model.DetRRU0.Any())
           {
   foreach (RRU0_E d in Model.DetRRU0)
  {
     <tr>
            <td class="text-center">@d.Linea</td>
       <td class="text-center">@d.DocNumTicket</td>
         <td>@(d.Socio ?? (d.Ticket != null ? d.Ticket.CardName : "-"))</td>
   <td class="text-center">@d.Guias</td>
   <td class="text-center">@d.Cajas</td>
  <td class="text-center">
<span class="badge badge-info">@d.Estado</span>
 </td>
           </tr>
      }
       }
         else
     {
      <tr>
<td class="text-center" colspan="6">No hay órdenes de devolución asociadas.</td>
</tr>
     }
      </tbody>
     </table>
    </div>
  </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var mensaje = '@ViewBag.Mensaje';
  if (mensaje && mensaje.trim() !== "") {
        var esError = mensaje.toLowerCase().includes('error');
 Swal.fire({
    title: 'Resultado de la operación',
text: mensaje,
 icon: esError ? 'error' : 'success',
    confirmButtonText: 'Aceptar',
     confirmButtonColor: '#3085d6'
      });
    }
});
</script>