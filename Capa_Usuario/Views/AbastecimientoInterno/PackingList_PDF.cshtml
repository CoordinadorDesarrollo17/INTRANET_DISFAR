@{
    ViewBag.Title = "Packing List";
    Layout = null;

    var baseUrl = $"{Request.Url.Scheme}://{Request.Url.Authority}";
    var logoUrl = $"{baseUrl}{Url.Content("~/imagenes/logoventa2.jpg")}";
}


<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        html, body, table, td, th {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 14px;
        }

        .encabezado {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

            .encabezado img {
                height: 50px;
            }

        .datos-usuario {
            text-align: right;
        }

        .titulo {
            text-align: center;
            font-size: 30px;
            font-weight: bold;
            margin-bottom: 0px;
            background-color: #006450;
            color: white;
            padding-top: 15px;
            padding-bottom: 15px;
        }

        th, td {
            border: 1px solid black;
            padding: 6px;
        }

        th {
            background-color: #f2f2f2;
            padding-top: 10px;
            padding-bottom: 10px;
            text-align: center;
        }

        td {
            padding: 6px;
        }

        tr:nth-child(even) {
            background-color: #fafafa;
        }

        .page-break {
            page-break-after: always;
        }
    </style>
</head>
<body>
    <div>
        <div class="encabezado">
            <img src="@logoUrl" alt="Logo COBEFAR">
            <div class="datos-usuario">
                <div class="mb-2"><strong>Usuario:</strong> @ViewBag.Usuario</div>
                <div><strong>Fecha y hora de impresión:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>

        <div class="titulo">Packing List - APROBADOS</div>

        <table class="table table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ubicación destino</th>
                    <th>Código del artículo</th>
                    <th>Descripción</th>
                    <th>Lote</th>
                    <th>Unidad Máster</th>
                    <th>Cant. Máster</th>
                    <th>Cant. Saldo</th>
                    <th>Cant. Unidades Cajas</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detalle in Model)
                {
                    <tr>
                        <td class="text-center">@detalle.CodigoUbicacion</td>
                        <td class="text-center">@detalle.ItemCode</td>
                        <td>@detalle.ItemName</td>
                        <td class="text-center">@detalle.BatchNum</td>
                        <td class="text-center">@detalle.UmAlm</td>
                        <td class="text-end">@detalle.QuantityMaster</td>
                        <td class="text-end">@detalle.QuantitySaldo</td>
                        <td class="text-end">@detalle.QuantityUnidadesCajas</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</body>
</html>