		//Buscador rápido para master y ubicaciones
        let selectActual = null;
        let modalInstance = null;
        function abrirModalBusquedaRapida(selectElement) {
            selectActual = selectElement;
            // Validar si aún no hay opciones (y cargar solo en caso sea de Ubicaciones)
            if (selectActual.options.length <= 1 && selectActual.id.startsWith('lote_ubicacion') ) {
                let idLote = selectElement.dataset.idloteubicacion;
                cargarUbicaciones('RESERVA', { idloteubicacion: idLote });
            }
            if (!modalInstance) {
                const modalElement = document.getElementById('modalBuscador');
                modalElement.setAttribute('aria-hidden', 'false');
                modalInstance = new bootstrap.Modal(modalElement);
            }
            const opciones = Array.from(selectElement.options).filter(opt => opt.value);
            const contenedor = document.getElementById('resultadosBusqueda');
            contenedor.innerHTML = '';
            opciones.forEach(opt => {
                const item = document.createElement('button');
                item.type = 'button';
                item.className = 'list-group-item list-group-item-action';
                item.textContent = opt.text;
                item.dataset.value = opt.value;
                item.onclick = () => seleccionarOpcion(opt.value);
                contenedor.appendChild(item);
            });
            modalInstance.show();
            const inputBusqueda = document.getElementById('inputBusqueda');
            inputBusqueda.value = '';
            inputBusqueda.focus();
            inputBusqueda.oninput = function () {
                const filtro = this.value.toLowerCase();
                Array.from(contenedor.children).forEach(item => {
                    item.style.display = item.textContent.toLowerCase().includes(filtro) ? 'block' : 'none';
                });
            };
        }
        function seleccionarOpcion(valor) {
            if (selectActual) {
                selectActual.value = valor;
                selectActual.dispatchEvent(new Event('change'));
            }
            modalInstance.hide();
            const modalElement = document.getElementById('modalBuscador');
            if (modalElement.contains(document.activeElement)) {
                document.activeElement.blur();
            }
            modalElement.setAttribute('aria-hidden', 'true');
            if (selectActual) {
                selectActual.focus();
            }
            selectActual = null;
        }

        function validarTipoDocumento(valor) {
            if (valor == "") {
                return;
            }

            document.querySelector('#div_botones').style.display = 'block';

            if (valor == "EMI") {
                document.getElementById("MotivoTraslado").readOnly = false;
                document.getElementById("MotivoTraslado").classList.remove("cls-readonly");
                document.getElementById("btn_AbrirModalImportacion").disabled = true;
                document.getElementById('DocNum').readOnly = true;
                document.getElementById('buscarDocNum').disabled = true;
                resetValoresVacios(["DocEntry", "DocNum", "NroGuia", "CardCode", "CardName", "OperarioResponsableSAP", "MotivoTraslado", "DocDate", "copiaDocEntry", "copiaDocNum", "copiaNroGuia", "copiaCardCode", "copiaCardName",
                    "copiaOperarioResponsableSAP", "copiaMotivoTraslado", "copiaDocDate"]);
                document.querySelector("#tbl_detalle tbody").innerHTML = '';
                document.getElementById("btn_transferir").onclick = realizarTransferenciaEMI;
            }else {
                document.getElementById("MotivoTraslado").readOnly = true;
                document.getElementById("MotivoTraslado").classList.add("cls-readonly");
                document.getElementById("btn_AbrirModalImportacion").disabled = false;
                document.getElementById('DocNum').readOnly = false;
                document.getElementById('buscarDocNum').disabled = false;
                document.getElementById("btn_transferir").onclick = realizarTransferencia;
            }
        }


        let contadorProducto = 1;
        function agregarArticulo() {
            let correlativo = `producto_${contadorProducto}`;
            let itemCode = `COD${contadorProducto.toString().padStart(4, "0")}`; // ejemplo: COD0001
            let idTablaLotes = `tbl_detalleLotes_${itemCode}`;
            let correlativoLote = `${itemCode}_0001`;

            // Fila principal
            let filaPrincipal = `
            <tr data-producto="${correlativo}" class="fila-detalle">
                <td class="details-control text-center">
                    <button id="btn_chevron_${correlativo}" class="btn btn-sm btn-dark">
                        <i class="bi bi-chevron-up"></i>
                    </button>
                </td>
                <td class="text-center"><input type="text" id="ItemCode_${correlativo}" class="form-control cls-readonly text-center" readonly /></td>
                <td class="">
                  <select id="ItemName_${correlativo}" class="form-select" onclick="abrirModalBusquedaRapida(this)">
                      <option value="">Seleccione</option>
                      ${cargarOpcionesArticulos()}
                  </select>
                </td>
                <td class="text-center dt-type-numeric">
                    <div class="d-flex justify-content-center"></div>
                </td>
                <td class="text-center">
                    <div class="d-flex justify-content-center">
                        <input type="text" class="form-control text-center cls-readonly" value="RESERVA" readonly style="width: 140px" />
                    </div>
                </td>
                <td class="text-center"></td>
                <td class="text-center">PENDIENTE</td>
                <td class="text-center">
                    <button class="btn btn-danger" onclick="limpiarValoresItem('cls-limpiarItem_${correlativo}')" data-bs-toggle="tooltip" title="Borrar valores asignados">
                        <i class="bi bi-arrow-repeat"></i>
                    </button>
                </td>
            </tr>`;

            // Fila de subdetalle
            let filaSubdetalle = `
<tr class="detalle-fila">
    <td colspan="100%">
        <div class="d-flex justify-content-center w-100">
            <table id="${idTablaLotes}" class="table table-sm table-bordered table-hover subtable w-75 tbl_detalleLotes">
                <thead class="table-success">
                    <tr>
                        <th class="text-center" style="width: 100px;">Lote</th>
                        <th class="text-center" style="width: 200px;">Fecha de Admisión</th>
                        <th class="text-center" style="width: 200px;">Fecha de Vencimiento</th>
                        <th class="text-center" style="width: 200px;">Stock UNIDADES</th>
                        <th class="text-center" style="width: 200px;">Unidad MASTER</th>
                        <th class="text-center" style="width: 200px;">Cantidad en MASTER</th>
                        <th class="text-center" style="width: 200px;">Cantidad en SALDO</th>
                        <th class="text-center" style="width: 200px;">Ubicación</th>
                        <th style="width: 5%;"></th>
                    </tr>
                </thead>
                <tbody>
                    <tr data-lote="${correlativoLote}">
                        <td class="text-center">
                            <select id="BatchNum_${correlativo}" name="transferenciaPost.Detalle[].BatchNum" class="form-select lote-select"
                                onclick="abrirModalBusquedaRapida(this)" style="width:150px">
                                <option value="">Seleccione</option>
                            </select>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center"><input type="text" id="InDate_${correlativoLote}" name="transferenciaPost.Detalle[].InDate" class="form-control cls-readonly text-center" readonly ></div>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center"><input type="text" id="ExpDate_${correlativoLote}" name="transferenciaPost.Detalle[].ExpDate" class="form-control cls-readonly text-center" readonly></div>
                        </td>
                        <td class="text-center">
                            <input type="text" id="lote_quantityUnidades_${correlativoLote}" name="transferenciaPost.Detalle[].QuantityUnidadesCajas" class="form-control text-center cls-limpiarItem_${correlativo}"
                                data-idcantmaster="lote_cantidadMaster_${correlativoLote}"
                                data-idcantsaldo="lote_cantidadSaldo_${correlativoLote}"
                                data-idundmaster="lote_undMaster_${correlativoLote}"
                                oninput="calcularStockUnidades(this.value, this.dataset)" />
                        </td>
                        <td class="text-center">
                            <select id="lote_undMaster_${correlativoLote}"
                                    data-idundmaster="lote_undMaster_${correlativoLote}"
                                    data-idcantmaster="lote_cantidadMaster_${correlativoLote}"
                                    data-idcantsaldo="lote_cantidadSaldo_${correlativoLote}"
                                    data-idquantityunidades="lote_quantityUnidades_${correlativoLote}"
                                    name="transferenciaPost.Detalle[].ValorUmAlm"
                                    class="form-select cls-limpiarItem_${correlativo}"
                                    onchange="calcularCantidadMasterSaldo(this.value, this.dataset)"
                                    onclick="abrirModalBusquedaRapida(this)">
                                <option value="">Seleccione</option>
                                ${cargarOpcionesMasters()}
                            </select>
                        </td>
                        <td class="text-center">
                            <input type="text" id="lote_cantidadMaster_${correlativoLote}" name="transferenciaPost.Detalle[].QuantityMaster" class="form-control text-center cls-readonly cls-limpiarItem_${correlativo}" readonly />
                        </td>
                        <td class="text-center">
                            <input type="text" id="lote_cantidadSaldo_${correlativoLote}" name="transferenciaPost.Detalle[].QuantitySaldo" class="form-control text-center cls-readonly cls-limpiarItem_${correlativo}" readonly />
                        </td>
                        <td class="text-center">
                            <select id="lote_ubicacion_${correlativoLote}"
                                name="transferenciaPost.Detalle[].CodigoUbicacion"
                                data-idloteubicacion="lote_ubicacion_${correlativoLote}"
                                data-itemcode="${itemCode}"
                                class="form-select cls-limpiarItem_${correlativo}"
                                onclick="gestionarBusquedaUbicaciones(this)" style="width: 200px">
                            <option value="">Seleccione</option>
                        </select>
                         </td>
                        <td class="text-center">
                           <input type="hidden" id="hidden_ItemCode_${correlativoLote}" name="transferenciaPost.Detalle[].ItemCode" />
                            <input type="hidden" id="hidden_ItemName_${correlativoLote}" name="transferenciaPost.Detalle[].ItemName" />
                            <button type="button" class="btn btn-sm btn-cobefar" onclick="clonarFilaLote('${idTablaLotes}')">
                                <i class="bi bi-plus-lg"></i>
                            </button>
