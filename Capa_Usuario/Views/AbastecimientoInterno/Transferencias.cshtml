@{
    ViewBag.Title = "Transferencias";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
}
<style>
    #tbl_detalle {
        font-size: 12px !important;
    }

        #tbl_detalle input,
        #tbl_detalle select,
        #tbl_detalle textarea,
        #tbl_detalle button,
        #tbl_detalle label {
            font-size: 12px !important;
        }
</style>
<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("Sesion", "Index")">Abastecimiento Interno</a></li>
            <li class="current"><em>@ViewBag.Title</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="row px-3 pt-3"><h3 class="titulo-seccion">@ViewBag.Title.ToUpper()</h3></div>
</div>

<div class="bg-white px-3 py-3 align-items-center">
    <div class="row mb-4">

        <div class="col-lg-2">
            <input type="hidden" id="DocEntry" name="DocEntry" readonly />
            <label for="TipoDocumento" class="form-label fw-bold">Tipo de documento:</label>
            <select id="TipoDocumento" name="TipoDocumento" class="form-select" onchange="validarTipoDocumento(this.value)">
                <option value="OWTQ">Solicitud de Traslado</option>
                <option value="EMI">Entrada de Mercadería Inventario</option>
            </select>
        </div>

        <div class="col-lg-2">
            <label for="DocNum" class="form-label fw-bold">DocNum:</label>
            <div class="input-group">
                <input type="text" id="DocNum" class="form-control border" name="DocNum" autocomplete="off" />
                <button id="buscarDocNum" type="button" class="btn btn-cobefar-2" onclick="buscarSolicitud()" data-bs-toggle="tooltip" data-bs-placement="top" title="Buscar solicitud de traslado">
                    <i class="bi bi-search"></i>
                </button>
                @*<button type="button" class="btn btn-outline-danger" data-bs-toggle="tooltip" data-bs-placement="top" title="Descargar PDF">
                        <i class="bi bi-file-earmark-pdf"></i>
                    </button>*@
            </div>
        </div>

        <div class="col-lg-2">
            <label for="NroGuia" class="form-label fw-bold">Nro. de guía:</label>
            <input type="text" id="NroGuia" class="form-control cls-readonly text-center" name="NroGuia" autocomplete="off" readonly />
        </div>

        <div class="col-lg-3">
            <label for="CardName" class="form-label fw-bold">Socio de Negocio:</label>
            <input type="hidden" id="CardCode" name="CardCode" readonly />
            <input type="text" id="CardName" class="form-control cls-readonly text-center" name="CardName" autocomplete="off" readonly />
        </div>

        <div class="col-lg-2">
            <label for="OperarioResponsableSAP" class="form-label fw-bold">Operario Responsable SAP:</label>
            <input type="text" id="OperarioResponsableSAP" class="form-control cls-readonly text-center" name="OperarioResponsableSAP" autocomplete="off" readonly />
            <input type="hidden" id="DocDate" name="DocDate" readonly />
        </div>

        <div class="col-lg-1 d-flex align-items-end">
            <button type="button" id="btn_AbrirModalImportacion" class="btn btn-success w-100" onclick="abrirModalImportacion()" data-bs-toggle="tooltip" data-bs-placement="top" title="Importar datos directamente a la base">
                <i class="bi bi-upload"></i>
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-2">
            <button id="btn_AgregarArticulo" class="btn btn-cobefar-2" onclick="agregarArticulo()">Agregar</button>
        </div>
    </div>

    <div class="col-12 align-items-center" style="max-height: 45vh; overflow-y: auto; margin: 0; padding: 0;">
        <div class="col-lg-12">
            <table id="tbl_detalle" class="dt-container dt-empty-footer table table-sm table-bordered" width="100%">
                <thead class="thead-cobefar">
                    <tr>
                        <th style="width: 5%;"></th>
                        <th scope="col" class="text-center">Código de artículo</th>
                        <th scope="col" class="text-center">Descripción</th>
                        <th scope="col" class="text-center">Cantidad</th>
                        <th scope="col" class="text-center">Alm. Destino</th>
                        <th scope="col" class="text-center">Lotes</th>
                        <th scope="col" class="text-center">Estado</th>
                        <th scope="col" class="text-center">
                            <button type="button" id="btn_validarTodo" class="btn btn-cobefar-3 text-dark btn-sm" onclick="validarTodo()" data-bs-toggle="tooltip" data-bs-placement="top" title="Validar todos los items">
                                <i class="bi bi-check-circle"></i> Validar todo
                            </button>
                        </th>
                    </tr>
                </thead>
                <tbody class="text-dark">
                </tbody>
            </table>
        </div>
    </div>

    <div id="copiaSap" hidden>
        <form id="frm_tablaCopiaSap">
            <div class="row mb-4">
                <div class="col-lg-12">
                    <input type="text" id="copiaDocEntry" name="DocEntry" readonly />
                    <input type="text" id="copiaDocNum" name="DocNum" readonly />
                    <input type="text" id="copiaNroGuia" name="NroGuia" readonly />
                    <input type="text" id="copiaCardCode" name="CardCode" readonly />
                </div>
            </div><!-- row -->

            <div class="row mb-4">
                <div class="col-lg-12">
                    <input type="text" id="copiaCardName" name="CardName" readonly />
                    <input type="text" id="copiaOperarioResponsableSAP" name="OperarioResponsableSAP" readonly />
                    <input type="text" id="copiaMotivoTraslado" name="MotivoTraslado" readonly />
                    <input type="text" id="copiaDocDate" name="DocDate" readonly />
                </div>
            </div><!-- row -->
        </form>
        <table id="tbl_copiaSap" class="table">
            <thead>
                <tr>
                    <th scope="col">ItemCode</th>
                    <th scope="col">ItemName</th>
                    <th scope="col">BatchNum</th>
                    <th scope="col">In Date</th>
                    <th scope="col">Exp Date</th>
                    <th scope="col">QuantityCajas</th>
                    <th scope="col">FromWhsCode</th>
                    <th scope="col">ToWhsCode</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

    <div class="row mt-3">
        <div class="col-6">
            <label for="MotivoTraslado" class="form-label fw-bold">Motivo Traslado:</label>
            <textarea id="MotivoTraslado" name="MotivoTraslado" class="form-control cls-readonly" rows="2" readonly></textarea>
        </div>
    </div>

    <hr />
    <div id="div_botones" class="row" style="display: none">
        <div class="col-lg-12">
            <button id="cancelarCritico" type="button" class="btn btn-danger" data-bs-toggle="tooltip" data-bs-placement="top" title="Cancelar" onclick="cancelarTransferenciaTraslado()"><i class="bi bi-x-lg"></i> Cancelar</button>
            <button type="button" id="btn_transferir" class="btn btn-success" data-bs-toggle="tooltip" data-bs-placement="top" title="Transferir" onclick="realizarTransferencia()"><i class="bi bi-arrow-left-right"></i> Transferir</button>
        </div>
    </div>
</div><!-- main -->


<div class="modal fade" id="ModalImportar" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-headerModals text-white">
                <h5 class="modal-title" id="modalLabel">IMPORTAR DATOS EXCEL</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="mb-3">
                    <label for="i_file" class="form-label text-dark">Seleccione archivo:</label>
                    <input id="i_file" name="file" type="file" class="form-control" accept=".xlsx" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" onclick="importarSolicitud()">
                    <i class="bi bi-database"></i> Guardar datos
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Busqueda Rapida -->
<div class="modal fade" id="modalBuscador" tabindex="-1" aria-labelledby="modalBuscadorLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-headerModals text-white">
                <h5 class="modal-title" id="modalBuscadorLabel">BÚSQUEDA RÁPIDA</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <input type="text" id="inputBusqueda" class="form-control mb-3" placeholder="Escriba para buscar...">
                <div id="resultadosBusqueda" class="list-group" style="max-height: 250px; overflow-y: auto;"></div>
            </div>

        </div>
    </div>
</div>

@section Scripts{
    <script>
		// Declaración de variables
        const articulos = @Html.Raw(Json.Encode(ViewBag.Articulos));
        let opcionesArticulos = '';
        let opcionesLotes = '';

        const masters = JSON.parse(`@Html.Raw(Json.Encode(ViewBag.Masters))`);
        let opcionesMasters = '';
		const configDataTable = {
			paging: false,          // Deshabilitar paginación
			searching: true,       // Ocultar la barra de búsqueda
			info: false,            // Ocultar el número de registros ("Mostrando X de Y registros")
			ordering: false,        // Deshabilitar la opción de ordenar columnas
			lengthChange: false,    // Ocultar el selector de cantidad de elementos por página
			bFilter: false,         // Desactivar filtrado de DataTables
			bSort: false,           // Desactivar ordenamiento en columnas
			bPaginate: false,       // Desactivar paginación manualmente
			autoWidth: false,       // Evita que DataTables ajuste el ancho de las columnas automáticamente
            responsive: true,        // Mantiene la tabla responsiva si es necesario
            language: {
                processing: "Procesando...",
                search: "Buscar:",
                lengthMenu: "Mostrar _MENU_ registros",
                info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                infoEmpty: "Mostrando 0 a 0 de 0 registros",
                infoFiltered: "(filtrado de _MAX_ registros en total)",
                infoPostFix: "",
                loadingRecords: "Cargando...",
                zeroRecords: "No se encontraron registros coincidentes",
                emptyTable: "No hay datos disponibles en la tabla",
                paginate: {
                    first: "Primero",
                    previous: "Anterior",
                    next: "Siguiente",
                    last: "Último"
                },
                aria: {
                    sortAscending: ": activar para ordenar la columna ascendente",
                    sortDescending: ": activar para ordenar la columna descendente"
                }
            }
		}
		// Funciones
		function cargarOpcionesMasters(unidadAlmSugerido) {
			opcionesMasters = ""; // Reiniciar la variable para evitar acumulación de valores previos
			masters.forEach(item => {
				opcionesMasters += `<option value="${item.ValorUmAlm}" data-umalm="${item.UmAlm}" ${item.UmAlm === unidadAlmSugerido ? 'selected' : ''}>${item.UmAlm}</option>`;
			});
			return opcionesMasters;
        }

        function cargarOpcionesArticulos() {
            opcionesArticulos = ""; // Reiniciar la variable para evitar acumulación de valores previos
            let vistos = new Set();

            articulos.forEach(item => {
                if (!vistos.has(item.ItemCode)) {
                    opcionesArticulos += `<option value="${item.ItemName}" data-itemcode="${item.ItemCode}" data-indate="${item.InDate}" data-expdate="${item.ExpDate}">${item.ItemCode} - ${item.ItemName}</option>`;
                    vistos.add(item.ItemCode);
                }
            });

            return opcionesArticulos;
        }

        function cargarOpcionesLotes(filtroItemCode = "") {
            if (!filtroItemCode) {
                generarAlerta("Error al cargar lotes", "Debes seleccionar un artículo.", "error");
                return "";
            }

            let opcionesLotes = "";
            let vistos = new Set();

            articulos
                .filter(a => a.ItemCode === filtroItemCode)
                .forEach(item => {
                    if (!vistos.has(item.BatchNum)) {
                        opcionesLotes += `<option value="${item.BatchNum}" data-indate="${item.InDate}" data-expdate="${item.ExpDate}">${item.BatchNum}</option>`;
                        vistos.add(item.BatchNum);
                    }
                });

            return opcionesLotes;
        }

		async function realizarTransferencia() {
			const form = document.querySelector('#frm_tablaCopiaSap')
			if (!form) {
				console.log("Formulario no válido.");
				return;
			}
			const filasSolicitudTraslado = document.querySelectorAll("#tbl_copiaSap tbody tr");
			let detallesSolicitud = [];
			filasSolicitudTraslado.forEach((fila) => {
				let inputs = fila.querySelectorAll("input, select");
				let detalleSolicitud = {};
				inputs.forEach(input => {
					let name = input.name.trim();
					if (name.startsWith("solicitudTraslado.Detalle[]")) {
						let key = name.replace("solicitudTraslado.Detalle[].", "").trim();
						detalleSolicitud[key] = input.value;
					}
				});
				if (Object.keys(detalleSolicitud).length > 0) detallesSolicitud.push(detalleSolicitud);
			});
			const filasTransferencia = document.querySelectorAll(".tbl_detalleLotes tbody tr");
			let detallesTransferencia = [];
			filasTransferencia.forEach((fila) => {
				let inputs = fila.querySelectorAll("input, select");
				let detalleTransferencia = {};
				let camposValidos = true; // Bandera para validar los campos requeridos
				inputs.forEach(input => {
					let name = input.name.trim();
					if (name.startsWith("transferenciaPost.Detalle[]")) {
						let key = name.replace("transferenciaPost.Detalle[].", "").trim();
						let value = input.value.trim(); // Aseguramos que no tenga espacios en blanco al inicio o fin
						if (key === "ValorUmAlm") {
							let selectedOption = input.options[input.selectedIndex];
							detalleTransferencia[key] = value;
							detalleTransferencia["UmAlm"] = selectedOption.dataset.umalm || ""; // Evita valores undefined
						} else {
							detalleTransferencia[key] = value;
						}
						// Verificar si los campos obligatorios están vacíos
						if ((key === "QuantitySaldo" || key === "UmAlm") && value === "") {
							camposValidos = false; // Marcar como inválido si algún campo está vacío
						}
					}
				});
				// Solo agregar si los campos requeridos tienen valores
				if (camposValidos && Object.keys(detalleTransferencia).length > 0) {
					detallesTransferencia.push(detalleTransferencia);
				}
			});
			const formData = new FormData(form);
			const jsonData = Object.fromEntries(formData.entries());
			const payload = {
				solicitudTraslado: {
					...jsonData, // Otros datos generales del formulario
					Detalle: detallesSolicitud
				},
				transferenciaPost: {
					...jsonData,
					SolicitudTrasladoDocNum: document.querySelector('#DocNum').value,
					Detalle: detallesTransferencia
				}
            };

            console.log(payload); return;
            registrarTransferenciaStock(payload)
		}

        async function realizarTransferenciaEMI() {
	        const form = document.querySelector('#frm_tablaCopiaSap')
	        if (!form) {
		        console.log("Formulario no válido.");
		        return;
	        }
            
            document.getElementById("copiaCardCode").value = 'P20600546041';
            document.getElementById("copiaCardName").value = 'COBEFAR S.A.C.';
            document.getElementById("copiaMotivoTraslado").value = document.getElementById("MotivoTraslado").value;

	        //const filasSolicitudTraslado = document.querySelectorAll("#tbl_copiaSap tbody tr");
	        //let detallesSolicitud = [];
	        //filasSolicitudTraslado.forEach((fila) => {
		       // let inputs = fila.querySelectorAll("input, select");
		       // let detalleSolicitud = {};
		       // inputs.forEach(input => {
			      //  let name = input.name.trim();
			      //  if (name.startsWith("solicitudTraslado.Detalle[]")) {
				     //   let key = name.replace("solicitudTraslado.Detalle[].", "").trim();
				     //   detalleSolicitud[key] = input.value;
			      //  }
		       // });
		       // if (Object.keys(detalleSolicitud).length > 0) detallesSolicitud.push(detalleSolicitud);
         //   });
            let detallesSolicitud = [];

	        const filasTransferencia = document.querySelectorAll(".tbl_detalleLotes tbody tr");
	        let detallesTransferencia = [];
	        filasTransferencia.forEach((fila) => {
		        let inputs = fila.querySelectorAll("input, select");
                let detalleTransferencia = {};
                let detalleSolicitud = {};
                let camposValidos = true; // Bandera para validar los campos requeridos

		        inputs.forEach(input => {
                    let name = input.name.trim();

			        if (name.startsWith("transferenciaPost.Detalle[]")) {
				        let key = name.replace("transferenciaPost.Detalle[].", "").trim();
				        let value = input.value.trim(); // Aseguramos que no tenga espacios en blanco al inicio o fin
				        if (key === "ValorUmAlm") {
					        let selectedOption = input.options[input.selectedIndex];
					        detalleTransferencia[key] = value;
					        detalleTransferencia["UmAlm"] = selectedOption.dataset.umalm || ""; // Evita valores undefined
				        } else {
					        detalleTransferencia[key] = value;
				        }
				        // Verificar si los campos obligatorios están vacíos
				        if ((key === "QuantitySaldo" || key === "UmAlm") && value === "") {
					        camposValidos = false; // Marcar como inválido si algún campo está vacío
                        }

                        // Solo tomar los campos requeridos para solicitudTraslado
                        if ([
                            "ItemCode", "ItemName", "BatchNum", "InDate", "ExpDate", "QuantityCajas"
                        ].includes(key)) {
                            detalleSolicitud[key] = value;
                        }
			        }
		        });

                // Forzar valores por defecto para almacenes
                detalleSolicitud["FromWhsCode"] = "16";
                detalleSolicitud["ToWhsCode"] = "16";

                // Solo agregar si los campos requeridos tienen valores
                if (Object.keys(detalleSolicitud).length > 0) {
                    detallesSolicitud.push(detalleSolicitud);
                }

		        if (camposValidos && Object.keys(detalleTransferencia).length > 0) {
			        detallesTransferencia.push(detalleTransferencia);
		        }
            });


	        const formData = new FormData(form);
	        const jsonData = Object.fromEntries(formData.entries());
	        const payload = {
                solicitudTrasladoPost: {
			        ...jsonData, // Otros datos generales del formulario
			        Detalle: detallesSolicitud
		        },
		        transferenciaPost: {
			        ...jsonData,
			        SolicitudTrasladoDocNum: document.querySelector('#DocNum').value,
			        Detalle: detallesTransferencia
		        }
            };

            //console.log(payload); return;
            registrarTransferenciaStock(payload);
        }

        async function registrarTransferenciaStock(payload) {
            try {
                const response = await fetch("/AbastecimientoInterno/RegistrarTransferenciaDeStock", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });
                if (!response.ok) {
                    throw new Error(`Error en la solicitud: ${response.status}`);
                }
                const data = await response.json();
                Swal.fire({
                    title: data.Titulo,
                    html: Array.isArray(data.Mensajes) && data.Mensajes.length > 0
                        ? data.Mensajes.join('<br>')
                        : data.Mensajes || "",
                    icon: data.Icono,
                    allowEscapeKey: false,
                    allowOutsideClick: false,
                    showConfirmButton: true
                }).then((result) => {
                    if (result.isConfirmed && data.Icono == "success") {
                        Swal.fire({
                            title: '¿Deseas continuar con la transferencia?',
                            text: "Solo para completar ítems que no han sido transferidos.",
                            icon: 'info',
                            showCancelButton: true,
                            confirmButtonColor: '#3085d6',
                            cancelButtonColor: '#d33',
                            confirmButtonText: '<i class="bi bi-check-lg"></i> Si, continuar',
                            cancelButtonText: '<i class="bi bi-x-lg"></i> Cancelar'
                        }).then(result => {
                            if (result.isConfirmed) {
                                buscarSolicitud()
                            } else {
                                location.reload()
                            }
                        });
                    }
                });
            } catch (error) {
                console.error("Error:", error);
            }
		}

        async function buscarSolicitud() {
            const copiaSapDiv = document.querySelector('#copiaSap');
            if (!copiaSapDiv) {
                console.log("No se encontró el div copiaSap.");
                return;
            }

            copiaSapDiv.hidden = true;
            copiaSapDiv.querySelectorAll('input').forEach(input => input.value = '');
            const tbody = copiaSapDiv.querySelector('#tbl_copiaSap tbody');
            if (tbody) tbody.innerHTML = '';

            document.querySelectorAll('button').forEach(btn => {
                btn.disabled = false;
            });

            let docNum = document.querySelector('#DocNum').value.trim();
            if (!docNum) {
                Swal.fire({
                    title: "Error",
                    text: "Ingrese un número de documento válido.",
                    icon: "error",
                    showConfirmButton: true
                });
                return;
            }

            if (document.querySelectorAll('#tbl_detalle tbody') && document.querySelectorAll('#tbl_detalle tr').length > 0) {
                $('#tbl_detalle').DataTable().clear().destroy();
                document.querySelector('#tbl_detalle tbody').innerHTML = '';
            }

            try {
                const response = await fetch("/AbastecimientoInterno/BuscarSolicitudDeTraslado", {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ docNum })
                });

                const contentType = response.headers.get("content-type") || "";

                if (!response.ok || !contentType.includes("application/json")) {
                    const errorText = await response.text();
                    console.error('Respuesta inesperada:', errorText);

                    Swal.fire({
                        title: 'Sesión expirada',
                        text: 'Se perdió la sesión o hubo un problema de conexión. Se actualizará la página.',
                        icon: 'warning'
                    }).then(() => {
                        window.location.reload();
                    });
                    return;
                }

                const data = await response.json();

                if (!data || data.Icono === "error") {
                    Swal.fire({
                        title: data.Titulo || "Error",
                        html: Array.isArray(data.Mensajes) && data.Mensajes.length > 0
                            ? data.Mensajes.join('<br>')
                            : data.Mensajes || "",
                        icon: data.Icono || "error",
                        allowEscapeKey: false,
                        allowOutsideClick: false,
                        showConfirmButton: true
                    });
                    document.querySelector('#div_botones').style.display = 'none';
                    return;
                }

                document.querySelector('#NroGuia').value = data.traslado.NroGuia || "";
                document.querySelector('#CardCode').value = data.traslado.CardCode || "";
                document.querySelector('#CardName').value = data.traslado.CardName || "";
                document.querySelector('#OperarioResponsableSAP').value = data.traslado.OperarioResponsableSAP || "";
                document.querySelector('#MotivoTraslado').value = data.traslado.MotivoTraslado || "";
                document.querySelector('#DocDate').value = data.traslado.DocDate || "";

                let traslado = agruparSolicitudPorItemCode(data.traslado.Detalle);

                if (data.transferencia != null) {
                    generarHTMLDetalle(formatLotesTransferenciaReserva, traslado.Detalle, data.transferencia.Detalle);
                    const todosAtendidos = data.transferencia.Detalle.every(item => item.AtendidoReserva === 1);
                    const todosTransferidos = Object.values(traslado).every(item => item.Estado === "TRANSFERIDO");

                    if (todosAtendidos && todosTransferidos) {
                        Swal.fire({
                            title: "Advertencia",
                            html: "La solicitud ya fue completamente TRANSFERIDA y ubicada.",
                            icon: "warning",
                            allowEscapeKey: false,
                            allowOutsideClick: false,
                            confirmButtonText: "Aceptar"
                        }).then(() => {
                            document.querySelectorAll('button').forEach(btn => {
                                if (btn.id !== "cancelarCritico" && btn.id !== "buscarDocNum") {
                                    btn.disabled = true;
                                }
                            });
                        });
                    }
                } else {
                    construirFormCopiaSap(data.traslado);
                    generarHTMLDetalle(formatLotes, traslado.Detalle);
                    document.querySelector('#btn_validarTodo').disabled = true;
                }

                permitirValoresNumericosPositivos();
                document.querySelector('#div_botones').style.display = 'block';

            } catch (error) {
                console.error("Error:", error);
                Swal.fire({
                    title: "Error inesperado",
                    text: "Hubo un problema al procesar la solicitud.",
                    icon: "error",
                    showConfirmButton: true
                });
            }
        }


        function abrirModalImportacion() {
            let modal = new bootstrap.Modal(document.getElementById('ModalImportar'));
            modal.show();
        }

        async function importarSolicitud() {
            let fileInput = document.querySelector("#i_file");
            if (!fileInput.files.length) {
                Swal.fire({
                    title: "Error",
                    html: "Debe seleccionar un archivo para importar.",
                    icon: "error",
                    showConfirmButton: true
                });
                return;
            }

            let formData = new FormData();
            formData.append("file", fileInput.files[0]);

            try {
                let response = await fetch("/AbastecimientoInterno/ImportarTransferenciaDeStock", {
                    method: "POST",
                    body: formData
                });

                const contentType = response.headers.get("content-type") || "";

                if (!response.ok || !contentType.includes("application/json")) {
                    const errorText = await response.text();
                    console.error('Respuesta inesperada:', errorText);

                    Swal.fire({
                        title: 'Sesión expirada',
                        text: 'La sesión expiró o hubo un error inesperado. Se actualizará la página.',
                        icon: 'warning'
                    }).then(() => {
                        window.location.reload();
                    });
                    return;
                }

                let data = await response.json();

                Swal.fire({
                    title: data.Titulo || "Éxito",
                    html: Array.isArray(data.Mensajes) ? data.Mensajes.join("<br>") : data.Mensajes,
                    icon: data.Icono || "success",
                    showConfirmButton: true
                });

                if (data.Icono === "success") {
                    document.querySelector("#ModalImportar").querySelector(".btn-close").click();
                }

            } catch (error) {
                console.error("Error capturado:", error);
                Swal.fire({
                    title: "Error",
                    text: "Hubo un problema al procesar la solicitud.",
                    icon: "error",
                    showConfirmButton: true
                });
            }
        }

