                    </tr>
                </tbody>
            </table>
        </div>
    </td>
</tr>`;

            // Insertar ambas filas
            const tbody = document.querySelector("#tbl_detalle tbody");
            tbody.insertAdjacentHTML("beforeend", filaPrincipal);
            tbody.insertAdjacentHTML("beforeend", filaSubdetalle);

            // Obtener elementos dinámicos recién creados
            let selectArticulo = document.getElementById(`ItemName_${correlativo}`);
            let inputItemCode = document.getElementById(`ItemCode_${correlativo}`);
            //let selectLotes = document.getElementById(`BatchNum_${correlativo}`);
            let selectLotes = document.querySelector(`select[id^="BatchNum_${correlativo}"]`);
            let inputInDate = document.getElementById(`InDate_${correlativoLote}`);
            let inputExpDate = document.getElementById(`ExpDate_${correlativoLote}`);

            // Asignar evento: cuando cambia el artículo, actualizar el ItemCode y los lotes
            selectArticulo.addEventListener("change", function () {
                let selectedOption = this.options[this.selectedIndex];
                let codigo = selectedOption.dataset.itemcode || "";
                inputItemCode.value = codigo;

                // Cargar lotes correspondientes al nuevo itemCode
                const opcionesLotes = cargarOpcionesLotes(codigo);
                selectLotes.innerHTML = '<option value="">Seleccione</option>' + opcionesLotes;

                inputInDate.value = "";
                inputExpDate.value = "";

                document.getElementById(`hidden_ItemCode_${correlativoLote}`).value = codigo;
                document.getElementById(`hidden_ItemName_${correlativoLote}`).value = document.getElementById(`ItemName_${correlativo}`).value;
            });

            if (selectLotes) {
                selectLotes.addEventListener("change", function () {
                    let selected = this.options[this.selectedIndex];

                    inputInDate.value = convertirFecha(selected.dataset.indate);
                    inputExpDate.value = convertirFecha(selected.dataset.expdate);
                });
            }

            contadorProducto++;
            permitirValoresNumericosPositivos();
        }

         function convertirFecha(fecha) {
            if (!fecha) return "";
            let partes = fecha.split("/");
            if (partes.length !== 3) return "";
            return `${partes[2]}-${partes[1]}-${partes[0]}`;
        }

        function clonarFilaLote(idTablaLotes) {
           const tabla = document.getElementById(idTablaLotes);
            const tbody = tabla.querySelector('tbody');
            const filaOriginal = tbody.querySelector('tr:last-of-type');
            const filaClonada = filaOriginal.cloneNode(true);
            const random = Math.floor(Math.random() * 10000);

            // Eliminar botón "+" en la fila clonada
            const botonClonado = filaClonada.querySelector('button.btn-cobefar');
            if (botonClonado) {
                botonClonado.remove();
            }

            const elementos = filaClonada.querySelectorAll('input, select');
            elementos.forEach(el => {
                // Limpiar valores
                if (el.tagName === 'INPUT') {
                    if (el.type !== 'hidden') el.value = '';
                } else if (el.tagName === 'SELECT') {
                    el.selectedIndex = 0;
                }

                // Reasignar ID
                if (el.id) {
                    const oldId = el.id;
                    const newId = `${oldId}_clone_${random}`;
                    el.setAttribute('id', newId);

                    // Actualizar datasets
                    if (el.dataset.idcantmaster) el.dataset.idcantmaster += `_clone_${random}`;
                    if (el.dataset.idcantsaldo) el.dataset.idcantsaldo += `_clone_${random}`;
                    if (el.dataset.idundmaster) el.dataset.idundmaster += `_clone_${random}`;
                    if (el.dataset.idquantityunidades) el.dataset.idquantityunidades += `_clone_${random}`;
                    if (el.dataset.idloteubicacion) el.dataset.idloteubicacion += `_clone_${random}`;
                }

                // Eventos
                if (el.classList.contains('lote-select')) {
                    el.addEventListener("change", function () {
                        const selected = this.options[this.selectedIndex];
                        const inDate = selected.dataset.indate || '';
                        const expDate = selected.dataset.expdate || '';

                        const fila = this.closest('tr');
                        const inputInDate = fila.querySelector('input[name*="InDate"]');
                        const inputExpDate = fila.querySelector('input[name*="ExpDate"]');

                        if (inputInDate) inputInDate.value = convertirFecha(inDate);
                        if (inputExpDate) inputExpDate.value = convertirFecha(expDate);
                    });
                }

                if (el.id?.includes('lote_undMaster_')) {
                    el.onchange = function () {
                        calcularCantidadMasterSaldo(this.value, this.dataset);
                    };
                }

                if (el.id?.includes('lote_ubicacion_')) {
                    el.onclick = function () {
                        gestionarBusquedaUbicaciones(this);
                    };
                }

                // Campos ocultos
                if (el.type === 'hidden' && el.id.startsWith('hidden_ItemCode_')) {
                    el.id += `_clone_${random}`;
                }

                if (el.type === 'hidden' && el.id.startsWith('hidden_ItemName_')) {
                    el.id += `_clone_${random}`;
                }
            });

            tbody.appendChild(filaClonada);
        }
    </script>
}