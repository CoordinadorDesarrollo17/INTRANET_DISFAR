                    ? `<button class="btn btn-danger" onclick="limpiarValoresItem('cls-limpiarItem_${itemCodeFormat}')" data-bs-toggle="tooltip" data-bs-placement="top" title="Borrar valores asignados">
                <i class="bi bi-arrow-repeat"></i>
