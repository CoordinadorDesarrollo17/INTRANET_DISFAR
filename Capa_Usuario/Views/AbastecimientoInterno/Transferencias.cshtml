		function agruparSolicitudPorItemCode(datos) {
			let solicitud = {
				Detalle: {} // Objeto donde agruparemos por ItemCode
			};
			for (let idx in datos) {
				let item = datos[idx]
				let itemCode = item.ItemCode || "";
				// Si el ItemCode no existe en el diccionario, se inicializa
				if (!solicitud.Detalle[itemCode]) {
					solicitud.Detalle[itemCode] = {
						FromWhsCode: item.FromWhsCode || "",
						ToWhsCode: item.ToWhsCode || "",
						ItemCode: itemCode,
						ItemName: item.ItemName || "",
						QuantityCajas: 0,
						Estado: item.Estado || "PENDIENTE",
						UnidadAlmSugerido: item.UnidadAlmSugerido,
                        AtendidoReserva: item.AtendidoReserva,
                        Validado:item.Validado,
                        SolicitudesTrasladoId: item.SolicitudesTrasladoId,
						DetalleLotes: []
					};
				}
				// Acumular la cantidad total de cajas para el ItemCode
				solicitud.Detalle[itemCode].QuantityCajas += item.QuantityCajas || 0;
				// Agregar el detalle del lote al ItemCode correspondiente
				solicitud.Detalle[itemCode].DetalleLotes.push({
					BatchNum: item.BatchNum || "",
					QuantityCajas: item.QuantityCajas || 0,
					InDate: item.InDate || "",
					ExpDate: item.ExpDate || ""
				});
			}
			return solicitud;
		}
