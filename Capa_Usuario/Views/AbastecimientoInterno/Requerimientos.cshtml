@{
    ViewBag.Title = "Requerimientos";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
}

<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><em>Abastecimiento Interno</em></li>
            <li class="current"><em>Requerimientos</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="row px-3 pt-3"><h3 class="titulo-seccion">REQUERIMIENTOS</h3></div>
</div>

<div class="bg-white px-3 py-3 align-items-center">
    <form id="frm_requerimiento">
        <div class="row mb-4">
            <div class="col-lg-2">
                <label for="Origen" class="form-label fw-bold">Origen:</label>
                <input type="text" id="Origen" class="form-control cls-readonly" name="Origen" value="Reserva" readonly autocomplete="off" />
            </div>

            <div class="col-lg-2">
                <label for="Destino" class="form-label fw-bold">Destino:</label>
                <input type="text" id="Destino" class="form-control cls-readonly" name="Destino" value="Picking" readonly autocomplete="off" />
            </div>

            <div class="col-lg-2">
                <label for="TipoAbastecimiento" class="form-label fw-bold">Tipo de abastecimiento:</label>
                <select id="TipoAbastecimiento" name="TipoAbastecimiento" class="form-select">
                    <option value="">Seleccione</option>
                    <option value="Picking">Picking</option>
                    <option value="Venta">Venta</option>
                </select>
            </div>
        </div><!-- // row-->

        <div class="row">
            <div class="col-lg-3">
                <button type="button" class="btn btn-primary" title="Agregar artículos" data-bs-toggle="tooltip" data-bs-placement="top" onclick="cargarListaArticulos()">
                    <i class="bi bi-plus-lg"></i> Agregar artículos
                </button>
            </div>

            <div class="col-lg-9 d-flex justify-content-end align-content-end">
                <button type="button" class="btn btn-cobefar-2" title="Ir a ubicaciones" data-bs-toggle="tooltip" data-bs-placement="top" onclick="redireccionarUbicaciones()">
                    <i class="bi bi-box-arrow-up-right"></i> Ir a ubicaciones
                </button>
            </div>
        </div><!-- // row-->

        <hr />

        <div class="row mb-3">
            <h4 class="text-cobefar fw-bold">Detalle del Requerimiento</h4>
        </div><!-- // row-->

        <div class="row">
            <div class="col-lg-12">
                <label for="" class="form-label fw-bold">Código de artículo:</label>
                <div class="d-flex align-items-center">
                    <input type="text" id="borrar_codigo_articulo" class="form-control" name="" autocomplete="off" style="width: 250px">
                    <button type="button" class="btn btn-danger" onclick="borrarItemDetalle(event)"><i class="bi bi-trash3-fill"></i> Borrar del detalle</button>
                </div>
            </div>
        </div><!-- // row-->
    </form>

    <div class="row mb-4">
        <div class="col-lg-12">
            <table id="tbl_detalleRequerimiento" class="dt-container dt-empty-footer table table-sm table-bordered table-striped table-hover font-14" width="100%">
                <thead class="thead-cobefar">
                    <tr>
                        <th scope="col" class="text-center">Código de artículo</th>
                        <th scope="col" class="text-center">Descripción</th>
                        <th scope="col" class="text-center">Lote</th>
                        <th scope="col" class="text-center">Cantidad</th>
                        <th scope="col" class="text-center">Ubicación PICKING</th>
                    </tr>
                </thead>
                <tbody class="text-dark">
                </tbody>
            </table>
        </div>
    </div><!-- // row-->

    <div class="row">
        <div class="col-lg-12">
            <button type="button" class="btn btn-success" title="Registrar requerimiento" data-bs-toggle="tooltip" data-bs-placement="top" onclick="registrarRequerimiento()">
                <i class="bi bi-plus-circle"></i> Registrar
            </button>
        </div>
    </div><!-- // row-->
</div>

<div class="modal fade" id="modalBusquedaArticulos" tabindex="-1" aria-labelledby="modalBusquedaArticulosLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-full-width">
        <div class="modal-content">
            <div class="modal-header text-white bg-headerModals">
                <h5 class="modal-title" id="modalBusquedaArticulosLabel">Búsqueda de artículos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar" tabindex="-1"></button>
            </div>

            <div class="modal-body bg-white">
                <div id="div_modalBody" class="container pb-0">
                    <form id="frm_busquedaArticulos">
                        <div class="row mb-4">
                            <div class="col-lg-2">
                                <label for="cod_articulo" class="form-label fw-bold">Código de artículo:</label>
                                <input type="text" id="cod_articulo" class="form-control" autocomplete="off" />
                            </div>

                            <div class="col-lg-3">
                                <div id="div_cantidadSolicitada" hidden>
                                    <label for="cantidad_solicitada" class="form-label fw-bold">Cantidad solicitada (día):</label>
                                    <input type="text" id="cantidad_solicitada" class="form-control cls-num cls-readonly" style="width: 250px" value="" readonly />
                                </div>
                            </div>

                            <div class="col-lg-7 d-flex justify-content-end align-items-end">
                                <button type="button" id="btn_guardarArticulos" class="btn btn-success" title="Guardar" data-bs-toggle="tooltip" data-bs-placement="top"><i class="bi bi-check-lg"></i> Guardar</button>
                            </div>
                        </div><!-- // row-->

                        <div class="row mb-4">
                            <div class="col-lg-12">
                                <button type="button" class="btn btn-cobefar-2" onclick="buscarArticulos()" title="Buscar" data-bs-toggle="tooltip" data-bs-placement="top"><i class="bi bi-search"></i> Buscar</button>
                            </div>
                        </div><!-- // row-->

                        <div class="row mb-4">
                            <div class="col-lg-12">
                                <div id="div_listadoArticulos"></div>
                            </div>
                        </div><!-- // row-->
                    </form>

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-bs-toggle="tooltip" data-placement="top" title="Cerrar">
                    <i class="bi bi-x-lg"></i> Cerrar
                </button>
            </div>
        </div>
    </div>
</div><!-- // modal -->

@section Scripts{
    <script>
		const configDataTable = {
			paging: false,                  // Deshabilitar paginación
			searching: false,           // Ocultar la barra de búsqueda
			info: false,                        // Ocultar el número de registros ("Mostrando X de Y registros")
			ordering: false,                // Deshabilitar la opción de ordenar columnas
			lengthChange: false,    // Ocultar el selector de cantidad de elementos por página
			bFilter: false,                 // Desactivar filtrado de DataTables
			bSort: false,                   // Desactivar ordenamiento en columnas
			bPaginate: false,           // Desactivar paginación manualmente
			autoWidth: false,       // Evita que DataTables ajuste el ancho de las columnas automáticamente
			responsive: true            // Mantiene la tabla responsiva si es necesario
		}

		document.addEventListener('DOMContentLoaded', function () {
			$(`#tbl_detalleRequerimiento`).DataTable(configDataTable)
			permitirValoresNumericosPositivos()
		});

		async function buscarArticulos() {
			const itemCode = document.querySelector('#cod_articulo').value.trim()
			const cantidadSolicitada = document.querySelector('#cantidad_solicitada').value || 0
			const tipoAbastecimiento = document.querySelector('#TipoAbastecimiento').value || ''

            document.querySelector('#div_listadoArticulos').innerHTML = ''

            if (!itemCode) {
                Swal.fire('El código de artículo ingresado no es válido.')
                return;
            }

			if (tipoAbastecimiento === "Picking") {
                document.querySelector('#div_cantidadSolicitada').hidden = false
			    calcularCantidadSolicitada()
			} else {
                document.querySelector('#div_cantidadSolicitada').hidden = true
			}

             try {
                 $.ajax({
                     url: `@Url.Action("ListarArticulos", "AbastecimientoInterno")?tipoAbastecimiento=${tipoAbastecimiento}&itemCode=${itemCode}&cantidadSolicitada=${cantidadSolicitada}`,
                     type: "GET",
                     dataType: "html",
                     success: function(response) {
                         if ($.trim(response)) {

                             if (response.Icono == "error") {
                                 Swal.fire({
                                     title: response.Titulo,
                                     html: Array.isArray(response.Mensajes) && response.Mensajes.length > 0
                                         ? response.Mensajes.join('<br>')
                                         : response.Mensajes || "",
                                     icon: response.Icono,
                                     allowEscapeKey: false,
                                     allowOutsideClick: false,
                                     showConfirmButton: true
                                 });

                                 return;
                             }

                             $('#div_listadoArticulos').html(response); // Cargar el contenido en el div
                              // Solo abrir si la respuesta no está vacía
                         } else {
                             console.warn("Error.");
                         }
                     },
                     error: function(jqXHR, textStatus, errorThrown) {
                         console.error("Error al cargar la lista de artículos:", textStatus, errorThrown);
                     }
                 });
             } catch (error) {
                 console.error("Excepción capturada:", error);
            }
        }

		async function calcularCantidadSolicitada() {
			const itemCode = document.querySelector('#cod_articulo').value || ''
			const tipoAbastecimiento = document.querySelector('#TipoAbastecimiento').value || ''
            let cantidadSolicitada = 0

			try {
				const response = await fetch("/AbastecimientoInterno/CalcularCantidadSolicitada", {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ tipoAbastecimiento, itemCode }) // Enviar los datos como JSON
				});

				if (!response.ok) {
					throw new Error(`Error en la solicitud: ${response.statusText}`);
				}

				const data = await response.json();

                if (typeof data.cantidadSolicitada === 'undefined') {
                    Swal.fire({
                        title: data.Titulo,
                        html: Array.isArray(data.Mensajes) && data.Mensajes.length > 0
                            ? data.Mensajes.join('<br>')
                            : data.Mensajes || "",
                        icon: data.Icono,
                        allowEscapeKey: false,
                        allowOutsideClick: false,
                        showConfirmButton: true
                    }).then((result) => {
                        if (result.isConfirmed) {
                            //location.reload()
                        }
                    });
                } else {
                    cantidadSolicitada = data.cantidadSolicitada
                }
                document.querySelector('#cantidad_solicitada').value = cantidadSolicitada
                document.querySelector('#btn_guardarArticulos').style.display = (cantidadSolicitada > 0) ? 'block' : 'none'
			} catch (error) {
				console.error('Error:', error);
			}
		}

		async function registrarRequerimiento() {
			const form = document.querySelector('#frm_requerimiento')
			const tipoAbastecimiento = document.querySelector('#TipoAbastecimiento').value
			const filasRequerimientos = document.querySelectorAll("#tbl_detalleRequerimiento tbody tr")
			let detallesRequerimientos = []

			if (!tipoAbastecimiento) {
				Swal.fire('Seleccione un tipo de abastecimiento.')
				return;
			}

            filasRequerimientos.forEach((fila) => {
                let inputs = fila.querySelectorAll("input, select");
                let detalleRequerimiento = {};

				inputs.forEach(input => {
					let name = input.name.trim();

                    if (name.startsWith("requerimiento.Detalle[]")) {
                        let key = name.replace("requerimiento.Detalle[].", "").trim()
                        let value = input.value.trim()   // Aseguramos que no tenga espacios en blanco al inicio o fin

                        if (key == 'CodigoUbicacionDestino') {
                            detalleRequerimiento[key] = Array.from(input.selectedOptions).map(option => option.value).join(', ')
                        } else {
                            detalleRequerimiento[key] = value
                        }
                    }
                });

				// Solo agregar si los campos requeridos tienen valores
			  //  if (camposValidos && Object.keys(detalleTransferencia).length > 0) {
				detallesRequerimientos.push(detalleRequerimiento);
			  //  }
			});

			const formData = new FormData(form);
			const jsonData = Object.fromEntries(formData.entries());

			const payload = {
				requerimiento: {
					...jsonData, // Otros datos generales del formulario
					Detalle: detallesRequerimientos
				}
			}

            //console.log(payload)
            //return;

            try {
                const response = await fetch("/AbastecimientoInterno/RegistrarRequerimiento", {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(payload) // Enviar los datos como JSON
                });

				if (!response.ok) {
					throw new Error(`Error en la solicitud: ${response.statusText}`)
				}

				const data = await response.json()

				Swal.fire({
					title: data.Titulo,
					html: Array.isArray(data.Mensajes) && data.Mensajes.length > 0
						? data.Mensajes.join('<br>')
						: data.Mensajes || "",
					icon: data.Icono,
					allowEscapeKey: false,
					allowOutsideClick: false,
					showConfirmButton: true
				}).then((result) => {
					if (result.isConfirmed && data.Icono =="success") {
						location.reload()
					}
				});
			} catch (error) {
				console.error('Error:', error);
			}
		}

        async function cargarUbicaciones(almacen, data, id) {
            let itemCode = data.itemcode

            try {
                const response = await fetch("/AbastecimientoInterno/BuscarUbicaciones", {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ almacen, itemCode }) // Enviar los datos como JSON
                });

                if (!response.ok) {
                    throw new Error(`Error en la solicitud: ${response.statusText}`);
                }

                const data = await response.json();
                let unicaUbicacion = data.resultUbicacionesLote
                let ubicaciones = ''
                data.resultUbicaciones.forEach((ubicacion, index) => {
                    ubicaciones += `<option value="${ubicacion}" ${ubicacion === data.resultUbicacionesLote ? 'selected' : ''}>${ubicacion}</option>`
                })

                document.querySelector(`#${id}`).innerHTML = ubicaciones
                document.querySelector(`#${id}`).classList.remove('form-select');
                document.querySelector(`#${id}`).setAttribute('multiple', 'multiple')
                const select = new SlimSelect({
                    select: `#${id}`,
                    searchingText: 'Buscar... '
                });

                // Solo mantener select abierto cuando tenga más de 1 ubicación
                // "data.resultUbicacionesLote" devuelve el la única ubicación del SKU + Lote
                if (unicaUbicacion == null) {
                    select.open();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function cargarListaArticulos() {
            const tipoAbastecimiento = document.querySelector('#TipoAbastecimiento').value
            const modal = document.querySelector('#modalBusquedaArticulos')
            const bootstrapModal = new bootstrap.Modal(modal, {
                focus: false,
                backdrop: 'static',
                keyboard: false
            })

			if (!tipoAbastecimiento) {
				Swal.fire('Seleccione un tipo de abastecimiento.')
				return;
            }
            resetValoresVacios(["cod_articulo", "cantidad_solicitada"])

            document.querySelector('#div_listadoArticulos').innerHTML = ''
            document.querySelector('#div_cantidadSolicitada').hidden = tipoAbastecimiento !== 'Picking' ? true:false

            const btn = document.querySelector('#btn_guardarArticulos')
            if (btn) {
                if (tipoAbastecimiento === 'Picking') {
                    btn.setAttribute('onclick', 'guardarArticulosPicking()');
                } else {
                    btn.setAttribute('onclick', 'guardarArticulosVenta()');
                }
            }

			bootstrapModal.show();
		}

		function redireccionarUbicaciones() {
			window.open('@Url.Action("UbicacionesPicking", "AbastecimientoInterno")', '_blank');
		}

        function borrarItemDetalle(e) {
            e.preventDefault()

            Swal.fire({
                title: '¿Estás seguro(a) de borrar?',
                text: "Se borrarán del detalle todos los ítems con el mismo código de artículo ingresado.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: '<i class="bi bi-check-lg"></i> Si, continuar',
                cancelButtonText: '<i class="bi bi-x-lg"></i> Cancelar'
            }).then(async (result) => {
                if (result.isConfirmed) {

                    const borrarItemCode = document.querySelector('#borrar_codigo_articulo').value.trim() || ''
                    let items = document.querySelectorAll('.cls-itemCodes')
                    let itemEncontrado = false

                    if (items.length > 0) {
                        items.forEach(item => {
                            if (item.value.trim() === borrarItemCode) { // Compara sin espacios extras
                                let fila = document.getElementById(item.dataset.fila); // Más eficiente que `querySelector`

                                if (fila) {
                                    fila.remove(); // Eliminar la fila
                                    console.log(`Fila ${item.dataset.fila} eliminada.`);
                                    itemEncontrado = true; // Se encontró y eliminó
                                } else {
                                    console.warn(`No se encontró la fila con ID: ${item.dataset.fila}`);
                                }
                            }
                        })

                        if (!itemEncontrado) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Código no encontrado',
                                text: 'El código de artículo ingresado no se encuentra en el detalle.',
                                allowEscapeKey: false,
                                allowOutsideClick: false,
                            });
                        }
                    }

                }
            });
        }
    </script>
}