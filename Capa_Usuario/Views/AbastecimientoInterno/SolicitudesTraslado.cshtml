@{
    ViewBag.Title = "Solicitudes de Traslado";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
}

<div class="pt-3">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><em>Abastecimiento Interno</em></li>
            <li class="current"><em>Solicitudes de Traslado</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="row px-3 pt-3"><h3 class="titulo-seccion">SOLICITUDES DE TRASLADO</h3></div>
</div>

<div class="bg-white px-3 py-3 align-items-center">
    <div class="row mb-4">
        <div class="col-lg-2">
            <input type="hidden" id="DocEntry" name="DocEntry" readonly />
            <label for="" class="form-label fw-bold">Tipo de documento:</label>
            <select id="" class="form-select">
                <option value="OWTQ">Solicitud de Traslado</option>
            </select>
        </div>

        <div class="col-lg-2">
            <label for="DocNum" class="form-label fw-bold">DocNum:</label>
            <input type="text" id="DocNum" class="form-control" name="DocNum" autocomplete="off" />
        </div>

        <div class="col-lg-2">
            <label for="NroGuia" class="form-label fw-bold">Nro. de guía:</label>
            <input type="text" id="NroGuia" class="form-control cls-readonly text-center" name="NroGuia" autocomplete="off" readonly />
        </div>

        <div class="col-lg-3">
            <label for="CardName" class="form-label fw-bold">Socio de Negocio:</label>
            <input type="hidden" id="CardCode" name="CardCode" readonly />
            <input type="text" id="CardName" class="form-control cls-readonly text-center" name="CardName" autocomplete="off" readonly />
        </div>

        <div class="col-lg-3">
            <label for="OperarioResponsableSAP" class="form-label fw-bold">Operario Responsable SAP:</label>
            <input type="text" id="OperarioResponsableSAP" class="form-control cls-readonly text-center" name="OperarioResponsableSAP" autocomplete="off" readonly />
            <input type="hidden" id="MotivoTraslado" name="MotivoTraslado" readonly />
            <input type="hidden" id="DocDate" name="DocDate" readonly />
        </div>
    </div><!-- row -->

    <div class="row">
        <div class="col-lg-12">
            <button type="button" class="btn btn-warning" onclick="buscarSolicitud()" data-bs-toggle="tooltip" data-bs-placement="top" title="Buscar"><i class="bi bi-search"></i> Buscar</button>
        </div>
    </div>

    <hr />

    <div id="copiaSap" hidden>
        <form id="frm_tablaCopiaSap">
            <div class="row mb-4">
                <div class="col-lg-12">
                    <input type="text" id="copiaDocEntry" name="DocEntry" readonly />
                    <input type="text" id="copiaDocNum" name="DocNum" readonly />
                    <input type="text" id="copiaNroGuia" name="NroGuia" readonly />
                    <input type="text" id="copiaCardCode" name="CardCode" readonly />
                </div>
            </div><!-- row -->

            <div class="row mb-4">
                <div class="col-lg-12">
                    <input type="text" id="copiaCardName" name="CardName" readonly />
                    <input type="text" id="copiaOperarioResponsableSAP" name="OperarioResponsableSAP" readonly />
                    <input type="text" id="copiaMotivoTraslado" name="MotivoTraslado" readonly />
                    <input type="text" id="copiaDocDate" name="DocDate" readonly />
                </div>
            </div><!-- row -->
        </form>

        <table id="tbl_copiaSap" class="table">
            <thead>
                <tr>
                    <th scope="col">ItemCode</th>
                    <th scope="col">ItemName</th>
                    <th scope="col">BatchNum</th>
                    <th scope="col">In Date</th>
                    <th scope="col">Exp Date</th>
                    <th scope="col">QuantityCajas</th>
                    <th scope="col">FromWhsCode</th>
                    <th scope="col">ToWhsCode</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

    <div class="row mb-4">
        <div class="col-lg-12">
            <table id="tbl_detalle" class="dt-container dt-empty-footer table table-sm table-bordered table-striped table-hover font-14" width="100%">
                <thead class="thead-cobefar">
                    <tr>
                        <th style="width: 5%;"></th>
                        <th scope="col" class="text-center">Código de artículo</th>
                        <th scope="col" class="text-center">Descripción</th>
                        <th scope="col" class="text-center">Cantidad</th>
                        <th scope="col" class="text-center">Alm. Destino</th>
                        <th scope="col" class="text-center">Lotes</th>
                        <th scope="col" class="text-center"></th>
                    </tr>
                </thead>
                <tbody class="text-dark">
                </tbody>
            </table>
        </div>
    </div>

    <div id="div_botones" class="row" style="display: none">
        <div class="col-lg-12">
            <button type="button" class="btn btn-danger" data-bs-toggle="tooltip" data-bs-placement="top" title="Cancelar"><i class="bi bi-x-lg"></i> Cancelar</button>
            <button type="button" id="btn_transferir" class="btn btn-success" data-bs-toggle="tooltip" data-bs-placement="top" title="Transferir"><i class="bi bi-arrow-left-right"></i> Transferir</button>
        </div>
    </div>
</div><!-- main -->

@section Scripts{
    <script>
		// ✅ Declaración de variables
		const masters = JSON.parse(`@Html.Raw(Json.Encode(ViewBag.Masters))`)
		let opcionesMasters = ''
		const configDataTable = {
			paging: false,          // ❌ Deshabilitar paginación
			searching: false,       // ❌ Ocultar la barra de búsqueda
			info: false,            // ❌ Ocultar el número de registros ("Mostrando X de Y registros")
			ordering: false,        // ❌ Deshabilitar la opción de ordenar columnas
			lengthChange: false,    // ❌ Ocultar el selector de cantidad de elementos por página
			bFilter: false,         // ❌ Desactivar filtrado de DataTables
			bSort: false,           // ❌ Desactivar ordenamiento en columnas
			bPaginate: false,       // ❌ Desactivar paginación manualmente
			autoWidth: false,       // ✅ Evita que DataTables ajuste el ancho de las columnas automáticamente
			responsive: true        // ✅ Mantiene la tabla responsiva si es necesario
		}



		// ✅ Funciones
		function cargarOpcionesMasters(unidadAlmSugerido) {
			opcionesMasters = ""; // Reiniciar la variable para evitar acumulación de valores previos
			masters.forEach(item => {
				opcionesMasters += `<option value="${item.ValorUmAlm}" data-umalm="${item.UmAlm}" ${item.UmAlm === unidadAlmSugerido ? 'selected' : ''}>${item.UmAlm}</option>`;
			});

			return opcionesMasters;
		}

		async function realizarTransferencia() {
			const form = document.querySelector('#frm_tablaCopiaSap')

			if (!form) {
				console.log("Formulario no válido.");
				return;
			}

			const filasSolicitudTraslado = document.querySelectorAll("#tbl_copiaSap tbody tr");
			let detallesSolicitud = [];

			filasSolicitudTraslado.forEach((fila) => {
				let inputs = fila.querySelectorAll("input, select");
				let detalleSolicitud = {};

				inputs.forEach(input => {
					let name = input.name.trim();

					if (name.startsWith("solicitudTraslado.Detalle[]")) {
						let key = name.replace("solicitudTraslado.Detalle[].", "").trim();
						detalleSolicitud[key] = input.value;
					}
				});

				if (Object.keys(detalleSolicitud).length > 0) detallesSolicitud.push(detalleSolicitud);
			});

			const filasTransferencia = document.querySelectorAll(".tbl_detalleLotes tbody tr");
			let detallesTransferencia = [];

			filasTransferencia.forEach((fila) => {
				let inputs = fila.querySelectorAll("input, select");
				let detalleTransferencia = {};

				inputs.forEach(input => {
					let name = input.name.trim();

					if (name.startsWith("transferenciaPost.Detalle[]")) {
						let key = name.replace("transferenciaPost.Detalle[].", "").trim();

							if (key === "ValorUmAlm") {
								let selectedOption = input.options[input.selectedIndex];
								detalleTransferencia[key] = input.value;
								detalleTransferencia["UmAlm"] = selectedOption.dataset.umalm || ""; // Evita valores undefined
							} else {
								detalleTransferencia[key] = input.value;
							}

					}
				});

				if (Object.keys(detalleTransferencia).length > 0) detallesTransferencia.push(detalleTransferencia);
			});

			const formData = new FormData(form);
			const jsonData = Object.fromEntries(formData.entries());

			const payload = {
				solicitudTraslado: {
					...jsonData, // Otros datos generales del formulario
					Detalle: detallesSolicitud
				},
				transferenciaPost: {
					...jsonData,
					Detalle: detallesTransferencia
				}
			};

			//console.log(payload)
			//return;

			try {
				const response = await fetch("/AbastecimientoInterno/RegistrarTransferenciaDeStock", {
					method: "POST",
					headers: {
						"Content-Type": "application/json"
					},
					body: JSON.stringify(payload)
				});

				if (!response.ok) {
					throw new Error(`Error en la solicitud: ${response.status}`);
				}

				const data = await response.json();
				//console.log(data)

				Swal.fire({
					title: data.Mensaje,
					html: Array.isArray(data.Comentario) && data.Comentario.length > 0
						? data.Comentario.join('<br>')
						: data.Comentario || "",
					icon: data.Icono,
					allowEscapeKey: false,
					allowOutsideClick: false,
					showConfirmButton: true
				}).then((result) => {
					if (result.isConfirmed) {
                        location.reload()
					}
				});

			} catch (error) {
				console.error("Error:", error);
			}
		}

		async function buscarSolicitud() {
			let docNum = document.querySelector('#DocNum').value.trim();

			if (!docNum) {
				Swal.fire({
					title: "Error",
					text: "Ingrese un número de documento válido.",
					icon: "error",
					showConfirmButton: true
				});
				return;
			}

			try {
				const response = await fetch("/AbastecimientoInterno/BuscarSolicitudDeTraslado", {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ docNum })
				});

				if (!response.ok) {
					throw new Error(`Error en la solicitud: ${response.statusText}`);
				}

				const data = await response.json();
				console.log("Datos recibidos:", data);
				//return;

				if (!data || !data.traslado) {
					Swal.fire({
                        title: data.Mensaje,
                        html: Array.isArray(data.Comentario) && data.Comentario.length > 0
                            ? data.Comentario.join('<br>')
                            : data.Comentario || "",
                        icon: data.Icono,
                        allowEscapeKey: false,
                        allowOutsideClick: false,
                        showConfirmButton: true
					});

					document.querySelector('#div_botones').style.display = 'none'
					return;
				}

				// Rellenar los campos con los datos recibidos
				document.querySelector('#NroGuia').value = data.traslado.NroGuia || "";
				document.querySelector('#CardCode').value = data.traslado.CardCode || "";
				document.querySelector('#CardName').value = data.traslado.CardName || "";
				document.querySelector('#OperarioResponsableSAP').value = data.traslado.OperarioResponsableSAP || "";
				document.querySelector('#MotivoTraslado').value = data.traslado.MotivoTraslado || "";
				document.querySelector('#DocDate').value = data.traslado.DocDate || "";

				// Construir formulario y tabla de detalle
				if (data.transferencia == null) {
					construirFormCopiaSap(data.traslado);
					construirDetalleSolicitudTraslado(data.traslado.Detalle);
				} else {
                    //let datos = marcarAtendidos(data.traslado, data.transferencia)
                    let traslado = organizarSolicitudDeTraslado(data.traslado.Detalle)
                    construirDetalleTransferenciaReserva(traslado.Detalle);
                    //console.log(traslado.Detalle)
				}

				document.querySelector('#div_botones').style.display = 'block'
				
			} catch (error) {
				console.error("Error:", error);
				Swal.fire({
					title: "Error",
					text: "Hubo un problema al procesar la solicitud.",
					icon: "error",
					showConfirmButton: true
				});
			}
		}

        function marcarAtendidos(traslado, transferencia) {
            // Convertir transferencia en un Map para búsqueda rápida
            let transferenciaMap = new Map();

            transferencia.Detalle.forEach(item => {
                let key = `${item.ItemCode}-${item.ItemName}-${item.BatchNum}-${item.FechaAdmision}-${item.FechaVencimiento}-${item.CodigoUbicacion}-${item.UmAlm}-${item.ValorUmAlm}-${item.QuantityMaster}-${item.QuantitySaldo}-${item.QuantityUnidadesCajas}`;
                transferenciaMap.set(key, true);
            });

            // Modificar traslado agregando la propiedad "atendido"
            traslado.Detalle = traslado.Detalle.map(item => {
                let key = `${item.ItemCode}-${item.ItemName}-${item.BatchNum}-${item.InDate}-${item.ExpDate}-UBI-SISTEMA-${item.UnidadAlmSugerido || ""}-7-71-3-${item.QuantityCajas}`;
                return { ...item, atendido: transferenciaMap.has(key) ? 1 : 0 };
            });

            return traslado;
		}

		// Construcción de la tabla de detalle
		function construirDetalleSolicitudTraslado(detalle) {
			let tbody = ''

            for (const itemCode in detalle) {
				let key = detalle[itemCode]

				tbody += `<tr data-producto="${key.ItemCode}" class="fila-detalle">
										<td class="details-control">
											<div class="d-flex justify-content-center"><button id="btn_chevron_${key.ItemCode}" class="btn btn-sm btn-cobefar-2"><i class="bi bi-chevron-down"></i></button></div>											
										</td>
										<td class="text-center">${key.ItemCode}</td>
										<td>${key.ItemName}</td>
										<td class="text-center">${key.CantidadTotalPorSKU}</td>
										<td class="text-center"><div class="d-flex justify-content-center"><input type="text" class="form-control text-center cls-readonly" value="RESERVA" readonly style="width: 140px"></div></td>
										<td class="text-center">${key.DetalleLotes.map(l => l.BatchNum).join(', ')}</td>
										<td class="text-center">
											<button class="btn btn-danger" onclick="limpiarValoresItem('cls-limpiarItem_${key.ItemCode}')" data-bs-toggle="tooltip" data-bs-placement="top" title="Borrar valores de este artículo">
												<i class="bi bi-eraser-fill"></i>
											</button>
										</td>
									</tr>`
			}

			document.querySelector('#tbl_detalle tbody').innerHTML = tbody
			inicializarSlimSelectsPorClase('cls-select')
			$('[data-bs-toggle="tooltip"]').tooltip()

			let table = $('#tbl_detalle').DataTable(configDataTable)

			$('#tbl_detalle tbody').on('click', 'td.details-control', function () {
				var tr = $(this).closest('tr');
				var row = table.row(tr);
				var productoID = tr.data('producto');
				var button = $(this).find('button i');

				if (row.child.isShown()) {
					// Cerrar fila
					row.child.hide();
					button.removeClass('bi-chevron-up').addClass('bi-chevron-down');
				} else {
					// Abrir y mostrar lotes
					row.child(formatLotes(detalle[productoID])).show();
					button.removeClass('bi-chevron-down').addClass('bi-chevron-up');
				}
			});

			$('.fila-detalle').each(function (index) {
				let productoID = $(this).data('producto');

				if (detalle[productoID] && detalle[productoID].DetalleLotes.length === 1) {
					document.querySelector(`#btn_chevron_${productoID}`).click();
				}
			});
		}

        function construirDetalleTransferenciaReserva(detalle) {
            let tbody = ''

            for (const itemCode in detalle) {
				let key = detalle[itemCode]

                tbody += `<tr data-producto="${key.ItemCode}" class="fila-detalle">
								<td class="details-control text-center">
									<button id="btn_chevron_${key.ItemCode}" class="btn btn-sm btn-cobefar-2"><i class="bi bi-chevron-down"></i></button>
								</td>
								<td class="text-center">${key.ItemCode}</td>
								<td><span class="ps-2">${key.ItemName}<span></td>
								<td class="text-center">${key.CantidadTotalPorSKU}</td>
								<td class="text-center">RESERVA</td>
								<td class="text-center">${key.DetalleLotes.map(l => l.BatchNum).join(', ')}</td>
								<td class="text-center">
									${key.Estado == "TRANSFERIDO" ? '<span class="fw-bold">TRANSFERIDO</span>' : `
										<button class="btn btn-danger" onclick="limpiarValoresItem('cls-limpiarItem_${key.ItemCode}')" 
											data-bs-toggle="tooltip" data-bs-placement="top" title="Borrar valores de este artículo">
											<i class="bi bi-eraser-fill"></i>
										</button>`}
								</td>
							</tr>`
            }

            document.querySelector('#tbl_detalle tbody').innerHTML = tbody
            inicializarSlimSelectsPorClase('cls-select')
            $('[data-bs-toggle="tooltip"]').tooltip()

            let table = $('#tbl_detalle').DataTable(configDataTable)

            $('#tbl_detalle tbody').on('click', 'td.details-control', function () {
                var tr = $(this).closest('tr');
                var row = table.row(tr);
                var productoID = tr.data('producto');
                var button = $(this).find('button i');

                if (row.child.isShown()) {
                    // Cerrar fila
                    row.child.hide();
                    button.removeClass('bi-chevron-up').addClass('bi-chevron-down');
                } else {
                    // Abrir y mostrar lotes
                    row.child(formatLotesTransferenciaReserva(detalle[productoID])).show();
                    button.removeClass('bi-chevron-down').addClass('bi-chevron-up');
                }
            });

            $('.fila-detalle').each(function (index) {
                let productoID = $(this).data('producto');

                if (detalle[productoID] && detalle[productoID].DetalleLotes.length === 1) {
                    document.querySelector(`#btn_chevron_${productoID}`).click();
                }
            });
		}

		// 2do Nivel
		function formatLotes(articulo) {
			let tableHtml = `<div class="d-flex justify-content-center w-100"><table id="tbl_detalleLotes_${articulo.ItemCode}" class="table table-sm table-bordered table-hover subtable w-75 tbl_detalleLotes">
							<thead class="table-success">
								<tr>
									<th scope="col" class="text-center" style="width: 100">Lote</th>
									<th scope="col" class="text-center" style="width: 200">Fecha de Vencimiento</th>
									<th scope="col" class="text-center" style="width: 200">Stock UNIDADES</th>
									<th scope="col" class="text-center" style="width: 200">Unidad MASTER</th>
									<th scope="col" class="text-center" style="width: 200"">Cantidad en MASTER</th>
									<th scope="col" class="text-center" style="width: 200">Cantidad en SALDO</th>
									<th scope="col" class="text-center" style="width: 200">Ubicación</th>
									<th scope="col" style="width: 5%;"></th>
								</tr>
							</thead>
							<tbody>`

			articulo.DetalleLotes.forEach(item => {
				tableHtml += `<tr data-lote="${item.BatchNum}">
								<td class="text-center">
									<input type="hidden" name="transferenciaPost.Detalle[].ItemCode" value="${articulo.ItemCode}" />
									<input type="hidden" name="transferenciaPost.Detalle[].ItemName" value="${articulo.ItemName}" />
									<input type="hidden" name="transferenciaPost.Detalle[].BatchNum" value="${item.BatchNum}" />${item.BatchNum}
								</td>
								<td class="text-center">
									<input type="hidden" name="transferenciaPost.Detalle[].InDate" value="${item.InDate}" />
									<input type="hidden" name="transferenciaPost.Detalle[].ExpDate" value="${item.ExpDate}" />${item.ExpDate}
								</td>
								<td class="text-center">
									<input type="text" id="lote_quantityUnidades_${item.BatchNum}" name="transferenciaPost.Detalle[].QuantityUnidadesCajas" class="form-control text-center cls-num cls-limpiarItem_${articulo.ItemCode}"
									data-idcantmaster="lote_cantidadMaster_${item.BatchNum}" data-idcantsaldo="lote_cantidadSaldo_${item.BatchNum}" data-cantidadtotal="${item.CantidadTotalPorSKUyLote}"
									data-idundmaster="lote_undMaster_${item.BatchNum}" oninput="calcularStockUnidades(this.value, this.dataset)" value="">
								</td>
								 <td scope="col" class="text-center align-middle">
									 <select id="lote_undMaster_${item.BatchNum}" data-idundmaster="lote_undMaster_${item.BatchNum}" data-idcantmaster="lote_cantidadMaster_${item.BatchNum}" data-idcantsaldo="lote_cantidadSaldo_${item.BatchNum}" data-cantidadtotal="${item.CantidadTotalPorSKUyLote}"
										data-idquantityunidades ="lote_quantityUnidades_${item.BatchNum}"
										name="transferenciaPost.Detalle[].ValorUmAlm" class="form-select cls-limpiarItem_${articulo.ItemCode}" onchange="calcularCantidadMasterSaldo(this.value, this.dataset)">
										 <option value="">Seleccione</<option>
										${cargarOpcionesMasters(articulo.UnidadAlmSugerido)}
									 </select>
								 </td>
								<td scope="col" class="text-center">
									<div class="mx-auto w-75">
										<input type="text" id="lote_cantidadMaster_${item.BatchNum}" name="transferenciaPost.Detalle[].QuantityMaster" class="form-control text-center cls-num cls-readonly cls-limpiarItem_${articulo.ItemCode}" readonly>
									</div>
								</td>
								 <td scope="col" class="text-center">
									<div class="mx-auto w-75"><input type="text" id="lote_cantidadSaldo_${item.BatchNum}" name="transferenciaPost.Detalle[].QuantitySaldo" class="form-control text-center cls-num cls-readonly cls-limpiarItem_${articulo.ItemCode}" readonly></div>
								</td>
								<td class="text-center">
									<select id="lote_ubicacion_${item.BatchNum}" name="transferenciaPost.Detalle[].CodigoUbicacion" data-idloteubicacion="lote_ubicacion_${item.BatchNum}" data-itemcode="${articulo.ItemCode}"
									class="form-select cls-limpiarItem_${articulo.ItemCode}" onfocus="cargarUbicaciones('RESERVA', this.dataset)" style="width: 200px">
										<option value="">Seleccione</option>
									</select>
								</td>
								<td class="lotes-control text-center">
									<button type="button" class="btn btn-sm btn-cobefar" onclick="clonarFila('tbl_detalleLotes_${articulo.ItemCode}')"><i class="bi bi-plus-lg"></i></button>
								</td>
							</tr>`
			});

			tableHtml += '</tbody></table></div>'
			return tableHtml
		}

        function formatLotesTransferenciaReserva(articulo) {
            let tableHtml = `<div class="d-flex justify-content-center w-100"><table id="tbl_detalleLotes_${articulo.ItemCode}" class="table table-sm table-bordered table-hover subtable w-75 tbl_detalleLotes">
					<thead class="table-success">
						<tr>
							<th scope="col" class="text-center" style="width: 100">Lote</th>
							<th scope="col" class="text-center" style="width: 200">Fecha de Vencimiento</th>
							<th scope="col" class="text-center" style="width: 200">Stock UNIDADES</th>
							<th scope="col" class="text-center" style="width: 200">Unidad MASTER</th>
							<th scope="col" class="text-center" style="width: 200"">Cantidad en MASTER</th>
							<th scope="col" class="text-center" style="width: 200">Cantidad en SALDO</th>
							<th scope="col" class="text-center" style="width: 200">Ubicación</th>
							<th scope="col" style="width: 5%;"></th>
						</tr>
					</thead>
					<tbody>`

            articulo.DetalleLotes.forEach(item => {
                tableHtml += `<tr data-lote="${item.BatchNum}">
						<td class="text-center">
							<input type="hidden" name="transferenciaPost.Detalle[].ItemCode" value="${articulo.ItemCode}" />
							<input type="hidden" name="transferenciaPost.Detalle[].ItemName" value="${articulo.ItemName}" />
							<input type="hidden" name="transferenciaPost.Detalle[].BatchNum" value="${item.BatchNum}" />${item.BatchNum}
						</td>
						<td class="text-center">
							<input type="hidden" name="transferenciaPost.Detalle[].InDate" value="${item.InDate}" />
							<input type="hidden" name="transferenciaPost.Detalle[].ExpDate" value="${item.ExpDate}" />${item.ExpDate}
						</td>
						<td class="text-center">
							<input type="text" id="lote_quantityUnidades_${item.BatchNum}" name="transferenciaPost.Detalle[].QuantityUnidadesCajas" class="form-control text-center cls-num cls-limpiarItem_${articulo.ItemCode}" value="${item.CantidadTotalPorSKUyLote}"
							data-idcantmaster="lote_cantidadMaster_${item.BatchNum}" data-idcantsaldo="lote_cantidadSaldo_${item.BatchNum}" data-cantidadtotal="${item.CantidadTotalPorSKUyLote}"
							data-idundmaster="lote_undMaster_${item.BatchNum}" oninput="calcularStockUnidades(this.value, this.dataset)">
						</td>
						 <td scope="col" class="text-center align-middle">
							 <select id="lote_undMaster_${item.BatchNum}" data-idundmaster="lote_undMaster_${item.BatchNum}" data-idcantmaster="lote_cantidadMaster_${item.BatchNum}" data-idcantsaldo="lote_cantidadSaldo_${item.BatchNum}" data-cantidadtotal="${item.CantidadTotalPorSKUyLote}"
								data-idquantityunidades ="lote_quantityUnidades_${item.BatchNum}"
								name="transferenciaPost.Detalle[].ValorUmAlm" class="form-select cls-limpiarItem_${articulo.ItemCode}" onchange="calcularCantidadMasterSaldo(this.value, this.dataset)">
								 <option value="">Seleccione</<option>
								${cargarOpcionesMasters(articulo.UnidadAlmSugerido)}
							 </select>
						 </td>
						<td scope="col" class="text-center">
							<div class="mx-auto w-75">
								<input type="text" id="lote_cantidadMaster_${item.BatchNum}" name="transferenciaPost.Detalle[].QuantityMaster" class="form-control text-center cls-num cls-readonly cls-limpiarItem_${articulo.ItemCode}" readonly>
							</div>
						</td>
						 <td scope="col" class="text-center">
							<div class="mx-auto w-75"><input type="text" id="lote_cantidadSaldo_${item.BatchNum}" name="transferenciaPost.Detalle[].QuantitySaldo" class="form-control text-center cls-num cls-readonly cls-limpiarItem_${articulo.ItemCode}" readonly></div>
						</td>
						<td class="text-center">
							<select id="lote_ubicacion_${item.BatchNum}" name="transferenciaPost.Detalle[].CodigoUbicacion" data-idloteubicacion="lote_ubicacion_${item.BatchNum}" data-itemcode="${articulo.ItemCode}"
							class="form-select cls-limpiarItem_${articulo.ItemCode}" onfocus="cargarUbicaciones('RESERVA', this.dataset)" style="width: 200px">
								<option value="">Seleccione</option>
							</select>
						</td>
						<td class="lotes-control text-center">
							<button type="button" class="btn btn-sm btn-cobefar" onclick="clonarFila('tbl_detalleLotes_${articulo.ItemCode}')"><i class="bi bi-plus-lg"></i></button>
						</td>
					</tr>`
            });

            tableHtml += '</tbody></table></div>'
            return tableHtml
        }

        function clonarFila(idTableLotes) {
            let tabla = $(`#${idTableLotes}`).DataTable(configDataTable); // Obtener instancia de DataTable

            $(`#${idTableLotes} tbody`).on('click', '.btn-cobefar', function () {
                let filaOriginal = $(this).closest('tr'); // Obtener la fila original
                let filaClonada = filaOriginal.clone(); // Clonar la fila

                actualizarIDs(filaClonada); // Actualizar los IDs y evitar duplicados

                // Agregar la nueva fila al DataTable sin reiniciar
                tabla.row.add(filaClonada[0]).draw(false);
			});

            $(`#${idTableLotes}_wrapper`).addClass('w-100');
        }

		function construirFormCopiaSap(traslado) {
			document.querySelector('#copiaDocEntry').value = traslado.DocEntry
			document.querySelector('#copiaDocNum').value = traslado.DocNum
			document.querySelector('#copiaNroGuia').value = traslado.NroGuia
			document.querySelector('#copiaCardCode').value = traslado.CardCode
			document.querySelector('#copiaCardName').value = traslado.CardName
			document.querySelector('#copiaOperarioResponsableSAP').value = traslado.OperarioResponsableSAP
			document.querySelector('#copiaMotivoTraslado').value = traslado.MotivoTraslado
			document.querySelector('#copiaDocDate').value = traslado.DocDate

			let tbody = ''
			for (var itemCode in traslado.Detalle) {
				key = traslado.Detalle[itemCode]

				key.DetalleLotes.forEach(item => {
					tbody += ` <tr>
											 <td scope="col"><input type="text" name="solicitudTraslado.Detalle[].ItemCode" value="${key.ItemCode}"></td>
											 <td scope="col"><input type="text" name="solicitudTraslado.Detalle[].ItemName" value="${key.ItemName}"></td>
											 <td scope="col"><input type="text" name="solicitudTraslado.Detalle[].BatchNum" value="${item.BatchNum}"></td>
											 <td scope="col"><input type="text" name="solicitudTraslado.Detalle[].InDate" value="${item.InDate}"></td>
											 <td scope="col"><input type="text" name="solicitudTraslado.Detalle[].ExpDate" value="${item.ExpDate}"></td>
											<td scope="col"><input type="text" name="solicitudTraslado.Detalle[].QuantityCajas" value="${item.CantidadTotalPorSKUyLote}"></td>
											<td scope="col"><input type="text" name="solicitudTraslado.Detalle[].FromWhsCode" value="${key.AlmacenOrigen}"></td>
											<td scope="col"><input type="text" name="solicitudTraslado.Detalle[].ToWhsCode" value="${key.AlmacenDestino}"></td>
										</tr>`
				})
			}

			document.querySelector('#tbl_copiaSap tbody').innerHTML = tbody
		}

        function organizarSolicitudDeTraslado(datos) {
            let solicitud = {
                Detalle: {} // Objeto donde agruparemos por ItemCode
			};

            datos.forEach(row => {
                let itemCode = row.ItemCode || "";

                // Si el ItemCode no existe en el diccionario, se inicializa
                if (!solicitud.Detalle[itemCode]) {
                    solicitud.Detalle[itemCode] = {
                        AlmacenOrigen: row.FromWhsCode || "",
                        AlmacenDestino: row.ToWhsCode || "",
                        ItemCode: itemCode,
                        ItemName: row.ItemName || "",
						CantidadTotalPorSKU: 0,
						Estado: row.Estado,
                        DetalleLotes: []
                    };
                }

                // Acumular la cantidad total de cajas para el ItemCode
				solicitud.Detalle[itemCode].CantidadTotalPorSKU += row.QuantityCajas || 0;

                // Agregar el detalle del lote al ItemCode correspondiente
                solicitud.Detalle[itemCode].DetalleLotes.push({
                    BatchNum: row.BatchNum || "",
                    CantidadTotalPorSKUyLote: row.QuantityCajas || 0,
                    InDate: row.InDate || "",
                    ExpDate: row.ExpDate || ""
                });
            });

            return solicitud;
        }

		async function cargarUbicaciones(almacen, data) {
			let itemCode = data.itemcode
			let idUbicacion = data.idloteubicacion

			try {
				const response = await fetch("/AbastecimientoInterno/BuscarUbicaciones", {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ almacen, itemCode }) // Enviar los datos como JSON
				});

				if (!response.ok) {
					throw new Error(`Error en la solicitud: ${response.statusText}`);
				}

				const data = await response.json();

				let ubicaciones = '<option value="">Seleccione</<option>'
				data.forEach((ubicacion, index) => {
					ubicaciones += `<option value="${ubicacion}">${ubicacion}</option>`
				})

				document.querySelector(`#${idUbicacion}`).innerHTML = ubicaciones
				//console.log("ubicaciones: "+ data)
			} catch (error) {
				console.error('Error:', error);
			}
		}

		function calcularStockUnidades(quantityUnidades, data) {
			let unidMaster = document.querySelector(`#${data.idundmaster}`).value

			if (Number(quantityUnidades) > Number(data.cantidadtotal)) {
				Swal.fire('La cantidad ingresada no debe superar el stock de unidades.')
				return;
			}

			let cantidadMaster = Math.floor(Number(quantityUnidades) / Number(unidMaster))
			let cantidadSaldo = Number(quantityUnidades) % Number(unidMaster)

			document.querySelector(`#${data.idcantmaster}`).value = cantidadMaster
			document.querySelector(`#${data.idcantsaldo}`).value = cantidadSaldo
		}

		function calcularCantidadMasterSaldo(valorSelectMaster, data) {
			if (isNaN(Number(valorSelectMaster)) || Number(valorSelectMaster) === 0) {
				document.querySelector(`#${data.idcantmaster}`).value = 0
				document.querySelector(`#${data.idcantsaldo}`).value = 0
				Swal.fire("La unidad MASTER seleccionada no es válida.")
				return;
			}

			let quantityUnidades = document.querySelector(`#${data.idquantityunidades}`).value

			if (Number(quantityUnidades) > Number(data.cantidadtotal)) {
				Swal.fire('La cantidad ingresada no debe superar el stock de unidades.')
				return;
			}

			let cantidadMaster = Math.floor(Number(quantityUnidades) / Number(valorSelectMaster))
			let cantidadSaldo = Number(quantityUnidades) % Number(valorSelectMaster)

			document.querySelector(`#${data.idcantmaster}`).value = cantidadMaster
			document.querySelector(`#${data.idcantsaldo}`).value = cantidadSaldo
		}

		document.addEventListener('DOMContentLoaded', function () {
			permitirSoloNumeros('DocNum')
			document.getElementById("btn_transferir").addEventListener("click", realizarTransferencia)
		});

		function limpiarValoresItem(claseItemCode) {
			let elementos = document.querySelectorAll(`.${claseItemCode}`)

			elementos.forEach(element => {
				if (element) {
					element.value = '';
				}
			});
		}

        function actualizarIDs(fila) {
            // Generar un solo uniqueID por fila para mantener consistencia
            let uniqueID = Math.floor(Math.random() * 1000);

            fila.find("[id]").each(function () {
				let baseID = $(this).attr("id");
				let baseIdUndMaster = $(this).attr("data-idundmaster") || ""
                let baseIdCantMaster = $(this).attr("data-idcantmaster") || ""
                let baseIdCantSaldo = $(this).attr("data-idcantsaldo") || ""

				let nuevoID = baseID + "_clone_" + uniqueID; // Reutiliza el mismo uniqueID en toda la fila
				$(this).attr("id", nuevoID);

                if (baseIdUndMaster) {
					let nuevoIdUndMaster = baseIdUndMaster + "_clone_" + uniqueID
					$(this).attr("data-idundmaster", nuevoIdUndMaster)
				}

                if (baseIdCantMaster) {
                    let nuevoIdCantMaster = baseIdCantMaster + "_clone_" + uniqueID
                    $(this).attr("data-idcantmaster", nuevoIdCantMaster)
				}

                if (baseIdCantSaldo) {
                    let nuevoIdCantSaldo = baseIdCantSaldo + "_clone_" + uniqueID
                    $(this).attr("data-idcantsaldo", nuevoIdCantSaldo)
                }
            });

            // Actualizar `data-detalle` manteniendo el mismo uniqueID
            fila.find("[data-detalle]").each(function () {
                let datosDetalle = JSON.parse($(this).attr("data-detalle"))
                datosDetalle.itemCode = datosDetalle.itemCode + "_clone_" + uniqueID
                $(this).attr("data-detalle", JSON.stringify(datosDetalle))
            });

            // Eliminar el botón .btn-cobefar de la fila clonada
            fila.find(".btn-cobefar").remove()

            fila.find("select[data-idloteubicacion]").each(function () {
                let baseDataId = $(this).attr("data-idloteubicacion");
                let newDataId = baseDataId + "_clone_" + uniqueID;
                $(this).attr("data-idloteubicacion", newDataId);
            });

            // **ACTUALIZAR `onfocus` PARA MANTENER EL NUEVO `dataset`**
            fila.find("[onfocus]").each(function () {
                let onfocusAttr = $(this).attr("onfocus");

                // Verificar si el onfocus contiene "this.dataset"
                if (onfocusAttr.includes("this.dataset")) {
                    let updatedOnfocus = onfocusAttr; // No necesitamos modificarlo, ya que apunta al dataset del propio elemento
                    $(this).attr("onfocus", updatedOnfocus);
                }
            });
        }
    </script>
}