        function clonarFila(idTableLotes) {
            // Verificar si la tabla ya está inicializada con DataTable
            if ($.fn.DataTable.isDataTable(`#${idTableLotes}`)) {
                $(`#${idTableLotes}`).DataTable().destroy();
            }
            let tabla = $(`#${idTableLotes}`).DataTable(configDataTable); // Obtener instancia de DataTable
            // Eliminar cualquier event listener de click previamente
            $(`#${idTableLotes} tbody`).off('click', '.btn-cobefar');
            $(`#${idTableLotes} tbody`).on('click', '.btn-cobefar', function () {
                let filaOriginal = $(this).closest('tr'); // Obtener la fila original
                let filaClonada = filaOriginal.clone(); // Clonar la fila
                actualizarIDs(filaClonada); // Actualizar los IDs y evitar duplicados
                // Agregar la nueva fila al DataTable sin reiniciar
                tabla.row.add(filaClonada[0]).draw(false);
            });
            $(`#${idTableLotes}_wrapper`).addClass('w-100');
        }
