		//Buscador rápido para master y ubicaciones
        let selectActual = null;
        let modalInstance = null;
        function abrirModalBusquedaRapida(selectElement) {
            selectActual = selectElement;
            // Validar si aún no hay opciones (y cargar solo en caso sea de Ubicaciones)
            if (selectActual.options.length <= 1 && selectActual.id.startsWith('lote_ubicacion') ) {
                let idLote = selectElement.dataset.idloteubicacion;
                cargarUbicaciones('RESERVA', { idloteubicacion: idLote });
            }
            if (!modalInstance) {
                const modalElement = document.getElementById('modalBuscador');
                modalElement.setAttribute('aria-hidden', 'false');
                modalInstance = new bootstrap.Modal(modalElement);
            }
            const opciones = Array.from(selectElement.options).filter(opt => opt.value);
            const contenedor = document.getElementById('resultadosBusqueda');
            contenedor.innerHTML = '';
            opciones.forEach(opt => {
                const item = document.createElement('button');
                item.type = 'button';
                item.className = 'list-group-item list-group-item-action';
                item.textContent = opt.text;
                item.dataset.value = opt.value;
                item.onclick = () => seleccionarOpcion(opt.value);
                contenedor.appendChild(item);
            });
            modalInstance.show();
            const inputBusqueda = document.getElementById('inputBusqueda');
            inputBusqueda.value = '';
            inputBusqueda.focus();
            inputBusqueda.oninput = function () {
                const filtro = this.value.toLowerCase();
                Array.from(contenedor.children).forEach(item => {
                    item.style.display = item.textContent.toLowerCase().includes(filtro) ? 'block' : 'none';
                });
            };
        }
        function seleccionarOpcion(valor) {
            if (selectActual) {
                selectActual.value = valor;
                selectActual.dispatchEvent(new Event('change'));
            }
            modalInstance.hide();
            const modalElement = document.getElementById('modalBuscador');
            if (modalElement.contains(document.activeElement)) {
                document.activeElement.blur();
            }
            modalElement.setAttribute('aria-hidden', 'true');
            if (selectActual) {
                selectActual.focus();
            }
            selectActual = null;
        }
    </script>
