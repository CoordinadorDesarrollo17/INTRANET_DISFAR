		function actualizarIDs(fila) {
			// Generar un solo uniqueID por fila para mantener consistencia
			let uniqueID = Math.floor(Math.random() * 1000);
			fila.find("[id]").each(function () {
				let baseID = $(this).attr("id");
				let baseIdUndMaster = $(this).attr("data-idundmaster") || ""
				let baseIdCantMaster = $(this).attr("data-idcantmaster") || ""
				let baseIdCantSaldo = $(this).attr("data-idcantsaldo") || ""
                let baseIdquantityunidades = $(this).attr("data-idquantityunidades") || ""
				let nuevoID = baseID + "_clone_" + uniqueID; // Reutiliza el mismo uniqueID en toda la fila
				$(this).attr("id", nuevoID);
				$(this).val('')
				if (baseIdUndMaster) {
					let nuevoIdUndMaster = baseIdUndMaster + "_clone_" + uniqueID
					$(this).attr("data-idundmaster", nuevoIdUndMaster)
				}
				if (baseIdCantMaster) {
					let nuevoIdCantMaster = baseIdCantMaster + "_clone_" + uniqueID
					$(this).attr("data-idcantmaster", nuevoIdCantMaster)
				}
				if (baseIdCantSaldo) {
					let nuevoIdCantSaldo = baseIdCantSaldo + "_clone_" + uniqueID
					$(this).attr("data-idcantsaldo", nuevoIdCantSaldo)
				}
                if (baseIdquantityunidades) {
                    let nuevoIdquantityunidades = baseIdquantityunidades + "_clone_" + uniqueID
                    $(this).attr("data-idquantityunidades", nuevoIdquantityunidades)
                }
			});
			// Actualizar `data-detalle` manteniendo el mismo uniqueID
			fila.find("[data-detalle]").each(function () {
				let datosDetalle = JSON.parse($(this).attr("data-detalle"))
				datosDetalle.itemCode = datosDetalle.itemCode + "_clone_" + uniqueID
				$(this).attr("data-detalle", JSON.stringify(datosDetalle))
			});
			// Eliminar el botón .btn-cobefar de la fila clonada
			fila.find(".btn-cobefar").remove()
			fila.find("select[data-idloteubicacion]").each(function () {
				let baseDataId = $(this).attr("data-idloteubicacion");
				let newDataId = baseDataId + "_clone_" + uniqueID;
				$(this).attr("data-idloteubicacion", newDataId);
			});
			// **ACTUALIZAR `onfocus` PARA MANTENER EL NUEVO `dataset`**
			fila.find("[onfocus]").each(function () {
				let onfocusAttr = $(this).attr("onfocus");
				// Verificar si el onfocus contiene "this.dataset"
				if (onfocusAttr.includes("this.dataset")) {
					let updatedOnfocus = onfocusAttr; // No necesitamos modificarlo, ya que apunta al dataset del propio elemento
					$(this).attr("onfocus", updatedOnfocus);
				}
			});
		}
		async function cancelarTransferenciaTraslado() {
