        async function validarTodo() {
            const tabla = document.querySelector("#tbl_detalle");

            if (!tabla) {
                console.warn("No se encontró la tabla con id 'tbl_detalle'.");
                return;
            }

            const tbody = tabla.querySelector("tbody");

            if (!tbody || tbody.children.length === 0) {
                console.warn("La tabla no tiene datos.");
                return;
            }

            // Seleccionar solo las filas que tienen al menos un <td> con la clase específica
            const filas = Array.from(tbody.querySelectorAll("tr")).filter(fila =>
                fila.querySelector("td.text-center.bg-secondary.text-white")
            );

            for (const fila of filas) {
                const columnas = fila.querySelectorAll("td");

                if (columnas.length < 2) {
                    console.warn("Fila con estructura inesperada:", fila);
                    continue; // Salta esta fila si tiene menos de 2 columnas
                }

                const itemCode = columnas[1]?.textContent?.trim(); // Asegurar que existe

                if (itemCode) {
                    await validarItemParaApilar(itemCode);
                } else {
                    console.warn("No se encontró itemCode en esta fila:", fila);
                }
            }
        }

