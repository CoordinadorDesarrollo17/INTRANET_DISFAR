							} catch (error) {
								console.error('Error al mostrar los lotes de transferencia:', error);
							}
						} else {
                            console.warn(`Detalle o DetalleLotes no válido para producto ID: ${productoID}`, detalleTraslado[productoID]);
						}
					}
				});
				$('.fila-detalle').each(function (index) {
					let productoID = $(this).data('producto');
                    if (detalleTraslado[productoID] && detalleTraslado[productoID].DetalleLotes.length === 1 && detalleTraslado[productoID].Estado === "PENDIENTE") {
                            document.querySelector(`#btn_chevron_${productoID}`).click();
					}
				});
			} else {
				console.warn('El parámetro func no es una función válida:', func);
				return;
			}
		}
