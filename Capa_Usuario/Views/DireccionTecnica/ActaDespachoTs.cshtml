@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.ActaDespachoTs_E>

@{
    Layout = null;
    var m = Model.ToList()[0];
    if (m.AlmOrigen == "CUAR07") { m.AlmOrigen = "ALM07"; }
    if (m.AlmDestino == "CUAR07") { m.AlmDestino = "ALM07"; }
}
<style>
    .conBorde td {
        border: 1px solid;
    }
</style>

<table border=0 style="font-size:12px">
    <tr>
        <td colspan=2><img width="120" height="50" src="~/imagenes/logoventa2.jpg" /></td>
        <td></td>
        <td></td>
        <td colspan="2" style="text-align:right;"><strong>REG-013-02</strong></td>
    </tr>
    <tr>
        <td></td>
        <td></td>
        <td width=750px align='center'><strong>ACTA DE DESPACHO DE PRODUCTOS - COBEFAR S.A.C.</strong></td>
        <td></td>
        <td></td>
        <td></td>
    </tr>
    <tr>
        <td width="180px"><strong>FECHA : @m.FechaActa</strong></td>
        <td></td>
        <td colspan="4" style="text-align:right" width="100px"><strong>GUIA N° : </strong>@m.NroGuia</td>
    </tr>
    <tr>
        <td colspan="3">
            <strong>ALMACÉN ORIGEN : </strong>@m.TaxOfficeOrigen
            &nbsp;<strong>ALMACÉN DESTINO : </strong>@m.TaxOfficeDestino
        </td>
        <td></td>
        <td></td>
        <td></td>
    </tr>
</table>

<table border=0 style="font-size:9px;text-align:center">
    <tr class="conBorde">
        <td width=25px>CANTIDAD </td>
        <td width=200px>DESCRIPCION DEL PRODUCTO</td>
        <td width=50px>LOTE/SERIE</td>
        <td width=35px>FECHA VCTO</td>
        <td width=55px>NRO R.S.</td>
        <td width=40px colspan=2>PROTOCOLO DE ANALISIS</td>
        <td width=40px colspan=2>CAJAS LIMPIAS</td>
        <td width=40px colspan=2>EMBALAJE CERRADO</td>
        <td width=40px colspan=2>CONSGINA CONDICION DE EMBALAJE</td>
        <td width=60px>CONDICION ALMACENAMIENTO</td>
        <td width=40px colspan=2>MANCHADO DERRAME ARRUGADO QUEBRADO HUMEDO</td>
        <td width=40px colspan=2>PRODUCTO CORRESPONDE AL DOCUMENTO</td>
        <td width=40px colspan=2>VEHICULO LIMPIO Y EQUIPADO CONDICION ADECUADA</td>
    </tr>
    <tr class="conBorde">
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td></td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>

    </tr>
    @foreach (var item in Model)
    {
        <tr class="conBorde">
            <td>@Math.Round(item.CantidadLote, 0)</td>
            <td style="text-align:left">@item.NombreComercial &nbsp;@item.Concentracion &nbsp;@item.FormaPresentacion &nbsp;@item.FormaFarmaceutica</td>
            <td>@item.NroLote</td>
            <td>@item.FechaVcto</td>
            <td>@item.RegistroSanit</td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td>@item.CondicionAlm</td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
        </tr>
    }

    <tr>
        <td colspan=2>OBSERVACIONES: NINGUNA</td>
        <td colspan=20></td>
    </tr>
    <tr>
        <td colspan="22" height="80"></td>
    </tr>
    <tr>
        <td colspan="4"></td>
        <td colspan="5" align="center" style="border-bottom: solid 1px">
            @if (ViewBag.FirmaResponsable != null)
            {<img src="@ViewBag.FirmaResponsable" width="150" />}
        </td>
        <td colspan="5" align="center"></td>
        <td colspan="7"></td>
    </tr>
    <tr>
        <td colspan="4"></td>
        <td colspan="5" align="center">RESPONSABLE DE ALMACEN</td>
        <td colspan="5" align="center"></td>
        <td colspan="7"></td>
    </tr>
    <tr>
        <td colspan="4"></td>
        <td colspan="5" align="center">(sello y firma)</td>
        <td colspan="5" align="center"></td>
        <td colspan="7"></td>
    </tr>
</table>
