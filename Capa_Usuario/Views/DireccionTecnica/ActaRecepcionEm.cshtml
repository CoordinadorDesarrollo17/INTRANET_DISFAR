@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.ActaRecepcionEm_E>

@{
    ViewBag.Title = "ActaRecepcionEm";
    Layout = null;
    var m = Model.ToList()[0];
    string coments = m.Comentario + m.Comentario2;
    List<string> lstComents = new List<string>();
    int posini = 0;
    int longitud = 0;
    for (int i = 0; i <= coments.Length; i++)
    {
        posini = i;
        i = coments.IndexOf(".", i);
        longitud = i - posini + 1;
        if (i >= posini && posini >= 0) { lstComents.Add(coments.Substring(posini, longitud)); }
        else { i = coments.Length + 1; }
    }

}
<style>
    .conBorde td {
        border: 1px solid;
    }
</style>
<table border="0">
    <tr>
        <td width="180"><img width="120" height="50" src="~/imagenes/logoventa2.jpg" /></td>
        <td width="455"></td>
        <td></td>
        <td>
            <table width="100%">
                <tr class="conBorde">
                    <td width="100" style="text-align: center;"><strong>F/ALM-002</strong></td>
                    <td style="text-align:center;" width="30"><strong>V1</strong></td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td colspan="4" width="650" align="center"><strong>ACTA DE RECEPCIÓN DE PRODUCTOS</strong></td>
    </tr>
    <tr>
        <td width="180"><strong>FECHA :</strong> @m.T0_DocDate</td>
        <td></td>
        <td width="280"><strong>FACTURA O GUIA DE REMISIÓN : </strong></td>
        <td colspan="2" style="text-align:left"> @m.NroFactura</td>
    </tr>
    <tr>
        <td width="180"><strong>PROCEDENCIA : </strong></td>
        <td colspan="3" style="text-align: left">@m.T0_CardName</td>
    </tr>
</table>

