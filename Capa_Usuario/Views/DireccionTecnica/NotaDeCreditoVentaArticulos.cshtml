     <td style="text-align:right">@Cab.F_Topgratuita(Cab.Sum_Topgratuita(Model.ToList()))</td>
       </tr>
        <tr>
   <td colspan="3"><hr /></td>
  </tr>
   <tr>
      <td style="font-weight:600">Importe Total</td>
           <td style="font-weight:600">S/</td>
<td style="font-weight:600, text-align: right">@Math.Round(Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())), 2)</td>
       </tr>
         </table>
    }
      </td>
  </tr>
        <tr>
 <td></td>
 <td style="text-align:center; border-bottom:2px solid black; border-left:2px solid black; border-right:2px solid black; font-size:10px; padding:10px" colspan="2">
 <strong>CANCELADO<br /><br /></strong>

       Lima...........de.................................del 20.....<br /><br />

        ------------------------------------------<br />
     COBEFAR S.A.C.

 </td>
     </tr>
    </table>
