@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.Reportes.NotaCreditoVentaArticulo_E>

@{
    Layout = null;
    var Cab = Model.ToList()[0];
    // Lógica original para detectar si es descuento especial
    bool esConcepto05 = Model.Any(x => x.TipoDescripcionC != null && x.TipoDescripcionC.Trim() == "05");
}

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nota de Crédito</title>
    <style>
        * {
  font-family: 'Verdana', sans-serif;
            font-size: 12px;
        }
table {
            border-collapse: collapse;
         width: 100%;
        }

  th, td {
   padding: 5px;
        }
    </style>
</head>
<body>
    <div>
      <table border="0">
    <tr>
   <td style="font-size: 10px; text-align: left; position: relative;">
     <img style="float:left" src="~/imagenes/logoventa2.jpg" width="230" height="80" /><br />
         www.cobefar.com.pe
   <!-- Imagen superpuesta en la esquina superior derecha -->
          <img src="~/imagenes/index/encabezado/bpa.jpg" width="45" height="40" style="position: absolute; top: 5px; right: 0;" />
             </td>
        <td style="text-align:left;font-size:10px; max-width:300px;">
            <strong>Dom. Fiscal:</strong> Cal.Carlos Pedemonte Nro. 145b Int. 2pis <br />
   Urb. Lotización Ex Fundo El Pino  Lima - Lima - San Luis<br />
      <strong>Almacén:</strong> Av. Nicolás Arriola N°2955-2963, 2do. Piso <br />
                    Urb. Mercurio - San Luis - Lima - Lima<br />
    <strong>Almacén:</strong> Jr. Antonio Miroquezada N° 806 Int. 303<br />
     Lima - Lima - Lima<br />
            <strong>Almacén:</strong> Jr. Antonio Miroquezada N° 806 Int. 502<br />
             Lima - Lima - Lima<br />
     <strong>Teléfono:</strong> 428-1248<br />
    <strong>Email:</strong> cobefar.ventas@gmail.com
       </td>
            <td>
   <div style="border: 2px solid green; vertical-align: top; padding: 5px; border-radius: 15px; font-size: 20px !important; text-align: center;">
        <div style="margin: 10px 0;"></div>
                 <div style="font-size: 20px !important; text-align: center;">R.U.C. 20600546041</div>
   <div style="margin: 25px 0;"></div>
    @if (ViewBag.Tipo == "NC")
          {
               <strong style="font-size: 20px !important; text-align: center;">NOTA DE CRÉDITO<br />ELECTRÓNICA</strong>
        }
             else if (ViewBag.Tipo == "ND")
                {
                  <strong style="font-size: 20px !important; text-align: center;">NOTA DE DÉBITO<br />ELECTRÓNICA</strong>
                }
     else
       {
        <strong style="font-size: 20px !important; text-align: center;">NOTA DE CRÉDITO<br />ELECTRÓNICA</strong>
       }
       <div style="margin: 25px 0;"></div>
  <div style="font-size: 20px !important; text-align: center;">N° @Cab.SerieDoc-@Cab.CorreDoc</div>
   <div style="margin: 10px 0;"></div>
          </div>
    </td>
</tr>
        </table>
        <div style="width:65%; display: inline-block; border: 2px solid green; vertical-align: top; padding: 5px; border-radius: 15px;margin-bottom:15px">
            <table style="text-align:left" border="0">
       <tr>
  <td><strong>Cliente:</strong></td>
     <td>@Cab.NombreSocio</td>
      </tr>
      <tr>
       <td><strong>Dirección:</strong></td>
        <td colspan="3">@Cab.DirPagar</td>
    </tr>
<tr>
            <td><strong>R.U.C.:</strong></td>
              <td colspan="3">@Cab.RUC</td>
         </tr>
            </table>
        </div>
    <div style="width:30%; display: inline-block; text-align:left;">
            <br />
        <table>
         <tr><td><strong>FECHA DE EMISIÓN:</strong> @Cab.Fecha.ToString("dd/MM/yyyy")</td></tr>
            <tr><td><strong>MONEDA:</strong> @Cab.MonedaLetras</td></tr>
   </table>
        </div>
    </div>

    <div>
        <table border="1" style="text-align:center;">
   <tr>
           <td>TIPO DE DOC.</td>
    <td>SERIE Y CORRELATIVO</td>
  <td>FECHA DEL DOCUMENTO</td>
     <td>FECHA DE EMISIÓN</td>
          <td width="250px">VENDEDOR</td>
  </tr>
   <tr>
                <td>@Cab.TipoDocOrigen</td>
                <td>@Cab.SerieDocOrigen-@Cab.CorreDocOrigen</td>
        <td>@Cab.FDocOrigen</td>
    <td>@Cab.Fecha.ToString("dd/MM/yyyy")</td>
                <td>@Cab.ElaboradoPor</td>
       </tr>
     </table>
    </div>

    @* --- 4. DETALLE DE PRODUCTOS --- *@
    @if (esConcepto05)
    {
        @* TABLA SIMPLIFICADA PARA DESCUENTO ESPECIAL (Concepto 05) *@
        <table border="1" style="font-size:11px;">
    <tr style="text-align:center">
     <th style="width: 100px;">CANT.</th>
                <th style="width: 400px;">DESCRIPCIÓN</th>
      <th style="width: 100px;">P. UNITARIO</th>
                <th style="width: 100px;">PRECIO<br />VENTA</th>
         </tr>
@{
        // Calcular los valores TOTALES para concepto 05
var valorNeto = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())) - Cab.Impuesto;
           var precioTotal = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList()));
   }
            @foreach (var item in Model)
      {
    <tr style="text-align: center; page-break-inside: avoid;">
        <td style="width: 100px;">1.00</td>
        <td style="width: 400px;">
              @if (item.TipoDescripcionC != null && item.TipoDescripcionC.Trim() == "05")
            {
  <span>Descuento Especial</span>
       }
          else
             {
  @Html.DisplayFor(modelItem => item.Descripcion)
   }
          </td>
          <td style="width: 100px;">@Math.Round(valorNeto, 2)</td>
  <td style="width: 100px;">@Math.Round(precioTotal, 2)</td>
       </tr>
            }
        </table>
    }
    else
    {
  @* TABLA COMPLETA PARA PRODUCTOS NORMALES *@
        <table border="1" style="text-align:center">
 <tr>
        <th style="width: 80px;">CANTIDAD</th>
    <th style="width: 260px;">DESCRIPCION</th>
       <th style="width: 50px;">LAB.</th>
    <th style="width: 80px;">LOTE</th>
        <th style="width: 100px;">FECHA<br />VENC.</th>
          <th style="width: 100px;">PRECIO<br />UNIT.</th>
    <th style="width: 80px;">DSCTO<br />%</th>
           <th style="width: 100px;">V. VENTA<br />NETO</th>
     <th style="width: 100px;">PRECIO<br />VENTA</th>
  </tr>
            @foreach (var item in Model)
 {
       <tr style="page-break-inside: avoid;">
         <td style="width: 80px;">
       @Math.Round(item.cantVta(), 0)
    @item.F_UM()
          </td>
          <td style="width: 260px;">
      @Html.DisplayFor(modelItem => item.Descripcion)
       </td>
    <td style="width: 50px;">
             @Html.DisplayFor(modelItem => item.Laboratorio)
          </td>
      <td style="width: 80px;">
      @Html.DisplayFor(modelItem => item.LoteNum)
      </td>
  <td style="width: 100px;">
      @Html.DisplayFor(modelItem => item.VctoLote)
    </td>
             <td style="width: 100px;">
                   @Math.Round(item.F_ItemPrecio(), 2)
             </td>
           <td style="width: 80px;">
                @Html.DisplayFor(modelItem => item.Descuento)
          </td>
      <td style="width: 100px;">
            @Html.DisplayFor(modelItem => item.PreVentaNeto)
   </td>
 <td style="width: 100px;">
   @Math.Round(item.ItemTotalxLot(), 2)
     </td>
       </tr>
  }
   </table>
    }

    <h6><strong>MOTIVO: </strong>@Cab.Motivo<br /><br /></h6>

    @* --- 5. SON (Importe en letras) --- *@
    <table style="font-size: 11px; page-break-inside: avoid;" border="0">
        <tr>
  <td colspan="9">
      -----------------------------------------------------------------------------------------------------------------------------------------------------------------------
  </td>
        </tr>
        <tr>
            <td colspan="8">
       SON: @Cab.TotalL()
        </td>
        </tr>
        <tr>
            <td colspan="9">
       -----------------------------------------------------------------------------------------------------------------------------------------------------------------------
        </td>
        </tr>
    </table>

    @* --- 6. PIE DE PÁGINA --- *@
    <table style="font-size: 11px; page-break-inside: avoid;" border="0">
        <tr>
<td style="text-align:center; padding:5px; font-size:11px; max-width:300px;">
    <img src="~/imagenes/index/encabezado/barras.png" width="140" height="45" /><br />
   Autorizado mediante N° R.S. 300-2014/SUNAT<br />
     Representación impresa de la Factura Electrónica. Puede ser consultada<br />
    en <strong>www.cobefar.com.pe</strong>
      <br /><br />
   <strong style="font-size:11px">Nota: No aceptamos devoluciones ni reclamos después de la entrega de la mercadería</strong>
 </td>
    <td style="border-bottom: 2px solid black; border-top: 2px solid black; border-left: 2px solid black; padding: 0px 5px 0px 15px; font-size: 10px; max-width: 180px;">
   <p>
  <strong>GERENTE DE VENTAS</strong><br />
    Cel.:982577809<br />
         Telf.:4281248<br />
      <strong>VENTAS PROVINCIA</strong><br />
 958950318 / 971559893<br />
   997895353<br />
   <strong>VENTAS POR MAYOR</strong><br />
   933567704 / 956381409
     </p>
        </td>
   <td style="border-bottom: 2px solid black; border-top: 2px solid black; border-right: 2px solid black; padding: 0px 5px 0px 15px; font-size: 10px; max-width: 180px;">
    <p>
     <strong>VENTAS LIMA</strong><br />
          954121505 / 933514870 / 982768938<br />
      939391010 / 932766022 / 933514897<br />
            986789108 / 986789103 / 942810044<br />
       977190699 / 980576206<br />
              950156844 / 980914611<br />
 939392020<br />
  Telf.: 4280115 / 4274304
</p>
      </td>
<td rowspan="2">
       @if (ViewBag.Tipo == "NC" && ViewBag.SubTipo == "S")
  {
      <table style="font-size:11px; padding:0" border="0">
            <tr>
      <td>Valor de venta</td>
       <td>S/</td>
<td style="text-align:right">@Math.Round(Cab.PreUnitSinIgv, 2)</td>
    </tr>
       <tr>
           <td>I.G.V.18%</td>
    <td>S/</td>
        <td style="text-align:right">@Math.Round(Cab.Impuesto, 2)</td>
    </tr>
  <tr>
         <td colspan="3"><hr /></td>
          </tr>
       <tr>
     <td style="font-weight:600">Importe Total</td>
      <td style="font-weight:600">S/</td>
   <td style="font-weight:600, text-align: right">@Math.Round((Math.Round(Cab.Impuesto, 2) + Cab.PreUnitSinIgv), 2)</td>
   </tr>
  </table>
  }
     else if (ViewBag.Tipo == "ND")
          {
       <table style="font-size:11px; padding:0" border="0">
          <tr>
          <td>Valor de venta</td>
        <td>S/</td>
     <td style="text-align:right">@Math.Round(Cab.PreUnitSinIgv, 2)</td>
              </tr>
            <tr>
      <td> I.G.V 18%</td>
  <td>S/</td>
      <td style="text-align:right">@Math.Round(Cab.Impuesto, 2)</td>
 </tr>
       <tr>
 <td colspan="3"><hr /></td>
    </tr>
        <tr>
            <td style="font-weight:600">Importe Total</td>
     <td style="font-weight:600">S/</td>
 <td style="font-weight:600, text-align: right"> @Math.Round(Cab.DocTotal, 2)</td>
     </tr>
      </table>
  }
     else if (esConcepto05)
     {
      @* TABLA SIMPLIFICADA PARA CONCEPTO 05 - DESCUENTO ESPECIAL *@
    <table style="font-size:11px; padding:0" border="0">
   <tr>
    <td>P. Unitario</td>
         <td>S/</td>
   <td style="text-align:right">
       @{
      var valorNeto = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())) - Cab.Impuesto;
       }
     @Math.Round(valorNeto, 2)
   </td>
</tr>
       <tr>
      <td>I.G.V 18%</td>
        <td>S/</td>
       <td style="text-align:right">@Math.Round(Cab.Impuesto, 2)</td>
          </tr>
   <tr>
 <td colspan="3"><hr /></td>
   </tr>
             <tr>
        <td style="font-weight:600">Precio Venta</td>
     <td style="font-weight:600">S/</td>
     <td style="font-weight:600, text-align: right">@Math.Round(Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())), 2)</td>
        </tr>
  </table>
     }
  else
    {
       @* TABLA COMPLETA PARA PRODUCTOS NORMALES (NO ES CONCEPTO 05) *@
  <table style="font-size:11px; padding:0" border="0">
       <tr>
<td>Op.Gravada</td>
     <td>S/</td>
    <td style="text-align:right">@Math.Round(Cab.Tgrabado(Cab.Sum_Topgratuita(Model.ToList()), Cab.Sum_Tinafecto(Model.ToList())), 2)</td>
 </tr>
            <tr>
 <td>Desc.&nbsp;Globales</td>
         <td>S/</td>
 <td style="text-align:right"><span>0.00</span></td>
</tr>
      <tr>
       <td> I.G.V 18%</td>
    <td>S/</td>
   <td style="text-align:right">@Math.Round(Cab.Impuesto, 2)</td>
   </tr>
   <tr>
      <td> Op.Inafecta</td>
        <td>S/</td>
       <td style="text-align:right">@Cab.F_Tinafecto(Cab.Sum_Tinafecto(Model.ToList()))</td>
        </tr>
         <tr>
       <td> Op.Exonerada</td>
    <td>S/</td>
    <td style="text-align:right"><span>0.00</span></td>
     </tr>
<tr>
 <td>Op.Gratuita</td>
