@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.Reportes.NotaCreditoVentaArticulo_E>

@{
    Layout = null;
    var Cab = Model.ToList()[0];
    bool esConcepto05 = Model.Any(x => x.TipoDescripcionC != null && x.TipoDescripcionC.Trim() == "05");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nota de Crédito Electrónica</title>
    <style>
        * {
            font-family: 'Arial', 'Verdana', sans-serif;
            box-sizing: border-box;
        }

        body {
            margin: 20px;
            color: #333;
            font-size: 11px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        .border-box {
            border: 1px solid #b0bfc6;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 15px;
        }

        /* Tabla de Ítems */
        .items-table {
            width: 100%;
            margin-top: 15px;
            margin-bottom: 15px;
        }

            .items-table th {
                background-color: #0a3a60;
                color: white;
                font-weight: bold;
                font-size: 10px;
                padding: 6px 4px;
                border: 1px solid #0a3a60;
                text-align: center;
            }

            .items-table td {
                padding: 6px 4px;
                border: 1px solid #b0bfc6;
                text-align: center;
                font-size: 11px;
            }

        /* Totales */
        .totals-container {
            width: 100%;
            margin-top: 10px;
        }

        .totals-table {
            width: 280px;
            float: right;
            border-collapse: separate;
            border-spacing: 0 4px;
        }

        .totals-label {
            background-color: #a6b1ba;
            color: white;
            text-align: center;
            font-weight: bold;
            padding: 5px;
            border-radius: 6px 0 0 6px;
            font-size: 10px;
            width: 150px;
        }

        .totals-value {
            border: 1px solid #b0bfc6;
            border-left: none;
            border-radius: 0 6px 6px 0;
            text-align: right;
            padding: 5px 10px;
            background-color: white;
            font-size: 11px;
            width: 130px;
        }

        .totals-label-final {
            background-color: #0a3a60;
            color: white;
            text-align: center;
            font-weight: bold;
            padding: 7px;
            border-radius: 6px 0 0 6px;
            font-size: 11px;
        }

        .totals-value-final {
            border: 2px solid #0a3a60;
            border-left: none;
            border-radius: 0 6px 6px 0;
            text-align: right;
            padding: 7px 10px;
            font-weight: bold;
            color: #0a3a60;
            font-size: 12px;
            background-color: white;
        }

        .footer-son {
            clear: both;
            border: 1px solid #b0bfc6;
            padding: 8px;
            font-size: 11px;
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <table style="margin-bottom: 20px;">
        <tr>
            <td style="width: 60%; vertical-align: top;">
                <img src="~/imagenes/logoventa2.jpg" width="180" height="60" style="float: left; margin-right: 15px;" />
                <div style="font-size: 12px; color: #0a3a60; font-weight: bold; margin-top: 5px;">DISFAR ORIENTE S.A.C.</div>
                <div style="font-size: 9.5px; color: #555; line-height: 1.4; margin-top: 4px;">
                    PJ. PROGRESO NRO. 118 (ALT CUADRA 2 VIA DEEVITAMIENTO)-MORALES-SAN MARTÍN SAN MARTÍN<br />
                    <br />
                    <span style="color: #777;">Morales - San Martín - San Martín</span>
                </div>
            </td>
            <td style="width: 40%; vertical-align: top;">
                <div style="border: 2px solid #0a3a60; border-radius: 15px; padding: 15px; text-align: center;">
                    <div style="font-size: 12px; color: #333; margin-bottom: 8px;">RUC: 20615244156</div>
                    <div style="font-size: 13px; font-weight: bold; color: #0a3a60; margin-bottom: 8px; line-height: 1.2;">
                        @if (ViewBag.Tipo == "ND")
                        {
                            <text>NOTA DE DÉBITO ELECTRÓNICA</text>
                        }
                        else
                        {
                            <text>NOTA DE CRÉDITO ELECTRÓNICA</text>
                        }
                    </div>
                    <div style="font-size: 12px; color: #333;">Nro. @Cab.SerieDoc-@Cab.CorreDoc</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="border-box">
        <table>
            <tr>
                <td style="width: 10%; font-weight: bold; padding: 4px 0;">Cliente:</td>
                <td style="width: 55%; padding: 4px 0;">@Cab.NombreSocio</td>
                <td style="width: 10%; font-weight: bold; padding: 4px 0;">Moneda:</td>
                <td style="width: 25%; padding: 4px 0;">@Cab.MonedaLetras</td>
            </tr>
            <tr>
                <td style="font-weight: bold; padding: 4px 0;">RUC:</td>
                <td style="padding: 4px 0;">@Cab.RUC</td>
                <td style="font-weight: bold; padding: 4px 0;">IGV:</td>
                <td style="padding: 4px 0;">18.00 %</td>
            </tr>
            <tr>
                <td style="font-weight: bold; padding: 4px 0;">Dirección:</td>
                <td style="padding: 4px 0;">@Cab.DirPagar</td>
                <td style="font-weight: bold; padding: 4px 0;">Motivo:</td>
                <td style="padding: 4px 0;">@Cab.Motivo</td>
            </tr>
            <tr>
                <td style="font-weight: bold; padding: 4px 0;">Ciudad:</td>
                <td style="padding: 4px 0;" colspan="3">ANDAHUAYLAS - APURÍMAC - ANDAHUAYLAS</td>
            </tr>
        </table>
    </div>

    <div class="border-box" style="padding: 0; overflow: hidden;">
        <table style="text-align: center;">
            <thead>
                <tr style="border-bottom: 1px solid #b0bfc6; background-color: #fafbfc;">
                    <th style="padding: 6px; font-weight: bold; border-right: 1px solid #b0bfc6; width: 25%;">Fecha de Emisión</th>
                    <th style="padding: 6px; font-weight: bold; border-right: 1px solid #b0bfc6; width: 25%;">Referencia</th>
                    <th style="padding: 6px; font-weight: bold; border-right: 1px solid #b0bfc6; width: 25%;">Fecha Doc. Origen</th>
                    <th style="padding: 6px; font-weight: bold; width: 25%;">Vendedor</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: 8px; border-right: 1px solid #b0bfc6;">@Cab.Fecha.ToString("dd-MMM-yyyy")</td>
                    <td style="padding: 8px; border-right: 1px solid #b0bfc6;">@Cab.SerieDocOrigen-@Cab.CorreDocOrigen</td>
                    <td style="padding: 8px; border-right: 1px solid #b0bfc6;">@Cab.FDocOrigen</td>
                    <td style="padding: 8px;">@Cab.ElaboradoPor</td>
                </tr>
            </tbody>
        </table>
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th style="width: 10%;">CÓDIGO</th>
                <th style="width: 6%;">CANT.</th>
                <th style="width: 8%;">UNID.</th>
                <th style="width: 36%;">DESCRIPCIÓN</th>
                <th style="width: 8%;">LOTE</th>
                <th style="width: 8%;">F. V.</th>
                <th style="width: 8%;">V. UNIT.</th>
                <th style="width: 6%;">DSCTO. %</th>
                <th style="width: 10%;">V.VENTA NETO</th>
                <th style="width: 10%;">V. VENTA</th>
            </tr>
        </thead>
        <tbody>
            @if (esConcepto05)
            {
                var valorNeto = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())) - Cab.Impuesto;
                var precioTotal = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList()));

                foreach (var item in Model)
                {
                    <tr>
                        <td></td>
                        <td>1</td>
                        <td></td>
                        <td style="text-align: left;">DESCUENTO ESPECIAL</td>
                        <td></td>
                        <td></td>
                        <td>@Math.Round(valorNeto, 2).ToString("F2")</td>
                        <td></td>
                        <td>@Math.Round(valorNeto, 2).ToString("F2")</td>
                        <td>@Math.Round(precioTotal, 2).ToString("F2")</td>
                    </tr>
                }
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td></td>
                        <td>@Math.Round(item.cantVta(), 0)</td>
                        <td>@item.F_UM()</td>
                        <td style="text-align: left;">@Html.DisplayFor(modelItem => item.Descripcion)</td>
                        <td>@Html.DisplayFor(modelItem => item.LoteNum)</td>
                        <td>@Html.DisplayFor(modelItem => item.VctoLote)</td>
                        <td>@Math.Round(item.F_ItemPrecio(), 2).ToString("F2")</td>
                        <td>@Html.DisplayFor(modelItem => item.Descuento)</td>
                        <td>@Html.DisplayFor(modelItem => item.PreVentaNeto)</td>
                        <td>@Math.Round(item.ItemTotalxLot(), 2).ToString("F2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="totals-container">
        <div style="width: 50%; float: left; font-weight: bold; color: #555; padding-top: 5px;">
            OBSERVACIONES
        </div>
        <div style="width: 50%; float: right;">
            <table class="totals-table">
                @if (esConcepto05)
                {
                    var valorNeto = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())) - Cab.Impuesto;
                    var precioTotal = Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList()));

                    <tr>
                        <td class="totals-label">OP. GRAVADAS</td>
                        <td class="totals-value">S/ @Math.Round(valorNeto, 2).ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="totals-label">OP. INAFECTAS</td>
                        <td class="totals-value">S/ 0.00</td>
                    </tr>
                    <tr>
                        <td class="totals-label">OP. EXONERADAS</td>
                        <td class="totals-value">S/ 0.00</td>
                    </tr>
                    <tr>
                        <td class="totals-label">TOTAL OP. GRATUITAS</td>
                        <td class="totals-value">S/ 0.00</td>
                    </tr>
                    <tr>
                        <td class="totals-label">DSCTOS. TOTALES</td>
                        <td class="totals-value">S/ 0.00</td>
                    </tr>
                    <tr>
                        <td class="totals-label">IGV</td>
                        <td class="totals-value">S/ @Math.Round(Cab.Impuesto, 2).ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="totals-label-final">TOTAL</td>
                        <td class="totals-value-final">S/ @Math.Round(precioTotal, 2).ToString("F2")</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td class="totals-label">OP. GRAVADAS</td>
                        <td class="totals-value">S/ @Math.Round(Cab.Tgrabado(Cab.Sum_Topgratuita(Model.ToList()), Cab.Sum_Tinafecto(Model.ToList())), 2).ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="totals-label">OP. INAFECTAS</td>
                        <td class="totals-value">S/ @Cab.F_Tinafecto(Cab.Sum_Tinafecto(Model.ToList()))</td>
                    </tr>
                    <tr>
                        <td class="totals-label">OP. EXONERADAS</td>
                        <td class="totals-value">S/ 0.00</td>
                    </tr>
                    <tr>
                        <td class="totals-label">TOTAL OP. GRATUITAS</td>
                        <td class="totals-value">S/ @Cab.F_Topgratuita(Cab.Sum_Topgratuita(Model.ToList()))</td>
                    </tr>
                    <tr>
                        <td class="totals-label">DSCTOS. TOTALES</td>
                        <td class="totals-value">S/ 0.00</td>
                    </tr>
                    <tr>
                        <td class="totals-label">IGV</td>
                        <td class="totals-value">S/ @Math.Round(Cab.Impuesto, 2).ToString("F2")</td>
                    </tr>
                    <tr>
                        <td class="totals-label-final">TOTAL</td>
                        <td class="totals-value-final">S/ @Math.Round(Cab.TotalFactura(Cab.Sum_Topgratuita(Model.ToList())), 2).ToString("F2")</td>
                    </tr>
                }
            </table>
        </div>
    </div>

    <div class="footer-son">
        SON: @Cab.TotalL()
    </div>

</body>
</html>