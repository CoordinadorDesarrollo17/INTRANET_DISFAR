    <table style="font-size:11px" border="0">
        <tr>
            <td colspan="2">
                <img src="~/imagenes/index/encabezado/logoC.jpg" width="130" height="60" /><br />
                www.cobefar.com.pe
            </td>
            <td valign="top">
                <img src="~/imagenes/index/encabezado/bpa.jpg" width="30" height="30" />
            </td>
            <td>
                <strong>Dom. Fiscal:</strong> Cal.Carlos Pedemonte Nro. 145b Int. 3piso<br />
                Urb. Lotizacion Ex Fundo El Pino Lima - Lima - San Luis<br />
                <strong>Almacen:</strong> Av. Nicolás Arriola N°2955-2963,2do. Piso<br />
                Urb. Mercurio - San Luis - Lima - Lima<br />
                <strong>Almacén:</strong> Jr. Antonio Miroquezada N° 806 int. 303<br />
                Lima - Lima - Lima<br />
                <strong>Almacén:</strong> Jr. Antonio Miroquezada N° 806 int. 502<br />
