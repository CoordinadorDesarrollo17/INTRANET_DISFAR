@model Capa_Entidad.Compras_ENT.Tablas.OPDN_E

@{
    ViewBag.Title = "RealizarEntradaDeMercancias";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-cobefar-degradado-1">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("ListadoEntradasDeMercancias", "DireccionTecnica")">Listado entrada de mercancías</a></li>
            <li class="current"><em>Realizar entrada de mercancías</em></li>
        </ol>
    </nav>
</div>

<div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">REALIZAR ENTRADA DE MERCANCÍAS</h3></div>
</div>

<div class="bg-form-pestanas-cobefar">
    <h4 class="text-center font-weight-bold text-cobefar pt-4">¿Está seguro(a) de realizar esta entrada?</h4>

    <div class="bg-section-form p-4 bg-form-cobefar">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">
                <div class="col-lg-10">
                    <label for="Tipo" class="text-dark form-label font-weight-bold font-18">Observaciones:</label>
                    <input class="form-control border-success" value="@Model.sqlopdn.Observaciones" name="Observaciones" />
                </div>
            </div>

            @Html.EditorFor(model => model.DocEntry, new { htmlAttributes = new { @class = "form-control", @type = "hidden" } })

            <div class="row mt-4">
                <div class="col-lg-4">
                    <button type="submit" class="btn btn-success"><i class="icon-checkmark"></i> Realizar</button>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-lg-3">
                    <label for="Estado" class="text-dark form-label font-weight-bold font-18">Estado:</label>
                    @Html.EditorFor(model => model.sqlopdn.Estado, new { htmlAttributes = new { @class = "form-control text-center border-success", @readonly = "true" } })
                </div>

                <div class="col-lg-2">
                    <label class="text-dark form-label font-weight-bold font-18">Fecha Realización:</label>
                    @Html.EditorFor(model => model.sqlopdn.FechaRealizacion, new { htmlAttributes = new { @class = "form-control text-center border-success", @readonly = "true" } })
                </div>

                <div class="col-lg-2">
                    <label class="text-dark form-label font-weight-bold font-18">Hora Realización:</label>
                    @Html.EditorFor(model => model.sqlopdn.FechaRealizacion, new { htmlAttributes = new { @class = "form-control text-center border-success", @readonly = "true" } })
                </div>

                <div class="col-lg-4">
                    <label class="text-dark form-label font-weight-bold font-18">OpRealizacion:</label>
                    @Html.EditorFor(model => model.sqlopdn.OpRealizacion, new { htmlAttributes = new { @class = "form-control text-center border-success", @readonly = "true" } })
                </div>
            </div>
        }



    <div class="bg-cobefar text-white mt-4 p-4 w-75">
        <div class="row">
            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">NroDocumento:</label>
                @Model.DocNum
            </div>

            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">FechaCont:</label>
                @Model.DocDate
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">NombreProv:</label>
                @Model.CardName
            </div>

            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">Guía:</label>
                @Model.NumAtCard
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">Total:</label>
                @Model.DocTotal
            </div>

            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">EstadoDoc:</label>
                @Model.U_SYP_STATUS
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <label class="form-label text-cobefar-3 font-18">Almacén:</label>
                @Model.Almacen
            </div>
        </div>
    </div>
    </div>

</div>


<script>
    if ('@ViewBag.Mensaje' != "") {
        Swal.fire('@ViewBag.Mensaje');
    }
</script>