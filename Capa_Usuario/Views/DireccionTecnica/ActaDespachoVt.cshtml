@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.ActaDespachoVt_E>

@{
    Layout = null;
    var m = Model.ToList()[0];
}
<style>
    .conBorde td {
        border: 1px solid;
    }
</style>
<table border="0" style="font-size:12px">
    <tr>
        <td><img width="120" height="50" src="~/imagenes/logoventa2.jpg" /></td>
        <td width="450"></td>
        <td></td>
        <td colspan="2">
            <table width="100%">
                <tr class="conBorde">
                    <td width="100" style="text-align: center;"><strong>F/ALM-001</strong></td>
                    <td style="text-align:center;" width="30"><strong>V1</strong></td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td colspan="4" align="center"><strong>ACTA DE DESPACHO</strong></td>
    </tr>
    <tr>
        <td width="180px"><strong>FECHA : </strong>@m.T0_DocDate</td>
        <td></td>
        <td colspan="2" style="text-align:right" width="100px"><strong>FACTURA/BOLETA N° : </strong>@m.T0_NumAtCard</td>
    </tr>
    <tr>
        <td colspan="4"><strong>CLIENTE : </strong>@m.T0_CardName </td>
    </tr>
</table>

<table border=0 style="font-size:9px;text-align:center;">
    <tr class="conBorde">
        <td width=25px>Cantidad Programada</td>
        <td width=200px>DESCRIPCION DEL PRODUCTO</td>
        <td width=50px>LOTE SERIE</td>
        <td width=35px>FECHA VCTO</td>
        <td width=55px>NRO R.S.</td>
        <td width=40px colspan=2>PROTOCOLO DE ANALISIS</td>
        <td width=40px colspan=2>CAJAS LIMPIAS</td>
        <td width=40px colspan=2>EMBALAJE CERRADO</td>
        <td width=40px colspan=2>CONSGINA CONDICION DE EMBALAJE</td>
        <td width=60px>CONDICION ALMACENAMIENTO</td>
        <td width=40px colspan=2>MANCHADO DERRAME ARRUGADO QUEBRADO HUMEDO</td>
        <td width=40px colspan=2>PRODUCTO CORRESPONDE AL DOCUMENTO</td>
        <td width=40px colspan=2>VEHICULO LIMPIO Y EQUIPADO CONDICION ADECUADA</td>
    </tr>
    <tr class="conBorde">
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td></td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td></td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>
        <td>SI</td>
        <td>NO</td>

    </tr>
    @foreach (var item in Model)
    {
        <tr class="conBorde">
            <td>@Math.Round(item.Quantity, 0)</td>
            <td style="text-align:left">@item.T8_ItemName</td>
            <td>@item.T4_DistNumber</td>
            <td>@item.T4_ExpDate</td>
            <td>@item.T4_MnfSerial</td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td>@item.T7_Location</td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
            <td><img width="7" height="7" src="~/imagenes/index/ReportesDigemid/check.png" /></td>
            <td></td>
        </tr>
    }

    <tr>
        <td colspan=2>OBSERVACIONES: NINGUNA</td>
        <td colspan=20></td>
    </tr>
    <tr>
        <td colspan="22" height="40"></td>
    </tr>
    <tr>
        <td colspan="4"></td>
        <td colspan="5" align="center" style="border-bottom: solid 1px">
            @if (ViewBag.FirmaResponsable != null)
            {<img src="@ViewBag.FirmaResponsable" width="150" />}
        </td>
        <td colspan="5" align="center"></td>
        <td colspan="7"></td>
    </tr>
    <tr>
        <td colspan="4"></td>
        <td colspan="5" align="center">ENCARGADO POR:</td>
        <td colspan="5" align="center"></td>
        <td colspan="7"></td>
    </tr>
    <tr>
        <td colspan="4"></td>
        <td colspan="5" align="center">(sello y firma)</td>
        <td colspan="5" align="center"></td>
        <td colspan="7"></td>
    </tr>
    <tr>
        <td colspan="20">
            <table width="50%" style="margin: auto; padding-top: 20px">
                <tr>
                    <td style="color: black; border: solid 1px; border-color: gray; font-size: 11px;text-align: center">Prohibido reproducir sin autorización de DROGUERÍA COBEFAR</td>
                </tr>
            </table>
        </td>
    </tr>
</table>
