@model Capa_Entidad.General_ENT.Tablas.COB_SALDO_E

@{
    ViewBag.Title = "EditarSaldoAnterior";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h4>EDITAR SALDO ANTERIOR</h4>
<a id="accion" href="@Url.Action("ListadoSaldosAnteriores", "DireccionTecnica")" class="btn btn-light">
    <span><strong>Volver Atras</strong></span>
</a>
<br />
<br />
<div class="alert-info">@ViewBag.Mensaje</div>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <div class="form-group">
            <div class="col-md-3">
                @Html.EditorFor(model => model.Code, new { htmlAttributes = new { @class = "form-control", @readonly = "true", @type = "hidden" } })
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
            </div>
        </div>
        <div class="form-group">
            @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-3">
                @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.U_COB_DESCRIPCION, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-6">
                @Html.EditorFor(model => model.U_COB_DESCRIPCION, new { htmlAttributes = new { @class = "form-control", @readonly = "true" } })
                @Html.ValidationMessageFor(model => model.U_COB_DESCRIPCION, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.U_COB_TIPOCONT, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                <select name="U_COB_TIPOCONT" id="U_COB_TIPOCONT" class="form-control">
                    <option value="">Seleccione</option>
                    @if (Model.U_COB_TIPOCONT == "P")
                    {
                        <option value="P" selected>Precursor</option>
                    }
                    else
                    {
                        <option value="P">Precursor</option>
                    }
                    @if (Model.U_COB_TIPOCONT == "E")
                    {
                        <option value="E" selected>Estupefaciente</option>
                    }
                    else
                    {
                        <option value="E">Estupefaciente</option>
                    }
                    @if (Model.U_COB_TIPOCONT == "S")
                    {
                        <option value="S" selected>Psicotropico</option>
                    }
                    else
                    {
                        <option value="S">Psicotropico</option>
                    }
                </select>
                @Html.ValidationMessageFor(model => model.U_COB_TIPOCONT, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.U_COB_TRIMESTRE, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                <select name="U_COB_TRIMESTRE" class="form-control">
                    <option value="">Seleccione</option>
                    @if (Model.U_COB_TRIMESTRE == 1)
                    {
                        <option value="1" selected>1 Trimestre</option>
                    }
                    else
                    {
                        <option value="1">1 Trimestre</option>
                    }
                    @if (Model.U_COB_TRIMESTRE == 2)
                    {
                        <option value="2" selected>2 Trimestre</option>
                    }
                    else
                    {
                        <option value="2">2 Trimestre</option>
                    }
                    @if (Model.U_COB_TRIMESTRE == 3)
                    {
                        <option value="3" selected>3 Trimestre</option>
                    }
                    else
                    {
                        <option value="3">3 Trimestre</option>
                    }
                    @if (Model.U_COB_TRIMESTRE == 4)
                    {
                        <option value="4" selected>4 Trimestre</option>
                    }
                    else
                    {
                        <option value="4">4 Trimestre</option>
                    }
                </select>
                @Html.ValidationMessageFor(model => model.U_COB_TRIMESTRE, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.U_COB_SALDOANTE, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-4">
                @Html.EditorFor(model => model.U_COB_SALDOANTE, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.U_COB_SALDOANTE, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Editar" class="btn btn-success" />
            </div>
        </div>
    </div>
}

