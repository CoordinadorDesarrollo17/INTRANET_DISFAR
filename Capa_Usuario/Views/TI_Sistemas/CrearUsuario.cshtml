@model Capa_Entidad.Seguridad_ENT.Usuario_E

@{
    ViewBag.Title = "CrearUsuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Scripts{
    <script src="~/Scripts/TI_Sistemas/Usuario.js"></script>
    <script>mostrarMensaje(`@ViewBag.Mensaje`)</script>
}

<div class="pt-4">
    <nav>
        <ol class="cd-breadcrumb bg-dark">
            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>
            <li><a href="@Url.Action("GestionPermisos", "TI_Sistemas")">Módulo gestión de permisos</a></li>
            <li class="current"><em>Registrar nuevo usuario</em></li>
        </ol>
    </nav>
</div>

<div class="bg-dark border-cabecera-seccion pb-2">
    <div class="px-3 pt-3"><h3 class="titulo-seccion">REGISTRAR NUEVO USUARIO</h3></div>
</div>

<div class="bg-form-pestanas-cobefar p-4 bg-form-cobefar">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-lg-3">
                <label for="Nombres" class="text-dark form-label font-weight-bold font-18">Nombres:</label>
                @Html.EditorFor(model => model.Nombres, new { htmlAttributes = new { @class = "form-control border-success text-capitalized", @autocomplete = "off" } })
            </div>

            <div class="col-lg-3">
                <label for="Apellidos" class="text-dark form-label font-weight-bold font-18">Apellidos:</label>
                @Html.EditorFor(model => model.Apellidos, new { htmlAttributes = new { @class = "form-control border-success text-capitalized", @autocomplete = "off" } })
            </div>

            <div class="col-lg-4">
                <label for="Email" class="text-dark form-label font-weight-bold font-18">Email:</label>
                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @type = "text", @class = "form-control border-success", @autocomplete = "off" } })
            </div>

            <div class="col-lg-2">
                <label for="CodigoSap" class="text-dark form-label font-weight-bold font-18">CodigoSap:</label>
                <input type="number" class="form-control border-success" id="CodigoSap" name="CodigoSap" min="1" value="@if(Model.CodigoSap != 0) { Write(Model.CodigoSap); }" oninput="validarCodigoSAP(this)" autocomplete="off">
            </div>

        </div>

        <div class="row mt-4">
            <div class="col-lg-3">
                <label class="text-dark form-label font-weight-bold font-18">Rol:</label>
                @Html.DropDownList("idRol", (SelectList)ViewBag.Roles, "Seleccione", new { @onchange = "infoIdUsuario(this);", @class = "form-control bg-cobefar text-white border-success" })
            </div>

            <div class="col-lg-2">
                <label class="text-dark font-weight-bold font-18">Usuario:</label>
                <input type="text" id="usuario" class="form-control text-center border-success" value="" readonly />
                <input type="hidden" id="id" name="Id" value="" />
                <input type="hidden" id="prefijo" name="Prefijo" value="" />
            </div>

            <div class="col-lg-3">
                <label for="WhsCode" class="text-dark form-label font-weight-bold font-18">Almacén:</label>
                <select name="WhsCode" type="text" class="form-control bg-cobefar text-white border-success">
                    <option value="">Seleccione</option>
                    @foreach (var almacen in new[] { "01", "03", "06", "07" })
                    {
                        <option value="@almacen" @(Model.WhsCode == almacen ? "selected" : "")>
                            ALM @almacen @(almacen == "01" ? "(Centro)" : "") @(almacen == "03" ? "(Arriola)" : "")
                        </option>
                    }
                </select>
            </div>
        </div>


        <div class="row mt-4">
            <div class="col-lg-3">
                <label for="Password" class="text-dark font-weight-bold font-18">Contraseña:</label>
                @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control border-success", @type = "text", @autocomplete = "off" } })
            </div>

            <div class="col-lg-3">
                <label for="Password2" class="text-dark form-label font-weight-bold font-18">Repetir contraseña:</label>
                @Html.Editor("password2", new { htmlAttributes = new { @class = "form-control border-success", @type = "text", @autocomplete = "off" } })
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-lg-2">
                <button type="submit" class="btn btn-success"><i class="icon icon-checkmark"></i> Crear</button>
            </div>
        </div>
    }
</div>