@model IEnumerable<Capa_Entidad.Seguridad_ENT.Usuario_E>@using Capa_Entidad.Seguridad_ENT@{    ViewBag.Title = "GestionPermisos";    Layout = "~/Views/Shared/_Layout.cshtml";    Usuario_E f = (Usuario_E)ViewBag.Usuario;}<script>    function filtrar() {        var object = $("#frm").serialize();        $(location).attr('href', "/TI_Sistemas/GestionPermisos?" + object);    }    function inactivar(DocEntry) {        Swal.fire({            title: '¿Está seguro(a) de inactivar este usuario?',            text: "Este usuario ya no podrá acceder a la INTRANET",            type: 'warning',            showCancelButton: true,            confirmButtonColor: '#3085d6',            cancelButtonColor: '#d33',            confirmButtonText: 'Si, estoy seguro(a)',            cancelButtonText: 'Cancelar'        }).then(result => {            if (result.value) {                var parametros = { "DocEntry": DocEntry };                $.ajax('/TI_Sistemas/InactivarUsuario',                    {                        data: parametros,                        dataType: 'json',                        cache: false,                        type: 'post'                    })                $(location).attr('href', "/TI_Sistemas/GestionPermisos");            }        });    }    function activar(DocEntry) {        Swal.fire({            title: '¿Está seguro(a) de activar este usuario?',            text: "Este usuario podrá acceder a la INTRANET",            type: 'warning',            showCancelButton: true,            confirmButtonColor: '#3085d6',            cancelButtonColor: '#d33',            confirmButtonText: 'Si, estoy seguro(a)',            cancelButtonText: 'Cancelar'        }).then(result => {            if (result.value) {                var parametros = { "DocEntry": DocEntry };                $.ajax('/TI_Sistemas/ActivarUsuario',                    {                        data: parametros,                        dataType: 'json',                        cache: false,                        type: 'post'                    })                $(location).attr('href', "/TI_Sistemas/GestionPermisos");            }        });    }</script><div class="pt-3">    <nav>        <ol class="cd-breadcrumb bg-cobefar-degradado-1">            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>            <li class="current"><em>Módulo gestión de permisos</em></li>        </ol>    </nav></div><div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-3">    <div class="px-3 pt-3"><h3 class="titulo-seccion">MÓDULO GESTIÓN DE PERMISOS</h3></div>    <div class="row pl-2 w-100 py-1">        <div class="d-flex col-lg-8 col-md-6 col-sm-12 col-6">            <a href="@Url.Action("CrearUsuario", "TI_Sistemas")" class="btn btn-success ml-2"><i class="icon icon-plus"></i> Crear usuario</a>            <button type="button" id="btn_gestionarRoles" class="btn btn-info ml-2"><i class="icon-users"></i> Operaciones por Rol</button>        </div>    </div></div><div class="bg-white bg-form-cobefar pt-3">    <form name="frm" id="frm">        <table id="tbl_listaUsuarios" class="table table-light table-sm table-hover font-14" width="100%">            <thead class="bg-cobefar-6">                <tr>                    <th class="text-center">DocEntry</th>                    <th class="text-center">Usuario</th>                    <th><span class="pl-2">Nombres y Apellidos</span></th>                    <th class="text-center">Almacén</th>                    <th><span class="pl-2">Rol</span></th>                    <th class="text-center">Fecha Creación</th>                    <th><span class="pl-2">Operario Creación</span></th>                    <th class="text-center">Activo</th>                    <th class="text-center">Acciones</th>                </tr>            </thead>            <tbody class="text-dark">                @foreach (var item in Model)                {    <tr>        <td class="text-center">@item.DocEntry</td>        <td class="text-center">@item.Prefijo@item.Id</td>        <td><span class="pl-2">@item.Nombres @item.Apellidos</span></td>        <td class="text-center">@item.WhsCode</td>        <td><span class="pl-2">@item.DescripcionRol</span></td>        <td class="text-center">@item.FechaRegistro</td>        <td><span class="pl-2">@item.OperarioRegistro</span></td>        <td class="text-center">            @if (item.Activo == 1) { Write("SI"); } else if (item.Activo == 0) { Write("NO"); }        </td>        <td class="text-center">            @if (item.Activo == 1)            {<a href="@Url.Action("EditarUsuario", "TI_Sistemas", new { DocEntry = item.DocEntry } )" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Editar usuario">    <i class="icon icon-pencil text-primary"></i></a><button type="button" data-docentryusuario="@item.DocEntry" data-nombresapellidos="@item.Nombres @item.Apellidos" class="btn btn-sm btn-light cls-button-permisos" data-toggle="tooltip" data-placement="top" title="Permisos por usuario">    <i class="icon icon-cog text-secondary"></i></button><button type="button" onclick="inactivar('@item.DocEntry');" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Inactivar usuario">    <i class="icon icon-blocked text-danger"></i></button>}else{<button type="button" onclick="activar('@item.DocEntry');" class="btn btn-sm btn-light" data-toggle="tooltip" data-placement="top" title="Activar usuario">    <i class="icon icon-checkmark text-danger"></i></button>}        </td>    </tr>}            </tbody>        </table>    </form></div><!-- Modal --><div class="modal fade" id="modalGestionarRoles" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">    <div class="modal-dialog modal-dialog-centered modal-full-width" role="document">        <div class="modal-content">            <div class="modal-header text-white bg-headerModals">                <h5 class="modal-title" id="myModalLabel">Gestionar Permisos por Roles</h5>                <button type="button" class="close" data-dismiss="modal" aria-label="Close">                    <span aria-hidden="true" class="text-white">&times;</span>                </button>            </div>            <div class="modal-body bg-blancoHumo">                <div class="container pb-0">                    <div class="row mb-3">                        <div class="col-6 d-flex align-items-center">                            <label class="text-dark form-label font-weight-bold mb-0">Rol:</label>                            <input type="hidden" id="idRol" name="idRol" />                            <input type="search" list="listaRoles" id="inputRoles" class="form-control w-50 mx-3" placeholder="Buscar rol..." autocomplete="off" />                            <datalist id="listaRoles">                                @foreach (var rol in ViewBag.Roles)                                {                    <option value="@rol.Nombre" data-idrol="@rol.Id"></option>                }                            </datalist>                        </div>                    </div>                    <div id="div_modalBody" class="row"></div>                </div>            </div>            <div class="modal-footer">                <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="icon-cross"></i> Cerrar</button>                <button type="button" id="btn_guardarCambios" class="btn btn-success"><i class="icon-checkmark"></i> Guardar cambios</button>            </div>        </div>    </div></div><div class="modal fade" id="modalGestionarPermisosPorUsuario" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">    <div class="modal-dialog modal-dialog-centered modal-full-width" role="document">        <div class="modal-content">            <div class="modal-header text-white bg-headerModals">                <h5 class="modal-title" id="myModalLabel">Gestionar Permisos por Usuario</h5>                <button type="button" class="close" data-dismiss="modal" aria-label="Close">                    <span aria-hidden="true" class="text-white">&times;</span>                </button>            </div>            <div class="modal-body bg-blancoHumo">                <div class="container pb-0">                    <div class="row mb-3">                        <div class="col-12 d-flex align-items-center">                            <label class="text-dark font-weight-bold col-2 mb-0">Permisos para:</label>                            <input type="hidden" id="usrDocEntry" />                            <input type="hidden" id="idRol" />                            <input type="text" id="permisosPara" class="form-control border border-success w-50" readonly />                        </div>                    </div>                    <div id="div_modalBody2" class="row"></div>                </div>            </div>            <div class="modal-footer">                <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="icon-cross"></i> Cerrar</button>                <button type="button" id="btn_guardarCambios2" class="btn btn-success"><i class="icon-checkmark"></i> Guardar cambios</button>            </div>        </div>    </div></div>@section Scripts{    <script>	if ('@ViewBag.Mensaje' != "") {			Swal.fire('@ViewBag.Mensaje');	}		document.addEventListener("DOMContentLoaded", function () {			visualizarPermisosPorUsuario();			var table = $('#tbl_listaUsuarios').DataTable({				ordering: false			});			table.on('search.dt', function () {				visualizarPermisosPorUsuario();			});			document.getElementById("btn_gestionarRoles").addEventListener("click", function () {				document.getElementById("idRol").value = 0;				document.getElementById("inputRoles").value = "";				document.getElementById("div_modalBody").innerHTML = "";				$('#modalGestionarRoles').modal('show');			});			document.getElementById('inputRoles').addEventListener('input', function () {				document.getElementById("div_modalBody").innerHTML = "";				const input = this.value;				const opcionSeleccionada = Array.from(document.querySelectorAll('#listaRoles option'))					.find(opc => opc.value === input);				if (opcionSeleccionada) {					//console.log(`Seleccionado: ${opcionSeleccionada.dataset.idcargo}`);					let url = `/TI_Sistemas/VisualizarPermisosPorRol/?rolID=${opcionSeleccionada.dataset.idrol}`;					cargarContenidoModal(url, "div_modalBody");					document.getElementById("idRol").value = opcionSeleccionada.dataset.idrol;				}			});			document.getElementById("btn_guardarCambios").addEventListener("click", function () {				asignarPermisosPorRol();			});			document.getElementById("btn_guardarCambios2").addEventListener("click", function () {				asignarPermisosPorUsuario();			});		});		function cargarContenidoModal(url, idContenido) {			document.getElementById("div_modalBody").innerHTML = "";			document.getElementById("div_modalBody2").innerHTML = "";			fetch(url)				.then(response => response.text())				.then(data => {					setTimeout(() => {						Swal.close();					}, 1000); // 1000 ms = 1 second					document.getElementById(idContenido).innerHTML = data;					cargarSeleccionDinamica();				})				.catch(error => {					console.error('Error al cargar la vista parcial:', error);				});		}		function cargarSeleccionDinamica() {			var selectAllCheckboxes = document.querySelectorAll(".seleccionar-todos");			selectAllCheckboxes.forEach(function (selectAllCheckbox) {				selectAllCheckbox.addEventListener("change", function () {					var grupo = selectAllCheckbox.dataset.grupo;					var checkboxes = document.querySelectorAll('input.form-check-input.' + grupo);					checkboxes.forEach(function (checkbox) {						checkbox.checked = selectAllCheckbox.checked;					});				});			});		}		function asignarPermisosPorRol() {			let rolID = document.getElementById("idRol").value;			let operaciones = Array.from(document.querySelectorAll('.chk-item:checked')).map(item => item.value);			fetch('/TI_Sistemas/AsignarPermisosPorRol', {				method: 'POST',				headers: {					'Content-Type': 'application/json'				},				body: JSON.stringify({ rolID: rolID, operaciones: operaciones })			})				.then(response => response.json())				.then(data => {					Toast.fire({						icon: data.Icono,						title: data.Mensaje,						html: data.Comentario.length > 0 ? data.Comentario.join(', ') : ''					});				})				.catch(error => console.error('Error, verificar el resultado', error));		}		function asignarPermisosPorUsuario() {			let usrDocEntry = document.getElementById("usrDocEntry").value;			let operaciones = Array.from(document.querySelectorAll('.chk-item:checked')).map(item => item.value);			fetch('/TI_Sistemas/AsignarPermisosPorUsuario', {				method: 'POST',				headers: {					'Content-Type': 'application/json'				},				body: JSON.stringify({ usrDocEntry: usrDocEntry, operaciones: operaciones })			})				.then(response => response.json())				.then(data => {					Toast.fire({						icon: data.Icono,						title: data.Mensaje,						html: data.Comentario.length > 0 ? data.Comentario.join(', ') : ''					});				})				.catch(error => console.error('Error, verificar el resultado', error));		}		function visualizarPermisosPorUsuario() {			var botones = document.querySelectorAll(".cls-button-permisos");			document.getElementById("permisosPara").value = "";			document.getElementById("usrDocEntry").value = "";			botones.forEach(function (btn) {				btn.addEventListener("click", function () {					document.getElementById("permisosPara").value = btn.dataset.nombresapellidos;					document.getElementById("usrDocEntry").value = btn.dataset.docentryusuario;					cargarContenidoModal(`/TI_Sistemas/VisualizarPermisosPorUsuario/?usrDocEntry=${btn.dataset.docentryusuario}`, 'div_modalBody2')					$('#modalGestionarPermisosPorUsuario').modal('show');				});			});		}    </script>}