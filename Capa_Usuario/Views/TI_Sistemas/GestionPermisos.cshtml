@model IEnumerable<Capa_Entidad.Seguridad_ENT.Usuario_E>@using Capa_Entidad.Seguridad_ENT@{    ViewBag.Title = "GestionPermisos";    Layout = "~/Views/Shared/_DefaultLayout.cshtml";    Usuario_E f = (Usuario_E)ViewBag.Usuario;}<style>    /* Separación entre columnas de la tabla */    #tbl_listaUsuarios th, #tbl_listaUsuarios td {        border-right: 1px solid #dee2e6;        text-align: center;        vertical-align: middle;    }    #tbl_listaUsuarios th:last-child, #tbl_listaUsuarios td:last-child {        border-right: none;    }    /* Centrar cabeceras y contenido */    #tbl_listaUsuarios th, #tbl_listaUsuarios td {        text-align: center !important;    }    /* Espaciado para los botones superiores */    .espacio-botones-superior {        margin-top: 15px;        margin-bottom: 10px;        margin-left: 10px;    }    /* Tamaño específico para cada columna */    #tbl_listaUsuarios th:nth-child(1), #tbl_listaUsuarios td:nth-child(1) { width: 40px; min-width: 30px; }    #tbl_listaUsuarios th:nth-child(2), #tbl_listaUsuarios td:nth-child(2) { width: 80px; min-width: 60px; }    #tbl_listaUsuarios th:nth-child(3), #tbl_listaUsuarios td:nth-child(3) { width: 180px; min-width: 150px; }    #tbl_listaUsuarios th:nth-child(4), #tbl_listaUsuarios td:nth-child(4) { width: 40px; min-width: 30px; }    #tbl_listaUsuarios th:nth-child(5), #tbl_listaUsuarios td:nth-child(5) { width: 100px; min-width: 80px; }    #tbl_listaUsuarios th:nth-child(6), #tbl_listaUsuarios td:nth-child(6) { width: 100px; min-width: 80px; }    #tbl_listaUsuarios th:nth-child(7), #tbl_listaUsuarios td:nth-child(7) { width: 150px; min-width: 120px; }    #tbl_listaUsuarios th:nth-child(8), #tbl_listaUsuarios td:nth-child(8) { width: 40px; min-width: 30px; }    #tbl_listaUsuarios th:nth-child(9), #tbl_listaUsuarios td:nth-child(9) { width: 130px; min-width: 100px; }</style><script>    function filtrar() {        var object = $("#frm").serialize();        $(location).attr('href', "/TI_Sistemas/GestionPermisos?" + object);    }    function inactivar(DocEntry) {        Swal.fire({            title: '¿Está seguro(a) de inactivar este usuario?',            text: "Este usuario ya no podrá acceder a la INTRANET",            icon: 'warning',            showCancelButton: true,            confirmButtonColor: '#198754',            cancelButtonColor: '#dc3545',            confirmButtonText: 'Si, estoy seguro(a)',            cancelButtonText: 'Cancelar'        }).then(result => {            if (result.value) {                var parametros = { "DocEntry": DocEntry };                $.ajax('/TI_Sistemas/InactivarUsuario', {                    data: parametros,                    dataType: 'json',                    cache: false,                    type: 'post'                });                $(location).attr('href', "/TI_Sistemas/GestionPermisos");            }        });    }    function activar(DocEntry) {        Swal.fire({            title: '¿Está seguro(a) de activar este usuario?',            text: "Este usuario podrá acceder a la INTRANET",            icon: 'warning',            showCancelButton: true,            confirmButtonColor: '#198754',            cancelButtonColor: '#dc3545',            confirmButtonText: 'Si, estoy seguro(a)',            cancelButtonText: 'Cancelar'        }).then(result => {            if (result.value) {                var parametros = { "DocEntry": DocEntry };                $.ajax('/TI_Sistemas/ActivarUsuario', {                    data: parametros,                    dataType: 'json',                    cache: false,                    type: 'post'                });                $(location).attr('href', "/TI_Sistemas/GestionPermisos");            }        });    }</script><div class="pt-3">    <nav>        <ol class="cd-breadcrumb bg-cobefar-degradado-1">            <li><a href="@Url.Action("Sesion", "Index")">Inicio</a></li>            <li class="current"><em>Módulo gestión de permisos</em></li>        </ol>    </nav></div><div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-3">    <div class="px-3 pt-3">        <h3 class="titulo-seccion">MÓDULO GESTIÓN DE PERMISOS</h3>    </div>    <div class="row w-100 py-1 espacio-botones-superior">        <div class="d-flex col-lg-8 col-md-6 col-sm-12 col-6 gap-2">            <a href="@Url.Action("CrearUsuario", "TI_Sistemas")" class="btn btn-success">                <i class="bi bi-person-plus"></i> Crear usuario            </a>            <button type="button" id="btn_gestionarRoles" class="btn btn-outline-info">                <i class="bi bi-people"></i> Operaciones por Rol            </button>        </div>    </div></div><div class="bg-white px-3 py-3 align-items-center">    <div class="row mb-4">        <div class="col-lg-12">            <div class="table-responsive">                <form name="frm" id="frm">                    <table id="tbl_listaUsuarios" class="dt-container dt-empty-footer table table-sm table-hover font-14 d-none">                        <thead class="thead-cobefar">                            <tr>                                <th>DocEntry</th>                                <th>Usuario</th>                                <th>Nombres y Apellidos</th>                                <th>Almacén</th>                                <th>Rol</th>                                <th>Fecha Creación</th>                                <th>Operario Creación</th>                                <th>Activo</th>                                <th>Acciones</th>                            </tr>                        </thead>                        <tbody class="text-dark">                            @foreach (var item in Model)                            {                                <tr>                                    <td>@item.DocEntry</td>                                    <td>@((item.Prefijo + item.Id).ToUpper())</td>                                    <td>@item.Nombres @item.Apellidos</td>                                    <td>@item.WhsCode</td>                                    <td>@item.DescripcionRol.ToUpper()</td>                                    <td>@item.FechaRegistro</td>                                    <td>@item.OperarioRegistro</td>                                    <td>                                        @if (item.Activo == 1) { Write("SI"); } else if (item.Activo == 0) { Write("NO"); }                                    </td>                                    <td>                                        @if (item.Activo == 1)                                        {                                            <a href="@Url.Action("EditarUsuario", "TI_Sistemas", new { DocEntry = item.DocEntry })" class="btn btn-sm btn-light" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar usuario">                                                <i class="bi bi-pencil text-primary"></i>                                            </a>                                            <button type="button" data-docentryusuario="@item.DocEntry" data-nombresapellidos="@item.Nombres @item.Apellidos" class="btn btn-sm btn-light cls-button-permisos" data-bs-toggle="tooltip" data-bs-placement="top" title="Permisos por usuario">                                                <i class="bi bi-gear text-secondary"></i>                                            </button>                                            <button type="button" onclick="inactivar('@item.DocEntry');" class="btn btn-sm btn-light" data-bs-toggle="tooltip" data-bs-placement="top" title="Inactivar usuario">                                                <i class="bi bi-person-x text-danger"></i>                                            </button>                                        }                                        else                                        {                                            <button type="button" onclick="activar('@item.DocEntry');" class="btn btn-sm btn-light" data-bs-toggle="tooltip" data-bs-placement="top" title="Activar usuario">                                                <i class="bi bi-person-check text-success"></i>                                            </button>                                        }                                    </td>                                </tr>                            }                        </tbody>                    </table>                </form>            </div>        </div>    </div></div><!-- Modal: Gestionar Permisos por Roles actualizado para Bootstrap 5 y SlimSelect --><div class="modal fade" id="modalGestionarRoles" tabindex="-1" aria-labelledby="myModalLabel" aria-hidden="true">    <div class="modal-dialog modal-dialog-centered modal-fullscreen" role="document">        <div class="modal-content">            <div class="modal-header text-white bg-headerModals">                <h5 class="modal-title" id="myModalLabel">Gestionar Permisos por Roles</h5>                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>            </div>            <div class="modal-body bg-blancoHumo">                <div class="container pb-0">                    <div class="row mb-3">                        <div class="col-lg-6 d-flex align-items-center">                            <label for="inputRoles" class="text-dark form-label font-weight-bold mb-0 me-2">Rol:</label>                            <input type="hidden" id="idRol" name="idRol" />                            <select id="inputRoles" name="inputRoles" class="form-control" autocomplete="off">                                <option value="">Seleccione</option>                                @foreach (var rol in ViewBag.Roles)                                {                                    <option value="@rol.Id">@rol.Nombre.ToUpper()</option>                                }                            </select>                        </div>                    </div>                    <div id="div_modalBody" class="row"></div>                </div>            </div>            <div class="modal-footer">                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cerrar</button>                <button type="button" id="btn_guardarCambios" class="btn btn-success"><i class="bi bi-check2"></i> Guardar cambios</button>            </div>        </div>    </div></div><!-- Modal: Gestionar Permisos por Usuario actualizado para Bootstrap 5 --><div class="modal fade" id="modalGestionarPermisosPorUsuario" tabindex="-1" aria-labelledby="myModalLabel" aria-hidden="true">    <div class="modal-dialog modal-dialog-centered modal-fullscreen" role="document">        <div class="modal-content">            <div class="modal-header text-white bg-headerModals">                <h5 class="modal-title" id="myModalLabel">Gestionar Permisos por Usuario</h5>                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>            </div>            <div class="modal-body bg-blancoHumo">                <div class="container pb-0">                    <div class="row mb-3">                        <div class="col-lg-12 d-flex align-items-center">                            <label for="permisosPara" class="text-dark font-weight-bold col-2 mb-0">Permisos para:</label>                            <input type="hidden" id="usrDocEntry" />                            <input type="hidden" id="idRol" />                            <input type="text" id="permisosPara" class="form-control border border-success w-50" readonly />                        </div>                    </div>                    <div id="div_modalBody2" class="row"></div>                </div>            </div>            <div class="modal-footer">                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cerrar</button>                <button type="button" id="btn_guardarCambios2" class="btn btn-success"><i class="bi bi-check2"></i> Guardar cambios</button>            </div>        </div>    </div></div>@if (TempData["Mensaje"] != null){    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>    <script>        var mensaje = @Html.Raw(Json.Encode(TempData["Mensaje"]));        if (typeof mensaje === 'string' && mensaje.toLowerCase().indexOf('éxito') !== -1) {            Swal.fire({                icon: 'success',                title: 'Cambios guardados',                text: mensaje,                showConfirmButton: true,                confirmButtonText: 'Aceptar',                confirmButtonColor: '#198754',                background: '#f6fff7',                color: '#198754',                customClass: {                    popup: 'swal2-modern-popup',                    title: 'swal2-modern-title',                    confirmButton: 'swal2-modern-confirm'                }            });        } else {            Swal.fire({                icon: 'info',                title: 'Mensaje',                text: mensaje,                showConfirmButton: true,                confirmButtonText: 'Aceptar',                confirmButtonColor: '#198754',                background: '#f6fff7',                color: '#198754',                customClass: {                    popup: 'swal2-modern-popup',                    title: 'swal2-modern-title',                    confirmButton: 'swal2-modern-confirm'                }            });        }    </script>    <style>        .swal2-modern-popup {            border-radius: 1rem !important;            box-shadow: 0 4px 24px rgba(0,0,0,0.10);        }        .swal2-modern-title {            font-weight: 700 !important;            color: #198754 !important;        }        .swal2-modern-confirm {            font-weight: 600 !important;            font-size: 1rem !important;            padding: 0.5rem 2rem !important;            border-radius: 0.5rem !important;        }    </style>}@section Scripts{    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">    <script src="https://cdn.jsdelivr.net/npm/slim-select@2.8.1/dist/slimselect.min.js"></script>    <link href="https://cdn.jsdelivr.net/npm/slim-select@2.8.1/dist/slimselect.min.css" rel="stylesheet" />    <script>        document.addEventListener('DOMContentLoaded', function () {            // Inicialización DataTable con textos en español y orden habilitado            if (!$.fn.DataTable.isDataTable('#tbl_listaUsuarios')) {                const tabla = $('#tbl_listaUsuarios').DataTable({                    pageLength: 10,                    ordering: true,                    order: [[0, 'desc']], // Ordenar por DocEntry ascendente                    language: {                        info: 'Mostrando _START_ a _END_ de _TOTAL_ registros',                        infoEmpty: 'No hay registros disponibles',                        infoFiltered: '(filtrado de _MAX_ registros totales)',                        lengthMenu: 'Mostrar _MENU_ registros por página',                        search: 'Buscar:',                        loadingRecords: 'Cargando...',                        processing: 'Procesando...',                        zeroRecords: 'No se encontraron registros'                    }                });                // Reasignar eventos tras redibujar                $('#tbl_listaUsuarios').on('draw.dt', function () {                    visualizarPermisosPorUsuario();                });            }            // Mostrar la tabla solo cuando DataTable esté lista            $('#tbl_listaUsuarios').removeClass('d-none');            // Inicializar evento para botones de permisos por usuario en la primera carga            visualizarPermisosPorUsuario();        });        document.addEventListener('DOMContentLoaded', function () {            new SlimSelect({ select: '#inputRoles', settings: { showSearch: false } });            document.getElementById('inputRoles').addEventListener('change', function () {                var idRol = this.value;                document.getElementById('idRol').value = idRol;                if (idRol) {                    let url = `/TI_Sistemas/VisualizarPermisosPorRol/?rolID=${idRol}`;                    cargarContenidoModal(url, "div_modalBody");                } else {                    document.getElementById("div_modalBody").innerHTML = "";                }            });            // Modal abrir con Bootstrap 5            document.getElementById("btn_gestionarRoles").addEventListener("click", function () {                document.getElementById("idRol").value = "";                document.getElementById("inputRoles").value = "";                document.getElementById("div_modalBody").innerHTML = "";                var modal = new bootstrap.Modal(document.getElementById('modalGestionarRoles'));                modal.show();            });            document.getElementById("btn_guardarCambios").addEventListener("click", function () {                asignarPermisosPorRol();            });            document.getElementById("btn_guardarCambios2").addEventListener("click", function () {                asignarPermisosPorUsuario();            });        });        function cargarContenidoModal(url, idContenido) {            document.getElementById("div_modalBody").innerHTML = "";            document.getElementById("div_modalBody2").innerHTML = "";            fetch(url)                .then(response => response.text())                .then(data => {                    setTimeout(() => { Swal.close(); }, 1000);                    document.getElementById(idContenido).innerHTML = data;                    cargarSeleccionDinamica();                })                .catch(error => { console.error('Error al cargar la vista parcial:', error); });        }        function cargarSeleccionDinamica() {            var selectAllCheckboxes = document.querySelectorAll(".seleccionar-todos");            selectAllCheckboxes.forEach(function (selectAllCheckbox) {                selectAllCheckbox.addEventListener("change", function () {                    var grupo = selectAllCheckbox.dataset.grupo;                    var checkboxes = document.querySelectorAll('input.form-check-input.' + grupo);                    checkboxes.forEach(function (checkbox) {                        checkbox.checked = selectAllCheckbox.checked;                    });                });            });        }        function asignarPermisosPorRol() {            let rolID = document.getElementById("idRol").value;            let operaciones = Array.from(document.querySelectorAll('.chk-item:checked')).map(item => item.value);            fetch('/TI_Sistemas/AsignarPermisosPorRol', {                method: 'POST',                headers: { 'Content-Type': 'application/json' },                body: JSON.stringify({ rolID: rolID, operaciones: operaciones })            })                .then(response => response.json())                .then(data => {                    let swalConfig = {                        icon: data.Icono || 'info',                        title: data.Titulo || 'Mensaje',                        text: data.Mensaje,                        showConfirmButton: true,                        confirmButtonText: 'Aceptar',                        confirmButtonColor: '#198754',                        background: '#f6fff7',                        color: '#198754',                        customClass: {                            popup: 'swal2-modern-popup',                            title: 'swal2-modern-title',                            confirmButton: 'swal2-modern-confirm'                        }                    };                    Swal.fire(swalConfig).then(result => {                        if (result.isConfirmed && data.Icono === 'success') {                            // Cerrar el modal de permisos por rol                            var modal = bootstrap.Modal.getInstance(document.getElementById('modalGestionarRoles'));                            if (modal) modal.hide();                        }                    });                })                .catch(error => console.error('Error, verificar el resultado', error));        }        function asignarPermisosPorUsuario() {            let usrDocEntry = document.getElementById("usrDocEntry").value;            let operaciones = Array.from(document.querySelectorAll('.chk-item:checked')).map(item => item.value);            fetch('/TI_Sistemas/AsignarPermisosPorUsuario', {                method: 'POST',                headers: { 'Content-Type': 'application/json' },                body: JSON.stringify({ usrDocEntry: usrDocEntry, operaciones: operaciones })            })                .then(response => response.json())                .then(data => {                    let swalConfig = {                        icon: data.Icono || 'info',                        title: data.Titulo || 'Mensaje',                        text: data.Mensaje,                        showConfirmButton: true,                        confirmButtonText: 'Aceptar',                        confirmButtonColor: '#198754',                        background: '#f6fff7',                        color: '#198754',                        customClass: {                            popup: 'swal2-modern-popup',                            title: 'swal2-modern-title',                            confirmButton: 'swal2-modern-confirm'                        }                    };                    Swal.fire(swalConfig).then(result => {                        if (result.isConfirmed && data.Icono === 'success') {                            // Cerrar el modal de permisos por usuario                            var modal = bootstrap.Modal.getInstance(document.getElementById('modalGestionarPermisosPorUsuario'));                            if (modal) modal.hide();                        }                    });                })                .catch(error => console.error('Error, verificar el resultado', error));        }        // Modal para permisos por usuario        function visualizarPermisosPorUsuario() {            var botones = document.querySelectorAll(".cls-button-permisos");            if (!botones.length) return;            var permisosPara = document.getElementById("permisosPara");            var usrDocEntry = document.getElementById("usrDocEntry");            botones.forEach(function (btn) {                btn.addEventListener("click", function () {                    if (permisosPara) permisosPara.value = btn.dataset.nombresapellidos;                    if (usrDocEntry) usrDocEntry.value = btn.dataset.docentryusuario;                    cargarContenidoModal(`/TI_Sistemas/VisualizarPermisosPorUsuario/?usrDocEntry=${btn.dataset.docentryusuario}`, 'div_modalBody2');                    var modal = new bootstrap.Modal(document.getElementById('modalGestionarPermisosPorUsuario'));                    modal.show();                });            });        }    </script>}