<div class="bg-white px-3 py-3 align-items-center">
    <div id="div_listado" class="row mb-4">

        <div class="col-lg-12">
            <div class="table-responsive" id="contenedorTablaCaja">
            </div>
        </div>

    </div>
</div>

<!-- Modal Exportar por Rango de Fechas -->
<div class="modal fade" id="modalExportarFechas" tabindex="-1" aria-labelledby="modalExportarLabel" aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="modalExportarLabel">
                    Exportar Tickets por Rango de Fechas
                </h5>

                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label for="fechaInicio">
                        Fecha Inicio: <span class="text-danger">*</span>
                    </label>
                    <input type="date" class="form-control" id="fechaInicio" required />
                </div>

                <div class="form-group">
                    <label for="fechaFin">
                        Fecha Fin: <span class="text-danger">*</span>
                    </label>
                    <input type="date" class="form-control" id="fechaFin" required />
                </div>

                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i>
                    Debe seleccionar ambas fechas para exportar el listado de tickets en el rango especificado.
                </div>

            </div>

            <div class="modal-footer">

                <button type="button" class="btn btn-secondary" onclick="cerrarModalFechas()">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>

                @*<button type="button" class="btn btn-success" onclick="exportarListadoPorFechas()">
                    <i class="bi bi-file-earmark-excel"></i> Exportar
                </button>*@

            </div>

        </div>
    </div>

</div>

<!-- Modal -->
<div class="modal fade" id="modalInfo" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">

    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header bg-cobefar text-white">
                <h5 class="modal-title" id="exampleModalLabel">
                    Tickets a cuadrar
                </h5>

                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" class="text-white">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="row">
                    <div id="div_vistaParcial" class="col-12">
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class='icon-cross'></i> Cerrar
                </button>
            </div>

        </div>
    </div>

</div>

<script>

    $(document).ready(function () {

        // Cargar la tabla de tickets en el div correspondiente y luego inicializar DataTable
        $('#div_listado')
            .load(`@Url.Action("ListarTicketsAPagar")?${window.location.search.substring(1)}`, function () {
                inicializarTablaTicketsCaja();
            })
            .fadeIn("fast");

        // Mostrar mensaje si existe
        if ('@ViewBag.Mensaje' != "") {
            Swal.fire('@ViewBag.Mensaje');
        }

        // Eventos para disparar filtro al hacer Enter o salir de la casilla
        $('#DocNum, #CardName, #TipoVenta').on('keypress blur change', function (e) {
            if (e.type === 'keypress' && e.which !== 13) {
                return; // Solo en Enter para inputs de texto
            }
            e.preventDefault();
            aplicarFiltros();
        });

        // Consultar nuevas solicitudes cada 15 segundos
        var consultarNuevasSolicitudes = function () {
            $.ajax({
                url: '/Caja/ConsultarNuevasSolicitudesTC',
                type: 'POST',
                dataType: 'json',
            }).done(function (response) {
                if (response.Mensaje != '') {
                    alertify.set('notifier', 'position', 'bottom-right');
                    alertify.set('notifier', 'delay', 15);

                    var msj = alertify.warning(`${response.Mensaje}`);

                    msj.callback = function (isClicked) {
                        if (isClicked)
                            window.location.href = `/Caja?EstadoContraEntrega=PENDIENTE`;
                    };
                }
            }).fail(function (jqXHR, textStatus, errorThrown) {
                console.log(jqXHR.status + textStatus + errorThrown);
            });
        }

        // Intervalo de 15 seg.
        setInterval(consultarNuevasSolicitudes, 15000);

    });

    function inicializarTablaTicketsCaja() {

        if ($.fn.DataTable.isDataTable('#tbl_listadoTC')) {
            $('#tbl_listadoTC').DataTable().destroy();
        }

        inicializarDataTable('tbl_listadoTC', 20, true, false);

        setTimeout(function () {
            $('.btn-cancelar-ticket').css('display', 'inline-block');
        }, 100);

    }

    // Aplicar filtros
    function aplicarFiltros() {
        const docNum = $('#DocNum').val();
        const cardName = $('#CardName').val();
        const tipoVenta = $('#TipoVenta').val();

        // Construir URL con parámetros de filtro
        let urlParams = new URLSearchParams();

        if (docNum) urlParams.append('DocNum', docNum);
        if (cardName) urlParams.append('CardName', cardName);
        if (tipoVenta) urlParams.append('TipoVenta', tipoVenta);

        // Recargar la tabla con los filtros
        const queryString = urlParams.toString();
        $('#div_listado')
            .load(`@Url.Action("ListarTicketsAPagar")?${queryString}`, function () {
                inicializarTablaTicketsCaja();
            });
    }

