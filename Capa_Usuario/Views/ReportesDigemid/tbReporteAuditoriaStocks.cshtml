@model IEnumerable<Capa_Entidad.ReportesDigemid_ENT.Reportes.AuditoriaStocks_E>
@using Capa_Entidad.ReportesDigemid_ENT.Reportes;

@{
    Layout = null;
}

<!DOCTYPE html>
<style>
    #tb th{
        color:black;
    }
</style>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>tbReporteAuditoriaStocks</title>
    <script>
        $(document).ready(function () { });
        function mostrar(clase) {
            if ($("." + clase).is(":visible")) {
                $("." + clase).css({ "display": "none" });
            }
            else {
                $("." + clase).css({ "display": "block" });
            }
        }
    </script>
</head>
<body>
    <div class="alert alert-danger">@ViewBag.Mensaje</div>
    @if (ViewBag.Mensaje == null && Model.ToList().Count > 0)
    {
        <table class="table" style="font-size:10px">
            <tr>
                <th>@Html.DisplayNameFor(model => model.DeFecha)</th>
                <td>@Html.DisplayFor(model => model.ToList()[0].DeFecha)</td>
                <th>@Html.DisplayNameFor(model => model.HastaFecha)</th>
                <td>@Html.DisplayFor(model => model.ToList()[0].HastaFecha)</td>
                <th>@Html.DisplayNameFor(model => model.Moneda)</th>
                <td>@Html.DisplayFor(model => model.ToList()[0].Moneda)</td>
            </tr>
            <tr></tr>
        </table>
        <table class="table" style="font-size:10px" border="1">
            @foreach (var cuta in ViewBag.CodArticulos)
            {
                int j = 1;
                <tr>
                    <th colspan="11"><button class="btn btn-info" type="button" onclick="mostrar('@cuta');">@cuta</button></th>
                </tr>
                <tr>
                    <td colspan="11">
                        <table class="@cuta" id="tb">
                            @foreach (AuditoriaStocks_E a in Model.Where(x => x.ItemCode == cuta))
                            {
                                if (j == 1)
                                {
                                    <tr>
                                        <th>#</th>
                                        <th>FechaSistema</th>
                                        <th>FechaCont</th>
                                        <th>Socio</th>
                                        <th>Documento</th>
                                        <th>Codigo</th>
                                        <th>Descripcion</th>
                                        <th>Almacén</th>
                                        <th>Cantidad</th>
                                        <th>Costos</th>
                                        <th>ValorTrans</th>
                                        <th>ValorAcumulado</th>
                                        <th>CantidadAcumulada</th>
                                    </tr>
                                }
                                <tr>
                                    <td>@j</td>
                                    <td>@Html.DisplayFor(modelItem => a.CreateDate)</td>
                                    <td>@Html.DisplayFor(modelItem => a.DocDate)</td>
                                    <td>@Html.DisplayFor(modelItem => a.CardName)</td>
                                    <td>@Html.DisplayFor(modelItem => a.Abreviatura)&nbsp;@Html.DisplayFor(modelItem => a.DocNum)</td>
                                    <td>@Html.DisplayFor(modelItem => a.ItemCode)</td>
                                    <td>@Html.DisplayFor(modelItem => a.ItemName)</td>
                                    <td>@Html.DisplayFor(modelItem => a.WhsCode)</td>
                                    <td>@Html.DisplayFor(modelItem => a.Quantity)</td>
                                    <td>@Html.DisplayFor(modelItem => a.Costos)</td>
                                    <td>@Html.DisplayFor(modelItem => a.ValorTrans)</td>
                                    <td>@(a.ValorAcumuladoTotal + a.ValorAcumulado)</td>
                                    <td>@Html.DisplayFor(modelItem => a.CantidadAcumulada)</td>
                                    @{j = j + 1;}
                                </tr>
                            }
                        </table>
                    </td>
                </tr>
            }

        </table>
    }
</body>
</html>
