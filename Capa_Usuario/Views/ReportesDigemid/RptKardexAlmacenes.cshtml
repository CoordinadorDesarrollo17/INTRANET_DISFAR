@{
    Layout = null;
}

<style>
    #div_plantillaRpt div * {
        font-family: "Arial", sans-serif !important;
        font-size: 12px;
    }

    .impresion {
        width: 100%;
        margin-left: -1% !important;
        background-color: white;
    }

    thead {
        display: table-header-group
    }

    tfoot {
        display: table-row-group
    }

    tr {
        page-break-inside: avoid
    }
</style>

<div id="tbl_detalle" class="impresion mt-4" style="width: 100%">
    <table width="100%">
        <tbody>
            <tr>
                <td class="border-0 text-left" width="250"><img class="no-export" src="~/Content/img/Logo - Disfar Oriente.png" width="150"></td>
                <td class="border-0 text-center" width="500"><h5 class="font-weight-bold">KÁRDEX CONTROL DE EXISTENCIAS</h5>@Model.WhsName</td>
                <td width="180" class="border-0 text-left font-weight-bold"><div>REG-009-03</div></td>
            </tr>
        </tbody>
    </table>

    <table width="100%" style="margin-top: 40px;">
        <tr>
            <td class="border-0 p-0 text-left" width="250"><b>DESCRIPCIÓN DEL PRODUCTO: </b>@Model.ItemName</td>
        </tr>
        <tr>
            <td class="border-0 p-0 text-left" width="250"><b>CÓDIGO DE PRODUCTO: </b>@Model.ItemCode</td>
        </tr>
        @if (!string.IsNullOrWhiteSpace(Model.Lote))
        {
            <tr>
                <td class="border-0 p-0 text-left" width="250"><b>LOTE: </b>@Model.Lote</td>
            </tr>
        }

    </table>

    <table class="table table-bordered text-center" width="100%" style="margin-top: 40px;">
        <thead class="text-dark">
            <tr>
                <th class="border text-dark" style="vertical-align: middle">REGISTRO SANITARIO</th>
                <th class="border text-dark" style="vertical-align: middle">FECHA DEL MOVIMIENTO</th>
                <th class="border text-dark" width="120" style="vertical-align: middle">DOCUMENTOS EMITIDOS</th>
                <th class="border text-dark" style="vertical-align: middle">PROVEEDOR O ESTABLECIMIENTO</th>
                <th class="border text-dark" style="vertical-align: middle">RUC</th>
                @if (string.IsNullOrWhiteSpace(Model.Lote))
                {
                    <th class="border text-dark" style="vertical-align: middle">LOTE</th>
                }
                <th class="border text-dark" style="vertical-align: middle">INGRESO (POR UNIDAD)</th>
                <th class="border text-dark" style="vertical-align: middle">SALIDA (POR UNIDAD)</th>
                <th class="border text-dark" style="vertical-align: middle">SALDO POR LOTE</th>
                <th class="border text-dark" style="vertical-align: middle">SALDO POR PRODUCTO</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.DetKardexAlmacenes != null && Model.DetKardexAlmacenes.Count >= 1)
            {
                foreach (var det in Model.DetKardexAlmacenes)
                {
                    <tr>
                        <td>@det.RegSanitario</td>
                        <td>@det.FechaCont</td>
                        <td>@det.FacturaGuiaBoleta</td>
                        <td>@det.ProvEstab</td>
                        <td>@det.Ruc</td>
                        @if (string.IsNullOrWhiteSpace(Model.Lote))
                        {
                            <td>@det.Lote</td>
                        }
                        <td>@det.CantIngreso</td>
                        <td>@det.CantSalida</td>
                        <td>@det.AcumuladoLote</td>
                        <td>@det.AcumuladoProducto</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<script>
    function descargarPDF() {
        printJS({ printable: 'div_plantillaRpt', type: 'html', targetStyles: ['*'] })
    }

    function descargarExcel(tableID, filename = '', { keepImages = false } = {}) {
        //window.open('/ReportesDigemid/RptExcelKardexAlmacenes?WhsCode=' + $('#WhsCode').val() + '&FecIni=' + $('#FecIni').val() + '&FecFin=' + $('#FecFin').val() + '&ItemCode=' + $('#ItemCode').val() + '&Lote=' + $('#Lote').val(), '_blank');

        const tableSelect = document.getElementById(tableID);
        if (!tableSelect) {
            console.error(`No existe el elemento #${tableID}`);
            return;
        }

        // Clonar para no tocar el DOM original
        const clone = tableSelect.cloneNode(true);

        // Por defecto quitamos imágenes (evita el ícono de “imagen vinculada” en Excel)
        if (!keepImages) {
            clone.querySelectorAll('img').forEach(img => img.remove());
            // O solo imágenes con clase específica:
            // clone.querySelectorAll('img.no-export').forEach(img => img.remove());
        }

        // Armar HTML mínimo compatible con Excel
        const html =
            '<!DOCTYPE html><html><head>' +
            '<meta http-equiv="Content-Type" content="application/vnd.ms-excel; charset=UTF-8"/>' +
            '<meta charset="UTF-8"/>' +
            '<style>table{border-collapse:collapse}th,td{border:1px solid #000;padding:4px}</style>' +
            '</head><body>' +
            clone.outerHTML +
            '</body></html>';

        const fname = filename.endsWith('.xls') ? filename : `${filename}.xls`;

        // Preferir Blob (mejor compatibilidad y sin límite de longitud)
        try {
            const blob = new Blob([html], { type: 'application/vnd.ms-excel;charset=utf-8;' });

            if (window.navigator && window.navigator.msSaveOrOpenBlob) {
                // IE/Edge Legacy
                window.navigator.msSaveOrOpenBlob(blob, fname);
            } else {
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = fname;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }
        } catch (e) {
            // Fallback a data URI si Blob fallara (raro)
            const dataUri = 'data:application/vnd.ms-excel;charset=utf-8,' + encodeURIComponent(html);
            const a = document.createElement('a');
            a.href = dataUri;
            a.download = fname;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }
    }
</script>